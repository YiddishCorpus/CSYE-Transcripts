			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts809" TIME_SLOT_REF2="ts811">
				<ANNOTATION_VALUE>on, un s'iz nisht geven &lt;keyn&gt; tsu zitsn &lt;tsu&gt; gornisht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts812" TIME_SLOT_REF2="ts815">
				<ANNOTATION_VALUE>un me hot undz bald, ikh mit mayne kinder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts819">
				<ANNOTATION_VALUE>kh'hob gehaltn lebn zikh, nakher ikh hob nokh gehat a shver,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts823">
				<ANNOTATION_VALUE>mayn man's a foter, iz er oykh geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1174" TIME_SLOT_REF1="ts824" TIME_SLOT_REF2="ts827">
				<ANNOTATION_VALUE>undz ze'mir ale gezesn. yeder hot zikh gehaltn mit zayn mishpokhe. un azoy zenen mir geforn biz nokh Var- &lt;neyn&gt;, nokh nisht nokh Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts829" TIME_SLOT_REF2="ts831">
				<ANNOTATION_VALUE>far Varshe, vayl di brik, di brik iz geven tsebrokhn, me hot nisht gekont arayngeyn nokh Varshe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts832" TIME_SLOT_REF2="ts835">
				<ANNOTATION_VALUE>mit keyn ferd, mit keyn gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts839">
				<ANNOTATION_VALUE>&lt;un m'iz&gt; gekumen dort baym NE- NAREW hot es geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts840" TIME_SLOT_REF2="ts843">
				<ANNOTATION_VALUE>gut, s'iz shoyn geven farfroyrn, a tog befor iz es nokh nisht geven in gantsn farfroyrn, zenen mentshn zenen adurkh, iz zenen dertrunken gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1111" TIME_SLOT_REF1="ts844" TIME_SLOT_REF2="ts848">
				<ANNOTATION_VALUE>mir zenen shoyn adurkh iz shoyn geven dos ayz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts847" TIME_SLOT_REF2="ts851">
				<ANNOTATION_VALUE>oyf dem oyf dem NAREW iz shoyn s'iz alts geven gefroyrn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts852" TIME_SLOT_REF2="ts855">
				<ANNOTATION_VALUE>mir hobn gehat mazl, m'iz adurkh besholem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts861">
				<ANNOTATION_VALUE>ze'mir gekumen, yeder hot gehat emetsn, bakante, zenen mir gekumen tsu undzere bakante nokh Varshe. UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>dos iz geven der nayn der... dos iz geven der nayn un draysik eh in eh GRUDZIEŃ, dos iz detsember.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts879">
				<ANNOTATION_VALUE>detsember iz gevezn, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts883">
				<ANNOTATION_VALUE>zenen mir dort ge- geshlofn eh oyf di podloges, m'iz geshlofn, me hot zikh ah</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1112" TIME_SLOT_REF1="ts884" TIME_SLOT_REF2="ts887">
				<ANNOTATION_VALUE>m'iz geven mid fun dem veg, fun azoy fil geyn, hot men zikh yeder oysgetsoygn oyf di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts891">
				<ANNOTATION_VALUE>oyf di eh RITSPAOT, un azoy zenen mir gelegn, gevart.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>un undzere mener vos zenen geforn dort, di di mener vos hobn genumen dem vogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1113" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts899">
				<ANNOTATION_VALUE>un eh un eh hot men zey &lt;bahal-&gt; farhaltn far NOWY DWÓR far Varshe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1114" TIME_SLOT_REF1="ts900" TIME_SLOT_REF2="ts903">
				<ANNOTATION_VALUE>un me hot zey dort ul- untergezukht, me hot dort</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts907">
				<ANNOTATION_VALUE>hot men zey ale SOWIESO tsugenumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts911">
				<ANNOTATION_VALUE>un zey hobn, zey hobn gelitn, me hot zey geshlogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts915">
				<ANNOTATION_VALUE>shoyn, dos iz shoyn geven di politsey, di di daytshe oder ikh veys nisht velkhe, di poylishe, ikh veys nisht velkhe politsey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts916" TIME_SLOT_REF2="ts919">
				<ANNOTATION_VALUE>me hot zey shoyn, un zenen gekumen zeyer in a shlekhtn tsushtand nokh Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts923">
				<ANNOTATION_VALUE>un azoy hot men geven in Varshe biz di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts931">
				<ANNOTATION_VALUE>&lt;BE- geto -m&gt;, in, mir grade hobn, &lt;eh bay undz&gt; iz geven a oysnam, hot men nokh gehat tsu dingen a voynung, me hot nokh gevoynt in undzer voynung.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1115" TIME_SLOT_REF1="ts932" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>ober di merheyt, zey hobn gevoynt in di shiln,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts939">
				<ANNOTATION_VALUE>in di eh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts940" TIME_SLOT_REF2="ts945">
				<ANNOTATION_VALUE>vos s'iz geven dort di eh, s'hot zikh, eh bote-midroshim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1116" TIME_SLOT_REF1="ts946" TIME_SLOT_REF2="ts951">
				<ANNOTATION_VALUE>i-, kehilishe pletser, un zey hobn zikh arayngetsoygn vayl zey hobn nisht gehat keyn gelt tsu batsoln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1117" TIME_SLOT_REF1="ts952" TIME_SLOT_REF2="ts955">
				<ANNOTATION_VALUE>s'hot gekost... ikh veys nisht eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts959">
				<ANNOTATION_VALUE>eh me hot, un un s'iz nisht geven tsu esn oykh nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts963">
				<ANNOTATION_VALUE>un dort efsher hot men gegebn epes tsu esn, ikh veys nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts964" TIME_SLOT_REF2="ts967">
				<ANNOTATION_VALUE>ober yeder eyner a shtikl broyt iz geven gold.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts971">
				<ANNOTATION_VALUE>shoyn, vos yeder hot gehat az me hot gekont adurkhfirn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1118" TIME_SLOT_REF1="ts972" TIME_SLOT_REF2="ts977">
				<ANNOTATION_VALUE>az me hot nokh gekont koyfn a shtikl broyt &lt;s'iz&gt; geven gut, ver hot gekont koyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts985">
				<ANNOTATION_VALUE>dos iz geven far di geto, efsher a yor tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts997">
				<ANNOTATION_VALUE>eh v- a gze-, gzeyres, s'zenen geven a yedn tog, ikh bin dokh nisht geganen, froyen zenen iber hoypt nisht geganen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1119" TIME_SLOT_REF1="ts998" TIME_SLOT_REF2="ts1004">
				<ANNOTATION_VALUE>mener zenen geganen tsu der arbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts1003" TIME_SLOT_REF2="ts1007">
				<ANNOTATION_VALUE>me hot gekhapt di mener tsu der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1011">
				<ANNOTATION_VALUE>az a man &lt;zol&gt; aroysgeyn in di gas arayn, avade, mayn man iz oykhet, mayn zun iz shoyn geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts1012" TIME_SLOT_REF2="ts1015">
				<ANNOTATION_VALUE>a dervaksn yingl fun draytsn yor. er iz geven a heldish kind, geflegt geyn mit dem foter, hot men im oykhet genumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts1017" TIME_SLOT_REF2="ts1019">
				<ANNOTATION_VALUE>eyn mol hot pasirt, me hot im gekhapt SOWIESO in di politsey, a gantse mayse gevezn, ikh veys nisht bizn hayntikn tog vos s'iz geven. me hot im gekhapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts1021" TIME_SLOT_REF2="ts1023">
				<ANNOTATION_VALUE>a yidish kind hot men gekhapt, me hot nisht avekgeshikt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts1024" TIME_SLOT_REF2="ts1027">
				<ANNOTATION_VALUE>me hot &lt;im&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts1029" TIME_SLOT_REF2="ts1031">
				<ANNOTATION_VALUE>me hot nor oysgeleyzt, me hot &lt;im&gt; aroysgenumen. shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts1033" TIME_SLOT_REF2="ts1035">
				<ANNOTATION_VALUE>me hot gelitn tsores, s'iz nisht geven gut, s'iz geven zeyer shlekht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts1036" TIME_SLOT_REF2="ts1039">
				<ANNOTATION_VALUE>kh'fleg geyn a mol bazukhn in di shul arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts1040" TIME_SLOT_REF2="ts1043">
				<ANNOTATION_VALUE>dort vu mayne shkheynim zenen gevezn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts1045" TIME_SLOT_REF2="ts1047">
				<ANNOTATION_VALUE>iz geven geferlekh, s'hot ge- ge- eh gebushevet di di krankeytn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts1048" TIME_SLOT_REF2="ts1051">
				<ANNOTATION_VALUE>epidemyes zenen gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1055">
				<ANNOTATION_VALUE>tifus un vos mentshn zenen oysgeshtorbn, yedn tog iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts1056" TIME_SLOT_REF2="ts1061">
				<ANNOTATION_VALUE>s'iz geven &lt;bay der&gt;, adurkhtsugeyn in Varshe in di gas iz nisht ge- hot men nisht gekont adurkhgeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts1063" TIME_SLOT_REF2="ts1067">
				<ANNOTATION_VALUE>dos iz geven nokh far di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts1068" TIME_SLOT_REF2="ts1071">
				<ANNOTATION_VALUE>iz shoyn gelegn fil, di harugim zenen gelegn tsugedekt mit a shtikl papir un dos iz gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1075">
				<ANNOTATION_VALUE>un nakher, s'iz geven di geto, eh kon men zikh shoyn forshteln vi s'iz gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts1077" TIME_SLOT_REF2="ts1079">
				<ANNOTATION_VALUE>s'iz geven zeyer shlekht. undz hot men zikh aroysgeshmuglt fun di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts1081" TIME_SLOT_REF2="ts1085">
				<ANNOTATION_VALUE>me hot zikh aroysgeshmuglt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts1087" TIME_SLOT_REF2="ts1093">
				<ANNOTATION_VALUE>ah zikher, vos far a frage?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1122" TIME_SLOT_REF1="ts1097" TIME_SLOT_REF2="ts1101">
				<ANNOTATION_VALUE>ikh kle- undz ze'mir geven tsvey yor in Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1123" TIME_SLOT_REF1="ts1103" TIME_SLOT_REF2="ts1109">
				<ANNOTATION_VALUE>&lt;mayne, az ikh bin&gt; geven a yor in geto, a yor iz men geven nokh far di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1124" TIME_SLOT_REF1="ts1111" TIME_SLOT_REF2="ts1117">
				<ANNOTATION_VALUE>yo, azoy UNK, azoy yo, ikh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts1119" TIME_SLOT_REF2="ts1125">
				<ANNOTATION_VALUE>eyn un fertsikstn yor, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1131">
				<ANNOTATION_VALUE>nu, vos kon ikh aykh fartseyln, s'iz geven zeyer shlekht, s'iz geven biter vi di gal.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts1132" TIME_SLOT_REF2="ts1135">
				<ANNOTATION_VALUE>zeyer shlekht, shoyn. s'iz geven azoy shlekht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts1136" TIME_SLOT_REF2="ts1139">
				<ANNOTATION_VALUE>ikh gedenk...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts1141" TIME_SLOT_REF2="ts1143">
				<ANNOTATION_VALUE>mayn man, eh, mir hobn nokh gehat a bisele gelt, me hot nokh eh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts1144" TIME_SLOT_REF2="ts1147">
				<ANNOTATION_VALUE>s'iz undz gelungen, me hot dos adurkhgefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts1148" TIME_SLOT_REF2="ts1151">
				<ANNOTATION_VALUE>s'iz geven &lt;azelkhe&gt;, bay mayn shvoger hot men ales tsugenumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts1153" TIME_SLOT_REF2="ts1155">
				<ANNOTATION_VALUE>un undz iz gelungen, me hot es shabes adurkhgefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts1157" TIME_SLOT_REF2="ts1159">
				<ANNOTATION_VALUE>hot me-, hot men nokh ge- epes gekoyft, un me hot nokh epes gekokht oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts1161" TIME_SLOT_REF2="ts1163">
				<ANNOTATION_VALUE>iz ikh gedenk &lt;iz&gt; tsugekumen arayn tsu mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts1164" TIME_SLOT_REF2="ts1167">
				<ANNOTATION_VALUE>zenen gekumen fun undzer shtetl mentshn vos kh'hob zey nisht derkent. in aza kurtser tsayt s'iz nisht geven keyn mentshn, s'iz geven shkeletn, nisht keyn mentshn koym,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts1168" TIME_SLOT_REF2="ts1171">
				<ANNOTATION_VALUE>un &lt;zey&gt; tsugekumen zenen geven vild,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts1173" TIME_SLOT_REF2="ts1175">
				<ANNOTATION_VALUE>oysgehungert, un &lt;zey&gt; tsugelofn tsu di &lt;kukh un&gt; zey hobn gekhapt aroys vos s'iz geven in di in in in tepl vos s'iz nor gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts1176" TIME_SLOT_REF2="ts1179">
				<ANNOTATION_VALUE>un ikh hob mamesh far di zelbe mentshn hob ikh moyre gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts1181" TIME_SLOT_REF2="ts1183">
				<ANNOTATION_VALUE>far mentshn vos nekhtn, vos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts1185" TIME_SLOT_REF2="ts1187">
				<ANNOTATION_VALUE>iz men gevezn di beste gute-fraynd in shtetl, ales iz geven undzere mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts1189" TIME_SLOT_REF2="ts1191">
				<ANNOTATION_VALUE>mentshn, iz geven zeyer vild.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts1193" TIME_SLOT_REF2="ts1195">
				<ANNOTATION_VALUE>dos iz der hunger, der noyt, di tsores hobn dos gebrengt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts1197" TIME_SLOT_REF2="ts1199">
				<ANNOTATION_VALUE>eh ot azoy iz geven, azoy iz geganen, biz in a, eynem a tog hot mayn man oysgezukht &lt;ot&gt; emetsn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts1201" TIME_SLOT_REF2="ts1205">
				<ANNOTATION_VALUE>un m'iz adurkh durkh di ployt, mit di kinder m'iz adurkh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts1207" TIME_SLOT_REF2="ts1212">
				<ANNOTATION_VALUE>eh eh s- eh es iz azoy geven:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts1211" TIME_SLOT_REF2="ts1215">
				<ANNOTATION_VALUE>di, di kinder's eltern zenen geven in a, nokh biz s'iz geven di daytshe REICH</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts1216" TIME_SLOT_REF2="ts1219">
				<ANNOTATION_VALUE>iz nokh nisht geven keyn geto dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts1220" TIME_SLOT_REF2="ts1223">
				<ANNOTATION_VALUE>hot men undz dort ahingefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts1225" TIME_SLOT_REF2="ts1227">
				<ANNOTATION_VALUE>m'hot undz nisht gefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts1228" TIME_SLOT_REF2="ts1232">
				<ANNOTATION_VALUE>zey hobn gevolt az me zol dort kumen, ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts1231" TIME_SLOT_REF2="ts1237">
				<ANNOTATION_VALUE>di shvester mi- mayne iz geforn vayl zi hot, geve- azoy vi a kristin hot zi oysgezen, a blonde.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts1239" TIME_SLOT_REF2="ts1243">
				<ANNOTATION_VALUE>di, Daytshland, yo. iz zi geforn befor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts1244" TIME_SLOT_REF2="ts1247">
				<ANNOTATION_VALUE>der sh- der shvoger mayner iz shoyn geven a rikhtiker yid. er iz shoyn geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts1248" TIME_SLOT_REF2="ts1251">
				<ANNOTATION_VALUE>oysgezen azoy, a rikhtiker yid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts1252" TIME_SLOT_REF2="ts1256">
				<ANNOTATION_VALUE>hot mayn shvester di di &lt;me hot ir&gt; geshikt a kristin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts1255" TIME_SLOT_REF2="ts1259">
				<ANNOTATION_VALUE>a rikhtike kristin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts1260" TIME_SLOT_REF2="ts1263">
				<ANNOTATION_VALUE>un m'hot dem farshtelt far a &lt;goy, yo&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts1265" TIME_SLOT_REF2="ts1267">
				<ANNOTATION_VALUE>dem shvoger, un zi hot im ibergefirt. azoy az zey zenen nisht geven baym, dort dem GOSTYNIN, in dem shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts1271" TIME_SLOT_REF2="ts1277">
				<ANNOTATION_VALUE>vi, yo, m'hot, m'hot bavakht di geto un s'iz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1130" TIME_SLOT_REF1="ts1278" TIME_SLOT_REF2="ts1285">
				<ANNOTATION_VALUE>s'iz kh've-, dos hot mayn man gemakht. ikh veys nisht vi dos iz gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1126" TIME_SLOT_REF1="ts1287" TIME_SLOT_REF2="ts1291">
				<ANNOTATION_VALUE>ikh veys er hot gezogt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1131" TIME_SLOT_REF1="ts1292" TIME_SLOT_REF2="ts1295">
				<ANNOTATION_VALUE>"makhst, host nokh epes, leyg arayn in epes a pekele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1132" TIME_SLOT_REF1="ts1296" TIME_SLOT_REF2="ts1299">
				<ANNOTATION_VALUE>nem tsuzamen vos s'iz do,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1127" TIME_SLOT_REF1="ts1300" TIME_SLOT_REF2="ts1303">
				<ANNOTATION_VALUE>mir geyen haynt adurkh di geto".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts1305" TIME_SLOT_REF2="ts1307">
				<ANNOTATION_VALUE>un me vet geyn tsu fus dort ahin in dem shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts1311" TIME_SLOT_REF2="ts1315">
				<ANNOTATION_VALUE>zenen mir ar- zenen mir zeyer uh shlekht... azoy iz geven, m'iz aroys fun di geto,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts1317" TIME_SLOT_REF2="ts1319">
				<ANNOTATION_VALUE>zenen mir adurkh dem ployt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts1321" TIME_SLOT_REF2="ts1323">
				<ANNOTATION_VALUE>hot mayn man gezen forn a kotsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts1325" TIME_SLOT_REF2="ts1329">
				<ANNOTATION_VALUE>in Varshe zenen geven kotshn azelkhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1128" TIME_SLOT_REF1="ts1335" TIME_SLOT_REF2="ts1337">
				<ANNOTATION_VALUE>ir veyst vos a kotsh iz?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts1339" TIME_SLOT_REF2="ts1343">
				<ANNOTATION_VALUE>mit di eh yo, hot er ge- hot er gerufn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts1344" TIME_SLOT_REF2="ts1347">
				<ANNOTATION_VALUE>un iz ahergekumen, mir ale zenen arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts1348" TIME_SLOT_REF2="ts1351">
				<ANNOTATION_VALUE>un dort, un er hot batsolt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1133" TIME_SLOT_REF1="ts1352" TIME_SLOT_REF2="ts1355">
				<ANNOTATION_VALUE>vifl &lt;undzer...&gt; me hot dokh geheysn gebn az me zol undz aroysfirn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1129" TIME_SLOT_REF1="ts1357" TIME_SLOT_REF2="ts1359">
				<ANNOTATION_VALUE>fun di geto, me zol undz aroysfirn oyf a veg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts1361" TIME_SLOT_REF2="ts1363">
				<ANNOTATION_VALUE>hot gezogt vi me zol undz firn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts1365" TIME_SLOT_REF2="ts1367">
				<ANNOTATION_VALUE>un dort vet men shoyn aleynt geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts1369" TIME_SLOT_REF2="ts1371">
				<ANNOTATION_VALUE>der hot undz oyfgenumen oyfn veg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts1373" TIME_SLOT_REF2="ts1375">
				<ANNOTATION_VALUE>hot mayn man gezen epes s'iz nisht der rikhtiker veg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts1377" TIME_SLOT_REF2="ts1379">
				<ANNOTATION_VALUE>mayn man iz geven a zeyer a spritner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts1380" TIME_SLOT_REF2="ts1385">
				<ANNOTATION_VALUE>ir veyst vos a spritner iz? a zeyer a feiker.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts1387" TIME_SLOT_REF2="ts1391">
				<ANNOTATION_VALUE>un er hot zikh oryentirt in di zakhn, hot er gezen, epes dos iz nisht der veg</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts1392" TIME_SLOT_REF2="ts1395">
				<ANNOTATION_VALUE>vos me firt undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts1397" TIME_SLOT_REF2="ts1399">
				<ANNOTATION_VALUE>s'iz nisht der rikhtiker.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts1400" TIME_SLOT_REF2="ts1403">
				<ANNOTATION_VALUE>hot er ongehoybn tsu shrayen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts1404" TIME_SLOT_REF2="ts1407">
				<ANNOTATION_VALUE>azoy vi mayn man hot geshrign, hobn mir ale geshrign.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts1408" TIME_SLOT_REF2="ts1411">
				<ANNOTATION_VALUE>ikh un mayne dray di kinder hobn geshrign, ale dray.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts1413" TIME_SLOT_REF2="ts1415">
				<ANNOTATION_VALUE>kh'hob dokh nokh gehat, ikh hob dokh a zun oykhet gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts1416" TIME_SLOT_REF2="ts1419">
				<ANNOTATION_VALUE>hot men ale geshrign, me hot azelkhene gevaldn gemakht, me hot azoy geshrign</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1135" TIME_SLOT_REF1="ts1420" TIME_SLOT_REF2="ts1423">
				<ANNOTATION_VALUE>un yo, un m'hot, er hot gezen vi eyner loyft aroyf oyf di trep fun di kotsh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts1425" TIME_SLOT_REF2="ts1427">
				<ANNOTATION_VALUE>hot er gezen. azoy vi s'iz, me hot geshrign,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts1429" TIME_SLOT_REF2="ts1431">
				<ANNOTATION_VALUE>hot men o-, hot zikh dort, ergets iz geven a koshtshol</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts1433" TIME_SLOT_REF2="ts1441">
				<ANNOTATION_VALUE>aza, dos zenen geven di eh nones hobn zey geheysn, di eh frume shvesters.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1136" TIME_SLOT_REF1="ts1442" TIME_SLOT_REF2="ts1447">
				<ANNOTATION_VALUE>un eh ge- hobn dort gevoynt. hobn zey gezen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1138" TIME_SLOT_REF1="ts1448" TIME_SLOT_REF2="ts1452">
				<ANNOTATION_VALUE>hobn gehert di gevaldn, zenen zey aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts1451" TIME_SLOT_REF2="ts1455">
				<ANNOTATION_VALUE>zey zenen aroys, zenen di tsvey vos hobn undz ba-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts1457" TIME_SLOT_REF2="ts1459">
				<ANNOTATION_VALUE>ge- aroyfgeshprungen oyf di trepn, &lt;tsvey zenen&gt; oyfgeshprungen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts1461" TIME_SLOT_REF2="ts1463">
				<ANNOTATION_VALUE>eyner vos iz geforn mit di kotsh iz geven un tsvey &lt;shgotsim&gt; zenen aroyfgeshprungen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts1464" TIME_SLOT_REF2="ts1467">
				<ANNOTATION_VALUE>hobn zey gegebn a khap di peklekh vos mir hobn gehat. ikh hob gehat a tukh oyf mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts1468" TIME_SLOT_REF2="ts1471">
				<ANNOTATION_VALUE>aza groys tukh. aropgekhapt mir dos tukh un di peklekh vos mir hobn gehat un zenen &lt;h&gt;antlofn. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts1473" TIME_SLOT_REF2="ts1475">
				<ANNOTATION_VALUE>hot zikh der goy opgeshtelt un mir zenen arop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts1476" TIME_SLOT_REF2="ts1479">
				<ANNOTATION_VALUE>mir zenen arop, zenen mir ahin dort tsu di nones.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts1481" TIME_SLOT_REF2="ts1483">
				<ANNOTATION_VALUE>mir zenen ahin, zogn zey "du veyst vi me hot &lt;aykh do&gt; gefirt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts1485" TIME_SLOT_REF2="ts1487">
				<ANNOTATION_VALUE>m'hot enk gefirt in a veldl arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts1488" TIME_SLOT_REF2="ts1491">
				<ANNOTATION_VALUE>do firt men ale vos tsum, vos me harget zey oys".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts1495" TIME_SLOT_REF2="ts1497">
				<ANNOTATION_VALUE>di nones hobn undz...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1139" TIME_SLOT_REF1="ts1498" TIME_SLOT_REF2="ts1504">
				<ANNOTATION_VALUE>yo, dos hobn di nones undz gezogt, di shvester,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts1503" TIME_SLOT_REF2="ts1507">
				<ANNOTATION_VALUE>di frume shvester.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts1508" TIME_SLOT_REF2="ts1511">
				<ANNOTATION_VALUE>eh MIŁOSIERNE PANNY zey hobn zey geheysn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts1513" TIME_SLOT_REF2="ts1515">
				<ANNOTATION_VALUE>hobn undz dos gezogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1140" TIME_SLOT_REF1="ts1516" TIME_SLOT_REF2="ts1519">
				<ANNOTATION_VALUE>"gut", zogt zi, "az ir hot gemakht gevaldn, az nisht, me hot enk opgeratevet yetst".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts1521" TIME_SLOT_REF2="ts1523">
				<ANNOTATION_VALUE>eh, iz shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts1525" TIME_SLOT_REF2="ts1527">
				<ANNOTATION_VALUE>"vu vilt ets geyn?" hot zi mir gezogt, zey hobn dokh farshtanen az m'iz aroys fun di geto</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts1528" TIME_SLOT_REF2="ts1531">
				<ANNOTATION_VALUE>un me vil ergets geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts1532" TIME_SLOT_REF2="ts1536">
				<ANNOTATION_VALUE>zogt zi "vos kon ikh, kon &lt;men undz enk&gt; helfn?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts1535" TIME_SLOT_REF2="ts1539">
				<ANNOTATION_VALUE>undz kon men gor nisht helfn. "do nemts, &lt;do&gt; geyts &lt;do, do&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1141" TIME_SLOT_REF1="ts1540" TIME_SLOT_REF2="ts1544">
				<ANNOTATION_VALUE>efsher vet er, vet ets hobn tsu ton an altn mentsh, alte mentshn, nisht keyn yunge zol undz nisht nemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts1543" TIME_SLOT_REF2="ts1547">
				<ANNOTATION_VALUE>nemts a dorozhke zol enk firn aroys oyf a veg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts1548" TIME_SLOT_REF2="ts1551">
				<ANNOTATION_VALUE>vi ets vilt geyn, shpeter vet ets shoyn geyn".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts1553" TIME_SLOT_REF2="ts1555">
				<ANNOTATION_VALUE>azoy iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts1556" TIME_SLOT_REF2="ts1559">
				<ANNOTATION_VALUE>hot men genumen vider a dorozhke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts1561" TIME_SLOT_REF2="ts1563">
				<ANNOTATION_VALUE>un m'iz aroys</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts1565" TIME_SLOT_REF2="ts1567">
				<ANNOTATION_VALUE>un m'iz geganen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts1569" TIME_SLOT_REF2="ts1571">
				<ANNOTATION_VALUE>iz azoy geven. ikh hob geganen me zol nisht geyn azoy fil, me zol UNK fardekhtikt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts1572" TIME_SLOT_REF2="ts1575">
				<ANNOTATION_VALUE>mit mayne, mit di tsvey meydelekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts1576" TIME_SLOT_REF2="ts1579">
				<ANNOTATION_VALUE>un mayn man iz geganen mitn zun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts1581" TIME_SLOT_REF2="ts1583">
				<ANNOTATION_VALUE>undz zenen mir adurkh, &lt;me hot&gt; geganen a tog un a nakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts1585" TIME_SLOT_REF2="ts1587">
				<ANNOTATION_VALUE>a gantse tog un a nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts1588" TIME_SLOT_REF2="ts1592">
				<ANNOTATION_VALUE>un mayn man iz geganen oykhet azoy,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts1591" TIME_SLOT_REF2="ts1595">
				<ANNOTATION_VALUE>ober er iz geganen oyf an andern veg un undz ze'mir geganen an andern veg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts1597" TIME_SLOT_REF2="ts1599">
				<ANNOTATION_VALUE>mayn man hot men gekhapt mitn zun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts1601" TIME_SLOT_REF2="ts1603">
				<ANNOTATION_VALUE>me hot im gekhapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts1604" TIME_SLOT_REF2="ts1607">
				<ANNOTATION_VALUE>iz shoyn nisht vikhtik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts1609" TIME_SLOT_REF2="ts1611">
				<ANNOTATION_VALUE>zey hobn gehat mazl, me hot zey opgelozt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts1612" TIME_SLOT_REF2="ts1615">
				<ANNOTATION_VALUE>undz hot men nisht gekhapt un m'iz gegan-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts1616" TIME_SLOT_REF2="ts1619">
				<ANNOTATION_VALUE>un shtelt aykh for, mir zenen gekumen oyfn plats</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts1620" TIME_SLOT_REF2="ts1624">
				<ANNOTATION_VALUE>do vu me hot gezolt kumen, un mayn man iz gekumen oyfn plats.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts1623" TIME_SLOT_REF2="ts1627">
				<ANNOTATION_VALUE>in dem shtetl, s'iz nokh nisht geven dos rikhtike shtetl, a shtetl befor, zenen mir arayn dort,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts1628" TIME_SLOT_REF2="ts1631">
				<ANNOTATION_VALUE>m'hot gezen vi me firt di yidn tsu der arbet. hot men shoyn gezen az dos iz es.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts1632" TIME_SLOT_REF2="ts1636">
				<ANNOTATION_VALUE>m'hot dort gehat oykhet mishpokhe un zey hobn undz arayngenumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1143" TIME_SLOT_REF1="ts1635" TIME_SLOT_REF2="ts1639">
				<ANNOTATION_VALUE>nakher iz men arayn tsu di shvester, un azoy iz men geven mit di shvester iz men shoyn gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts1641" TIME_SLOT_REF2="ts1645">
				<ANNOTATION_VALUE>biz, biz, biz a-, biz aroys fun UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts1647" TIME_SLOT_REF2="ts1651">
				<ANNOTATION_VALUE>di ah, yo, in GOSTYNIN, dos iz di mame gevezn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1145" TIME_SLOT_REF1="ts1652" TIME_SLOT_REF2="ts1655">
				<ANNOTATION_VALUE>zi hot dort gevoynt, un zi hot nisht gevoynt &lt;hot&gt; zi iz oykhet dort ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1146" TIME_SLOT_REF1="ts1656" TIME_SLOT_REF2="ts1659">
				<ANNOTATION_VALUE>vayl zey hobn gehat dort a shvoger &lt;vu der,&gt; der man hot gehat a bruder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts1661" TIME_SLOT_REF2="ts1663">
				<ANNOTATION_VALUE>hot er, hobn zey dort gevoynt, zenen zey dort ahin un undz zenen mir vider tsu zey ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts1664" TIME_SLOT_REF2="ts1667">
				<ANNOTATION_VALUE>azoy iz men shoyn geven tsuzamen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts1669" TIME_SLOT_REF2="ts1679">
				<ANNOTATION_VALUE>mit sh- dray shvester zenen mir geven tsuzamen. ikh un di daytshe, fun Daytshland,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts1680" TIME_SLOT_REF2="ts1685">
				<ANNOTATION_VALUE>un di, ir muter, iz men geven dray shvester tsuzamen. nu shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts1691" TIME_SLOT_REF2="ts1697">
				<ANNOTATION_VALUE>s'iz shoyn in tsvey un fertsikstn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts1699" TIME_SLOT_REF2="ts1701">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts1703" TIME_SLOT_REF2="ts1709">
				<ANNOTATION_VALUE>GOSTYNIN, GOSTYNIN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1170" TIME_SLOT_REF1="ts1711" TIME_SLOT_REF2="ts1717">
				<ANNOTATION_VALUE>GOSTYNIN yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts1719" TIME_SLOT_REF2="ts1723">
				<ANNOTATION_VALUE>iz geven, undz, iz men gekumen iz yo shoyn geven di geto</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1150" TIME_SLOT_REF1="ts1724" TIME_SLOT_REF2="ts1729">
				<ANNOTATION_VALUE>in di tsvey un fertsikstn yor iz shoyn geven di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts1731" TIME_SLOT_REF2="ts1737">
				<ANNOTATION_VALUE>tsvey un fertsikstn iz shoyn geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts1739" TIME_SLOT_REF2="ts1744">
				<ANNOTATION_VALUE>yo, m'hot gevoynt in di geto, zikher, arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1153" TIME_SLOT_REF1="ts1743" TIME_SLOT_REF2="ts1748">
				<ANNOTATION_VALUE>di shvester hot oykh nisht gevoynt aleynt, zi hot oykh dort gevoynt a, a mishpokhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts1747" TIME_SLOT_REF2="ts1753">
				<ANNOTATION_VALUE>azoy az di di geto iz nisht &lt;geven&gt;, nisht gevoynt eyner aleyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts1754" TIME_SLOT_REF2="ts1761">
				<ANNOTATION_VALUE>nu, s'iz shoyn geven di geto, vayl zi hot oykh gevoynt mit nokh a mishpokhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1154" TIME_SLOT_REF1="ts1762" TIME_SLOT_REF2="ts1767">
				<ANNOTATION_VALUE>un undz zenen mir oykh gekumen tsun ir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts1769" TIME_SLOT_REF2="ts1771">
				<ANNOTATION_VALUE>ober &lt;zint ikh&gt; mayn shvester iz geganen tsu der arbet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts1773" TIME_SLOT_REF2="ts1775">
				<ANNOTATION_VALUE>arb-, ale zenen geganen tsu der arbet. ikh bin nisht geganen tsu der arbet, ikh bin shoyn geven nisht di...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts1776" TIME_SLOT_REF2="ts1779">
				<ANNOTATION_VALUE>ober undz zenen mir lang nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts1780" TIME_SLOT_REF2="ts1783">
				<ANNOTATION_VALUE>fun yener geto, fun GOSTYNIN, zenen mir nokh STRZEGOWO</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts1785" TIME_SLOT_REF2="ts1788">
