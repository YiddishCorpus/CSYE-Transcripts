	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Regina Pozmanter">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts47">
				<ANNOTATION_VALUE>SHALOM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a3" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts77">
				<ANNOTATION_VALUE>nokh fun undzer shtetl?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts83">
				<ANNOTATION_VALUE>s'iz gevezn a kleyn shtetl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts87">
				<ANNOTATION_VALUE>nisht keyn sakh FAMILIES,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts91">
				<ANNOTATION_VALUE>ober s'iz gevezn a shtetl mit a rov, mit a shames, mit a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts92" TIME_SLOT_REF2="ts95">
				<ANNOTATION_VALUE>shoykhet, mit a khazn un dos alts iz gevorn oysgehaltn fun dem shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
				<ANNOTATION_VALUE>natirlekh, s'iz nisht geven keyn zeyer raykh ober s'iz ge-, me hot es oysgehaltn, di kehile hot dos alts oysgehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts103">
				<ANNOTATION_VALUE>spn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts104" TIME_SLOT_REF2="ts107">
				<ANNOTATION_VALUE>s'iz geven a balbatish lebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts111">
				<ANNOTATION_VALUE>a fayn lebn, nisht geven keyn groyse</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts115">
				<ANNOTATION_VALUE>tsu fil negidim, s'iz nisht geven keyn sakh oreme-layt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts119">
				<ANNOTATION_VALUE>azoy. iber hoypt, der, di yidish, yidn zenen gevezn sokhrim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a16" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts123">
				<ANNOTATION_VALUE>yeder hot gehat a, a kleyt, zay- zayn gesheft,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts127">
				<ANNOTATION_VALUE>a gevelb, in mitn mark zenen geven di yidishe gesheftn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>un dos iz geven di parnose.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts135">
				<ANNOTATION_VALUE>yeder hot gehat, eyner &lt;aza&gt; kleyt, eyner aza s- UNK, eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts139">
				<ANNOTATION_VALUE>dos iz geven di yidishe parnose.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts143">
				<ANNOTATION_VALUE>un got a dank, s'iz geven biz der milkhome iz gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts147">
				<ANNOTATION_VALUE>zeyer gut, di ga-, di ale yidn hobn gelebt azoy vi eyn mishpokhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1173" TIME_SLOT_REF1="ts148" TIME_SLOT_REF2="ts151">
				<ANNOTATION_VALUE>s'iz geven a simkhe, zenen ale zikh tsuzamengekumen: der rov, un der khazn, un der shoykhet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts155">
				<ANNOTATION_VALUE>un a- un di yidn, di kehile.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts156" TIME_SLOT_REF2="ts159">
				<ANNOTATION_VALUE>un s'iz geven di zelbe zakh, a simkhe, a bris, ober alts, un kholile-vekholile es zol nisht geshen az s'iz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts160" TIME_SLOT_REF2="ts163">
				<ANNOTATION_VALUE>a tsore hobn ale mitgeveynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts164" TIME_SLOT_REF2="ts167">
				<ANNOTATION_VALUE>dos iz geven dos yidishe lebn, dos shtile lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts171">
				<ANNOTATION_VALUE>un &lt;es zol geyn&gt; mit di kristn hobn mir oykh nisht shlekht gelebt. mir z- hobn gut gelebt mit zey, zenen gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts172" TIME_SLOT_REF2="ts175">
				<ANNOTATION_VALUE>shkheynim. me ken nisht zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts179">
				<ANNOTATION_VALUE>biz di milkhome. me hot zey nisht gehetst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts183">
				<ANNOTATION_VALUE>s'iz geven, dos iz geven di tsore, az me hot zey nisht gehetst, zenen nisht geven k'aza min</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts184" TIME_SLOT_REF2="ts187">
				<ANNOTATION_VALUE>inteligent folk vos zey hobn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts191">
				<ANNOTATION_VALUE>zey hobn eh aleynt farshtanen. az me hot zey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts192" TIME_SLOT_REF2="ts195">
				<ANNOTATION_VALUE>geganen mit zey in gutn iz undz oykh geven gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts196" TIME_SLOT_REF2="ts199">
				<ANNOTATION_VALUE>az me hot zey gehetst zenen zey geven nisht gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts203">
				<ANNOTATION_VALUE>letstns ven s'iz geven shoyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts204" TIME_SLOT_REF2="ts207">
				<ANNOTATION_VALUE>far der milkhome az me hot shoyn geredt azoy vegn der milkhome hobn zey shoyn gehat mer khutspe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts208" TIME_SLOT_REF2="ts211">
				<ANNOTATION_VALUE>hobn zey shoyn mer ongehoybn tsu boykotirn, nisht tsu kumen in di yidishe gesheftn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts212" TIME_SLOT_REF2="ts215">
				<ANNOTATION_VALUE>un s'iz shoyn geven nisht azoy gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts216" TIME_SLOT_REF2="ts219">
				<ANNOTATION_VALUE>vayl eh der Hitler, me hot zey gehetst, az Hiter vet kumen vet er, vet er makhn a khurbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts220" TIME_SLOT_REF2="ts223">
				<ANNOTATION_VALUE>leyder, leyder hot zikh es eh farvirklekht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts231">
				<ANNOTATION_VALUE>SKĘPE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts239">
				<ANNOTATION_VALUE>lebn LIPNO, lebn SIERPC</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts240" TIME_SLOT_REF2="ts243">
				<ANNOTATION_VALUE>in di di WOJEWÓDZTWO WARSZAWSKIE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts251">
				<ANNOTATION_VALUE>in a POWSZECHNY shul,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts255">
				<ANNOTATION_VALUE>nor in a POWSZECHNY shul.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1074" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
				<ANNOTATION_VALUE>ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1106" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1075" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>ya, spetsyel, keyn organizatsye, s'iz nisht geven &lt;vayl&gt; s'iz nisht geven a groyser yugnt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts279">
				<ANNOTATION_VALUE>nor der yugnt iz geven tsienistish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts280" TIME_SLOT_REF2="ts285">
				<ANNOTATION_VALUE>mir hobn geshtrebt ale &lt;nokh&gt; demolt Palestine, demolt iz dokh nokh nisht geven Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1076" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts293">
				<ANNOTATION_VALUE>hobn ale ge- gesh- ge-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1077" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts299">
				<ANNOTATION_VALUE>geshtrebt nokh dem, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts303">
				<ANNOTATION_VALUE>iz ikh gedenk, zenen gekumen referentn, flegn kumen un haltn referatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts304" TIME_SLOT_REF2="ts307">
				<ANNOTATION_VALUE>fun Yisroel, zey hobn tsuzamengenumen zakhn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts311">
				<ANNOTATION_VALUE>un gelt, zilber, gold, gelt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts315">
				<ANNOTATION_VALUE>oyf eh far Kern-Kayemes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts323">
				<ANNOTATION_VALUE>tsu koyfn do in land bodn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts327">
				<ANNOTATION_VALUE>iz yeder eyner iz geven azoy ibergenumen az MAMASH kinder</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts328" TIME_SLOT_REF2="ts331">
				<ANNOTATION_VALUE>vos zenen geven, bay undz iz alts forgekumen az s'iz geven a referat iz geven in di shul,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1079" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts335">
				<ANNOTATION_VALUE>zenen zikh ale tsuzamengekumen in di shul.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts339">
				<ANNOTATION_VALUE>&lt;zey hobn&gt; zikh tsuzamengekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts340" TIME_SLOT_REF2="ts343">
				<ANNOTATION_VALUE>un yeder eyner az ver hot geredt dervegn iz azoy ibergenumen geven dermit,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts344" TIME_SLOT_REF2="ts347">
				<ANNOTATION_VALUE>az me hot, vos me hot gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts348" TIME_SLOT_REF2="ts351">
				<ANNOTATION_VALUE>a fingerl, a por oyringlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts352" TIME_SLOT_REF2="ts355">
				<ANNOTATION_VALUE>hot yeder, di di kinder, di meydelekh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts356" TIME_SLOT_REF2="ts359">
				<ANNOTATION_VALUE>fun di tsveyte zayt vos bay undz iz geven a a froyen-shul far &lt;-zunder&gt; un a mener-shul</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1080" TIME_SLOT_REF1="ts360" TIME_SLOT_REF2="ts363">
				<ANNOTATION_VALUE>un durkhn fentster hot men gevorfn dos vos me hot gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts367">
				<ANNOTATION_VALUE>az me, yo, tsienistish, me hot ge-, ale tsienistish. s'iz nisht geven keyn andere parteyen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts368" TIME_SLOT_REF2="ts371">
				<ANNOTATION_VALUE>in di gresere shtet iz yo, s'iz geven parteyen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1081" TIME_SLOT_REF1="ts372" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>s'iz geven bundistn, s'iz geven pale-tsienistn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts381">
				<ANNOTATION_VALUE>bay undz zenen ale mir gevezn tsienistn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts387">
				<ANNOTATION_VALUE>ale, zey hobn ge- geshtrebt nokh Yisroel. me hot nisht gevust epes andersh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts401">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1082" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts407">
				<ANNOTATION_VALUE>di, mayn shvester, ikh hob ge- di eltste shvester mayne hot gevoynt in Hamburg in Daytshland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts411">
				<ANNOTATION_VALUE>iz azoy vi me hot oysgevizn di yidn fun Daytshland</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts412" TIME_SLOT_REF2="ts415">
				<ANNOTATION_VALUE>zenen geven poylishe birger, hot men zey geshikt nokh ZBĄSZYŃ.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts419">
				<ANNOTATION_VALUE>un demolt zey, zey zenen nisht geforn nokh ZBĄSZYŃ, zenen zey gekumen tsu undz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts423">
				<ANNOTATION_VALUE>mir d-, nokh SKĘPE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts424" TIME_SLOT_REF2="ts429">
				<ANNOTATION_VALUE>un zenen geven mit undz tsuzamen biz me hot undz geyogt aroys fun SKĘPE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts441">
				<ANNOTATION_VALUE>zibn un draysikstn, meyn ikh, iz es geven, yo, ikh meyn az yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts447">
				<ANNOTATION_VALUE>zey hobn nisht fartseylt, zey hobn moyre gehat tsu redn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts451">
				<ANNOTATION_VALUE>zey hobn moyre gehat tsu redn, ober dos vos zey hobn gezogt az s'iz shlekht, s'iz nisht gut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1086" TIME_SLOT_REF1="ts452" TIME_SLOT_REF2="ts455">
				<ANNOTATION_VALUE>az me hot zey aroysgeyogt, zey hobn shoyn nisht &lt;gekont, az zey hobn&gt; ales tsugenumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1097" TIME_SLOT_REF1="ts456" TIME_SLOT_REF2="ts459">
				<ANNOTATION_VALUE>m'iz gekumen bay der nakht un m'hot zey aroysgeyogt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1107" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts467">
				<ANNOTATION_VALUE>shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts471">
				<ANNOTATION_VALUE>nor dos iz geven a nes bay undz, a nes, s'iz leyder nisht geven shoyn shpeter keyn nes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
