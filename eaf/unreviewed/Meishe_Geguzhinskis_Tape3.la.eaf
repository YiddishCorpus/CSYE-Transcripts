		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
				<ANNOTATION_VALUE>un mir un der der ployt flegt iz shoyn geven oyfgebrokhn, es fle- es</ANNOTATION_VALUE>
