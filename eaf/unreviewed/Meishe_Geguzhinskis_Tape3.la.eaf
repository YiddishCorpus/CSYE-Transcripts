		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a620" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>eh mir hobn ir aroysgelozt, s'bay undz geven aroysloz ovnt, zi hot gekrogn gevise farbindungen mit a</ANNOTATION_VALUE>
