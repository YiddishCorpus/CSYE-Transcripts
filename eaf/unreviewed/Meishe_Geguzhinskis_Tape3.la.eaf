		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a695" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
				<ANNOTATION_VALUE>un in dem zelbn shpitol iz geven a spetsyeler gag- eh gever-tsimer, vu m'flegt haltn gever.</ANNOTATION_VALUE>
