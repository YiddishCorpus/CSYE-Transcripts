		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a702" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
				<ANNOTATION_VALUE>vi a meydl, a shvartse arbet dortn, ba- badinen di eh di ofitsirn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a703" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
				<ANNOTATION_VALUE>flegt zi aroysganvenen a biks a a Grabin un bahaltn</ANNOTATION_VALUE>
