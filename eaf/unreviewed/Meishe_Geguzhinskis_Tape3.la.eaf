			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a621" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>litvishn KSIADZ, mit a litvishn gaystlekhn, velkher hot ir ongenumen velkher hot zikh ongenumen ir tsu bahaltn in a monastir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
