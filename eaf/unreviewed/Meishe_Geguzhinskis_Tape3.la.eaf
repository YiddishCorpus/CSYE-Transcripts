		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a625" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>mir hobn zikh tsunoyfgeklibn, s'hot zikh gefunen dortn farshidene produktn oyfn tish, vifl s'nokh geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a968" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>eh nokh ver nit iz hot gebrakht dortn, efsher hot men a UNK &lt;a shtarke&gt; oystsutrinken,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a969" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>oyf vifl ikh gedenk dakht zikh az s'iz nit geven, nor efsher iz es yo geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a970" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts135">
				<ANNOTATION_VALUE>un eh azoy vi ikh bin geven azoy tsu zogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
