		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a978" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts453">
				<ANNOTATION_VALUE>in dem moment, hobn mir zikh durkhgerisn dem plats vu er hot undz nit bamerkt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a871" TIME_SLOT_REF1="ts452" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>tsu dem parkan fun dem beys-oylem, dortn iz shoyn geshtanen Mendele Moskovitsh, er hot undz gevart,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a873" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>mir hobn gekhapt di beyde zek, un er hot undz gekusht, poshet gevolt kushn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a875" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>far freyd vos mir zaynen geblibn lebn, vos mir hobn dem ge- oysgefilt undzer ga- undzer undzere oyfgabe, un mir za- un mir hobn genu- getrogn di zek durkhn durkh di di beys-oylem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a876" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>biz Troko gas biz Trako gas. dortn hot shoyn iz tsuge- eh hobn mir hobn mir zikh avekgeleygt lebn parkan un gevart oyf di mashin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a979" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>di mashin hot zikh bavizn in etlekhe minut arum. der shofer iz geven zeyer zeyer eh pinktlekh. er iz gekumen punkt dray a zeyger,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
