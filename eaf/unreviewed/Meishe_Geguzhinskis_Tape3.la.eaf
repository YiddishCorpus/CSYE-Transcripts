		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a840" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>emes eh Mendele Moskovitsh, der driter undzerer khaver, iz nisht gegangen mit undz tsuzamen. er iz geshtanen baym parkan un gevart oyf undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a841" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>mir hobn opge- mir hobn ongelodn mit di biksn, vi ikh hob shoyn gezogt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a842" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>un mir hobn gedarft aroysgeyn. in dem moment ven mir hobn gezolt aroysgeyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a844" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts413">
				<ANNOTATION_VALUE>durkhn fentsterl hobn mir bamerkt vi es shteyt der es shteyt der postn, er hot zikh grod opgeshtelt. s'geven a frostike nakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a847" TIME_SLOT_REF1="ts412" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>un kentik iz im geven zeyer kalt, hot er iz er geshtanen lebn fent- lebn fen- lebn f- lebn fentsterl fun yener zayt un zikh gevaremt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a849" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>un do gib ikh a kuk oyfn zeyger, hot mitgenumen mit zikh a zeyger, a kuk az s'iz shoyn bald der tsayt, azoy iz es shoyn bald dray, mir muzn fun dort aroysgeyn mit di ongeve- mit di ongeleygte zek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a850" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>tsvey zek hobn mir gehat, un andere</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a851" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
				<ANNOTATION_VALUE>un andere materyeln, velkhe m'shraybt vegn dem in a in a bukh, Fayglzon hot er geshribn az s'geven dray zek. praktish zenen geven vi tsvey zek in gantsn gever. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a852" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>Itske Mikitshanski iz geven a heyser yat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a853" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>zogt er, mir vartn nit, mir muzn im, zogt er, opshisn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a854" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>dem postn, un mir veln zikh durkh-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a855" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>durkh- adurkhraysn bizn beys-oylem, dortn veln eh vi vi es iz do di hert di ir zet durkh trogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a856" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>un mir veln onlodn onlodn di di mashin, vayl di mashin darf kumen dray a zeyger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a857" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>ikh bin geven a bisl in dem a bisl shtiler,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a858" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>zog ikh tsu im, "Itske, m'darf efsher nokh vartn a minut. vart!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a859" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts437">
				<ANNOTATION_VALUE>dos vet zayn der letster etap azoy tsu zogn, dos iz der letster oysgang.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a861" TIME_SLOT_REF1="ts436" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>efsher veln mir nokh opvartn nokh a por minut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a862" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>efsher vet er zikh fort, der der postn, avekgeyn fun danet."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a863" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>un punkt azoy hot pasirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a864" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>vi ikh zol nor aroys di verter vegn dem az mir darfn vartn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a865" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>mir shteyen shoyn mit di zek beyde ongelodn oyf di pleytse, shvere zek, geferlekh shvere, kam kam vos mir hobn zey oysgehaltn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a866" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>fun di ge- di sh- ge- ge- ge- gekvetsht di zek in pleytse es iz geven shver oystsuhaltn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a867" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>zog ikh tsu im, vart nokh oyf. in dem moment hot er sh- plutsling zikh ongehoybn tsu bavegn, az er iz avekgegangen in dem tsveytn vinkl fun fun fun hoyf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
