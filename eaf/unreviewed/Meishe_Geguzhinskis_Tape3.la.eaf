		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a768" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>der shtab fun der partizanisher organizatsye hot bashlosn az,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a770" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts311">
				<ANNOTATION_VALUE>mir hobn batrakht di gantse lage vi azoy es tsum ton,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a772" TIME_SLOT_REF1="ts310" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>mir hobn bashlosn es tsu aroys tsu ganvenen fun dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a774" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>bashtimt hot men dray khevre.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a776" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>Itske Midreshanski iz geven, Meyshe Yeguzhinski, s'heyst</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a778" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>eh Mendele Moskovitsh, un ikh, Meyshe Yeguzhinski.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a779" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>der plan iz geven do ongefirt azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a780" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>in mitn nakht hobn mir zikh gedarft aroyskhapn fun geto,</ANNOTATION_VALUE>
