		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a615" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>a yidishe meydl Liza Liza Ulgina. Liza Olgina hot gelebt oykh in kolektiv.</ANNOTATION_VALUE>
