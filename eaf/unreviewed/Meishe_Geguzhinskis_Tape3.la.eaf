			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts242" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>durkh gants Kovner gasn, hobn mir gehat a me- a a mentshn Trakhinov hot er geheysn, oykh a partizaner,</ANNOTATION_VALUE>
