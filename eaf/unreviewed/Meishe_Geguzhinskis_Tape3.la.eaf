		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a973" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>Sonye Rubinzon flegt oyfbrekhn, shoyn gehat oyfgeef- -efnt a a sh- a bret, </ANNOTATION_VALUE>
