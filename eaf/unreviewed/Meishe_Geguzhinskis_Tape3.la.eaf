		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts240" TIME_SLOT_REF2="ts243">
				<ANNOTATION_VALUE>fardekn mit eh mit bezemer un avektrogn es durkh geyn durkhn</ANNOTATION_VALUE>
