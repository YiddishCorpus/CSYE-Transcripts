		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a699" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>flegt zi bay tog arbetndik, zi flegt dort heytsn di oyvns,</ANNOTATION_VALUE>
