			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a781" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>un durkh di hintersh- durkhn hintershtn zayt fun dem fun dem shpitol iz geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a784" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>oyf der hinter fun der hot iz geven a sh- iz geven a beys-oylem. durkh dem beys-oylem hobn mir zikh gedarft araynkhapn in dem, ven ven der postn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a785" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>zoln undz nit bamerkn, araynkhapn zikh in dem shpitol,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a786" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>un eh fun dortn aroysganvenen di gever.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a787" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
				<ANNOTATION_VALUE>farshteyt zikh gever iz geven farshlosn in a in in farshlosn unter a shlos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a976" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>Sonye Rubinzon hot undz tsugegreyt a shlisl, der shlisl hot hobn mir gemakht tsu ersht in geto,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a788" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>m- s'iz geven far dem ikh vil eh vegn dem efsher nit eh dertseyln, nor ikh gey dermonen vegn dem. az tsu ersht hot men hot zi genumen dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a789" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>dem &lt;ODCISK&gt; vel ikh zogn fun dem dem shtamp fun dem fun dem shlos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a790" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
				<ANNOTATION_VALUE>un gebrakht dos in geto, un in geto hobn undzere khevre tsugegreyt a shlisl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a791" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>di shlisl hot men tsu ersht tsi zi shlist gut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a792" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>iz men gegangen mit dem shlisl eyn mol mit a brigade un ikh hob prubirt dem sh- dem shlos ven keyner iz nit geven, di daytshn hobn nit bamerkt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a977" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
				<ANNOTATION_VALUE>un ikh hob gegebn a por gedreyt es, eh s'efnt zikh di tir. mit dem shlisl zenen mir aroys ale dray fun geto</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a793" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>baku- eh baganvenen di gever.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a794" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
				<ANNOTATION_VALUE>di arbet undzere hot zikh ongerufn bay undz Bambirshke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a795" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
				<ANNOTATION_VALUE>un di Bambirshke hob ikh untergenumen, dos iz geven in fir un fertsikstn yor in yanvar monat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a797" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>s'iz geven dan a groyser frost, kalt, mir zaynen aroys in mitn nakht a zeyger tsvelf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a801" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts357">
				<ANNOTATION_VALUE>un mir hobn zikh durkhge- mir zenen durkhgegangen do di ale Kovner gasn biz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a803" TIME_SLOT_REF1="ts356" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>biz eh biz dem K- eh Shantser, biz dem Karmeliter, Karmeliter, iz di Shantser iz geven Karmeliter shpitol, hobn mir zikh gehaltn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a804" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>mir zenen geblibn lign oyfn beys-oylem un gevart ven der postn ver s'iz geshtanen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a806" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>lebn HOSPIT- lebn dem sh- dem shpitol s'zol avekgeyn a bisl on a zayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a808" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>in dem moment hobn mir gedarft aribershpringen ibern parkan,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a809" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>un zikh durkh- durkhkrikhn di di veg vos er velkher er zol er zol nit zen, un arayngeyn in dem shpitol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a812" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>yo, dray a zeyger hot oyf undz gedarft vartn a mashin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a814" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>aropgeredte mashin mit a i- mit a shofer, Shepikist hot er geheysn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a816" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts373">
				<ANNOTATION_VALUE>er hot gedarft tsuforn tsu dem beys-oylem fun dem gesl Traku,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a819" TIME_SLOT_REF1="ts372" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>un vartn oyf undz mit di onge- mit mit di tsugegreyte gever.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a820" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>mir zaynen arayngekrokhn, mir za- in mitn nakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a821" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>Itske Biketshanski iz der ershter aribergeshprungen ibern parkan, ikh hinter im, mir zenen geven bavofnt mit kleyne kleyne revolvern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a822" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>belgishe F.N. dakht zikh hobn zey geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a823" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>mit dem hobn mit dem bading az eyder m'vet undz khapn zoln mir zikh zelbst dershisn, vayle mir hobn farshtanen az</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a824" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>mir hobn farshtanen az oyber m'vet undz khapn in aza min operatsye, farshteyt zikh vet men undz geferlekh, vet veln mir shoyn nit blaybn lebn. iz beser zikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a825" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>oysshisn, der letster koyl zol zol UNK lozn iber farlozn lozn far zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a826" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>nor den mol iz nit undz oysgekumen tsum shisn, mir hobn pamelekh araynge- arayngekhapt in dem in dem gane- in dem koridor vu s'geven der der gever-kamer</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a828" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>mir hobn bay nakht, mir hobn geefnt di tir, di shlisl hot zeyer gut gepast,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a829" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>s'hot zikh geefnt di tir in der fintster,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a830" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>un do hobn mir bamerkt oyf di sh- oyf di polkes oyf di politses iz gelegn ongeleygt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a831" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts397">
				<ANNOTATION_VALUE>ful mit Grabinen, in a in a ka- kastn iz gelegn granatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a834" TIME_SLOT_REF1="ts396" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>eyer hobn mir zey hobn hobn mir zey gerufn hobn zey mir gerufn, runde granatn zenen geven di daytshishe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a835" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts401">
				<ANNOTATION_VALUE>mir hobn getsu- mit di tsugegreyte zek hobn mir onge- onge- ongelodn mit biksn, mit di granatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a838" TIME_SLOT_REF1="ts400" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>mit nokh farsheydene klezayen vi s'hot zikh nor gelozn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a839" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>un mir hobn gedarft fun dortn aroysgeyn shoyn biz draye bavayzn biz dray a zeyger vet vartn oyf undz der mashin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
