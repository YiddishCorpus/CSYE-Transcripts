		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a626" TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>shoyn dan ongehoybn tsu shraybn farsheydene dikhtn oyf yidish,</ANNOTATION_VALUE>
