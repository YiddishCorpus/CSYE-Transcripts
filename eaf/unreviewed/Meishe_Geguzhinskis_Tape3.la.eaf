		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a681" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>ikh hob oykh untergenumen in shafn gever. nit eyn mol hob ikh geshlept a biks ba- bahaltn in a bezem.</ANNOTATION_VALUE>
