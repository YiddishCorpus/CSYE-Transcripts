			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a607" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>er hot mir gezogt, "oyber bistu aza min kegn oyb du shtelst zikh kegn undzere undzere ordenung, veln mir dir fun dem kolektiv aroystraybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
