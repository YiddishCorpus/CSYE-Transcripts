			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a685" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
				<ANNOTATION_VALUE>dem biks fleg ikh krign in &lt;kranknlame&gt;-shtele in a yidish- in a daytshishe daytshishn HOSPITAL azoy tsu zogn, a shpitol,</ANNOTATION_VALUE>
