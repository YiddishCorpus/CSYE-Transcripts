	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Pinek Kraindels">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>ya, in dem lager dos iz gevorn likvidirt. s'k- mer keyn yidn dortn nisht mer gevezn. un yetst vet ir fregn vos iz gevorn mit der fabrik? der fabrik iz vayter ongegangen, ober dortn iz geblibn di polyakn arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>un azoy vi di yidn zenen aroys, vayzt zikh oys az m'hot gebrengt avade nokh mer andere polyakn tsu der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
				<ANNOTATION_VALUE>ober Starakhovitse iz gevorn likvidirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>der lager Starakhovitse iz gevorn likvidirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts21">
				<ANNOTATION_VALUE>ya,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>oh ya. di gantse tsayt, mit undz tsuzamen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>in ya. ober di polyakn aleyn hobn okyh tsugeleygt a hant, hobn oykh geshlogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>s'dortn gevezn formaners fun di polyakn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>nisht eyn mol hot er mikh ongeshlogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>nisht eyn mol hot er mikh tseharget,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>un andere oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>zey hobn gekrign batsolt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
				<ANNOTATION_VALUE>zey hobn gekrign batso- mir gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>arum Starakhovitse. fun di shtot Starkhovits. ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>di fabrik iz vayter ongegangen, di nor der lager iz gevorn likvidirt. der lager fun di yidn iz gevorn likvidirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts57">
				<ANNOTATION_VALUE>un m'hot undz genumen, m'hot undz aroysgeshikt mit vagonen arayn keyn Oyshvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts61">
				<ANNOTATION_VALUE>ikh gedenk dem tog m'iz ongekumen keyn Oyshvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>un di date nisht, dos iz geven zumer, end oyf zumer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>un ikh bin ongekum- dos iz geven ende zumer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts69">
				<ANNOTATION_VALUE>september, oktober.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>demolts bin ikh alt gevezn fuftsn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>un demolts ven ikh bin ongekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>hot mikh demolts bamerkt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>a mayns a shteterisher shtot, a shte- YOU KNOW, an Apter BOY vos hot gevoynt bay undz in hoyz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>Khaim Ernberg hot er geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a62" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>zey hobn gehat in mark a sheyn gesheft, der foter. un ikh ken im, ales,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>hot er mikh derkent, zogt er, Pinek,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>mir dakht zikh, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>zolst gedenken vos ikh zog dir. ikh vil dir zogn dir, zolst dikh oyfgebn do elter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>du bist fuftsn yor alt, ikh gedenk dikh ven ikh fun der heym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>zog ikh, vos heyst ikh zol mikh oyfgebn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>zolst dikh oyfgebn khotsh akhtsn, ikh vil dir nisht zogn zekhtsn, iz gib dikh oyf bist alt akhtsn yor, dray yor mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>un du bist a MAHLER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>zolst zogn du host a baruf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>du host gearbet in der heym bay dayn tatn MAHLER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>dayn tate iz geven a MALARZ, du bist a MALARZ.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>di verter zolstu redn. zog ikh, Khaim, gib mir a shtikl broyt, ikh gey shtarbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>zogt er, vest krign a gants broyt, oyb du vest dos zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>ven m'hot gemakht rekhts un links, Monge- Mengele, ven ikh bin arayngekumen keyn Oyshvits,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>hot er mir derlangt a shos, er hot gevorfn di bombe, aza baytsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts113">
				<ANNOTATION_VALUE>un do iz arayn di bombe, oyfgehakt mir dos dos oyg, do lebn oyg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts114" TIME_SLOT_REF2="ts117">
				<ANNOTATION_VALUE>he?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts118" TIME_SLOT_REF2="ts119">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts123">
				<ANNOTATION_VALUE>Mengele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts124" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>ikh hob nisht gevust vi m'ruft im demolts. demolts hob ikh gezen er iz a daytsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>un er shrayt, un m'firt op, un er shrayt oyf di mentshn un zidlt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>"VERFLUCHTE HUNDE!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>un er hot ge- un un un er hot gevorfn a bombe, un di bombe iz mir do arayn, do do in der rekhter zayt in rekhtn oyg, un s'hot do ongehoybn tsu blutikn, un s'gist zikh di blut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>hob ikh aropgenumen dos hitl un ikh hob tsugeleygt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>nu vos eh ikh hob nisht gehat. vos hob ikh gehat? eh ikh hob nisht gehat keyn tashntikhl, ikh hob nisht gehat keyn NAPKINS, ikh hob nisht gehat keyn layb keyn lebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>hob ikh tsugeleygt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>hot men undz avekgeshtelt tsvishn yungvarg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>un m'hot undz avekgenumen undz yungvarg hot men undz avekgenumen in der zayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>un der hot mikh bamerkt, Khaim Ernberg, dortn, hot er gevust az s'vart oyf mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>zeyer a toyte zakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>er hot shoyn gevust vos vart oyf mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
				<ANNOTATION_VALUE>zogt er, Pinekl, gib dikh oyf elter!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>un gib dikh oyf dray yor elter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a95" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>vestu kumen arbetn, zogt er, vu ikh arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
				<ANNOTATION_VALUE>zogt er, vos zol ikh tun? zogt er, zest der S.S. man vos er dreyt zikh arum mit di shtekn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
				<ANNOTATION_VALUE>iz geven azelkhe yingere, eltere, hot er gehakt do iber di kep. ver s'hot geredt a vort, hot geshrign, esn, broyt, vaser, hot er gegebn a zets mit der shtekn ibern kop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
				<ANNOTATION_VALUE>hot men geshvign. hot er ayngeshleft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
				<ANNOTATION_VALUE>zogt er, er shlogt dokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
				<ANNOTATION_VALUE>zog zog du vest farlangen, vest dikh oyfshteln dikh, un vest zikh gebn a shtel oyf, vest zogn, "ikh UNK WILL WAS</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts166">
				<ANNOTATION_VALUE>SPRECHEN tsu dir,"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
				<ANNOTATION_VALUE>vet er mit dir redn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a103" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>tomer vestu shrayen broyt, vaser, vet er dir oykh gebn a zets ibern kop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a104" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
				<ANNOTATION_VALUE>du geyst dokh nisht redn keyn broyt. tsu mir redstu broyt. un ikh vel dir gebn broyt nor az du vestu dos zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts174">
				<ANNOTATION_VALUE>er hot zikh dernentert, hob ikh mikh gegebn a shtel oyf, zog ikh, her shturmbanfirer, zog ikh, ken ikh SPRECHEN, ken ikh VERSPREKHEN tsu du IHNEN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts176">
				<ANNOTATION_VALUE>zogt er, WAS WOLLstu DEN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>zog ikh, zey HABEN dokh eyn IRRTUM mit mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
				<ANNOTATION_VALUE>ICH BIN DOCH ACHTZEHN JAHRE ALT, WIESO KOMME ICH DEN HIER REIN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
				<ANNOTATION_VALUE>ICH HABE EIN BERUF. ICH BIN EIN MALER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
				<ANNOTATION_VALUE>BITTE, MACHEN SIE UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
				<ANNOTATION_VALUE>zogt er, ven hostu den GEARBEIT? ICH HABE GEARBEIT bay mir far der MALER. vi lang? ZWEI JAHRE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
				<ANNOTATION_VALUE>shteyt un trakht un trakht un trakht un kukt mikh op un trakht. zogt er, OK, KOMME mit mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts190">
				<ANNOTATION_VALUE>un nemt mit mikh un firt mikh aroys fun dem lager un firt mikh arayn in tsveytn lager in byuro,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
				<ANNOTATION_VALUE>shrayb im ayn tsu di tsu di UNK, tsu di tsu di a GIRL iz geshtanen. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a947" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
				<ANNOTATION_VALUE>shrayb im ayn tsu di do tsu di tsu di MALER KOMPANIE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
				<ANNOTATION_VALUE>un shraybt mikh ayn als MALER,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">
				<ANNOTATION_VALUE>un m'nemt mikh tsurik aroys un m'firt mikh arayn mit a khevre, un m'gibt mir a plats.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts201">
				<ANNOTATION_VALUE>un m'git mir a plats vu tsu shlofn, bald gibt men bald mir a plats in blok fertsn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts202">
				<ANNOTATION_VALUE>dort vestu ahingeyn, kum ikh ahin dortn, m'firt mikh arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
				<ANNOTATION_VALUE>un der der un der blok ALTESTER, eyder m'geyt arayn in blok arayn, blokt er der blok ALTESTER hot er gehat aza kleyn tsimerl, eyder m'geyt arayn in dem groysn blok.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>hot er mikh ongenumen, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>un vayzt un firt mikh arayn un get mir der plats oyfn dritn oyfn dritn FLOOR,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>do iz dayn bet. dem dritn FLOOR shlofn zeks mentshn. leyg dikh do. do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
				<ANNOTATION_VALUE>un demolts hoyb ikh ersht on gevoyer tsu vern mentshn, un ikh her ikh hob mikh shoyn bafrayt, un ikh zits shoyn azoy oyfn bet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
				<ANNOTATION_VALUE>kumen mentshn, dertseylt men, du bist ersht gekumen? zog ikh, yo. zogt er, du veyst vos do geyt tsu? zog ikh, UNK vos veys ikh?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>zog ikh, vos arbet men?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
				<ANNOTATION_VALUE>zogt er, do arbet men nisht. do brent men.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>vos heyst m'brent?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
				<ANNOTATION_VALUE>do brent men mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
				<ANNOTATION_VALUE>un dan nakher iz gekumen Khaim Ernberg tsu mir, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a948" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>arayn tsu mir, ikh bin do geven in zelbn m'hot mikh arayngeshikt in zelbn lager arayn, get er a kum arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a949" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>khapt mikh arum, zogt er, ikh hob dikh opgeratevet fun eyn toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>zog ikh, vosara toyt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a135" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
				<ANNOTATION_VALUE>zogt er, morgn voltstu shoyn nisht gelebt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
				<ANNOTATION_VALUE>dos alts lebt shoyn nisht mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
				<ANNOTATION_VALUE>do mit di ale khevre du bist geven iz gevorn farbrent di nakht. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>zog ikh, vos heyst m'farbrent?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
				<ANNOTATION_VALUE>m'farbrent, zogt er, mentshn, m'fargazevet, m'farbrent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts242" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>di hobn genoy hobn genumen dertseyln un ikh bin geblibn shteyn, ikh hob gerisn barn kop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>zog ikh, vos heyst m'farbrent mentshn? do, zogt er, bistu nisht gekumen lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
				<ANNOTATION_VALUE>do vestu, zogt er, arbetn, biz du vest nisht kumen, vestu geyn in oyvn arayn, in gaz-kamern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
				<ANNOTATION_VALUE>vos vel ikh dir zogn dir? ikh hob ongehoybn tsu arbetn, ikh zol aroysgeyn bald in der fri oyfn apel, zol ikh zukhn dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a950" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
				<ANNOTATION_VALUE>dem kapo, ikh veys geven demolts FORTY NINE,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a951" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>nayn un fertsik NUMBER, di kapo nayn un fertsik iz geven der kapo fun dem ales,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>un er hot shoyn gehat geredt, Khaim Ernberg, er hot gehat a man vos er iz geven der onfirer, a er iz geven a yid, a Lodzher yid, er iz geven der firer fun di MALARZEs.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>hot er shoyn geredt, ikh shik dir a yungn BOY, zolst gedenken, er iz gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>er ken gor nisht. ober du muzt im oyslernen epes tsu tun, du muzt im oyshaltn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a952" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>az s'vet emetser kumen, vestu im gebn tsu mishn a fas mit mit kalekh, a veyst dokh a mol hot men gekalekht, a fas mit kalekh a fa- epes zolstu im gebn epes tsu tun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a953" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>un du muzt fun im makhn a mentsh, vayl s'vet gornisht helfn. er zol er hot oyfgegebn er iz a MALER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>un ikh hob im aroysgenumen fun toytn lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>un er iz do do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>hot er shoyn gevust,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>in der fri, ikh kum ahin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>zogt er, du bist der BOYtshik? zogt er, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>zogt er, ikh hob shoyn gehert. Khaim Ernberg hot mit mir geredt. zogt er, shoyn, UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>ikh vel dir shoyn gebn vos tsu tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts281">
				<ANNOTATION_VALUE>mish do a fas vaser, a brengen vaser, mish do dem kalekh, mish oys dem kalekh, breng dos, breng yents.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts280" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>ikh hob genumen arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>un er hot fun mir gemakht a layt. er hot mir gemakht, s'nisht bloyz m'darf yedes mol mishn, m'hot gedarft epes tun oykhet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>farshtopn lekher, farshmirn lekher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>eyn mol, tsvey mol hot men gevizn, ikh hob es gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>un ikh ver gevoyer vos tut zikh, un di un di kremetoryums, dos ikh bin geven Birkenou,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>dos heyst Oyshvits, ober dos iz geven in Birkenoy vu di gaz-kamern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>un di gaz-kamern arbetn, un m'brent, un es tut zikh, bay tog un bay nakht geyt aroys di roykh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>m'zet nor dort, zogt er, zest der roykh? dos iz yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>do geyen a roykh fun yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts301">
				<ANNOTATION_VALUE>un m'hakt, un m'shlogt, un m'kaylt!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts300" TIME_SLOT_REF2="ts302">
				<ANNOTATION_VALUE>m'geyt aroys oyf der gas, m'geyt adurkh, m'zet an S.S. man, hostu nisht gegebn keyn a gutn kuk, KOMM MAL aher!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>nemt er der shtekn, er hakt im ibern kop, iber di oygn, iber di yorn, un er tseharget dikh biz tsum toyt. fertik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>zuntik zey hobn nisht gehat vos tsu tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>di S.S., zey zenen nisht aroysgegangen, di vos zenen aroysgegangen oyf CHOFESH, zenen aroysgegangen oyf CHOFESH; di vos zenen nisht aroysgegangen oyf keyn CHOFESH,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>hobn zey gemakht zeyere shtiklekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>hot men gegangen di, arumgelofn a a gantse vokh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>s'hot epes emetser nisht gefoln,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>genumen di hant, oyfgeshribn di NUMBER, STRAFKOMPANIE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>s'hot geheysn STRAFKOM- oyf zuntik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>zuntik hot men SPECIAL nisht gearbet, m'hot gereynikt dem blok. yeder eyner hot gereynikt dos bet, gereynikt dem blok, gevashn ales, m'hot getun, yeder iz geven basheftikt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>ober zuntik, ver s'geven oyf der STRAFKOMPANIE oysgeshtelt, hot gemuzt avekgeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>sh- tsushteln zikh tsu zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>tsi m'iz tsurikgekumen fun dortn gants,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>ze'mir gevezn fun der tsveyter velt. oyb s'tsurikgekumen a mentsh fun di STRAF.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>fun di shtrof vos zey hobn gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
				<ANNOTATION_VALUE>zey hobn mit undz gemakht azelkhe shtrofn, azelkhe zakhn, vos s'nisht ibertsugebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a954" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>m'hot undz azoy tserisn oyf shtiker, m'hot undz azoy getribn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a955" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>m'hot oyf undz getretn, m'zol zikh valgern oyf der erd,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>un undz arayngevorfn in a BRECHA,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
				<ANNOTATION_VALUE>m'zol aroys shpringen shnel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>zen ver s'nisht aroysgegangen shnel, hot er gegebn a kop mitn fus in ponem arayn, tsurik arayn in vaser arayn. eltere mentshn geblibn toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
				<ANNOTATION_VALUE>alts hot dos pasirt ven du host gehat di STRAFKOMPANIE zuntik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>un a gantse vokh hot men gebrent un geharget.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
				<ANNOTATION_VALUE>un vos vil ikh aykh zogn, dos esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
				<ANNOTATION_VALUE>m'hot gekrign dos bisl zup, far nakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>in der fri hot men gekrign tsvey shtikelekh SLICES broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
				<ANNOTATION_VALUE>mit a shtikl margarin mit a kave.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>un mitog tsayt hot er gekrign a halbn liter zup.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>m'iz aheymgekumen hot men gekrign a halbn liter zup.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>freg ikh aykh, m'hot gearbet dortn iz gevezn shver biter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>m'hot dir gegebn azelkhe arbetn az du zolst es gornisht konen endikn. un du host es gemuzt endikn. vos mol mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>un ikh drey zikh arum un kuk tsu vos do geyt tsu. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>vos tut men do?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>un mit eyn mol firt mikh arayn, ikh hob shoyn gekent arbetn mer PAINTINGeray, maleray, ikh hob vos a mol bin ikh gevorn mer, ir veyst dokh, ikh bin arayn, in der in der BUSINESS arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>hot men mikh arayngefirt oyf a plats tsu kalekhn oyf a plats vu s'gelign der gold un di brilyantn iz gelign oyf der FLOOR a barg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>fun di yidn. fun tseyn, fun brilantn, shteyner finef karator.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts379">
				<ANNOTATION_VALUE>in Oyshvits, ikh hob m'hot gearbet a HOSPITOL hot men gearbet far di daytshn, dos iz geven lebn Oyshvits a HOSPITOL, a naye beyde,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts380" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>ye, oysnveynik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>aroysgegangen fun lager. m'hot aroys marshirt. bald in der fri mit a muzik. mit a muzik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>geshtanen der muzik, iz geshtanen der lager firer un er hot gekukt oyf ale heftlinger. yeder kapo hot gemoldn, ikh hob MAL FUNFZIG HAFTLINGE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts389">
				<ANNOTATION_VALUE>un der kapo NUMBER FORTY NINE mit FUFZIG HAFTLINGE, spn, spn, m'hot getseylt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts388" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>eyner iz geshtanen oyfgeshribn, spn, un m'hot undz hot men marshirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>aheym geyendik hot er gemoldn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>ikh hob, zogt er,  finef un VIERZIG HAFTLINGE, un FUNF TOTE. finef toyte.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>tsvey toyte, dray toyte, finef toyte, dos vegele mit di toyte iz nokhgegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>vu hostu di toyte? dos vegele iz nokhgegangen, vayzn di toyte.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>ikh hob gearbet dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>hob ikh gebetn a blekherzh, hob ikh gezen vos dortn tut zikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>un Khaim Ernberg hob ikh mikh mit im gezen yedn tog,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>zogt er, "Pinek, kenst gornisht epes shafn dortn bay der arbet, epes trefn epes?" zog ikh, ikh vel zen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>hob ikh mikh avekgezetst,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>un ikh bin avekgegangen tsu a blekherzh mit a mit a pakh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts413">
				<ANNOTATION_VALUE>er zol mir makhn a DOUBLE &lt;DIDIDNO&gt;, a DOUBLE &lt;DIDNO&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts412" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>a unterleygn a DOUBLE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>zogt er, vos darfstu dos? zog ikh, "vos darfstu visn? ikh vil a DOUBLE &lt;DIDNO&gt;. makh mir dos!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>hot er mir gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
				<ANNOTATION_VALUE>az ikh bin arayngegangen arbetn, der pakh iz geven farshmirt mit kalekh, ober ikh bin aroysgeganen hobn zey oysgegosn dem kalekh, zen tsi s'ikh hob nisht a mol in dem kalekh epes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a956" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>di S.S. zenen geshtanen. ikh bin arayngegangen arbetn in aza plats vu der gold iz gelegn, di brilantn gelegn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>vos hob ikh getun? ikh hob arayngeleygt a por shtiklekh brilantlekh in der DOUBLE &lt;DIDNO&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>un der heykh iz geven kalekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>ikh bin aroysgegangen hot er oysgegosn kalekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>vos hot er gevust vos dortn do a tsvey &lt;DIDNO&gt;? hintn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>shoyn. ikh bin gegangen avek kalekhn dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>shpeter hob ikh mitgenumen roste ringlekh un bahaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>aheym gebrengt tsu Khaim Ernberg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts439">
				<ANNOTATION_VALUE>er hot mir gevizn in dem blok, hot er avekgenumen a bretl, in der zayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts438" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>hot er avekgeleygt, zogt er, dos vet zayn far a shvartse sho, oyf a shvartse sho.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>zog ikh, vos far a shvartse sho ken do zayn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>az m'nemt, zog ikh, farbrenen, vos ken nokh zayn mer? vos ke-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>zogt er, "kenst gornisht visn, Pinekl, vos ken kumen. du breng aheym vifl du kenst!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>far dem ken men zikh efsher oprateven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>ikh hob dortn gearbet un gearbet un gearbet. shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>un ikh aheym gebrengt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>mit eyn mol shtey ikh in a zal un ikh shmir, ikh maleve a fentster.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>in dem zayt shteyt oykh a mentsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>oykhet a yunger BOY vi ikh, fun Rumenyen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>un shmirt a sf- malevet a fentster.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>bin ikh avekgeganen fun mayn fentster a minut un tsugeganen tsun im oyf a minut redn a vort. git a gey adurkh an S.S.,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>un zet mikh az ikh shtey red mit im,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>git er a loyf arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>zogt er, "KOMM MAL HER!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>zogt er, "WILLST DU MIT MIR THEATER SPIELEN?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>az ikh vil mit im shpiln teater. dos heyst az az er iz nishto, gey ikh tsu ir redn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>ikh makh nisht mayns.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>zog ikh, ICH HABE NUR gevolt nemen, zog ikh, fun im, a BISSCHEN kit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>tsu farkiteven mayn fentster. er hot dos. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>zogt er, "MACH MACH MAL DEIN SCHNAUZE ZU!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>ikh zol tsumakhn dos moyl, ikh zol nisht mer redn. "kapo!" un er shrayt der kapo. der kapo kumt arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>er iz gevezn a Varshever sheygets, Zigmund,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>er hot mikh shtark lib gehat, der kapo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>ven er hot gekrign a pekl fun Poyln hot er mikh gerufn ikh zol kumen helfn esn. der sheygets.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>er hot mikh zeyer gehaltn. er hot gezen er git a ruf dem kapo un er zet mikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>iz im gevorn shlekht. zogt er, kapo, breng mir a shtek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>er zol im brengen a shtik. a STICK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>un der kapo loyft arum un brengt arayn a shtekn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>un zogt mir, buk DICH.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>in mitn zal, ikh zol mikh aynbeygn, ikh zol mikh aropbeygn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>zog ikh tsun im, &lt;ershte&gt; mayn firer, shisn SIE nisht. bite!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>shisn SIE nisht, SCHLAGEN SIE MICH nisht, nor shisn SIE nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>zogt er, "ICH vel IHNEN nisht shisn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>shoyn shisn? nisht a MAL tsayt. buk DICH!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>vi ikh beyg zikh arop, beyg zikh ayn, er zol kenen oyfheybn di shtekn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>ikh ze vi er vil aroplozn dem shtekn, geb ikh mikh a glaykh oys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>shrayt er tsu mir, dos kost di doplt!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>ikh veys nokh nisht vifl er darf mir gebn, er shrayt shoyn doplt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>geyt tsu der kapo, un zogt tsu mir, "Pinek, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>shpil zikh nisht arum mit im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>beyg dikh arop, un az nisht vestu zayn toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>az er zogt dir doplt,"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>hot er mir genumen knakn!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>ikh hob nor dershpirt di ershte fir finef shtik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>shpeter di tsvontsik hob ikh shoyn nisht gefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>ikh bin shoyn gevezn fertik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>un ikh bin shoyn gelign oysgetsoygn oyf der erd.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>un er hot nokh dem arayngehakt in mayn kop arayn mit shtekenes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>az ikh derman zikh, spn ende velt. ende velt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>er iz avek, der S.S. man,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>ikh bin geblibn lign,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>der kapo iz arayngekumen nokh tsen minut, hot er gezogt im er zol mikh avekfirn oyfn vegele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>tsum gaz kamer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>iz der kapo arayngekumen er hot oyf mir gegosn a UNK vaser, hob ikh mir gegebn a treysl op, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>un ikh hob oyf im gegebn a kuk, un ikh hob mikh oyfgeshtelt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>zogt er, UNK?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>zog ikh tsu im, UNK, vos hob ikh tsu tun?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>zog ikh, zol ikh tsurikgeyn tsu der arbet? zogt er, du kenst? zog ikh, ikh vel ales tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>bin ikh tsurikgegangen tsu der arbet. er hot mikh tsurikgefirt tsu der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>un er hot gezogt dem kapo er zol mikh leygn oyfn vegele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>far nakht, un firn mikh in gaz kamer arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>un ikh shtey oyf un gey tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>iz dortn geven mit mir a daytsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
