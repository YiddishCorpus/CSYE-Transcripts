		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts572" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>er iz geven a heftling fun Daytshland. a daytsh.</ANNOTATION_VALUE>
