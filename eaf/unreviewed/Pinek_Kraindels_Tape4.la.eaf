				<ANNOTATION_VALUE>ober in ende fir un fertsik iz arayngekumen a transport mit mayn bruder Avram,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a495" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts852">
				<ANNOTATION_VALUE>vos er lebt nisht un er iz nishto,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a496" TIME_SLOT_REF1="ts853" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>er iz arayngekumen keyn Oyshvits un ikh hob im getrofn, un ikh hob arayngenumen tsu mir in mayn blok arayn, er zol shlofn mit mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a497" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts856">
				<ANNOTATION_VALUE>shpeter bin ikh aropgegangen oyfn tsveytn FLOOR, er iz geshlofn, ikh hob im gegebn mayn plats in der heykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a498" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>un shtubn dinstn vos hobn gearbet dortn in Oyshvits,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a499" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>iz yedn in der fri, az zey hobn gegebn a makh oyf di luft,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a500" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>"oyfshteyn, arunter fun di betn!" hostu dikh gemuzt gebn a glitsh arop. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a501" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
				<ANNOTATION_VALUE>sh- naket. shteyn. koydem kol shtey untn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a503" TIME_SLOT_REF1="ts865" TIME_SLOT_REF2="ts866">
				<ANNOTATION_VALUE>nisht in bet. tomer a shray gebn, "arunter fun di betn!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a504" TIME_SLOT_REF1="ts867" TIME_SLOT_REF2="ts868">
				<ANNOTATION_VALUE>hostu gemuzt shteyn. mayn bruder hot zikh farshpetikt mit efsher a tsvey minut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a505" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>ikh shray "Avrom! Avrom! Avrom!" biz er krikht arop, biz er er makht zikh oyf di oygn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a506" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>zenen shoyn do di tsvey shtubn dinstn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a507" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts874">
				<ANNOTATION_VALUE>zey viln fardinen shoyn dos broyt vos er darf krign in der fri, ebn zey krign. er vet shoyn zayn toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a508" TIME_SLOT_REF1="ts875" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>ikh hob dokh gevust vos m'tut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a509" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>ver s'hot zikh farshpetikt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a510" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>hot men gegebn, m'hot im tse- koydem hot men im tseboksevet un avekgeleygt, aroyfgeleygt a shtekele oyfn haldz. er hot do aroyf getretn un er hot do aroyf getretn, un m'hot im ayngekvetsht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a511" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts882">
				<ANNOTATION_VALUE>un vi er iz shoyn toyt a mol, avekgenumen di shtekele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a512" TIME_SLOT_REF1="ts883" TIME_SLOT_REF2="ts884">
				<ANNOTATION_VALUE>dos iz geven di toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts885" TIME_SLOT_REF2="ts886">
				<ANNOTATION_VALUE>un azoy hot men geharget yedn in der fri tsvey, dray, fir. s'dokh gekumen frishe. yedes mol gekumen frishe. fun di frishe hot men azoy geharget.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a514" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts888">
				<ANNOTATION_VALUE>un ikh hob gezen vos vart oyfn bruder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a515" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>zey geyen zikh tsun im nemen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a516" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>vi zey geyen zikh tsu im nemen, UNK eyder er hot nokh aroysgetsoygn a hant tsu gebn im a boks, hot er shoyn gekrign fun mir. hot er gekrign fun mir a shos, un dem andern der zayt, un ikh hob im beyde tseklapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a517" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>un ikh hob zey vi azoy tseklapt. s'nisht geven genug eynem. ikh hob gegebn yedn eynem tsu finef un dem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a519" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>zenen geblibn lign.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a520" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>ale mentshn shrayen tsu mir, "Pinek, du bist meshuge?! vos hostu getun?!" zog ikh, lozn dem bruder hargenen?! ikh hob dokh shoyn gevust m'geyt im leygn shtekele bald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a521" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>m'geyt im koydem tseklapn, nakher vet men hargenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a522" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>dos iz dokh mayn bruder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a523" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
				<ANNOTATION_VALUE>un zey geyen arayn, tseklapt, geyen zey arayn tsu dem daytsher, der f- der firer fun dem blok,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts906">
				<ANNOTATION_VALUE>git er shray, "nayntsn tsvey fir un DREISIG, kum dokh MAL aher!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a525" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>zol do- er zol vayzn ver iz dos. hobn zey ongevizn, hobn mikh aher gerufn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a527" TIME_SLOT_REF1="ts910" TIME_SLOT_REF2="ts912">
				<ANNOTATION_VALUE>OK. OK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Sidney Zoltak">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a529" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
				<ANNOTATION_VALUE>mir hobn geredt eh in eh, vegn Starakhovitse,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a531" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
				<ANNOTATION_VALUE>az ven ir zent avek fun dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a532" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts7">
				<ANNOTATION_VALUE>a- iz vos iz geblibn in dem lager aleyn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a533" TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts9">
				<ANNOTATION_VALUE>likvidirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a534" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>un di fabrik, in der tsayt vos ir hot gearbet dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a536" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts23">
				<ANNOTATION_VALUE>hobn polyakn oykh gearbet?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a537" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts27">
				<ANNOTATION_VALUE>dos heyst az a khuts yidn zenen andere oykhet gearbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a538" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
				<ANNOTATION_VALUE>ober di polyakn dortn hobn gekrign batsolt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a539" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
				<ANNOTATION_VALUE>un ir?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a540" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts47">
				<ANNOTATION_VALUE>un fun vanen zenen di arbeter gekumen, fun a- arum Starakhovitse?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a541" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
				<ANNOTATION_VALUE>un ven ir zent avek fun Starakhovitse, fun dem eh lager,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a543" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts53">
				<ANNOTATION_VALUE>iz der di fabrik ongegangen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a544" TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts59">
				<ANNOTATION_VALUE>ir gedenkt dem tog ven ir zent ongekumen keyn Oyshvits?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a545" TIME_SLOT_REF1="ts60" TIME_SLOT_REF2="ts63">
				<ANNOTATION_VALUE>ir gedenkt di date?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a546" TIME_SLOT_REF1="ts68" TIME_SLOT_REF2="ts71">
				<ANNOTATION_VALUE>vi alt zent ir geven demolts?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a547" TIME_SLOT_REF1="ts112" TIME_SLOT_REF2="ts115">
				<ANNOTATION_VALUE>ir gedenkt Mengelen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a548" TIME_SLOT_REF1="ts116" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>ir gedenkt Mengelen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a549" TIME_SLOT_REF1="ts122" TIME_SLOT_REF2="ts125">
				<ANNOTATION_VALUE>ir hot gevust ver er iz demolts?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a550" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts243">
				<ANNOTATION_VALUE>un ot o di hobn aykh dertseylt genoy vos m'tut mit di mentshn vi azoy m'nemt zey?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a551" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>un vi oft hot dos pasirt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a552" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>avu hot ir gemalet alts?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a553" TIME_SLOT_REF1="ts378" TIME_SLOT_REF2="ts381">
				<ANNOTATION_VALUE>dos heyst in lager un oysnveynik?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a557" TIME_SLOT_REF1="ts570" TIME_SLOT_REF2="ts573">
				<ANNOTATION_VALUE>er iz oykh geven a heftling?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a558" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts585">
				<ANNOTATION_VALUE>far vos iz er gevezn dortn in lager?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a561" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts911">
				<ANNOTATION_VALUE>mir veln eh makhn a iberrays yetst az m'zol kenen baytn di kasete.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
