		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>nokh a halbe sho, ikh, nakher vayter der bruder. un m'hot zikh azoy gehaltn unter di orems, un azoy hot men gevokt.</ANNOTATION_VALUE>
