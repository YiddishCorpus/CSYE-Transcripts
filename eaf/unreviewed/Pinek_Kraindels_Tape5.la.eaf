			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>er kumt tsurik, geyt er esn. er geyt esn, shtey ikh un kuk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>git er shnayd op nokh a shtikl broyt, zogt er, na dir du yunger! na dir! git er mir shtikl broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>nem ikh a halbs, gib dem bruder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>un azoy mir hobn zikh opgeshlept zikh biz Gleyvits. m'iz arayngekumen keyn Gleyvits iz geven a yidisher lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts491">
				<ANNOTATION_VALUE>hot men undz arayngefirt dort bay nakht, opruen zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts492" TIME_SLOT_REF2="ts495">
				<ANNOTATION_VALUE>in Gleyvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts496" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>Gleyvits dos tsvishn di grenets fun der tsvishn Poyln un Daytshland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts500" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>Gleyvitse. Gleyvits. yeder eyner veyst vu Gleyvits. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts504" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>oyf daytsher zayt. Gleyvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts508" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>s- dortn iz geven a lager fun yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>ober dos iz geve- arbets lager, ober vos iz dortn UNK on iz geven leydik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>vos iz geven? m'hot undz arayngefirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>hob ikh mikh avekgeleygt, gey ikh tsum bruder, zog ikh tsum bruder, du leyg dikh avek, ikh gey aroys gebn a kuk vu iz do do ergets a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>epes tsu khapn epes esn, efsher vel ikh kenen epes trefn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>gey ikh vu zukht men? in der kekh. ikh zukh di kekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>gey ikh tsu s'geven niderike hayzer, ikh geb a makh oyf di lodn, ze ikh s'ofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>ikh gey arayn ineveynik arayn, tref ikh di gantse kesl, a UNK fule kesl, di groyse kesl, UNK kartofl, opgekokhte kartofl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>ikh nem a kartofl, veykh vi gold.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>ikh hoyb on tsu esn. nem ikh arop dos hitl un ful op a ful hitl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>un ikh breng arayn dos tsu mayn bruder tsum oyfn oyfn bet. zogt er, reboyne-shel-oylem. es, zogt er, vifl du vilst. ikh gey tsurik brengen nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>ikh bin tsurikgekumen iz shoyn gevezn dortn ful.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>ikh bin arayngegangen, hob ikh gekhapt nokh, ongekumen di S.S., m'hot geshrign HERAUS!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>un ver s'aroysgelofn hot men derlangt a shtekn ibern kop,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>un ikh vayter, ikh hob ongeleygt zikh ful mit nokh mit POTATOES, un ikh bin aroysgeshprungen fun fentster, hobn nisht espiet mir tsu gebn a klap</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>un ikh bin gelofn arayn tsum bruder, nokh mit ful mit kartofl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>un m'hot dos mit zikh gehaltn, un m'iz gegangen vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>biz azoy lang gegang- gegangen biz m'iz gegangen dentsmol du veyst dokh iber iber Tshekhoslovakye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>in Tshekhoslovakye, dos hot dos dertseyl ikh nor, dos dos hot nisht genumen biz azoy haynt un morgn, m'iz gegangen azoy gantse vokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>m'iz adurkhgegangen nokh Tshekhoslovakye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>oy, hobn zey shoyn gevust di tshekhn az do kumen zey on mater- az do kumen zey op a transport vos zey geyen tsu fus oyfn toytn-marsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>hot men gehaltn broyt mit vaser. un undz hot men geshrign, broyt!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a995" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>vaser! broyt! vaser! di gevald undz zenen gevezn. zey hobn gevorfn broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a996" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts559">
				<ANNOTATION_VALUE>dos iz geven goyim, mit vaser.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts560" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>di tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>hobn di S.S. genumen shisn un zenen antlofn. ver s'hot gekhapt, der hot gekhapt. ver s'hot nisht gekhapt zenen antlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>un shoyn. mit eyn mol geyt men nokh nokh a dorf. m'iz adurkhgegangen nokh a dorf, nokh a dorf adurkhgegangen. ir hert?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>shteyt a goy, ze ikh fun der vaytns, hert?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>er varft dortn kartofl un kokht di kartofl un er shit aroyf leym, far di khazeyrim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>gib ikh a loyf aroys fun der shure,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>un gib a khap tsvey fule hent, leym mit di kartofl, un loyf arayn tsurik. un der S.S. man zet mir zogt er, spn du!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>hunt hunt! ikh bin shoyn tsurik do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>un gebn dem bruder, es. genumen esn. mitn leym, mit alem, s'gold.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>ikh gegesn, er hot gegesn, vayter derkhapt dos harts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>un azoy a mol hot men zikh opgedreyt zikh bizkale merts. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>februar, ende februar. merts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>m'iz shoyn arayngekumen keyn Daytshland. m'iz shoyn geven in Daytshland. hot men undz gefirt mit vagonen ahin un tsurik biz m'hot undz gefirt arayn nakher keyn Dakhau.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts588" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>in Doytshland ze'mir shoyn gegangen mit di vagonen. biz tsu der Doytshland, bizn Doytshland, tsu fus.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>eh vifl ze'mir ongekumen. ze'mir aroysgegangen dortn aza iz aroysgegangen efsher tsvey toyznt iz men gegangen,un m'iz ongekumen tsvey dray hundert.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts597">
				<ANNOTATION_VALUE>s'hot UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts598" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>zey hobn zikh avekgezetst, zey hobn gegesn ayz, zey hobn gegesn shney, hobn gekrign hobn gekrign a UNK, avekgezetst hot men zey tsu geshosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>m'hot gegebn a bafel nakher di di soltisn oyf di oyf di vegn m'zol arop roymen di toyte.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a997" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>vayl di shlitenes kenen nisht forn, di toyte lign oyf di gasn, oyf der HIGHWAY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts607">
				<ANNOTATION_VALUE>hot men gegebn a bafel tsu yeder soltis zol aroysshikn di mentshn zol arop roymen di toyte.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts608" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>alts iz geven yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts612" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>he? di vekhters, daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts616" TIME_SLOT_REF2="ts617">
				<ANNOTATION_VALUE>ver s'hot es,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts618" TIME_SLOT_REF2="ts622">
				<ANNOTATION_VALUE>keyn andere nisht, nisht keyn ukrainer, nor daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
				<ANNOTATION_VALUE>S.S.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
				<ANNOTATION_VALUE>un ver s'hot zikh avekgezetst, er hot zikh ni- er hot zikh nisht bald nisht gekent unterheybn zikh, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>hot er genumen dos biksl un derlangt a koyl. geblibn zitsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
				<ANNOTATION_VALUE>der marsh hot zikh geendikt ven m'iz aroyfgegangen oyf di vagones un m'hot undz arayngefirt keyn Dakho.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts634" TIME_SLOT_REF2="ts636">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts639">
				<ANNOTATION_VALUE>arayngefirt keyn Dakho in lager,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>dos iz gevezn in di BEGINNING OF OF merts, ende ende februar merts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>iz hot men geven in Dakhau, un gearbet dort oykh epes a a dray vokhn, biz ende merts,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>un nakher hot men gegangen, biz ende merts</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>hot men dortn gearbet farshidene arbetn. nakher hot men gegangen m'hot undz vider aroysgefirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>fun Dakho. fun Dakho.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>un m'hot undz aroysgefirt oykhet aroys oyf di vegn, tsurik oyf di vagonen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>tsurik ongelodnt di vagonen. vu fort men yetst? m'veyst nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
				<ANNOTATION_VALUE>ongelodnt di vagonen, farshlosn di vagonen, ir hert? un m'firt undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>dort men ahin, m'fort tsurik. m'fort ahin, un m'fort tsurik. teg un nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts663">
				<ANNOTATION_VALUE>m'varft undz arayn a shtikl broyt a tog,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts664" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>in di vagonen? efsher hot gekont zayn dentsmolt efsher a finef hundert mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>s'arayngegangen az m'hot nisht gehat keyn otem. m'hot nisht gekont UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>un ikh hob nokh gehat a tsvey kartofl in mayn tash vos ikh hob es nisht gerirt, roye. ir hert? roye kartofl in der tash.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>un az m'fort in di vagonen, m'git nisht keyn broyt, un m'git gornisht, mayn bruder farkhalesht zikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>hot men ayngeribn mit a shtikl kartofl hot men im gegebn, un do dortn, ayngeribn di shleyfn. halt dikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>un Got mit eyn mol gibn di S.S. a for avek,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>un m'lozt undz iber fray, un m'freyt zikh, mir zenen bafrayt gevorn. di S.S. zenen antlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>m'hot gevust az di un di krig di krig geyt tsu ende.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>un m'shteyt zikh un m'freyt zikh un m'freyt zikh. mit eyn mol nokh a sho tsayt get a kum op a tsveyte vagon oyf der tsveyter zayt un UNK geyen aroys S.S. azoy vi in a front arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>HELMETS, mit hant-granatn, mit mashin-gever, m- ayngeshtekt hant-granatn, vey iz mir nebekh, in a front arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts688">
				<ANNOTATION_VALUE>un m'shrayt, JUDEN RAUS! HUNDE RAUS! un m'heybt on oyftsushlisn di vagonen, m'shlist oyf di vagonen, RAUS!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts690">
				<ANNOTATION_VALUE>un m'hoybt undz op aroystsushikn, un ikh zog tsum bruder, un bay yeder aroysgeyn get men a shtekn oyfn kop. on dem heybt zikh dokh nisht on. a shtekn oyfn kop, yeder eyner vos geyt aroys fun vagon.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts692">
				<ANNOTATION_VALUE>ikh zog tsum bruder, du zolst gebn a shpring arop, zolst nisht khapn keyn shtekn, vayl tomer khapstu a shtekn bistu shoyn farloyrn. du darfst nisht mer nor a klap.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>eyn klap bistu fertik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>zogt er, vi makht men dos? du vest es muzn makhn. gib dikh a sh- varf aroys, du zolst flien. az du vest nisht khapn keyn shtekn vestu dikh oyfheybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>un azoy iz gevezn. ikh hob im gegebn kuk vi er flit aroys, er hot nisht gekhapt keyn shtekn, Got tsu dank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>ikh bin gefloygn vayter. geven yung, gegebn a shprung aroys. vi hot er aza lange shtekn tsu mir?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>ver s'hot gekhapt hot gekhapt, ver s'hot nisht gekhapt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>un m'hot undz gefirt durkh di felder glaykh arayn in vald arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>zog ikh tsum bruder, dos iz undzer letster veg. dos iz es.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts708">
				<ANNOTATION_VALUE>m'shlept undz arayn in vald oystsushisn. nor gedenk eyn zakh zog ikh tsun im, in geyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>m'kumt arayn in vald arayn, mir veln beyde antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>azoy vi m'derzet di beymer, azoy heybn mir on tsu loyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>un dos iz gevezn. m'iz arayngekumen in vald arayn, m'hot ongehoybn tsu loyfn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>loyfn undz nokh tsvey S.S., "ir HUNDE shteyn blaybn!" m'shist, "shteyn blaybn!" m'shist. un ikh zog tsum bruder, kuk dikh nisht um un loyf!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>ikh bin gelofn unter im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>un m'loyft un m'loyft, undz ze'mir gelofn efsher a sho. un di tsvey kholeres lo- geyn lozn zikh nisht op. un m'loyft nokh undz, un m'shrayt, HUNDE shteyn blaybn!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>un mir loyfn, zey loyfn. un der bruder Avram khapt a koyl in kop arayn, un falt arop,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>un ikh shray, Avrom! Avrom! ikh hob shoyn nisht vemen tsu redn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>un nokh dem geb ikh a kuk, di tsvey S.S. dernentern zikh tsu mir. bin ikh oyfgehoybn un antlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>ikh bin antlofn, hobn zey mikh shoyn nisht nokhgeyogt. zey hobn shoyn gezen er iz shoyn toyt, hobn zikh getrakht zikh, loyf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>un ikh bin gelofn a gantsn tog biz shpet fintster in der nakht in di velder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>ikh hob nisht gornisht gezen nor loyfn. ikh hob afile nisht gevolt umkukn zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>un dan nakher bin ikh antshlofn gevorn. ikh hob zikh aropgezetst antshlofn gevorn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>oyfgevekt fir in der fri, in der fri, s'hot ongehoybn tsu togn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>un ikh shtey un veyn, reboyne-shel-oylem, vos hostu mit mir gemakht? ikh hob gehat eyn bruder, host mikh shoyn avekgeharget oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a998" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>vos hostu mit mir gemakht? vi nemt men yetst esn? vi geyt men aroys fun vald aroys?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a403" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>vu gey ikh? a gantser tog bin ikh gelofn in vald on an ek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>hob ikh genumen raysn groz. ikh hob gerisn groz, ikh zol hobn dem kvas, dem dos, dem eh di a bisl epes in moyl aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>un ikh hoyb on tsu geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>ikh hoyb on tsu geyn, bin ikh gegangen efsher tsen fuftsn minut, geb ikh a derze a hoyz un nokh a hoyz, oy iz dos a derfl. ikh gey arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>zol shoyn dortn zayn Hitler, zol zayn Himler, ver s'zol nisht zayn. ikh gey arayn, ikh geb zikh unter, ikh ken nisht mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a999" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>un der toyt ligt in di oygn, ikh ken nisht mer, ikh ken nisht mer kemfn. ikh gib zikh unter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts753" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>un bin arayn in dem hoyz arayn, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a411" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>un ikh red tsu der froy, ikh klap on bay der tir, zog ikh, "ken ICH bite EINE CAFE HABBEN? ikh hob nisht gevolt nemen keyn broyt, efsher hobn zey oykh nisht tsulib der milkhome.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>kukt zi mikh on, ikh red tsu zi a eh nayes daytsh un EVERYTHING un zi hot moyre gehat far mir, ikh ikh hob oysgezen punkt vi a payats mit aza hitl, mit</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>holtserne shikh mit aza PASIAK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>ruft zi dem man, der man get a kum tsu, JA WAS WUNSCHEN SIE? zog ikh zog ikh, koydem kol zog ikh, gris Got, gris Got.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>un ikh hob mikh mit im tseredt, un un un ikh dertseyl im dos ales.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>un er veyst er, er hot mikh oyfgeheybn, un er makht mir kave. un er zogt mir, kum arayn bite, ikh zol arayngeyn mit ineveynik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>kum arayn, zets zikh avek barn tish, un er gibt mir kave. un brengt arayn azoy vi a halber tish. un ikh ze dos broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>un zey hobn gehat dortn a tokhter oyfgevekt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>hobn zey geshnitn gantse reftlekh un ongeshmirt mit der mit mit marmelad.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts775">
				<ANNOTATION_VALUE>un vi lang er shmirt dray reftlekh, hob ikh shoyn arayngelozt. aza,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts776" TIME_SLOT_REF2="ts779">
				<ANNOTATION_VALUE>he?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts780" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>no no. er hot mikh gefregt ver ikh bin. zog ikh, ICH bin, zog ikh, EIN POLE. zogt er, SIE SPRECHEN dokh SO SO UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1000" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>SO NICE doytsh. zog ikh, ICH bin a P- a POLE, heyst a goy. ikh bin a po- ikh bin nisht keyn yid. ikh hob nisht gezogt ikh bin a yid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>ANYWAYS, hin un aher, ikh hoyb on tsu esn un tsu trinken,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>un dos iz es. un er shrayt tsu mir, nakher fregt zi mikh, di froy, vi azoy HABEN SIE SO hunger?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a430" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>hob ikh gezogt, ikh kum fun Oyshvits, fun di lagern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>o! mayn Got! UNK DARUM HABEN SIE SO hunger!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>hin aher, zog ikh, "ICH vil ZICH dos dos badanken, ikh hob UNK, keyn gelt. viln SIE mayn MUTZE HABBEN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>viln SIE mayne shikh HABBEN?" "neyn. vu WOLLEN SIE den geyn?" "ikh vil geyn zukhn di COMPANY, di khevre."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1001" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts799">
				<ANNOTATION_VALUE>zi hot gevust vos tut zikh. zogt zi tsu mir, di fir, geyen SIE bite nisht RAUS,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1002" TIME_SLOT_REF1="ts798" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>zi hot shoyn moyre gehat di shkheynim zoln mikh nisht zen. az di shkheynim veln mikh hobn gezen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1003" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
				<ANNOTATION_VALUE>ebn zey fornemen tsu di zhandamerye, far vos hot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts805">
				<ANNOTATION_VALUE>gehaltn do a yid. zi hot im gelozt aroysgeyn. far vos zey hobn nisht gefodert far di POLICE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts806" TIME_SLOT_REF2="ts808">
				<ANNOTATION_VALUE>nokh nisht gevust. ober vi kenen zey araynnemen a mentshn fun in aza PASIAK un azelkhes, vayl ikh hob gezogt ikh bin fun lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts809" TIME_SLOT_REF2="ts810">
				<ANNOTATION_VALUE>az ikh bin fun lager, trakht vos du vilst. zi hot dokh gezen ikh bin fun lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts811" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>hob ikh gezogt, zogt zi mikh gebetn, zogt zi, mayne NEIGHBOURS, veln ICH WOLTE nisht di NEIGHBOURS zoln DICH zen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts813" TIME_SLOT_REF2="ts814">
				<ANNOTATION_VALUE>bite GEHEN SIE nisht HERAUS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>un er heybt zikh on tsu tseylemen. ikh, ikh vel IHN ophitn, ICH vel IHN ales gebn, blaybn SIE NUR HIER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a444" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts818">
				<ANNOTATION_VALUE>hob ikh mikh epes gelozt tsuredn, ikh bin geblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts820">
				<ANNOTATION_VALUE>un ikh hob gehert di CHADASHOT yedes mol di NEWS vos s'geyt on UNK tsvishn di daytshn un di amerikaner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts823">
				<ANNOTATION_VALUE>un dervayl iz ongekumen in droysn STRASSE kamfn in a shtetl, ponem tsu ponem hobn zey gekemft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a448" TIME_SLOT_REF1="ts822" TIME_SLOT_REF2="ts824">
				<ANNOTATION_VALUE>hob ikh im gefregt nakher dem goy, vi vayt iz dos fun danet biz danet, ven ikh gehert di, ikh hob nisht gevust vu ikh gefin zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1004" TIME_SLOT_REF1="ts825" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>ober ikh hob gehert vu di kamfn kumen for,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1005" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts828">
				<ANNOTATION_VALUE>vos heyst di nemen, hob ikh im gezogt vi vayt? zogt er epes a fertsik kilometer. fertsik kilometer, zog ikh, MY mayne yorn, morgn veln di amerikaner do zayn!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a449" TIME_SLOT_REF1="ts829" TIME_SLOT_REF2="ts830">
				<ANNOTATION_VALUE>fir tog hot genumen biz zey zenen arayn in dem dorf arayn, un zey zenen arayn in dorf arayn un zey hobn farnumen ales,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts831" TIME_SLOT_REF2="ts832">
				<ANNOTATION_VALUE>zey gebn a kum tsu, di amerikaner, geyt aroys der mentsh, er vil ahin geyn tsu der ferd gebn esn, shteyn tsvey NEIGHBOURS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts833" TIME_SLOT_REF2="ts835">
				<ANNOTATION_VALUE>HALT! hot er moyre gekrign, iz er gelofn tsu mir, Pinek, tsien ZICH MAL ayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a455" TIME_SLOT_REF1="ts834" TIME_SLOT_REF2="ts836">
				<ANNOTATION_VALUE>zogt er, s'geven mentshn DRAUSSEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a456" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts838">
				<ANNOTATION_VALUE>hob ikh gezogt, ver iz in droysn? di Vermakht? di natsis? ver iz in droysn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1006" TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts840">
				<ANNOTATION_VALUE>zogt er, di AMI. ikh hob nisht gekont farshteyn vos er zogt di AMI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1007" TIME_SLOT_REF1="ts841" TIME_SLOT_REF2="ts842">
				<ANNOTATION_VALUE>dort in BAVARIA zogn zey oyf di amerikaner AMI, a halbe vort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1008" TIME_SLOT_REF1="ts843" TIME_SLOT_REF2="ts844">
				<ANNOTATION_VALUE>un ikh hob nisht farshtanen, zog ikh, ir veyst dokh nisht vos zey WOLLEN. WAS vi iz dortn? far vos zol ikh mikh on-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a457" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts846">
				<ANNOTATION_VALUE>zogt er tsu mir, Doytshland HAT nokh keyn NEGRO, NEGRO. NEGRO?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1009" TIME_SLOT_REF1="ts847" TIME_SLOT_REF2="ts848">
				<ANNOTATION_VALUE>iz dos nisht di amerikaner? zogt er JA!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1010" TIME_SLOT_REF1="ts849" TIME_SLOT_REF2="ts850">
				<ANNOTATION_VALUE>ikh geb mikh a tu on dem PASIAK, gib a gey aroys, get mir a gey tsu mit tsvey revolvern, git mir a shtel tsu, ARE YOU GERMAN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a459" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts852">
				<ANNOTATION_VALUE>oy, zog ikh, I'M NOT GERMAN. ikh hob nor gevust tsvey tsvey verter tsu redn. I'M JEWISH, I'M CONCENTRATION CAMP, un ikh vayz zey dos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a460" TIME_SLOT_REF1="ts853" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>hobn zey avekgenumen di revolvern fun mir, m'hot ongehoybn tsu rufn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a461" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>iz gekumen eyner a vayser, un der vayser heybt on mit mir tsu redn, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a463" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>tsum, OK OK OK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
