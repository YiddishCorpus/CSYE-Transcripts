		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1216" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts501">
				<ANNOTATION_VALUE>vos?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1038" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
