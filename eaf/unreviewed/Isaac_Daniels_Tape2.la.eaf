		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a991" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>ikh gey arum mit a meydl, ikh trakht vegn khasene hobn, ikh gey far zikh."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
