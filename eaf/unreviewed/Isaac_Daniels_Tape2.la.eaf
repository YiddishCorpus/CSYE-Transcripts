		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a941" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>firn men dortn oyf, vayl m'iz gevezn ale a bisl geneygt TO link.</ANNOTATION_VALUE>
