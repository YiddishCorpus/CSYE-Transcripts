		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1015" TIME_SLOT_REF1="ts464" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>an oreme meydl a, an orem meydl a, nokh erger vi ikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1016" TIME_SLOT_REF1="ts468" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>mayn mayn shvoger's a shvegerin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1017" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>ikh ho- ikh hob ir gedorfn gebn tsu esn. zi hot gevoynt bay der shvester,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1019" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>vayl zey hobn gehat dortn a voynung, eyn tsimer dortn, hobn hobn ge&lt;UNK&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1020" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts477">
				<ANNOTATION_VALUE>iz der foter irer geshtorbn, hot men epes a halb gegebn ir, a halb di andere shvester.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1022" TIME_SLOT_REF1="ts476" TIME_SLOT_REF2="ts479">
				<ANNOTATION_VALUE>vayl der shvoger hot oysgenart bay ir, spn a gantse mayse.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1024" TIME_SLOT_REF1="ts480" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>s'dokh nisht vikhtik di aleser.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1025" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>iz der khevreman un di khaveyrim, "du darfst ir say vi say gebn esn, du darfst ir say vi say ontun, hob khasene!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1028" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>iz in fuftstn JUNE, ze'mir aroyfgegangen tsu a rov, mir ho'mir khasene gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1031" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>geven mayne mayn bruder iz gevezn, der tsveyter iz gekumen, mayn muter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1033" TIME_SLOT_REF1="ts490" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>UNK zenen gekumen tsu der khasene.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1034" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>s'geven a khasene s'ge- spn, s'geven a khasene un broyt mit vursht, un fertik.</ANNOTATION_VALUE>
