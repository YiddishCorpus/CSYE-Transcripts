	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Isaac Daniels">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a598" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts4">
				<ANNOTATION_VALUE>vu vu ikh bin geven bay dem UNK, azoy ikh bin gekumen tsu der kuzin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a600" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>der dem dem zi hot geshikt a a BOY vos hot mikh gebrengt dortn tsun ir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a601" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>zi hot mikh ongekukt, hot zi geveynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a602" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
				<ANNOTATION_VALUE>ober, s'nisht geven keyn SUIT, s'nisht geven keyn shikh, s'gornisht gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a604" TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>ANYWAYS, zi hot mir gegebn optsuesn farshtendlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a605" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>un zi hot gezogt, "fun dan vestu nisht aroysgeyn biz vanen ikh vel dir shafn a JOB."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a606" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>FINALLY, hot zi gehat a bakantn vos er flegt farkoyfn tsu shnayders skhoyre.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a608" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
				<ANNOTATION_VALUE>iz hot zi im gezogt az efsher veyst er, azoy vi er hot farkoyft skhoyres,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a610" TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>er zol gevoyer vorn tsi m'darf a shnayder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a612" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
				<ANNOTATION_VALUE>fayn, iz er arayngekumen mit a simkhe, s'do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a614" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>s'do un do, get mir dem adres, un ikh for avek dortn ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a616" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>ikh kum arayn, un der balbos iz nishto, s'zitsn zeks arbetorers un arbetn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a618" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts33">
				<ANNOTATION_VALUE>un di arbetorers zogn tsu mir, "o du bist gekumen aher arbetn?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a620" TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>zog ikh, "ikh hob gehert az er darf hobn dos."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a621" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>"derbarem dikh. antloyf! der balbos iz a merder, an oysnitser, a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a624" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>a an oysvorf a du kenst zikh nisht forshteln. antloyf!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a625" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>ikh bin hungerik un ikh hob nisht keyn sent vos, zog ikh, "hert oys, khaveyrim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a628" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
				<ANNOTATION_VALUE>ikh gey nisht mit im khasene hobn. er vet mir gefeln iz gut, nisht iz nisht."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a630" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts45">
				<ANNOTATION_VALUE>in dem kumt arayn der balbos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a631" TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>a yid, yo. geheysn hot er Midlash.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a632" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
				<ANNOTATION_VALUE>er iz shoyn gehat gevezn in Argentine. er iz gekumen krik fun Argentine.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a633" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
				<ANNOTATION_VALUE>der mentsh iz geven a guter balbos, er hot gehat a sakh arbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a634" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>zogt er, ye. UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a635" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>"vos kenstu tun?" zog ikh, "vos ir vet mir gebn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a636" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>zogt er, "kenst makhn a por SLACKS?" zog ikh, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a638" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>get er mir, er git er a kuk vi ikh nem es eh in der haynt arayn, zet er az ikh ikh veys vos ikh hob tsu tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a641" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>un keyn SLOWer bin ikh nisht gevezn keyn mol nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a643" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>ikh hob fertik gemakht di PANTS, zogt er, "kenst makhn a VEST?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a645" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>m'gegebn mir. makht er es.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a647" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>nokh der arbet ruft er mikh in di tsveytn in o tsimer arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a648" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>zogt er, "vos vilstu fardinen?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a649" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>mir in der heym hot men gezogt in Varshe darf men zogn groyse prayzn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a650" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>ikh hob ober ikh hob moyre gehat tsu zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a651" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>zog ikh, ikh vil fardinen finef un tsvontsik zlotes a vokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a652" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>"ikh tsol nisht di prayzn. s'tsu tayer far mir."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a654" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>DON'T TOUCH THIS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a656" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>"ikh ken dir gebn zibetsn zlotes a vokh, mit mitogn. kenst esn bay mir mitog." mit zibetsn zl-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a660" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>vi ikh hob gehert er hot mir gezogt zlotes, trakht ikh ikh bin dokh a gvir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a661" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>ikh bin shoyn a gvir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a662" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>vayl zibetsn zlotes hob ikh gekent eh lebn al- eyner aleyn tsvey vokhn. basheydn tsu lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a666" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>ikh bin bashtanen. ikh hob ongehoybn tsu arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a668" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>hob ikh opgearbet bay im azoy noent fun tsvey monatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a671" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>ikh kum tsu geyn tsu der arbet montik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a672" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>zogt er mir, "du host nisht mer bay mir keyn JOB.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a673" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>far di ikh hob nisht far dir keyn arbet."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a674" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>"far vos? ir hot dokh a sakh arbet."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a676" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts105">
				<ANNOTATION_VALUE>"nu du geyst arum un du sheltst mikh, un mit azelkhene kloles, mit azoy oysergeveyntlekh,"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a678" TIME_SLOT_REF1="ts104" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>zogt er, "ikh darf dir hobn az du zolst mikh arumgeyn sheltn?" b-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a680" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>di arbetorers hobn im ongeredt, zey hobn dertseylt alemen. hot er vayter mir opgezogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a683" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>ikh red ahin un aher, s'farfaln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a684" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>gey ikh aroys oyf der gas, ikh shtey azoy oyfn trotuar,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a686" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>un antkeygn iber hot gevoynt nokh a shnayder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a687" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>iz yener punkt aroysgekumen, er hot mikh gezen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a688" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>shteyn azoy, ruft er mikh tsu. zogt er, "vos, du arbetst nisht haynt?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a689" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>zog ikh im, "er hot mir opgezogt. er zogt ikh shelt im, mit mayns gesheft."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a690" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>zogt er, "hostu a gesheft? kum arayn tsu mir."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a691" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>bin ikh arayngegangen tsu im arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a692" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>ober di arbet iz geven shoyn nisht noent tsu mayn hartsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a693" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>shoyn geven a bilikere,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a694" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>un di gelt iz oykh gevezn, hot es gerufn, danken got az er hot batsolt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a696" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>nisht derfar vos er vayl er hot nisht gevolt, nor </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a697" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>nu prost poshet iz er geven shoyn SHORT, vi zogt men, in gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a699" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>hob ikh opgearbet bay im biz sukes. sukes, for aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a701" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>ikh bin aheymgeforn, nisht mit aza min gringn harts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a703" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>ANYWAY, ikh hob di mame nisht dertseylt. vos darf ikh ir ontun UNK?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a705" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>di mame hot zikh dervust, zey hobn zikh dervust az m'hot mikh baganvet mit dem alemen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a706" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>s'geven ge- bay zey oysergeveyntlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a707" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>ikh bin gegangen ongetun a por PANTS, eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a708" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>hot men gekent zen az ikh veys vu oyf YOUNG STREET az er az er gantsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a710" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
				<ANNOTATION_VALUE>un azoy vi ikh hob ongehoybn arbetn bay im, bin ikh gegangen, ikh hob ge-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a711" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts153">
				<ANNOTATION_VALUE>genumen a shtikl skhoyre far an antsug, oyf oystsolekhts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts152" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>eh mayn kuzine, di fun Prage, hot garantirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
				<ANNOTATION_VALUE>un ikh hob mir gemakht a SUIT.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
				<ANNOTATION_VALUE>hob ikh shoyn vos ontsuton.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
				<ANNOTATION_VALUE>ikh hob gehat dortn a khaver iz er geven a shuster.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
				<ANNOTATION_VALUE>er iz geven a tayerer un noenter khaver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a718" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
				<ANNOTATION_VALUE>zogt er, du vest mir oystsoln, hot er mir gemakht a por shikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a719" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts166">
				<ANNOTATION_VALUE>ikh bin geven krik ongeton, an ongetuener. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
				<ANNOTATION_VALUE>ANYWAY, ikh bin avekgeforn oyf sukes aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>ikh bin opgeven yontev, ikh for krik keyn Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a724" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
				<ANNOTATION_VALUE>ikh zits in der ban un for UNK, ikh vil nisht geyn arbetn tsu yenem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a726" TIME_SLOT_REF1="ts173" TIME_SLOT_REF2="ts175">
				<ANNOTATION_VALUE>nu vos tut men? vi azoy zogt men, az az m'ken nisht ariber,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a728" TIME_SLOT_REF1="ts176" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>geyt men arunter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a729" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
				<ANNOTATION_VALUE>antkeygn vu ikh hob gearbet in di BEGINNING, iz geven a frukht gesheft. a yung khsidish COUPLE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a733" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
				<ANNOTATION_VALUE>in iber di tsayt, iber di tsvey monatn vos ikh hob opgearbet, hob ikh zikh zeyer gut bakent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a735" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
				<ANNOTATION_VALUE>a sakh mol flegt er mikh araynrufn shabes far kidesh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a736" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
				<ANNOTATION_VALUE>eh ikh hob gekent a por toyre verter, eh er avade un avade, azoy az m'hot zikh zeyer noent bakent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a737" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts189">
				<ANNOTATION_VALUE>ven ikh bin gekumen krik tsu forn, bin ikh arayngeforn tsu im in STORE arayn bin ikh arayngegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a739" TIME_SLOT_REF1="ts188" TIME_SLOT_REF2="ts190">
				<ANNOTATION_VALUE>mit mayn valizkele. un eyder ikh kuk zikh um,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a741" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
				<ANNOTATION_VALUE>iz der ershter balbos gegebn a kum arayn, er hot gekhapt mayn valizke, "kum mit mir!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a743" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
				<ANNOTATION_VALUE>a naye neshome a neshome hot im arayngezetst in harts arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a745" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
				<ANNOTATION_VALUE>nor eh ikh hob mir getrakht nor va- az du bist shoyn gekumen nokh mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a748" TIME_SLOT_REF1="ts196" TIME_SLOT_REF2="ts198">
				<ANNOTATION_VALUE>vestu shoyn mir gebn mer gelt vi zibetsn dolar, ikh vel shoyn far dir UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a750" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
				<ANNOTATION_VALUE>ANYWAY, ikh hob gedankt got az er shteyt in,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a751" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
				<ANNOTATION_VALUE>ikh volt gearbet far zibetn oykhet, ven er ven er vert an akshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a752" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts205">
				<ANNOTATION_VALUE>ANYWAY, ikh bin arayngekumen iz arayngekumen di balboste, zogt zi,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a755" TIME_SLOT_REF1="ts204" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>"ikh hob gezogt mayn man az ir zent tsu eydl ir zolt sheltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a757" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>nor di arbetorers hobn ongeredt, mayn man hot tsugehert tsu zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a758" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>zey arbetn shoyn nisht do haynt. di arbetn shoyn frishe mentshn, andere mentshn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a760" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
				<ANNOTATION_VALUE>zog ikh tsu im, "panye Midlesh, ikh vel far keyn zibetsn dolar nisht arbetn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a761" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
				<ANNOTATION_VALUE>"nu shoyn, vet er nisht arbetn far zibetsn. vestu arbetn far tsvontsik."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a762" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>ikh halt shoyn bay tsvontsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a763" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
				<ANNOTATION_VALUE>zog ikh, "NO, ikh vil finef un tsvontsik."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a764" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>zogt zi, "zetst aykh tsu der arbet, un m'vet adurkhkumen, UNK nokh tsvey dolar."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a768" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
				<ANNOTATION_VALUE>ikh bin geblibn arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a769" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
				<ANNOTATION_VALUE>ikh arbet op dem tog, zogt er tsu mir azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a770" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>ikh hob im gezogt, s'kost mikh RENT, nokh azoy vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a771" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>zogt er tsu mir azoy, "vos darfstu RENT?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a772" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>host do a tsimer, kenst do shlofn, ikh vel dir keyn RENT nisht RENTn, vos darfstu UNK?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a776" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
				<ANNOTATION_VALUE>trakht mir, ikh breng mir shoyn arayn gelt dortn oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a777" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
				<ANNOTATION_VALUE>shoyn mer vi finef un tsvontsik dolar a vokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a778" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
				<ANNOTATION_VALUE>hot er gehat a a a boytshikl, er hot dokh gemuzt alt zayn a yor fir, finef.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a781" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>ikh hob zeyer lib kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a782" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts241">
				<ANNOTATION_VALUE>un dos kind, azoy nokh der arbet bin ikh arayngegangen in frukht gesheft, ikh hob im gekoyft a CANDY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a784" TIME_SLOT_REF1="ts240" TIME_SLOT_REF2="ts242">
				<ANNOTATION_VALUE>oder an ICE CREAM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a785" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>un dos kind hot zikh tsugevoynt tsu mir, er hot nisht gevolt bay zey esn. nor bay mir oyf der shoys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a788" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>er vil nor esn er vil nor esn, er hot shoyn gehat poylisher, UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
