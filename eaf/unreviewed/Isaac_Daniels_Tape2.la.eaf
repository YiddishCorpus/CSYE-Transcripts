			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1007" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>opgearbet, un s'gekumen in fir un draysikstn yor, in JUIN dem fift- in zibetn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1011" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>iz azoy. ven ikh hob gearbet, ikh hob shoyn fardint, afilesh ikh hob gearbet bay yenem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1013" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>iz dos meydl vos ikh bin mit arumgegangen, hob ikh gedorfn koyfn a DRESS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
