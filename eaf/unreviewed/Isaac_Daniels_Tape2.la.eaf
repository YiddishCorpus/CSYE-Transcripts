			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1001" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>un az eyner hot zikh gemakht a SUIT, hot er getrogn finef zeks yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
