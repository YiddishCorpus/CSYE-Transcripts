		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1002" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>nakher hot er gedarft makhn oyf der linker zayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1003" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts455">
				<ANNOTATION_VALUE>ANYWAY, ikh hob ongehoybn epes gekrign arbet eh etlekhene,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1005" TIME_SLOT_REF1="ts454" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>eyner hot men arayn&lt;UNK&gt; an andern CUSTOMER. ober s'nisht geven tsu fil.</ANNOTATION_VALUE>
