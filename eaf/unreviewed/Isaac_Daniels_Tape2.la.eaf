			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a950" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>zay- er bashraybt vegn a muter. mir dort dort iz mit revolutsyonerishe inhalt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a953" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts403">
				<ANNOTATION_VALUE>nu az m'hot gevolt legalizirn, hot men nisht getort,</ANNOTATION_VALUE>
