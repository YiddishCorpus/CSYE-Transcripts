			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1037" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>un mayne khaveyrim hobn nisht gevust. keynem nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
