		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a945" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>mir hobn men gedorfn oyffirn a pyese fun eh Gorki's, efsher hot ir geleyent Maksim Gorki.</ANNOTATION_VALUE>
