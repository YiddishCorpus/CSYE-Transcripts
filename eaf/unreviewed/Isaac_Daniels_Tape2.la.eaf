		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a936" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts391">
				<ANNOTATION_VALUE>mir firn oyf di ershte forshtelung in grestn yidishn teater.</ANNOTATION_VALUE>
