		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a989" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>ikh for nisht keyn Pariz. ikh hob nisht gezogt emes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
