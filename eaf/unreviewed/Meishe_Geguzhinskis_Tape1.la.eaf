			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>un di yidishe yugnt hot, a groyser teyl fun der yidishe yugnt, hot ont- iber hoypt fun di sport organizatsyes, flegn onteyl nemen in di untererdishe komyugishe organizatsyes.</ANNOTATION_VALUE>
