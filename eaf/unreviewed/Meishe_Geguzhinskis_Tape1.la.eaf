			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>az er, ikh hob gekrogn bay im a a groysn tsutroy, er hot mir gegebn in a gutn,</ANNOTATION_VALUE>
