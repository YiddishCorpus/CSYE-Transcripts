			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>mit mir hobn gearbet in dem in di ge- in di agit-brigade azelkhene khevre vi Leyzer Zilber, Rifke Levit,</ANNOTATION_VALUE>
