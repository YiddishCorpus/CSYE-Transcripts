		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>ikh bin geven tsuzamen tsvishn di yidishe arbeter yugnt un ikh hob bashlosn ikh vil dos ton.</ANNOTATION_VALUE>
