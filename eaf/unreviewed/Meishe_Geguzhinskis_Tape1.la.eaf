			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts11">
				<ANNOTATION_VALUE>ikh Roze Bilauskinye nem intervyu bay Meyshn Geguzhinski. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a455" TIME_SLOT_REF1="ts10" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>Vilne, Lite, di shprakh yidish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
