			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>nu di arbet farshteyt zikh iz geven a rizike, vayl in yener tsayt far proklamatsyes flegt men kenen araynzetsn in turme,</ANNOTATION_VALUE>
