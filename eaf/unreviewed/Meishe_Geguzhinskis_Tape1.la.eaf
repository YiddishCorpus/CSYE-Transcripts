			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts347">
				<ANNOTATION_VALUE>un bay nakht, tsvelf a zeyger, zaynen mir hobn mir genumen di proklamatsyes bay Avremke Lan,</ANNOTATION_VALUE>
