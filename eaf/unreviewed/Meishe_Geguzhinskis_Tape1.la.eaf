		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>in a gevisn tog zogt er tsu mir, "ikh hob komunistishe proklamatsyes, m'darf zey oys klebn."</ANNOTATION_VALUE>
