			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>hot mayn narisher seykhl gezogt tsuge- geb- bay bay meyn narisher seykhl hot mir ge- ge- ge- ge&lt;kirt&gt; ikh zol nemen di iberike di ko- proklamatsyes un oysklebn oyf undzer tir vu ikh hob gearbet.</ANNOTATION_VALUE>
