		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>kinder hobn geshuln, DA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>az m'iz nisht gegangen aroys mit der mitn shtern, iz geven geferlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>groyse mentshn fleg men shlogn hargenen. kinder nisht azoy. nor groyse mentshn zey hobn zikh gevizn oyf der gas, un oyf der nakht hot men nisht getort geyn. s'geven a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>biz akht oyf der nakht hot men nisht getort geyn. un s'geven in der fri biz eleve hot men nisht getort geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>m'hot nisht gekent aynkoyfn keyn broyt keyn gornisht, un ven m'iz shoyn gegangen koyfn iz shoyn nisht geven gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts317">
				<ANNOTATION_VALUE>nu ober,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts318" TIME_SLOT_REF2="ts321">
