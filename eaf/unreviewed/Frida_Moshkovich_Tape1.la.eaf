		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>nu m'ho- vifl m'hot zikh gekent oyshaltn hot men zikh oysgehalt- ver s'hot gekent. un ver nisht iz gefaln.</ANNOTATION_VALUE>
