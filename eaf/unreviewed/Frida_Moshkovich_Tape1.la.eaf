		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>koydem ho'mir iber hoypt nisht gekent. s'hot gekritst unter di tseyn di blote.</ANNOTATION_VALUE>
