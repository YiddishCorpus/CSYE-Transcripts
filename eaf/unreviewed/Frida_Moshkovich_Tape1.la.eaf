		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a458" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>un deys ho'mir gegesn, azoy ho'mir undz gelebt.</ANNOTATION_VALUE>
