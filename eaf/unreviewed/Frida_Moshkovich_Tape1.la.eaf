		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts638" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>un ho'mir shoyn bakumen kleyder. eh vi eh vi der nu di heftling kleyder, UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>dort hot men, un dort ho'mir gearbet in a munitsyon fabrik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>dort iz geven shtark a sakh frantsoyzn, rusn, dort iz geven tsvontsik toyznt gefangen. un akht hundert yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>nu zey hobn bakumen besere kost, undz ho'mir bakumen funem lager genug gemeyne kost.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts649">
				<ANNOTATION_VALUE>gearbet ho'mir tsvelef sho. eyn vokh bay der nakht un eyn bay tog.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts648" TIME_SLOT_REF2="ts651">
				<ANNOTATION_VALUE>ikh hob gearbet bay pistoletn, un ikh hob zey gekukt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts650" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>di hent flegn bay dir tsufrirn bay der tsu di pistoletn, m'hot nisht gekent opraysn di finger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts655">
				<ANNOTATION_VALUE>ales iz geven zeyer in a shtark a groyser fabrik. un kalt. un hungerik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts654" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>bay der nakht ver s'hot gearbet bay der nakht in Gaystlingen, hot er bakumen fun der kantin a bisl esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a447" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
				<ANNOTATION_VALUE>un deys hot undz gehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a448" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts661">
				<ANNOTATION_VALUE>vayl der lager iz geven shtark m'hot undz gemeyn, m'hot undz gegebn yedn tog esn, ehm ribn, UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a450" TIME_SLOT_REF1="ts660" TIME_SLOT_REF2="ts662">
				<ANNOTATION_VALUE>ehm UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
