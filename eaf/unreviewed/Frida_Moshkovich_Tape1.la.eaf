				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a471" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>undz ze'mir gegangen in der fabrik arbetn UNK. mit soldatn bavakht mit S.S.n.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a473" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>un dort ze'mir arayn in der fabrik. in der fabrik hot undz oykhet S.S.n gevart,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a474" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>un azoy iz undz shtendik ze'mir geven unter kontrol, di S.S.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a475" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>dort hobn gearbet froyen tsivil, daytshn, in dem eh in der fabrik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a478" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>zey hobn nisht getort mit undz redn gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a479" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>eh azoy fil az ikh hob gearbet oykhet bay di pistoletn oyfn kontrol,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a480" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>flegn zey a mol leygn. ho'mir genumen, di kestlekh zenen geshtanen in der mit, zey hobn vayl zey hobn kontrolirt nokh undz nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a482" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>in der pis- eh flegn zey a mol emetser gebn fleg a vunk ton un leygn a shtikl broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a484" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>un dort undz ze'mir shoyn geven di gantse tsayt, biz ze'mir nisht avek</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a487" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>oyg Gaystlingen. Gaystling iz nisht vayt fun Shtutgart.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a489" TIME_SLOT_REF1="ts732" TIME_SLOT_REF2="ts735">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a490" TIME_SLOT_REF1="ts736" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a491" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>a nokh dem hot men a- d- deys iz der Gaystling in Daytshland dos iz nisht vart fun Shtutgart.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a493" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>Shtutgart hot men ongehoybn shtark bombirn, Gaystlingen hot men nisht bombirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a495" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>deye mentshn, di daytshn, un zenen antlofn ale oyf Gaystlingen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a497" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>un undz hot men avekgefirt oyf Minkhn Alekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a499" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>dort ze'mir gekumen oyf Minkhn Alekh, dort iz shoyn geven a sakh yidishe mener.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a501" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>dort ho'mir gezen di ershte yidishe mener.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a502" TIME_SLOT_REF1="ts753" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>iz geven dort tsvey iber ikh veys az mer vi tsvey toyznt mener.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a504" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>nor di drotn hobn undz ibergehakt. ehm deys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a506" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>un dort ho'mir shoyn vayter iz geven shver. dort iz shoyn vayter keyn bet nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a508" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>dort iz shoyn geven layz. dort iz eh vaser iz geven, nor di mentshn zenen geven shtark oysgehungert.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a510" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>hot es azoy hot es gemakht eh layz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a511" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>un m'hot shoyn geligt oyf der erd oyf epes hey. un zet es oys deys hey iz geven nisht zoyber.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a512" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>dort iz shoyn gevorn vayter groyse tsores.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>dort iz shoyn gevorn layz, tifus, eh krankheytn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a517" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>nor mentshn hot men avekgefirt shoyn nisht in di krematoryums, m'hot zey shoyn gefirt in di shpiteler.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a518" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>in zeyere in di daytshe shpiteler.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a519" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a520" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
				<ANNOTATION_VALUE>un fun dort dort hot men undz aynvogenirt, un m'hot yedn eynem gegebn a zak,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>un m'hot gez- undz ho'mir azoy gevust az m'firt undz hargenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a525" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>iz geven toyznt froyen, un tsvey toyznt mener.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a527" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>un vifl ze'mir geven dort in eh in Minkhn Alekh, ikh veys nisht, a khoydesh, tsvey, ikh gedenk nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a529" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>a khoydesh efsher, mer a khoydesh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a530" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>un m'hot undz avekgefirt oyf in di vagonen, aynvogenirt. un di mener hot men gegebn ofene vagonen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a531" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>un di froyen hot men gegebn tsugemakhte vagonen. finef un zibetsik mentshn in a vagon.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a533" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>un azoy ze'mir geforn a tsvey dray vokhn. un m'hot undz shoyn nisht arayngelozt in ergets.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a536" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>undz hot shoyn ibergenumen di Royte Kreyts. undz ho'mir shoyn bakumen a bisele esn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a540" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>funem Roytn Kreyts. yeder eyner hot bakumen a pekl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a541" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>nor azoy vi di mener iz geven in ofene vagonen, un tsugemakht mit drot, mit shtekhedik drot,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a544" TIME_SLOT_REF1="ts799" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>un undz ze'mir geven in tsugemakhte vagonen, nor in undzer vagon iz geven iberol tsu tsvey daytshn, S.S.n.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a545" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
				<ANNOTATION_VALUE>eh bay nakht zenen zey avek shlofn in zeye- in zeyere vagonen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a546" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>un zey hobn undz tsugemakht fun droysn di vagonen, un a gantsn tog zenen zey geven mit undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a548" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>nu dort hot men undz gegebn aroys yedn tog di shtikl broyt, dort epes tsu dem broytl op tsu, s'shoyn geven deys</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a549" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts808">
				<ANNOTATION_VALUE>dey peklekh iz shoyn geven gringer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a550" TIME_SLOT_REF1="ts809" TIME_SLOT_REF2="ts810">
				<ANNOTATION_VALUE>un zey hobn undz aroysgelozt azoy oyf a feld ze'mir geshtanen, iz geven a groyser shalon,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a551" TIME_SLOT_REF1="ts811" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>ze'mir geshtanen oyf a feld, un dort flegt men undz, di soldatn undz froyen, meydlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a554" TIME_SLOT_REF1="ts813" TIME_SLOT_REF2="ts814">
				<ANNOTATION_VALUE>hot men undz aroysgelozt m'zol a bisl zayn in droysn oyf der luft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a555" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>un ven m'hot bakumen di peklekh iz geven getriknte milkh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a556" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts818">
				<ANNOTATION_VALUE>un dort ho'mir oysgezukht shteyner, un eh sh- shpendlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a558" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts821">
				<ANNOTATION_VALUE>un ho'mir getrofn oyfn feld eh fun konzervns blekhlekh. un m'hot zey dort, epes iz geven vaser, un m'hot zey oysgevashn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a560" TIME_SLOT_REF1="ts820" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>un ho'mir gemakht milkh heyse.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Yacov Eliashevich">
