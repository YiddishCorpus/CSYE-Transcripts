		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>un m'hot opgegesn hot men aropgevorfn tsurik dem top. oyfn zamd.</ANNOTATION_VALUE>
