			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>un zilber hot men tsugenumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>un gold UNK. vos hot men gehat, hot men gemuzt gebn, az nisht hot men moyre gehat. der tate iz tsufelik nisht gevezn avade, nor di mame. der tate hot zikh gehaltn oyfn boydem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>&lt;BUT&gt; nokh alts nisht gevolt oy- oysshnaydn di bord.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a822" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts519">
				<ANNOTATION_VALUE>ABER shpeter, leyder, hot er gemuzt opshnaydn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts520" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>yo. dos iz gevezn bald. azoy vi zenen zey arayngekumen di yekes, hobn mir shoyn gemuzt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts525">
				<ANNOTATION_VALUE>ontun a shtern yeder eyner fun &lt;dos&gt;. undz ho'mir nisht ongetun, di kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts526" TIME_SLOT_REF2="ts527">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts528" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>keyn TRAM hot men nisht gemegt forn. keyn tsug hot men nisht gemegt forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>&lt;BUT&gt; m'hot nisht gemegt geyn tsu goyishe gesheftn aynkoyfn, nor alts tsvishn &lt;do&gt; tsvishn yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>az s'hot men gevolt geyn oyf di lange gas, gevezn goyishe gesheftn azoy vi UNK &lt;WIELKY&gt; vos iz geven tshokolade vos hot men UNK dort gekoyft</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>hot men nisht gemegt geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts538" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>oh, zey hobn &lt;es&gt; gehat hanoe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
