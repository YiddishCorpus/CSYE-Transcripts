		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>ABER undz ze'mir zeyer gut gevezn mit di shvester un mir ir</ANNOTATION_VALUE>
