		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>zey hobn g- hanoe. zey hobn gezogt az eh dos &lt;iz&gt; gevezn yidishe hayzer</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a823" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>&lt;un&gt; undzere gasn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a824" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>yetst vet zayn undzere gas oy-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a825" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>gasn, un zeyer h- eh nisht keyn, nisht keyn yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a826" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>yidishe h- hayzer &lt;un&gt; zeyere gasn zenen &lt;zey&gt; gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a827" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>un shpeter hobn zey gezogt az dos vet zayn undzere gasn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a828" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>undzere gasn, undzere hayzer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>oh, zey hobn gehat hanoe mit dem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>zey hobn gehat hanoe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts562" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>yo. zey hobn gezogt az zey makhn dos a plats far undz, a spetsyeln PODGORZE, a spetsyel plats</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>undz &lt;veln mir&gt; ale dort voynen, un fun dort veln mir geyn tsu di arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>nor azoy az UNK ongehoybn, hot mayn tate hot UNK gevust UNK kleyne kinder, hot takesh nisht gevolt blaybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>in Kroke, iz er geforn keyn SKAWINA. dos iz a dorf &lt;arayn&gt;. mir ho'mir gehat dort mishpokhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>iz er geforn keyn dorf arayn, un m'hot gedungen dort a WOHNUNG, un m'hot dort ge- gelebt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>ABER dos hot nisht lang gedoyert.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>bald zenen zey gekumen, hobn zey gezogt vider di ale dorfn kumen keyn Kroke vider tsurik</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>keyn UNK keyn PODGORZE</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>in geto arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts583">
				<ANNOTATION_VALUE>un mir &lt;hobn&gt; UNK ale bald tsurikgekumen in geto arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>di geto iz in PODGORZE</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts588" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>oyf di JOZEFINSKI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>iz gevez- gevezn di geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a829" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>dos iz geven d- a gantse</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>vi me zogt a &lt;kleyne&gt; shtetele arum un arum, un ale yidn hobn dort gevoynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>es iz gevezn arum un arum</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>drotn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>un zey hobn gemakht di kleyne hayzelekh. zey hobn oyfgepast UNK zoln mir undz nisht loyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>un di TRAM iz adurkhgeforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>durkhn geto, azoy az hot men gekent zikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>a bisl aroysganvenen, undz kinder perzenlekh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>hobn mir zikh gekent aroys&lt;UNK&gt; vos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>vayl di TRAM iz geforn eyns oyf eyn zayt, un eyne &lt;ON&gt; di tsveyte zayt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a832" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts616">
				<ANNOTATION_VALUE>un tsvishn iz gevezn a groyse oyfmakhn, un do iz geshtanen a budke mit a yeke</ANNOTATION_VALUE>
