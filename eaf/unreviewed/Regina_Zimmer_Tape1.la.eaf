		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts464" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>neyn. m'hot nisht gehat vu tsu loyfn. der tate hot nisht gevolt, di mame hot nisht gevolt iberlozn di mishpokhe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>un m'hot nisht s- m'hot gekent, m'hot nisht gekent loyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts470" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>dos iz gevezn shpeter vos zenen zey avekgeforn. frier z- iz gevezn veynik mentshn vos zenen avek</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>f- shpeter az m'hot undz shoyn genumen in ge- in lager arayn, in geto, in lager</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a818" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>hot men ongehoybn UNK avek. ABER vu iz men geforn? in di derfer arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>m'iz geforn in di derfer, vayl m'hot gemeynt in derfer dort nisht pasirn gornisht, ober dos iz nisht vor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>nisht lang iz dos gekumen alts in di derfer. JUSTE di zelbe. ze'mir takesh gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a819" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>zenen mir gevezn in Kroke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a820" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>shpeter iz eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts487">
				<ANNOTATION_VALUE>hot zikh ongehoybn vos hot men tsugenumen, hot geheysn opgebn dos gantse gold un dos gantse zilber</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts488" TIME_SLOT_REF2="ts489">
				<ANNOTATION_VALUE>un</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts490" TIME_SLOT_REF2="ts493">
				<ANNOTATION_VALUE>in, alts in geto nokh. alts in geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts494" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>neyn, dos iz gevezn in insh- in, in Kroke, vu ikh hob gevoynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>hot men gemuzt ales opgebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>m'hot UNK afile dos kleyntshike UNK radyo hot  gedarft men opgebn, zol men nisht visn keyn nayes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>ales hot men gemuzt opgebn. zenen zey gekumen in shtub arayn. zey hobn tsugenumen, m'hot gehat hengen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>vi haynt gedenk ikh az er hot &lt;tapet&gt; oyf di re- oyf di vant.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a821" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>hot er dos aropgenumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>ikh hob nisht farshtanen vos dos iz. dos hot gemuzt zayn a ekhte &lt;tapet&gt; vos hot UNK geganen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>aropnemen dem &lt;tapet&gt; der yeke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
