			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>ikh muz aykh dertseyln vegn dem vi azoy ikh bin ikh bin gegangen tsu der arbet dortn yedn tog,</ANNOTATION_VALUE>
