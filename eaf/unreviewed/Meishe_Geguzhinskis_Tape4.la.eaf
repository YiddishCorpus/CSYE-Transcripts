			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a878" TIME_SLOT_REF1="ts250" TIME_SLOT_REF2="ts252">
				<ANNOTATION_VALUE>alemen tsuzamen unter di kleyne tirl. farshteyt zikh durkh a kleyne tirl iz shver arayntsugeyn,</ANNOTATION_VALUE>
