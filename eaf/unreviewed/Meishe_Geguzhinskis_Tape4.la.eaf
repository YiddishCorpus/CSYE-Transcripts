		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>nu ikh zog nit az zey zenen geblibn ale lebn, nor nor a klenere tsol fun zey flegn oysshtarbn.</ANNOTATION_VALUE>
