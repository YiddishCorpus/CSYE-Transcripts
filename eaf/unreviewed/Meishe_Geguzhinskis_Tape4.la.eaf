				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
				<ANNOTATION_VALUE>shpeter hot men undz ongehoybn  o- o -m'hot undz oysgemushtirt un m'hot gezogt</ANNOTATION_VALUE>
