			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>zenen mir shoyn geven tsufridn vegn dem az der bruder vet kho- vet khotsh zayn mit di mamen tsuzamen. </ANNOTATION_VALUE>
