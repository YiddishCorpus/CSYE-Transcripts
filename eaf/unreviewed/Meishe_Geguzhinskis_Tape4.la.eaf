		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>keyner hot iz fun zey nit geblibn lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>ober di litvishe yidn velkhe zenen shoyn geven a bisl ayngevoynt fun di lager badingungen zayendik shoyn in di getos mit di un farshidene dortn a- andere lagern,</ANNOTATION_VALUE>
