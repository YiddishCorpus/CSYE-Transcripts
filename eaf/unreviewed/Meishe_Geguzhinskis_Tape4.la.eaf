			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>yidn un m'hot oyf di oyf tsu boyen mit tsement mit eh beton fun betonirn dortn di un- di un- di un- di untererdishe</ANNOTATION_VALUE>
