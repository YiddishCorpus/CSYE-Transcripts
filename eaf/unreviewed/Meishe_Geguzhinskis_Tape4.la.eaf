			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a881" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>eh der ikh hob eh bashlosn, mir hobn beyde bashlosn, az efsher zoln mir fo- mayn bruderl iz geven zeyer a shvakher in gezunt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>un mir hobn bashlosn iz der bruder vet efsher blaybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts273">
				<ANNOTATION_VALUE>in nu er er zol zikh tsu tsu tsu eh onshlisn on di kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts272" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>tsu efsher vet men di kinder nit tshepenen. mir hobn keyn fal nit keyn fal nit gegleybt az di daytshn zenen oyf azoy fil</ANNOTATION_VALUE>
