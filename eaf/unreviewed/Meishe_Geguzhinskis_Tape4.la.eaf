		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a880" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>un der bruderl mayner iz geven, ober der foter mitn bruderl hot men aroysgefirt fun geto in UNK.</ANNOTATION_VALUE>
