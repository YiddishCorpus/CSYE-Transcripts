			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>az zey zoln nemen kinder un zey um- un zey umbrengen. efsher veln di ki- veln di kinder efsher blaybn lebn. hobn mir bashlosn az der bruderl zol geyn tsvishn di kinder, un mir mitn foter velkhe zenen shoyn geven mer veyniker shtarker,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
