			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>flegt men flegt sh- flegn shteyn di di kapos, di poylishe kapos, un klapn ibern ibern nakn ibern kop.</ANNOTATION_VALUE>
