			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>vos heyst gegangen? m'hot undz getribn tsu der arbet yedn tog. gegesn gegesn hot men undz gegebn zeyer shvakh, zeyer veynik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
