		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
				<ANNOTATION_VALUE>un di kapos flegn undz traybn dortn in barak,</ANNOTATION_VALUE>
