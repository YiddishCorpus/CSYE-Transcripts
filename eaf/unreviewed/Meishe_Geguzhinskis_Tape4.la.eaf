			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>un geven hungerik un oysgemutshet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>un ikh hob bash- ikh hob der- dersh- der- geyendik farbay geyendik tsu der ar- tsu der arbet, hob ikh bamerkt az s'do a feld</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>bamerkt a feld fun kartofl. vos iz ge- vos dortn hobn opgevaksn kartofl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>hob ikh bashlosn zikh aroys tsu ganvenen funem arbets-ort ibern parkan,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>in mitn der arbet az der postn zol mir nit bamerkn, un ikh zol efsher kenen on- on grablen a bisl kartofl un arayntsuleygn zikh bay zikh un arayntrogn in lager arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>ikh hob eh fun dem feld fun di kartofl fun dest vegn gefunen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>un ikh hob ongehoybn grablen untern shney, nor di- dine shikhtn shney, un ikh hob ongehoybn ganvenen di kartofl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>un geven zeyer tsufridn vos ikh zol kenen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a883" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>mit di kartoflekh efsher helfn zikh un dem f- mayn foter iz oykh geven in dem zelbn lager, khotsh helfn im, er iz gelegn krank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a884" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>un ikh hob im gevolt khotshik oysbrengen etlekhe kartofl tsum shtiln zayn hunger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts391">
				<ANNOTATION_VALUE>ikh hob zikh arayngeton in der a- in in dem grablen, az ikh hob fargesn di tsayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts390" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>un in der zelber tsayt iz der arbets-brigade,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>s'hot zikh geendikt der arbets- di tsayt fun der arbets-brigade,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>un zey ze- m'hot zey avekgetribn tsurik in lager un ikh bin geblibn eyner aleyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>ikh kum tsu geyn oyfn arbets-ort, keyner iz nito.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>ikh trakht zikh, vos zol ikh do ton?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>in der zelber tsayt hot men shoyn oysgetseylt in arbets-lager az s'felt eyn mentsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>hot men aroysgelozn di postns mit hint tsum zukhn dem mentshn. der mentsh bin geven UNK bin mir geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>s'shoyn geven shpet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>un ikh hob eh farlorn di oryentatsye vu der lager gefint zikh, ikh hob ongehoybn tsu blondzhenen. ikh hob gevolt kumen shoyn aleyn in lager dokh vi nit iz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>vayl ikh hob farshtanen az m- az s'vet feln a mentsh veln mir shpeter vet men shpeter eh kenen derfar eh laydn di iberike oykh fun lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>hob ikh genumen hob ikh eh ongehoybn blondzhenen, un ikh hob derhert</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>es biln hint geferlekh, di m'hot aroysgef- aroysgekukt postns mit hint zukhn, mit shpir-hint zukhn dem ge- antlofenem mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>un zey hobn mir gekhapt. zey farshteyt zikh mir glaykh gekhapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>zey hobn mikh gekhapt, un avekge- tsu ersht hobn zey mir gut ongeshlogn, gegebn, gekrogn fun zey ge- gu- gute klep,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
				<ANNOTATION_VALUE>nor eyn daytsh velkher iz geven dortn der sh- der der eltster fun zey hot nit gelozt hargenen mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a885" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>zogt er tsu mir, zogt er tsu zey tsu zey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a886" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>ikh vel zikh mit zey mit im, zogt er, aleyn oprekhenen. tshepet im nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>un tsu mir zogt er oyf daytsh, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>"veyst, du kleyner yunger, ikh men ikh vel dikh LA- LASSEN SCHLAGEN dikh."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>du gey foroys, un m'hot mir gefirt in lager, un er hot mir nit gelozn shlogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>ven ven m- ven m'iz gekumen in lager tsuzamen mit di gantse kompanye postns velkhe zenen gegangen hinter mir mit di hint,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>m'hot mir arayngefirt tsum komendant.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts437">
				<ANNOTATION_VALUE>tsk der komendant fun lager iz geven a vilder mentsh a geferlekher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts436" TIME_SLOT_REF2="ts439">
				<ANNOTATION_VALUE>er hot shoyn gevust zayne f- eh vi azoy tsu mutshenen mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts438" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>hot er bashlosn oystsufirn oyf mir a ekzekutsye. mir oyfhengen oyf a drot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>ikh zol blaybn hengen oyf a drot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>er hot genumen nokh tsvey mentshn lebn zikh, tsvey postns,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>farbundn m- ge- tsugefirt mir tsum shtolp,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>aroyfgetsoygn a drot oyfn shtolp in der heykh, farbundn mir di hent oyf hintn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>dos iz geven a eyne fun di greste g- greste mutshenish in di lagern fun fun OSWIECIM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>er iz kentik geven dortn komendant in OSWIECIM, un er hot gevust di ale farsheydene metodn vi tsu m- oys- oystsumatern mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>hot men farbundn di hent oyf hintn mit di drotn, un hot men mir tsugebundn dem drot un mir aroyfgetsoygn oyfn shtolp in der heykh. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts457">
				<ANNOTATION_VALUE>ikh bin gehangen do oyf shtolp farshteyt zikh ikh gedenk shoyn nit vifl tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts456" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>nor ikh veys nor eyns, az di kartofl velkhe ikh hob gehat bahaltn hobn zikh aroysgeshotn bay mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>hot der komendant bamerkt, zogt er, "o! du host nokh kartofl mit zikh? dan muztu hengen nokh mer!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>ikh bin gehangen a kurtse tsayt, biz ikh hob farlorn dem bavustzayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>ikh gedenk nit ver vi azoy es pasirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>nor ikh veys nor az ver nit iz opgesh- opgeshnitn dem drot, ver nit iz nor biz haynt veys ikh nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>un m'hot mir arayngetrogn in barak. in barak un m'hot mir avekgeleygt oyfn nare.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>di hent zenen bay mir geven tseshnitn fun di drotn, farblutikt geferlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>di harts ligndik di harts bay mir geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>geferlekhe veytogn un di oygn bay mir geven un di kop hot mir ge- ge- geshvindlt, ikh hob nit gevust oyf velkhe velt ikh bin. un m'hot mir avekgeleygt dortn in in barak lign. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts477">
				<ANNOTATION_VALUE>undzer blok-eltster iz geven a yid. er hot geheysn Itsik Mayer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts476" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>er iz geven a yid mit a groysn bagazh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>er iz geven di lagern fun OSWIECIM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts483">
				<ANNOTATION_VALUE>un er flegt, er hot zikh dortn oysgelernt vi azoy tsum</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts482" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>vi azoy tsum shlogn di yidn. er iz geven a zeyer a biterer mentsh. a Lodzher yid, a Lod- fun Lodzh, a Varshe- a poylisher yid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>Itsik Mayer hot men im dort hot men im gerufn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>oyf yidish heyst er Itsik Meyer, nor azoy mitn mitn aktsen fun di poylisher heyst er "Mayer".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts491">
				<ANNOTATION_VALUE>fun dest vegn iz li- eh li- eh ligndik in barak,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts490" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>hot er eyn mol tsu mir tsuget- eh a farvundeter in barak, hot er tsu mir tsugetrogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>a sh- a gedikhte kesele mit mit z- mit zup, mit gedikhte zup.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>un er hot tsu mir gezogt, di verter gedenk ikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a890" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts499">
				<ANNOTATION_VALUE>"ey du, pshakrev! du eh nem nu balek fun di deyshke</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a891" TIME_SLOT_REF1="ts498" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>un eh makh zikh nit visndik du du bist bay mir a held!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>a rikh in dayn totn's totn's totn's arayn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>ot di verter gedenk ikh zayne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>un a tsveytn mol hot er mir oykh tsugetro- oyf morgn hot er mir oykh tsugetrogn di bisele a bisl gedikhte zup.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>di iberike hot er, di iberike yidn velkhe zenen geven in barak, hot er mit mi- tsu zey batsoygn zikh zeyer nit gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a887" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>tsu mir hot er gehat kentik rakhmones un er hot mir geholfn blaybn lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>a lange tsayt bin ikh gelegn in barak a farvundeter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>un ikh hob farshtanen az ikh muz blaybn lebn. als eyns ikh bin nokh yung un ikh muz, ikh lo- ikh ikh hob gehoft az ikh volt vern bafrayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>tsu arbet hot men nit geshikt vayl ikh bin geven in gantsn farvundet. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>nor bislekhvayz hob ikh zikh avekgeshtelt oyf di fis,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>un ikh bin shoyn aroys di ershte tsayt tsu der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>nu spn vayter, in der tsayt iz geven, s'shoyn geven friling tsayt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>finf un fertsikstn yor, dos iz shoyn geven MART monat dakht zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>di yidn di asirim fun fun lager hobn ongehoybn kran- krenken oyf oyf tifus.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>fun fun fun hunger, fun kelt, fun noyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>ikh bin arumgelofn, ikh bin ikh bin geven oykh hungerik vi ale,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>ikh bin shoyn geven enlekh tsu a musulman. a musulman dos iz a mentsh velkher er farlirt dem gantsn oyszen zaynem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>er vert es es es zeen zikh bay im aroys di beyner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>un un mer nit vi di di di beyner fun di fun di shokes UNK,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>s'iz di velkhe zenen geven in lager veysn velkher heyst a musulman.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>afile in di sovetishe lagern veysn oykh vos heyst a musulman. ikh hob nit lang geredt mit a mentshn, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a888" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts543">
				<ANNOTATION_VALUE>er hot ibergezetst mayne mayne memuarn vegn vegn dem, zogt er, o</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a889" TIME_SLOT_REF1="ts542" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>di shraybst in dayne memuarn vegn musulman, zogt er, ikh veys vos dos heyst, zogt er, in Sibir hobn mir es oykh gehat azelkhene musulmanen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>aza min bin ikh geven oykh shoyn gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>nor plutsung, ya, geyendik azoy bay di barakn hob ikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts551">
				<ANNOTATION_VALUE>eh gezukht vu tsu a shtik- khapn a shtikl broyt oder a shtikl kartofl, kedey tsu shtiln shtiln dem hunger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts553">
				<ANNOTATION_VALUE>un mertsn teyl hob hob ikh zikh bin bin ikh arayn in di zone vu es zenen gelegn di tifus kranke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts552" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>vayl dortn flegn di kranke shoyn, a sakh kranke flegn farn shtarbn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>flegn zey iberlozn di shtikele broyt vos zeyer portsye broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>un fun zey hob ikh getrakht efsher, hob ikh ge- gevelt vos nit far zikh vos nit iz gefinen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a404" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>ikh efn di tir fun a barak, ikh gib a kuk unter a koldre, es ligt a bavaksener mentsh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>aza min, ober mit azelkhene shey- sheyne gute oygn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts565">
				<ANNOTATION_VALUE>ikh gib a kuk, epes a bakanter, ver iz er?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts564" TIME_SLOT_REF2="ts567">
				<ANNOTATION_VALUE>ikh hob es dermont. dos iz mayn amoliker lerer Yisroel Kaplan.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts566" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>ikh hob im dakht zikh vegn dem dermont, er iz geven mayn ershter lerer in Slabodke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>er hot mir derzen, zogt er, o Gegele! er hot mir gerufn, in der tsayt fun lernen hot er hob ikh gehat a tsunomen Gegele, loyt der familye Geguzhinski.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>Gegele, zogt er, bist do, zogt er, bist mayner a shiler!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts575">
				<ANNOTATION_VALUE>her tsu, efsher kenstu mir ton a toyve?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts574" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>zog mir, efsher kenstu mir brengen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>a pa- shtikl papir vayse. ot, zogt er, ikh kentik kentik gey ikh shoyn nit oyshaltn, zogt er, vayle zest dokh vi ikh lig oyf tifus krank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>ikh vel shoyn mistome shtarbn, ober farn toyt vil ikh onshraybn khotshabe vegn mayn lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>ikh hob nit oyf vos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>un a shtik papir iz geven shver tsu krign in lager. nor fun dest vegn bin ikh aroysgelofn fun fun zayn barak un ikh hob gezukht ikh hob gefunen a shtikl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>tsekneytshte papir un ikh hob im gegebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>un azoy hot der eh der lerer Kaplan geshribn vegn zayn lebn in lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>tsvishn andere vil ikh zogn az ersht nokhn krig,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>tsufelik hob ikh geleyent a tsaytung, in der Yerusholaim Belite,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a430" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>az s'gevorn nayntsik yor eynem a Yisroel Kaplan. nayntsik yor iz im gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts597">
				<ANNOTATION_VALUE>m'hot im bagrist. un mit aza mit zayn fotografye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts596" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>ikh hob gegebn a kuk di fotografye, ikh geb a kuk, s'rikhtik s'mayn lerer. vi azoy iz er geblibn lebn? ikh hob zikh nit forgeshtelt az a mentsh velkher iz gelegn shoyn oyfn toytn bet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>hot zikh hot nokh derlebt biz nayntsik yor, er lebt in Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>un ikh hob gikh avekgeshikt a telegrame</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>tsu im un ikh hob im bagrist mit zayn nayntsik yorikn iberley.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>hob ikh glaykh tsurik gekrogn a briv,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a441" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>mayn liber talmed, shraybt er tsu mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>mir freyt zeyer vu du lebst un ikh vil dir zen. kum tsu forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
