		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts318" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>oyb es flegt flegn feln ver nit iz eyner oyfn loytn tsol, flegt der komendant</ANNOTATION_VALUE>
