		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts342" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>iz geven dortn a BOY vos zayns a bruder hot men gehat ayngezetst oyf a yor,</ANNOTATION_VALUE>
