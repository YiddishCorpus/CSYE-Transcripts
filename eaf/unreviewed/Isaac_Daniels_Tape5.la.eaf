		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>un ikh ze vos zey hobn ge- vos zey hobn getrogn, vi zey zenen gegangen ongeton.</ANNOTATION_VALUE>
