			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>zogt er, yo. m'hot geshmuest, ikh hob im dertseylt vegn ikh hob gehat a FACTORY, mayns gesheft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a570" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>ANYWAY, m'iz opgezesn draytsn draytsn monatn, s'hot zikh geFINISHt oysforshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a571" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>endikt shoyn di oysforshn, in dem eleftn FEBRUARY,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a573" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>hot men mikh genumen, m'hot mikh geshikt in a tsveyte shtot arayn in a bay an andere tfise.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a574" TIME_SLOT_REF1="ts753" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>hot men undz arayngezetst, m'iz gevezn akhtsn man.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a575" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>hot men undz arayngezetst in a ROOM arayn, s'hot geheysn a karantin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a576" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>oyb vest oyshaltn di ROOM, vest nisht krank vern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>geystu arayn in dort in in a REGULAR ROOM arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>iz eh keyn fentster iz nisht geven nor kratn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>a frost az feygl zenen gefroyrn gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a580" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>do hot men undz gehaltn dray teg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>ikh ho- ikh ho- ikh hob gevust az ikh ho- ikh hob nisht keyn tseyn mer oys, hak mir oys di ts-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a582" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>m'hot ibergehaltn di dray teg, keyner iz nisht krank gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a583" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>mir arayngelozt in a ROOM arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a584" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts774">
				<ANNOTATION_VALUE>iz di vent iz dortn iz ge- a mol iz geven a a BAD,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a586" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>m'hot geBUILDet a a a a a shtotishe bod,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a588" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
				<ANNOTATION_VALUE>un s- m'hot es nisht fertik gemakht, iz oyf di vent iz geven ayz azoy grob.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a590" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>m'hot undz arayngelozt dortn, undz ze'mir geven zibn un nayntsik mentshn. in eyn ROOM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a592" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>un m'iz geshlofn azoy untn oyf der erd, hot men avekgeleygt a por bretlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a593" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>un fun oybn iz geven nares, iz geshlofn untn un fun der hey-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a594" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>zibn un nayntsik mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a595" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>un di mentshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
