		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>zog ikh, du veyst dayn bruder iz mit mir do un do?</ANNOTATION_VALUE>
