			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>az zi darf hobn sulfur, optsuCLEANen di lungs, zi hot a a, oyf di lungen hot zi nokh a dos.</ANNOTATION_VALUE>
