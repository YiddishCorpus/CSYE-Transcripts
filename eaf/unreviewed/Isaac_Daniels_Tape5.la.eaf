		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>dortn hot gemuzt zayn ikh veys eh fuftsn hundert mentsh- tsvey toyznt mentshn, efsher mer nokh mer. ful.</ANNOTATION_VALUE>
