		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>in dem HOSPITAL, di krankeyt darf zey hobn varem zeyer a sakh.</ANNOTATION_VALUE>
