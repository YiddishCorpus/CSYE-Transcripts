		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>ikh bin geven a por teg, iz mayn tokhter krank gevorn oyf skarlet un in difteres, difterit.</ANNOTATION_VALUE>
