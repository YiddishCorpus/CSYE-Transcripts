		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
				<ANNOTATION_VALUE>o yo, zeyer tsufridn. zog ikh, Lalek, host epes gelt bay zikh?</ANNOTATION_VALUE>
