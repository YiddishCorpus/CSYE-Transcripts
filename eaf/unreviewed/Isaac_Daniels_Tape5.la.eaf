		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>nor der BOY vos ikh hob im getrofn dortn hot er mir, er iz gekumen fun Ulyanosk,</ANNOTATION_VALUE>
