		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>fir rubl a a sho tsi a tog, ikh gedenk gornisht dos genoy.</ANNOTATION_VALUE>
