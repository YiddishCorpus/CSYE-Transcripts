		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts343">
				<ANNOTATION_VALUE>ikh kum aroys. iz der, tsk vu ikh bin geforn mit di tsvey mit di tsvey FAMILIES avek,</ANNOTATION_VALUE>
