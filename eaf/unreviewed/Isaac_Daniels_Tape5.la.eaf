		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>ANYWAY, er hot mir gegebn tsvey hundert rubl, m'hot gekoyft broyt mit a fleshl milkh.</ANNOTATION_VALUE>
