		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>ikh gey arayn in apteyk arayn, zogt zi s'nishto. zi hot nisht.</ANNOTATION_VALUE>
