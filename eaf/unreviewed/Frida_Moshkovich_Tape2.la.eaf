		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>di zun UNK? di zun geyt oyf un fargeyt, un in lager iz di nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>shtey ikh azoy bay dem fentster, mit soldatn shtrengs bavakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>di zun geyt oyf un fargeyt, un in lager iz di nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>shtey ikh azoy bay dem fentster, mit soldatn shtrengs bavakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>vu ir vilt kent ir mikh firn, fun antloyfn bin ikh vayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts593">
				<ANNOTATION_VALUE>khotshik benk zikh nokh der frayheyt, tseraysn ken ikh nisht dos drot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts592" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>oy drotn, mayne drotn, ikh gedenk aykh fun a mol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>mayn geyst vet ir nisht taytn, nor dem kerper fun a mol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>in mayner HEIMAT dort blien di royzn, in mayne HEIMAT, dort blit dos glik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>ikh MECHT mikh eyn MAL mayne muter tsu KUSSEN,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
