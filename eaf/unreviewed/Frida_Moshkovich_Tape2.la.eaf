	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Frida Moshkovich">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
				<ANNOTATION_VALUE>in Oyshvits hob ikh gehat a khavertorin, a undz ze'mir geven shkheynes meydlekh geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>zi iz elter geven fun mir mit a yor. zi iz geven hoykh, un ikh bin geven niderik un dar.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>zi hot men shtendik oysgekloybn in krematoryum arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>zi iz oykh koydem gekumen mit mir oyf arbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>in Oyshvits hot zi Mengele oysgekloybn. un nokh dem yedes mol, vifl mol Mengele hot ibergekloybn, hot er zi alts aroysgevorfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>un eh ze'mir geven fir sh- meydlekh, fir shkheynim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>ale fir meydlekh, zey zenen geven ale elter, ikh bin geven di yingste.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>zey hobn alts geklert vos m'ken ton, eh mayn khavertorin Goldi,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a16" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
				<ANNOTATION_VALUE>m'zol zi kenen eh eh rateven fun Mengele's hent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>ze'mir gegan dort eh hot men undz geshikt eyn mol in der vokh hot men undz gefirt bodn. dort hot undz Mengele oyfbakukt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
				<ANNOTATION_VALUE>dos heyst geheysn di zone.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
				<ANNOTATION_VALUE>dort, fun dort mikh hot men alts oysgekloybn oyf arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>un zi hot alts avekgevorfn. zi hot men alts geleygt, az m'hot alts gefunen oyf ir epes a shprenkele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>bin ikh antlofn fun dort, m'hot mir gekent shisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>mikh hot men avek gevolt aveknemen in der arbet. ikh hob nisht gevolt geyn, vayl ale mayne mentshn, mayne bakonte, zenen geblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>mikh hot men koydem gevolt oyf Daytshland firn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>bin ikh antlofn durkh ir. zi ho- ho'mir gefunen un zi iz vayter geven mit undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>nokh dem vayter hot men undz vayter ongehoybn tsu kloybn, zi hot men vayter aroysgevorfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
				<ANNOTATION_VALUE>undz ze'mir shoyn geven oder in transport tsu geyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
				<ANNOTATION_VALUE>oyf Daytshland. undz hot men shoyn nisht aroysgelozt, undz ho'mir shoyn geheysn blok SPERRE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
				<ANNOTATION_VALUE>vi m'hot zey aroys- iz eh vi ze- ze'mir gekumen ahin in der zone, hot zi Mengele vayter aroysgevorfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>un fun dort iz geven, m'hot zi avekgefirt in a revir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts52">
				<ANNOTATION_VALUE>a revir eh UNK. dos iz a eh neyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>dos iz a UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>un undz ho'mir nisht gevust vu dos iz, un undz hot men nisht aroysgelozt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>di meydlekh hobn gezogt m'darf Go- Goldi zol zayn mit undz, vayl oyb nisht, Goldi geyt in krematoryum arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>iz tsugegan- iz es, bin ikh gegangen UNK m'hot undz nisht aroysgelozt, vayl s'geven blok SPERRE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>hobn zey gezogt di meydlekh az zol ikh veynen az s'tut mikh vey di boykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>az m'zol mikh lozn UNK tualet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>ikh hob ongehoybn tsu veynen s'tut mikh vey der boykh, un ikh bin gelofn zukhn Goldin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts69">
				<ANNOTATION_VALUE>dos iz geven in lager dort. nor dort hot men eh s'geven ful eh bra- barakn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts68" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>oder m'hot nisht getort geyn in ergets fun eyn barak in andern arayn. un ikh hob zi gefunen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>nor un ikh hob shoyn gekent tun az zi zol aroyskumen fun dort, vayl dort iz geven a kalitke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a62" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>nor di kalitke hot men gekent oyfmakhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>un undz hot men shoyn oyfgenumen loyt dem nomen un undz ze'mir shoyn gedarft avekforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>un do hot men eh do iz shoyn nisht do keyn shum min, azoy vi ikh hob zi geho- getrofn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>ze'm- m'hot undz aroysgelozt oyfn hoyf makhn apel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>vu s'geven poylishe meydlekh, di shrayberins, vos zey hobn undz oyfgenumen, zey zenen shoyn geven fir yor in lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>hobn zey gezogt, yo ho'mir undz gezogt az mir viln mir baytn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>az zi zol kumen tsun undz un an andere zol geyn ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>hot zi gezogt, vayl undz ho'mir getrofn a froy, undz ho'mir in hoyf ongehoybn tsu shrayen ver s'vil geyn ahin in revir arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>hot zikh ongerufn eyn froy az zi vil geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>un zi iz avek ahin in revir, eh UNK, hot zi gezogt, di shrayberin, az zi ken gornisht tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a76" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>vayl dos iz shoyn oyfgenumen yedn loyt dem nomen un zi ken gornisht tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>un hot zi gezogt far der froy, "nokh vos geystu ahin?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>du veyst vos dort iz?" zogt zi, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>zogt zi, far vos vilstu geyn ahin? zogt zi, far dort iz mayn mame un ikh vil shtarbn in eynem mit mayn mame.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>iz di ze'mir gegangen un hobn zi avekgefirt un Goldin aroysgenumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>Goldi iz vayter gegangen mit undz in transport, oder do heybt zikh on vayter a Mengele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>un di vagonen zenen shoyn geshtanen un do iz shoyn nisht geven keyn shum min hilf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>hobn di meydlekh gezogt az ikh zol geyn foroys, vayl ikh vel durkhgeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>un zey ebn blaybn fun hintn mit Goldin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>ober dos iz geven azoy vi a &lt;PE&gt; gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>zey hobn mikh gekent fun hintn zen, vi azoy ikh bin arayn do un Mengele hot mikh bakukt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1101" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>m'hot gedarft arayngeyn in der zone bodn zikh un fun dort aroysgeyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1102" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts119">
				<ANNOTATION_VALUE>iz shoyn geven an ander plats, nor vi azoy zey zenen ges- -shtanen fun hintn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts118" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>hobn zey mikh gezen ale. vi azoy ikh, zey hobn gekukt vi azoy ikh gey aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>ikh bin aroysgegangen shnel fun dort,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>ikh hob gekukt az s'zol zayn shoyn a tsen fuftsn mentshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>un ikh hob ge- tsiterdike hent gehaltn dos vaser in di hent, un a shray gegebn, "Goldi, loyf!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a95" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts129">
				<ANNOTATION_VALUE>un Goldi iz gelofn. zi hot zikh geshtelt geven tsu shmirn un eh, undz ze'mir ale naket geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts128" TIME_SLOT_REF2="ts131">
				<ANNOTATION_VALUE>ikh hob ir afile gegebn a shtroy vaser, vifl ikh hob gehat in di hent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts133">
				<ANNOTATION_VALUE>un UNK di daytshn hobn in akht genumen, az emetser iz gelofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts132" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>nor az m'hot ibergetseylt, zey hobn nisht farshtanen vos dos iz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a103" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>un azoy ze'mir arayn, avekgeforn ale oyf Daytshland. SO mer keyn Mengele iz shoyn nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>DA UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a106" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>ze'mir aheymgekumen funem konts-lager, zi iz alts geven krank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>un ir foter iz aheymgekumen funem konts-lager. azoy vi ikh hob keynem nisht gehat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts151">
				<ANNOTATION_VALUE>undz ze'mir geven shkheynim, hot ir tate gezogt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts150" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>az deys vos er vet esn vel ikh oys esn, un mikh lot er nisht in ergets vayl ikh hob nisht vu tsu geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>ikh bin dokh dokh geven nor a kind un ikh hob keynem nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
				<ANNOTATION_VALUE>nu di momentn iz geven shtark shvere.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
				<ANNOTATION_VALUE>ikh hob a sakh geveynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts160" TIME_SLOT_REF2="ts162">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts165">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts167">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a119" TIME_SLOT_REF1="ts168" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts172" TIME_SLOT_REF2="ts173">
				<ANNOTATION_VALUE>UNK yidish?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts176">
				<ANNOTATION_VALUE>ven ze'mir ongekumen oyf Oyshvits, hot men gezogt di mener ekster.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>der di mener zenen avek ekster, un ikh mit der mame mit di kinder mit di fir briderlekh ze'mir geven in eynem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
				<ANNOTATION_VALUE>s'hot nisht gedoyert a tsen minut eh hot der tate gezen vu undz ze'mir, hot er mir gebrengt a shtikl broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a129" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts182">
				<ANNOTATION_VALUE>un a keml, az ikh zol zikh hobn mit vos tsu kemen vayl ales hot men undz tsugenumen. er hot dos gefunen oyf der erd dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
				<ANNOTATION_VALUE>un m'ot ongehoybn, di daytshn hobn ongehoybn tsu shrayen, iz er tsurik antlofn. SO deys hob ikh im gezen, nisht mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
				<ANNOTATION_VALUE>un mentshn hobn gezogt az er hot oysgehaltn dem lager, bakonte,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
				<ANNOTATION_VALUE>nokh dem lager iz er geshtorbn, ergets in Daytshland. vu, veys ikh nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts192" TIME_SLOT_REF2="ts195">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts199">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts203">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>iz fun der Royter Kreyts ven hot undz ibergenumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>un gekumen groyse mashinen, last-oytos, un hobn gebrengt peklekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>zet es oys, zey zenen shoyn gevoyer gevorn az dort iz yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
				<ANNOTATION_VALUE>un zey hobn undz gebrengt di peklekh. undz ho'mir shoyn nisht gekent geyn in an ergets, vayl der front iz shoyn gegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
				<ANNOTATION_VALUE>nisht aher nisht ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>nor fornt mit undz iz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts219">
				<ANNOTATION_VALUE>ale daytsher, di ofitsirn, di soldatn, velkhe zenen geven mit undz in eynem in Gaystlingen un in Minkhn Alekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts218" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>iz dey ale gegangen mit undz. nor zey hobn gehat a gute kuper, a sheynem &lt;tsugnish&gt; geven un undz ho'mir gehat eh proste vagonen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts223">
				<ANNOTATION_VALUE>un eh ven undz ho'm- m'hot shoyn gezen az der front nentert zi</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts222" TIME_SLOT_REF2="ts225">
				<ANNOTATION_VALUE>un zey hobn shoyn nisht gekent geyn in ergets nisht, vayl shoyn di amerikaner zenen shoyn ongekumen. iz ongekumen di tanken,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts224" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>ho'mir undz gezen az di daytshn velkhe zenen geven mit undz in di vagonen az zey nemen zikh epes tsu pakn zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>ober keyner hot nisht gevust vos dos iz. zey hobn zikh tsamgepakt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>di tsvey soldatn vos zenen gezesn in vagon,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
				<ANNOTATION_VALUE>un zenen avek un zey hobn undz tsugeshpart fun droysn undz zol'mir nisht kenen aroysgeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
				<ANNOTATION_VALUE>un di mener hobn gezen az di tanken geyen. vayl zey zenen dokh geven in ofene vagonen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
				<ANNOTATION_VALUE>hobn zey gezen di tanken. un v- m'hot gevolt shisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1103" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>zenen zey gegangen, ver vos hot ge- vi azoy er hot gekent, di shtikl hemd hobn zey tserisn, un zey hobn aroysgeleygt vayse fonen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
				<ANNOTATION_VALUE>un azoy ze'mir undz gevo- hot men oyfgehert tsu shisn. az s'iz yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts243">
				<ANNOTATION_VALUE>un un u- undz ale meydlekh ho'mir gemeynt az m'harget undz. undz ze'mir geven oyf dem gegreyt, vayl ale m'hot bakumen a zekl az m'vet undz aro- m'firt undz oyf di Tirol berg un m'vet undz aropvarfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1104" TIME_SLOT_REF1="ts242" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>vi azoy, vos, veyst men nisht. az yedn vet men araynleygn in a zak arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>ven m'hot ongehoybn tsu shisn ho'mir zikh ale meydlekh tsamgenumen tsuzamen, in vagon,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
				<ANNOTATION_VALUE>un ho'mir gezogt in eynem vil'mir shtarbn. s-UNK vos a khilek in tsi ekster tsi vi azoy, ale in eynem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
				<ANNOTATION_VALUE>un oyf dem hobn oyfgemakht di amerikaner di tir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
				<ANNOTATION_VALUE>un zey hobn gezogt, ir zent fray. undz ho'mir nisht geshtelt zikh nisht gekent forshteln az ze'mir bafrayt gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>nokh dem s'shoyn oyfgemakht ale vagonen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>m'hot shoyn gekhapt di ale daytshn velkhe zenen antlofn, m'hot zey shoyn avekgefirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>un undz ho'mir shoyn ongehoybn tsu geyn zukhn a shtikl broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
				<ANNOTATION_VALUE>iz geven a vagonen, epes eyn vagon iz geven vos iz geven esnvarg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts260" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>i far undz i far di daytshn. nu, zey hobn bakumen besers.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>iz vifl mener zey hobn gekent nebekh, velkhe zey hobn nokh gehat koyekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>zenen zey gegangen hobn oyfgerisn di vagonen un yeder hot gekh- gerisn zikh gekhapt a bisl esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>un un nokh dem ze'mir hot men undz arayngefirt in dorf. dos iz geven i der Ifldorf, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>i der Sh- i Lishtaltaykh. ikh gedenk nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>un dort tsu dray tog hobn undz di amerikaner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>in di hayzer ze'mir geven. mer keyn daytsh iz shoyn dort nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts277">
				<ANNOTATION_VALUE>un undz ho'mir gedarft nor esn. nor esn ho'mir gekukt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1105" TIME_SLOT_REF1="ts276" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>ze'mir arayn in di hayzer zukhn esn. vu nor geblibn esn hot men genumen. a bisl ontun zikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>m'iz dokh geven naket POCHTI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>un nokh dem hot men undz avekgenumen. dray tog hot men gelozt m'zol UNK tun vos m'vil,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>un m'hot men tsamgenumen un m'hot undz avekgefirt oyf Landsberg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>iz geven a groyser kanzarm, dort iz geven a daytsher kazarm.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>un di amerikaner, shtark a sakh mentshn geven, nokh fremde oykhet, rusishe, farshidene mentshn iz geven dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>un dort azoy vi ze'mir geven shtark opgehungert un opgemogerte,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>hot men undz shoyn nisht gegebn oyf a mol esn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>az m'zol zikh nisht eh fardarbn, m'zol nisht oysshtarbn, vayl zeyer a sakh mentshn zenen geshtorbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>hot men undz gegebn gemoln fleysh mit kashe. yedn tog hot men undz gekokht gemoln fleysh un yede vokh hot men undz gevoygn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>eh tsi mir nem'mir on a bisl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>un m'hot shtark opgehit az m'zol nisht epes a khap ton.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
				<ANNOTATION_VALUE>nokh dem, un zey hobn undz gefirt shoyn oyf Tshekhoslovakay.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>ze'mir ongekumen di ershte shtot oyf Belzn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>oykhet in a restorant, m'hot undz gegebn esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>nor fun dort ze'mir durkhgeforn oyf Prag,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts311">
				<ANNOTATION_VALUE>Prag hot men undz oykhet iberol, der Dzhoynt hot shoyn gevart undz iberol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts310" TIME_SLOT_REF2="ts313">
				<ANNOTATION_VALUE>iberol hot men gegebn esn, iberol hot men gegebn a por eh heler.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts312" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>un fun dort ze'mir ongekumen oyf Bratislava.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>Bratislava ze'mir geven epes tsvey vokhn oykhet, in a shul, in a hotel hot men oysgeleydikt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>oykh gegebn a bisl un a bisele esn. iberol hot men undz gegebn esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>un fun dortn ze'mir avekgegangen, hot men undz avekgefirt, zeyer shver geven tsu forn mit di tseger,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>oyf der oyf der shteyger fun der oyvn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>ze'mir ongekumen oyf Budapest.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>in Budapest ze'mir vayter geven a tsvey dray vokhn, un dort iz shoyn geven fray. ver vemen hot gevolt hot er shoyn gekent geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>un ikh hob alts gevart az der tate vet kumen funem lager oykh aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>tsk un gekumen rakhover mentshn vos zey hobn gekent mayn tatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
				<ANNOTATION_VALUE>hobn zey gezogt, s'nishto vos tsu vartn, nokhn bafrayenishn iz er ge- iz er geshtorbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>un nokh dem hot zikh ongehoybn shver dos lebn aleyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts336" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>WRACHOWA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts342" TIME_SLOT_REF2="ts343">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts344" TIME_SLOT_REF2="ts346">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts350" TIME_SLOT_REF2="ts352">
				<ANNOTATION_VALUE>DA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts357">
				<ANNOTATION_VALUE>spn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>er eh zayn familye iz geven Shvimer, tsk er iz geven mayn shokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>un er eh hot er iz arayn in a dire, zayn dire iz oykh geven tsebrokhn. er iz arayn in an anderer dire.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>un er hot mikh oyfgehaltn vayl ikh hob nisht gehat vu tsu zayn. er im ho'mir mir getrofn in Budapest. nisht in Budapest, in Bratislava.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>er iz oykh bafrayt gevorn. er aleyn hot gornisht gehat tsu esn, nokh di shlakht, ales tsugenumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>nor er eh hot gezogt, afile eyn mol in tog, deys vos er vet esn, vet er mir oykh gebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>ikh hob keynem nisht gehat, mir iz keyner nisht aheymgekumen, ikh bin eyner aleyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>far mir iz geven shtark shver dos lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>un fun dort ho'mir gehert az s'do a Dzhoynt in Usharod.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>un bin ikh geforn, ober dos iz nisht lang geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>dos iz dort ze'mir geven, ho'mir bakumen a OBSHCHEZHITIE,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>biz oykhet di Dzhoynt hot undz gehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>un hobn mentshn hobn zikh mit dem farnumen un dey mentshn hot men nokh dem opgehaltn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>dos tsu aveknemen ale opgehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>di gantse deys iz shoyn gevorn, ales hot men tsugenumen fun undz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>un m'hot undz ibergefirt oyf a eh iz shoyn gevorn UNK, shtatlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts393">
				<ANNOTATION_VALUE>un dos iz shoyn geven &lt;Shveyna Bovna Fabrika&gt;. aza nomen hot es gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts392" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>un s'zeyer shver geven, fardint hot men veynik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>undz ze'mir nokh geven a gelernt a, vos bisl neyen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>nor azoy vi m'zogt, shvere arbet, konfektsyon arbet, ober keyner hot mikh gornisht gekent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>iz geven shtark shver. ehm biz ze'mir a bisele tsu zikh gekumen, biz ho'mir zikh oysgelernt arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>nor undz ho'mir shoyn nisht bakumen keyn esn, undz ho'mir shoyn gornisht bakumen. m'hpt shoyn fun undz tsugenumen di OBSHCHEZHITIE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>iz yede meydlekh khasene gehat, velekh mit vemen, zey hobn zikh bakont gemakht, az m'zol nisht zayn aleyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>un zeyer a sakh ire hobn khasene gehat tsu eltere mentshn, DAZHE finef un tsvontsik yor RAZNITSA, iz geven an untershid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>un der far dey mener iz di familye geharget gevorn, in di krematoryum, avekgefirt oyf Daytshland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>un di meydlekh zenen geblibn aleyn, yunge kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>hot men khasene gehat tsu a elterer mentsh, azoy fil m'zol hobn a heym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>ikh hob mir bakont gemakht mit mayn man dort in der kokh. in undzere yidishe kokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>er hot oykh dort gearbet, un dort ho'mir zikh bakont gemakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>un mir ho'mir khasene gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>shoyn zibn un fertsiker yor ho'mir undz khasene gehat. mayn man iz far mir elter geven mit tsen yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts425">
				<ANNOTATION_VALUE>nu, dos heyst nayn. UNK. un eh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts430" TIME_SLOT_REF2="ts431">
				<ANNOTATION_VALUE>NIET.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>oyf yidish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>in Oyshvits, ho'mir undz nisht gearbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>vi azoy ikh hob nisht gekent zitsn oyf di pritshn zekhtsn ire. nisht geven nisht afile zitsn iz nisht geven vu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts447">
				<ANNOTATION_VALUE>ikh mit mayne khavertorin az ze'mir gegangen unter di pritshn, eh oyfn hoyln shteyn, on an alemen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts446" TIME_SLOT_REF2="ts449">
				<ANNOTATION_VALUE>eh vi azoy m'zogt naket, kimat nor in a hoyl kleydl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts448" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>un gelign oyf di shteyner. in der tunkl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>un m'hot nisht gekent -tort aroysgeyn in hoyf oykh nisht. tog un nakht gelegn oyf di shteyner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>biz m'hot undz gegebn a bisl esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>in azoyne groyse di, vi azoy heyst klop oyf yidish, vantsn hobn undz gegesn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts460" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>far undz iz geven zeyer biter ales. dos der pakhed fun der krematoryum.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>undz ho'mir dos nisht gevust az undzere eltern hot men undz avek, az m'firt avek in krematoryum arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>undz hot men gezogt, in a vokh arum e'mir zikh trefn mit di eltern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts473">
				<ANNOTATION_VALUE>un vu di krematoryum iz geven, dos ho'mir nor shpeter nor arum gezen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts472" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>az dort iz geven oysgeshribn, "arbet makht fray".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>zey hot men gefirt ahin, un dort iz geven muzik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>dort iz geven ales, az zey geyen in a sheynem vald arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>nor bay nakht az ze'mir oyfgeshtanen, ho'mir gezen vi azoy di di roykh geyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts482" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts488" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts492" TIME_SLOT_REF2="ts495">
