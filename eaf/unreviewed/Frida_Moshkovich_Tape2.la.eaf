		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>nor eh s'nisht gelungen. s'vi azoy m'zogt, geloybt tsu got az s'nisht emes.</ANNOTATION_VALUE>
