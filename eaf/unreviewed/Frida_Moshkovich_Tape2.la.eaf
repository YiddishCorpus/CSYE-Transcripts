				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts534" TIME_SLOT_REF2="ts537">
				<ANNOTATION_VALUE>neyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts540" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>eh ven undz ze'mir in Gaystlingen geven, nu a sakh mol hot men bombardirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>flegn mir f- loyfn eh di UNK. iz di daytshkes mit undz mitgegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>un ho'mir ge- ge- zey hobn gevust az s'geyt der front. undz ho'mir oykh gevust az di bombes faln, ober mer ho'mir undz gornisht gevust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1106" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>undz iz geven azoy ales eyns. ven m'ho- zey hobn a shray gegebn flig alarem ho'mir zikh undz gefreyt, e'mir nisht arbetn shver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts551">
				<ANNOTATION_VALUE>gey'mir in in di UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts557">
				<ANNOTATION_VALUE>undz ho'mir keyn mol gornisht gezen, hobn zey gezungen, di daytshn, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts556" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>hobn zey oysgelernt undz zingen a lid in mayne HEIMATEN, dort blien di royzn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>un ven m'iz gezesn baym baym UNK, ze'mir gezungen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts562" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>a daytsh lid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
