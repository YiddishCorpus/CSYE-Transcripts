			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a441" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>m'hot gegebn in esn bron.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>un dos gleybt keyner nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>DA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a444" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>m'hot undz vi m'zogt ineveynik geharget.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts722" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>DA UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>zoln lebn biz hundert tsvontsik yor. ikh hob tsvey zinen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a447" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts731">
				<ANNOTATION_VALUE>ikh hob finef eyniklekh, tsvey shnurn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a449" TIME_SLOT_REF1="ts730" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>geloybt tsu got. ales iz gut, normal.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a450" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts737">
				<ANNOTATION_VALUE>UNK zog ikh dikh, bay di ungarn nokh, het er geven antisemitizm farshidene.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts738" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>nor &lt;Posyovaner&gt; dos iz shoyn geven finef un fertisker yor. demolts nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>demolts momental, zenen di goyim velkhe zenen geblibn, zenen zey geven gants kemayse. z- nu m'hot gezen az eh undz ze'mir ale naket un borves gekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a455" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>zey hobn tsugenumen di yidishe zakhn ales.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a456" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>keyner hot fun er- keyner hot gornisht bakumen tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a457" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>nu iz avade iz geven, far zey iz geven gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a458" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts751">
				<ANNOTATION_VALUE>zey zeen ven di yidn's eh stradayen, demolts iz far zey gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a461" TIME_SLOT_REF1="ts750" TIME_SLOT_REF2="ts753">
				<ANNOTATION_VALUE>nu demolts eh zenen iz nisht geven keyn shum in- eh deys az vos heyst eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a463" TIME_SLOT_REF1="ts752" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>dey mentshn velkhe zenen geven fashistn, dey hot men opgehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a465" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>un dey di iberike proste mentshn zenen geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a466" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>undz ho'mir nisht geshpirt keyn shum min antisemitshaft. gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a469" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>nokh eh nokh dem makht zikh alts. alts hot men nisht lib keyn yid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a470" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>ikh undz ho'mir gearbet, undz hobn gehat groys koved bay mentshn. undz hot men uvazhayet, nu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a472" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>keyn shum, ze'mir yidn, ze'mir antlofn oyf Erets.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a473" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a474" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>mayn man iz geven krank. er hot shoyn gehat dort tsveyte grupe INVALIDNOST.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a476" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>er hot shoyn nisht gearbet. un er hot gezogt az er geyt nisht oyf Izrael. a kranker mentsh hot nisht vos tsu ton in Izrael.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a478" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts774">
				<ANNOTATION_VALUE>undz ho'mir im gezogt, kuk aher, undz ze'mir shoyn nisht, s'shoyn nisht keyn kleyne kinder, der elterer zun iz shoyn geven a khasene gehater</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a479" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>der yingerer iz geven mit undz, eh ikh vel arbetn, er vet arbetn, m'vet fardinen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a481" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
				<ANNOTATION_VALUE>m'vet lebn. vayle m'hot zikh ibergeshribn mit khaveyrim, mit yedn eynem, hobn gezogt, YOU KNOW, s'shver dos lebn, ober ver vi azoy, s'nemt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a482" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>undz ze'mir gekumen aher, undz ho'mir gebrengt. deys ales ales ho'mir undz gebrengt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a483" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>undz ho'mir gornisht nisht POCHTI do gekoyft UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a484" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>nor dem televizye, di lekter TOVAREs.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a485" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>oder deys iz nisht azoy vi azoy undz ho'mir geklert.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a486" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>mir iz geven do zeyer shver tsvey yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a487" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>er hot nisht bakumen keyn nisht keyn pensye, nisht gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a489" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>a yor hot undz der Sakhnut geholfn, bifl er hot gekent, arbetn hot er nisht gekent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a491" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>ikh bin avek arbetn vu ikh hob gekent oykhet. ikh bin geven in a restorant hob ikh gearbet, ikh hob gevashn geshir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a492" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>un eh kinder hob ikh TAPELET, nokh dem hob ikh im nisht gevolt iberlozn aleyn, spn shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a494" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>UNK ikh hob nisht gevolt iberlozn aleyn, bin ikh genumen kinder TAPELET.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a495" TIME_SLOT_REF1="ts799" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>un eh do bin ikh ikh bin geven alts mit im er zol im nisht er iz arumgegangen tsu bislekh, oder er iz geven zeyer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
