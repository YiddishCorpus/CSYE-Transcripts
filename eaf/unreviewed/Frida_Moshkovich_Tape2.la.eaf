		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>in lager hot keyner nisht gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
