		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a872" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>ikh shik dikh avek, on alem, darfst gornisht batsoln. hobn zelbn plats un zelbe eltern, vest krigstu ales.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a640" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
				<ANNOTATION_VALUE>vest nemen lernen dortn, far geshvoyrn hob ikh dokh shoyn gehat geshvoyrn, ales iz fertik. hot der konsulat mir gegebn a yor keyn Yisroel un kumen tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a642" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
				<ANNOTATION_VALUE>hob ikh gezogt ikh bin READY. hob ikh gehat di peklekh fertik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a644" TIME_SLOT_REF1="ts250" TIME_SLOT_REF2="ts252">
				<ANNOTATION_VALUE>tsvey tog shpeter iz gekumen a TRUCK, hot mikh avekgefirt in a vald arayn. dortn iz gevezn aza yu- a yidisher lager, dortn hinter Mondri- hinter MUNICH,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a645" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>hob ikh dortn arayngenumen un dan nakher m'hot gemakht a transport, ikh veys dort efsher a fuftsik khevre hot men aroyfgeleygt undz oyf a T- oyf a oyto MASA, UNK ikh veys nisht, a a TRUCK,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a873" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>un m'hot undz arayngefirt keyn Marsel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a646" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>keyn Frankraykh. m'hot undz arayngefirt keyn Frankraykh, dortn iz shoyn geven a lager fun yidn vos fun iberal ver s'geforn keyn Yisroel hot men nokh do gezamlt m'zol makhn transport.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a647" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>un dos iz es. m'iz arayngeforn keyn Marsel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a648" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>un ikh bin dortn gezisn efsher tsvey vokhn, biz m'hot tsugegreyt m'hot tsugegreyt a shif, un di shif hot geheysn Pan York,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a649" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>un dos iz gevezn aza shifl, aza balye, m'hot undz arayngezetst un m'hot undz geshift arayn keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a651" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>eh vi dos vi s'geven iz geven alts in tsvey toyznt eh boyes mit meydlekh. iz er geven dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a653" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>un m'hot undz arayngefirt, s'geven yene shif, a shif vos m'hot gefirt a mol ferd, khazeyrim, s'nisht vikhtik. vu m'iz gelegn iz men gelegn, s'geven gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a654" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>m'hot nisht gezukht keyn luksus, m'hot nisht gezukht keyn bakvemlekhkeytn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a655" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>m'hot nor gezukht arayntsuforn keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a656" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>m'iz ongekumen keyn Yisroel, gedenk ikh vi haynt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a658" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>hot men undz gelozt shteyn in mitn dem vaser, far der port.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a659" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>hot men undz oyfgezungen di Hatikva vos m'hot gezungen in Poyln,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a660" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>LASHUV LAARETZ, nu un do zingt men andersh. un nakher di shif tsugeforn hot men gezungen di naye Hatikva.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a661" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>demolts hot men undz oysgelandet, un m'hot undz bald avekgefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a663" TIME_SLOT_REF1="ts286" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>avekgefirt, yo, UNK bald avekgefirt, tsevorfn in a in a KIBBUTZ, shnel tsevorfn in a KIBBUTZ,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a874" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>az m'hot undz arayngevorfn in a KIBBUTZ arayn, un bald tsu morgns iz men gegangen m'hot tsamgenumen di gantse khevre,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a875" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>un m'hot undz gegebn a fir arayn in a MACHANE fun di TZAVA. bay Etlit, Atlit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a666" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts295">
				<ANNOTATION_VALUE>m'hot undz arayngefirt keyn Atlit,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a876" TIME_SLOT_REF1="ts296" TIME_SLOT_REF2="ts299">
				<ANNOTATION_VALUE>ver gedenkt dates?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a877" TIME_SLOT_REF1="ts300" TIME_SLOT_REF2="ts303">
				<ANNOTATION_VALUE>akht un fertsik, akht un fertsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a667" TIME_SLOT_REF1="ts304" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>no no, zumer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a668" TIME_SLOT_REF1="ts308" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>ya. hot men undz arayngefirt dortn keyn Atlit, un ikh bin arayngegangen in lager arayn un m'hot undz gehaltn bizkele m'hot undz genumen far nakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a669" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts313">
				<ANNOTATION_VALUE>hot men undz aroysgefirt in a PARDES, un m'hot undz gelernt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a671" TIME_SLOT_REF1="ts312" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>shisn. ver hot gehaltn a biks in der hant? zog ikh, ver hot gehaltn a biks in der hant? ver hot gehat a biks? ver veyst vos a biks?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a672" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>m'hot undz gelernt vi m'lodnt op, vi m'shist un vi m'shist, un vi m'tsilevet, un hin aher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a878" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts319">
				<ANNOTATION_VALUE>far nakht vet men tseleven, arayn in azan, oyfhengen aza shildl oyf a boym in a PARDES un m'vet shisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a673" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>un demolts bin ikh shoyn gevezn alt eh zibetsn, akhtsn yor, nayntsn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a674" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>un ikh bin dan arayngegangen, ikh hob ongehoybn tsu shisn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a675" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>s'ge- hot er gezogt, o! a guter shiser! dos ershte mol ikh hob gegebn a shos. zogt er, bist shoyn gut!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a676" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>tsu morgns, m'iz gegangen, m'hot undz ongetun di kleyder, gegebn naye kleyder, a khaki kleyder, un gegebn a biksl, eynem a sten, eyner a biks,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a677" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>un m'hot gezogt az m'geyt aroys bay nakht oyfn front arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a679" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts333">
				<ANNOTATION_VALUE>yo, un bay tog hot men geshvoyrn. m'hot geshvoyrn far MEDINAT YISRAEL,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a681" TIME_SLOT_REF1="ts332" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>barn gebn dos gever, hot men geshvoyrn az m'vet zayn getray un azoy vayter. m'iz aroysgegangen kemfn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a683" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>di nakht, di zelbe nakht m'iz aroysgegangen, iz gefaln bald tsvontsik tsvontsik khevre fun undz, fun di naye, geharget gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a684" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>ikh tsu morgns, ikh gey nisht mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a686" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
				<ANNOTATION_VALUE>vos heyst, du geyst nisht? kumst UNK farkert? zogt er, ikh gey nisht mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a687" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>vos heyst du geyst nisht mer?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a688" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>ikh gey nisht mer in front arayn. ikh nem nisht mer keyn biks. kenst mir gebn a mashin-GUN,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a691" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
				<ANNOTATION_VALUE>azoy hert di verter, kenst mir gebn a mashin-GUN, ikh bin gekumen nisht oyf keyn khasene, ikh bin gekumen in a milkhome arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a692" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>un ikh veys az ikh bin gekumen kemfn, ikh hob oyf dem untergeshribn az ikh kum.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a694" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
				<ANNOTATION_VALUE>kenst mir gebn a mashin-GUN, ikh blayb, un az nisht farloz ikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a695" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
				<ANNOTATION_VALUE>zogt er, zog ikh, tsu vemen ken ikh redn? zogt er, muzt redn, zogt er, tsu eynem fun di greste, zogt er. vemen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a696" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>muzt redn tsum SAMAL, SAMAL tsum KATZIN, biz vest ongekumen tsu dem tsu dem tsum gen- general.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a697" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
				<ANNOTATION_VALUE>un s'ongekumen biz tsum general.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a698" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>ikh hob gezogt, ikh gey nisht mer. ikh gey nisht esn, ikh gey nisht trinken, ikh vil a mashin-GUN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a699" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>ver iz geven der general? Yigal Alon.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a700" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>ikh zol aranysh- m'zol araynfirn dem foygl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a701" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>nemt men mikh, zogt men, kenst makhn a salut? zog ikh, ikh vel makhn vi azoy ikh ken.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a702" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>s'den do a salut shoyn oyf eh oyf yidish? eyner vi ikh vel veln vel ikh makhn, oyf english, oyf poylish, oyf poylish, vi azoy ikh vel veln vel ikh makhn a salut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a703" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>shtel dikh glaykh un makh a salut. m'hot mikh epes gelernt? UNK shisn, a koyl UNK oysgeshosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a704" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>geb ikh a kum arayn, shtel dikh glaykh, un gemakhn a salut, makht er mir oykhet. zogt er, SHEV.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a705" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>zog ikh, "ANI YACHOL LEDABER IVRIT, AVAL LO HAIVRIT KEMO SHEATA."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a707" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>ikh hob dokh gelernt gemore, ikh hob dokh gelernt rashes, ikh hob dokh gelernt toysfes, ikh hob dokh gelernt ales, hob, loshn koydesh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a708" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>zog ikh, "ikh ken loshn koydesh, ober du redst a moderne ivrit, un dayn redn shnel ken ikh nisht farshteyn oykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a879" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>oyb azoy muztu nokh tsu mir redn yidish, vayl in a kurtser tsayt vel ikh mikh oysglaykhn, ikh vel redn mit dir di zelbe."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a709" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>zogt er, yidish. vos iz dayn farlang? zog ikh, "ikh ken nisht kemfn mit keyn biks.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a710" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>ikh bin nisht gekumen tsu keyn khasene, ikh bin gekumen tsu a milkhome, un ikh vil kemfn. kenst mir geyn a mashin-GUN?" get er mikh a kuk on,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a711" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>zogt er, "yingele, vi zol ikh dir nemen shoyn a mashin-GUN?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a712" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>zog ikh, "dos iz an armey on a mashin-GUN?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>ikh darf hobn a mashin-GUN, gey ikh aroys in der milkhome arayn oyf yedn kraft un yedn, vos s'vet nor nisht fo-"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>zogt er, "ikh vel TRYen alts tsu tun. yetst nem tsu vos m'git dir. du bist bay mir oyf der list. azelkhe darf ikh a sakh vi dir."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>un klap mir di pleytse arayn, un zay a voyler BOY, un nem op ales, ikh vel dar dir da- ikh vel far dir daygen. tsu morgns hot er gebrengt a mashin-GUN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a718" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts399">
				<ANNOTATION_VALUE>un get er a shik tsu a SAMAL, un er zol mir gebn shnel a kurs. vi azoy on tsu lodenen un vi oys tsu lodenen, un vi oyftsu- oyftsumakhn, vi tsu tsenemen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a880" TIME_SLOT_REF1="ts398" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>un ikh gib mikh a lern oys, in tsvey sho hob ikh gekent di toyre. oysgelernt ales. un ikh hob dos alts gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a719" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>un ikh hob gekemft. un ikh hob gekrign eyn medal hob ikh gekrign direkt fun Ben-Guryon.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>vos ikh bin nokh nisht gevezn keyn BAL-DARGA, ikh hob nokh demolts nisht gehat keyn ranges.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>m'iz gegangen arayn far EGYPT, hot men gehat tsu kemfn, iz geven dray groyse EMDOT fun di araber, fun di mitsrim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a725" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>un m'hot dos gedorfn farnemen. az m'farnemt dos iz der veg fray.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a727" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>un zey hobn oyf undz geshosn, m'iz gegangen hobn zey gegebn aza fayer, ir hert, az ikh bin arayn oyf a feld,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a728" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>dos heyst SHETACH MET, zey shteyen oyfn barg, un zey kenen undz zen, bay nakht, ober ven m'shist</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a730" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>zey makhn op, zey hobn oyfgemakht aza min fayer az m'hot gekent zen di mentshn oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a732" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>zey hobn gevorfn azelkhe vos heyst MEVAYER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a733" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>un do ze ikh az m'kumt arayn in mitn feld un di mentshn loyfn tsurik. un di ofitsirn shrayen KADIMA!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a734" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts421">
				<ANNOTATION_VALUE>un m'hakt. vifl s'vet blaybn, tsu tsu der vant. az ikh loyf tsu der vant, er shteyt in der heykh, ken nisht, er ken mir shisn nor vi lang du shteyst dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a736" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts425">
				<ANNOTATION_VALUE>he?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a737" TIME_SLOT_REF1="ts426" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>ikh hob nor gekemft mit di egipter. nor mit di egipter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a739" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>un ikh heyb mikh oyf un ikh gib a a loyf aroys, ir hert, fun di shure aroys, un gib zikh a ruk avek in der linker zayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a740" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts433">
				<ANNOTATION_VALUE>un ikh loyf tsu tsu der vant, tsum barg, un ikh loyf aroys oyfn barg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a743" TIME_SLOT_REF1="ts432" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>un der ofitsir shrayt, Pinek! ANI LO SHOMEA OTCHA. e- der eyntsiker mashin-GUN, er hert nisht er hert nisht mayn mashin arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a744" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>un ikh tor nisht redn. ikh loyf aroys oyfn barg, un di mashin-GUNS fun di araber klapn do oyf di khevre. zey hobn gehat di di Vikers, englisher mashinen. azoy hot es geshosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a745" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>un ikh gib mikh a khap aroyf oyfn barg un ikh shtey shoyn in di zelbe DARGA mit zey. ikh hob nor gehat eyn tash mit vos ikh bin gegangen, ikh hob gehat MISPAR SHTAYIM a tsveyter vos hot getrogn dos kestl koyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a746" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>ikh hob im oykh ibergelozt. ikh trog nor a tashme VRAZHE,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a747" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>dos argste darf zayn bay mir eyn tashme, a tashme fun hundert koyln. un ikh gib mir a khap aroyf oyfn barg aroyf,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a748" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>un ikh gib a shtel avek dem mashin-GUN un ikh gib a leyg arayn di tashme, un dos harts makht &lt;yoyre&gt;, zog ikh, gotenyu, ikh zol nor matsliekh zayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a881" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>un ikh shtey direkt tsu dem KIVUN fun di araber, un ikh makh oyf di tashme un ikh shekht avek ale. ale opgehakt di kep.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a750" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>ale di gantse tashme arayn in dem bunker.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a751" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>finef shtik opgehakt vos di hobn gemakht toyt far undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a752" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>un in dem shray ikh, Mendi! tsum ofitsir, er zol aroyf. vu, EYFA ATA? zog ikh, ANI LEMALA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a754" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>un krikht aroyf mit di khevre, un s'gevorn shtil. un kumt tsu tsu mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a756" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>zog ikh, yetst gey tsu mitn FLASHLIGHT, un ze tsi s'nokh do emetser lebedik dortn, efsher iz nokh emetser dortn geblibn, az du vest tsukumen vet er dikh avek shisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a757" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>un geyt mit di FLASHLIGHT un er CHECKt arum, zogt er, host ale opgeha- ale opgehakt mit di kep. ale zenen toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a759" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>un m'hot farnumen dem gantsn EMDA, tsu morgns, m'hot gehat toyte genug,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a761" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>un tsu morgns iz gekumen Ben-Guryon undz VISITn, m'hot farnumen dos ales,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a763" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>un m'shtelt undz oys. un der der ofitsir get iber far Ben-Guryon, dos iz der boytshik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a764" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a765" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>un Yigal Alon iz mir gekumen shpeter tsu morgns hot mir gedankt, zogt er, ikh hob gevust, zogt er, du fest zayn mayn mayn bester khaver, mayn UNK. un er hot mikh geshikt oyf kursn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a766" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>ikh bin gegangen oyf SAM- koydem kol UNK iz mem KAF,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a767" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>SAMAR, RAV SAMAL, RASAB, RASAR, un dan nakher bay NINETEEN SIXTY SEVEN, bin ikh shoyn gevorn ofitsir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a769" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts475">
				<ANNOTATION_VALUE>un ongefirt mayn gantse ar- armey bay Aza.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a772" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts479">
				<ANNOTATION_VALUE>ikh bin gevezn koydem kol CHEYL RAGLI,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a773" TIME_SLOT_REF1="ts480" TIME_SLOT_REF2="ts483">
				<ANNOTATION_VALUE>un nakher bin ikh aribergegangen tsu tank dos, tanken, tsu ZAKHALIN, ir veyst ZAKHALIN, halb tanken.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a774" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>in di milkhome bay SIXTY SEVEN vos ikh hob ongefirt bin ikh gegangen mit ZACHALIN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a882" TIME_SLOT_REF1="ts488" TIME_SLOT_REF2="ts491">
				<ANNOTATION_VALUE>ikh bin geven in d- ikh bin geven in dray milkhomes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a883" TIME_SLOT_REF1="ts492" TIME_SLOT_REF2="ts495">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a775" TIME_SLOT_REF1="ts496" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>ya, ober nisht keyn STEADY, ikh bin kimat mit di kursn iz oysgekumen kimat vi in STEADY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a777" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>ikh bin aheymgegangen hot men tsurikgeshikt vayter oyf a kurs, ikh bin aheymgegangen hot men tsurikgeshikt vayter oyf a kurs.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a778" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>ober alts in eynem arayn bin ikh geven tsvontsik yor in der armey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a779" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts505">
				<ANNOTATION_VALUE>tsvontsik yor in d- in eh in in Yisroel un kimat di gantse tsayt in der armey. ikh bin geven a khoydesh in der heym, un a khoydesh in TZAVA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a781" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>ikh hob gehat andere basheftungen. ikh hob gehat farshidene farsheftungen in Yisroel, avade hob ikh gehat farshidene farshe- ober in vos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a782" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts511">
				<ANNOTATION_VALUE>dos iz gevezn mayn ales. ikh bin gevezn tsufridn, ikh hob kha- yo, un ikh hob khasene gehat in Yisroel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a783" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>keyn Poyln?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a784" TIME_SLOT_REF1="ts518" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>ikh bin gef- ikh bin geforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a785" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts523">
				<ANNOTATION_VALUE>ikh hob aroysgenumen a aza AWIADECTWO, aza list, fun di amerikaner un fun di rusn az ikh vil brengen mayn FAMILY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a884" TIME_SLOT_REF1="ts522" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>in der tsvishn der tsayt hob ikh gehert</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a885" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>hob o- iz a mentsh ongekumen fun Rusland iz gekumen arayn keyn Daytshland, hot mir opgegebn a grus</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a886" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>az do do do eyner a Pinek Kreyndels</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a887" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>az du host a bruder vos er iz gekumen fun Rusland. dos iz der bruder vos iz avek keyn Rusland, hot er gezogt tsum tatn er fort avek,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a786" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>er iz gekumen tsurik. un er hot vayter gevoyer gevorn vayter shoyn in Poyln az ikh leb.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a789" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>un ven er iz avek keyn Rusland bin ikh geven azoy. un az er hot mir bafoyln nokh eyenemen az er iz gekumen un zukht mikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a790" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>ze'mir gekumen iz ongekumen tsu mir keyn Minkhn a mentsh zogn mir du host a bruder, er vart oyf dir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a791" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts539">
				<ANNOTATION_VALUE>un for ahin im nemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a792" TIME_SLOT_REF1="ts540" TIME_SLOT_REF2="ts543">
				<ANNOTATION_VALUE>in Min- un ikh hob, vu dem bruder? in Poyln. er hot nisht gekont ariberforn keyn Daytshland. er iz gezisn in Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a796" TIME_SLOT_REF1="ts544" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>er iz geblibn nisht in Patov, in Patov hot men geharget. di di A.K. di bande hobn gehat yidn nokh der milkhome. iz er geblibn in Tsozemir, in Sandormierzh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a797" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>mit zayne FRIEND, er hot gehat FRIEND, iz er geblibn in Sandormierzh. dortn iz geven a bisl mer BEZPIECZNE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a888" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts551">
				<ANNOTATION_VALUE>mer zikhere vi in Apt. iz er geblibn dortn, un ikh heyb zikh oyf un ikh nem aroys a papir fun di amerikaner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a889" TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>un ikh nem aroys a papir ALSO fun danet fun eh fun di rusn, zey hobn nokh gearbet tsuzamen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a890" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>az ikh ken forn brengen mayn FAMILY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a891" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>un ikh for arayn keyn Poyln, kum ikh arayn keyn keyn Apt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a892" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>ikh kum arayn keyn Apt, zogt men mir UNK du host do a bruder, vayl s'geven a por apter yidn shoyn bafrayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a893" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>un m'hot gevoynt in eyn in eyn hoyz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a894" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts563">
				<ANNOTATION_VALUE>vu iz der bruder? in Sandormierzh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a798" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>ven ikh bin arayngekumen keyn Apt, dentsmol, nokh der bafrayung, demolts hob ikh getrofn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a799" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>s'gevezn mer, dos iz dokh geven bald in der BEGINNING. ven ikh bin arayngeforn keyn Apt hob ikh getrofn, demolts in dem hoyz vu ikh bin gevezn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a800" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>iz gevezn zeks oder akht yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a801" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>fun der gantser shtot? s'nisht geblibn keyn sakh. s'hot gekent efsher efsher hot gehat blaybn a hundert BOYS,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a802" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts579">
				<ANNOTATION_VALUE>vos zenen in Toronto a por yetst, do dortn, a hundert mentshn hot gekent blaybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a804" TIME_SLOT_REF1="ts580" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>vos ikh hob gekent, khaveyrim, in mayne yorn, azoy vayter, ya, ya, vos mir zenen nokh yetst oykh FRIEND.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a805" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts585">
				<ANNOTATION_VALUE>ikh hob gehat gute FRIEND vos m'iz geven in shul tsuzamen un oykh in lager tsuzamen un zey voynen yetst in Toronto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a806" TIME_SLOT_REF1="ts586" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a807" TIME_SLOT_REF1="ts590" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>ikh hob im getrofn in Sandormierzh, un dan bin ikh gegangen ikh hob im aribergefirt un tsurik keyn Daytshland tsu mir aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a808" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>ober ikh hob gehat PROBLEMS mit di rusn, zey hobn mikh geshlogn, geharget, far vos ikh fir adurkh mentshn bay Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a810" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>fun Poyln arayntsuforn keyn Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a811" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>ikh fir fir mentshn. un fun Tshekhn forn arayn keyn Daytshland. dos heyst ikh nem aroys, fun der komunistisher zayt nem ikh aroys, ikh hob nisht bloyz genumen dem bruder, der bruder hot shoyn gehat geheyrat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a812" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>hob ikh genumen dem bruder mit der bruder, un der bruder hot gezogt ikh hob do a gus- a gutn FRIEND Tup halt er zikh mit un er vil im oykh mitnemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a895" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>hob ikh im oykh mitgenumen, shteyt FAMILY. FAMILY iz nisht geven keyn nemen vifl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a813" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>nu hobn zikh di rus, der der vakh-man bay der grenets hot zikh ongekhapt in mir un er vil mir tseraysn di papir un er hot zikh mit mir tseshlogn, ikh hob im geshlogn, er hot mikh geshlogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a896" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>der bruder iz arayn tsum komendatur, zogt er, zayt ven, zogt er, geb a kuk do shlogt men tsivile mentshn? iz aroysgegangen der komendatur,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a897" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts609">
				<ANNOTATION_VALUE>un er iz tsugelofn tsu dem CHAYAL, er hot im gekhapt er hot im arayngefirt, ikh hob im tseklapt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a898" TIME_SLOT_REF1="ts608" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>fun mir iz gegangen blut, fun im iz gegangen blut, hot er mikh geheysn opvishn, un im hot er aropgelozt a paker un aropgelozt in keler arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a899" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>dem z- dem SOLDIER. un ikh hob di ale mentshn adurkhgefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a814" TIME_SLOT_REF1="ts614" TIME_SLOT_REF2="ts616">
				<ANNOTATION_VALUE>aribergefirt arayn keyn Daytshland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a815" TIME_SLOT_REF1="ts618" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>ya,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a816" TIME_SLOT_REF1="ts622" TIME_SLOT_REF2="ts625">
				<ANNOTATION_VALUE>nokh nokh di milkhome nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a817" TIME_SLOT_REF1="ts626" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>in der tsayt iz epes andersh geven. in der tsayt fun der milkhome iz hot men gedankt got az m'hot tsu esn. ober nokh der milkhome hob ikh oyfgegebn oykh oyfgegebn di RELIGIOUS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a818" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>oyfgegebn. ikh hob gezogt dos alts iz gornisht, eh OK vi eyner nemt dos op.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a819" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
				<ANNOTATION_VALUE>az m'zol zogn, az ikh hob gekent aroysgeyn fun vald ken eyner zog- oystaytshn got hot mikh gefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a820" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
				<ANNOTATION_VALUE>ikh bin gelofn a gantsn tog in vald ven m'hot mikh geshosn, ikh hob nisht gezen keyn ek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a821" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts636">
				<ANNOTATION_VALUE>un tsu morgns in tsayt in tsen minut hob ikh getrofn aroystsugeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a822" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts639">
				<ANNOTATION_VALUE>treft op a a yid, a khosid, vet er es ontrefn un zogn got hot im gefirt. zol zayn a got hot im gefirt, dos iz gevezn mayn UNK. ikh veys nisht vos iz gevezn. ikh bin bald aroys. tsu morgns.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a824" TIME_SLOT_REF1="ts640" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>neyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a825" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>ikh bin gegangen a bisl in a shule in der Ort shule, un dan nakher hob ikh genumen ongehoybn arbetn far mir tsu makhn a por dolar, vayl m'hot dokh nisht gekent lebn ales nor vos der Unra gibt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a826" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>hob ikh genumen a bisl arbetn, firn mit skhoyre, gearbet mit skhoyre, gevorn gehandlt, un THAT'S ALL. biz ikh bin avekgeforn nakher keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a827" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>ikh bin arayn in der armey arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a828" TIME_SLOT_REF1="ts654" TIME_SLOT_REF2="ts657">
				<ANNOTATION_VALUE>ikh hob ge- ikh hob ge- ikh hob geheyrat in Yisroel, ikh hob bakent mayn vayb dortn, un ikh hob ikh hob dray kinder geboyrn dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a830" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>ikh hob bagegnt mayn froy iz geven durkh a tsufal eh oyf a khasene, ikh bin geven oyf a khasene als als &lt;sarver&gt;, bin ikh geven tsu oyf a khasene, ikh hob zi bakent, un m'hot zikh bakent fun demolts on hot men zikh genumen trefn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a831" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts663">
				<ANNOTATION_VALUE>un m'hot geheyrat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a832" TIME_SLOT_REF1="ts664" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>Lea.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a833" TIME_SLOT_REF1="ts668" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>Shmueli, Shmueli.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a834" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>dos heyst shoyn dos iz a ivrit nomen. der foter fun der heym hot geheysn Shmuali, panye Shmuali. un nu Shmuali oyf ivrit hot men es ibergearbet oyf Shmueli.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a835" TIME_SLOT_REF1="ts674" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>mayn vayb iz gekumen mit tsvey yor alt keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a837" TIME_SLOT_REF1="ts680" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>zey zenen gekumen, der foter iz avek nakher der foter iz avek eh keyn Ungarn, fun Ungarn iz er arayn keyn Rumenye un er hot dortn geheyrat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a838" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>un er hot dortn gehat di kinder, nakher iz er aroyf eh arayngeforn. dos iz nokh far der milkhome. zey zenen nisht geven, der foter hot nisht gevust fun keyn milkhome.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a839" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>zey hobn nokh gevoynt dortn efsher in fuftsn tsvontsik yor far der milkhome.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a840" TIME_SLOT_REF1="ts688" TIME_SLOT_REF2="ts691">
				<ANNOTATION_VALUE>in Rumenye nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a842" TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts694">
