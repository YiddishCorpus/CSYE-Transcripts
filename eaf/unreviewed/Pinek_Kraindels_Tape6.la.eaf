			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a843" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>zi iz arayngekumen, zi iz alt geven tsvey yor, keyn Yisroel.</ANNOTATION_VALUE>
