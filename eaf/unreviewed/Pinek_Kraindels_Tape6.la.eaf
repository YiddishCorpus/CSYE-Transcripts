		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a845" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>m'hot mikh ongetun a brandzelet, m'hot mir gegebn a zeyger,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a846" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>un ongetun a brandzelet oyf der hant, a gevorn a gantser amerikaner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
