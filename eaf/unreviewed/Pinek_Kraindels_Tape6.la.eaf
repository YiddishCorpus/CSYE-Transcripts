		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a546" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>ikh bin arayngekumen do tsu di mentshn un zey hobn mikh oysbahaltn do biz yetst, biz ir zent gekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a547" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>vos far a shprakh redstu? redstu, zogt er, er hot geredt tsu mir daytsh. zog ikh red daytsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a550" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>vos nokh redstu? zog ikh, du redst yidish? zog ikh, yo. red tsu mir in yidish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a551" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>hob ikh gezogt yidish. ikh bin arayngekumen do tsu zey. zey hobn mikh oysbahaltn un zenen geven zeyer gut tsu mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a552" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>zogt er, ikh bin oykh a yid. hob ikh shoyn ongehoybn tsu veynen. un er hot geveynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a555" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
				<ANNOTATION_VALUE>zogt er, "yingele, ales vet zayn in ordenung. du kumst yetst mit mir."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a556" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>zogt er tsu dem balbos, er nemt mikh tsu. zogn zey, neyn. zey hobn mikh oysbahaltn, mir viln er zol do blaybn bay undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a557" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts27">
				<ANNOTATION_VALUE>hot er gebetn, er ken nisht blaybn yetst. di ale velder zenen ful mit S.S., s'nokh nisht CLEAR. er darf kumen mit undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a560" TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>mir veln im ophitn vet dir nisht fargesn, er vet tsu dir kumen. ikh bin take gekumen yedes mol, VISITn, vet er kumen VISITN, er vet tsu aykh kumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
