		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a844" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>in vald, m'hot mikh ongetun amerikaner kleyder, mit shikh, mit alem. yeder eyner hot mir gegebn a por dolar in tash arayn, mit a tayster.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
