				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a564" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>m'hot mikh ongetun amerikaner kleyder. ikh hob gebetn dos ershte bayn im, gib mir a por shikh. zogt er, "yingele, ales vestu krign, kum mit mir."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a565" TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts41">
				<ANNOTATION_VALUE>eh demolts iz geven a date vos Minkhn iz nokh nisht geven genumen. Minkhn iz nokh geven di daytshn.</ANNOTATION_VALUE>
