		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a544" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>zog ikh, ikh bin, zog ikh, a JEWISH BOY fun POLAND.</ANNOTATION_VALUE>
