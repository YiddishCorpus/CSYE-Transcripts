				<ANNOTATION_VALUE>er veyst az du host im opgetun a guts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a562" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>un er hot mikh genumen avek in vald arayn. Dzhek! Mek! un genumen rufn ale genereler, ALL groyse ofitsirn, yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
