		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts79">
				<ANNOTATION_VALUE>zogt zi mir der ofitsir, "morgn darf vern Minkhn genumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts78" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>morgn vet faln Minkhn," zogt er, vet men araynforn in shtot arayn, ikh vel dikh arayngebn, zogt er, in a plats,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a580" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>vu du vest dikh erhoyln dikh. ikh hob gevoygn demolts draysik kilo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>un azoy iz es gevezn, tsu morgns, un ikh bin geven mit zey, m'hot mir gegebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a582" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>eh vos tsu esn nisht keyn SPECIAL, vayl vayl a sakh zenen avekgegangen fun esn bald toyt. ober m'hot mir gege- gegebn nor vos nor tsu derkhapn dos harts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a583" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>zogt er, "morgn vestu ales visn vos du darfst esn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a584" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts91">
				<ANNOTATION_VALUE>tsu morgns tsvey a zeyger kumt a PHONE CALL, Minkhn iz gevorn genumen, durkh di amerikaner, bafrayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a847" TIME_SLOT_REF1="ts90" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>iz aroysgegangen di SHAYAROT, aroysgeforn ale di tanken, ikh bin geforn mit dem ofitsir bay im in Dzhip</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a848" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>biz m'iz arayngekumen keyn Minkhn. m'iz arayngekumen keyn Minkhn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a849" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>iz er gegangen zukhn dem plats vu arayntsugebn mikh, un er hot getrofn dem plats, vayl dortn zenen arayngekumen oykhet amerikaner tsu erhoyln zikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a850" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
				<ANNOTATION_VALUE>vos zey hobn farloyrn a sakh vog un azoy vayter, zenen geven opgeshvakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a851" TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>zenen oykh dortn arayngekumen. ikh geb a kum arum, un get a kum zitsn mit dem firer fun der HOSPITAL, iz oykhet dortn, geyt er a f- a fartekh, ver veyst dokh ver dos iz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a586" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>zogt er, PAPER, PAPER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a587" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>zogt er mir der amerikaner tsu im, zog nisht keyn PAPER, er iz nisht keyn amerikaner. ikh bin gegangen ongetun amerikaner kleyder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a852" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
				<ANNOTATION_VALUE>zogt er iz a a yid fun Poyln vos iz bafrayt fun Oyshvits. mir hobn im bafrayt. mir hobn im getrofn in zayn PASIAK mit alem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
