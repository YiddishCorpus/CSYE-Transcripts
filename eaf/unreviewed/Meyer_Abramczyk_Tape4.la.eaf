			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a596" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>az ikh vel shtarbn, ikh vel arbetn vi lang ikh vel konen, ober nor zogn nor,</ANNOTATION_VALUE>
