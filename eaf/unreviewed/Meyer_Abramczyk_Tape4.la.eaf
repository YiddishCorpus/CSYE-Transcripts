				<ANNOTATION_VALUE>s'geven mentshn vos zey hobn gearbet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a598" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>un zey hobn mit di shoyvl, veyst dokh vos s'iz, hobn zey untergeshtelt azoy, der kapo hot nisht do gevezn, oder ver andersh s'geven, zenen zey geshtanen azoy. az der kapo iz gekumen hobn zey ongehoybn tsu grabn.</ANNOTATION_VALUE>
