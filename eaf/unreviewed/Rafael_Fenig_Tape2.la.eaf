			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a549" TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts980">
				<ANNOTATION_VALUE>&lt;okh, do- o, do, o.&gt; &lt;un der, ha&gt;klal, &lt;un&gt; der poylisher politsyant nemt undz arayn un firt undz arayn tsu der GESTAPO.</ANNOTATION_VALUE>
