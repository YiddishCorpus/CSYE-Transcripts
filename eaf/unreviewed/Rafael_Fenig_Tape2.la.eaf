				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a552" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>UNK un &lt;shoyn&gt;. un mit eyn mol heybt zikh oyf &lt;der, s'iz epes&gt; gekumen a, a VOICE fun oyvn, a kol,</ANNOTATION_VALUE>
