		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>un di r- rusishe heftl- uh, vos zenen gezitsn dort, di rusn, SOLDIERS mit &lt;d-&gt;...</ANNOTATION_VALUE>
