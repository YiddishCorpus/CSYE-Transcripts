			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>avekgenumen fun di d-... un, un dervayl iz er geshtanen, der tshekhisher SOLDIER, der SERGEANT, a SERGEANT gevezn,</ANNOTATION_VALUE>
