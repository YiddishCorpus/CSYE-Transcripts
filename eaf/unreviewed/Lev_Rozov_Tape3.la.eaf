		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>ersht me hot undz ongehoybn bombirn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
