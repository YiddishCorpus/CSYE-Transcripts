		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a983" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>oder s'iz dokh nit keyn lebn.</ANNOTATION_VALUE>
