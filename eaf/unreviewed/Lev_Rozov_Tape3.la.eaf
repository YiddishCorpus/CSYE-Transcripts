		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a957" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
				<ANNOTATION_VALUE>un zi iz geven di bukhhalter; zi iz geven a mentsh oykh mit a kop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>zog ikh, "ikh veys gornit vi me..." uh, zogt zi, "kum, ikh'l geyn mit aykh."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
