		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>ikh hob gehat rekht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts117">
				<ANNOTATION_VALUE>ikh bin avekgegangen. zaynen mir arayng- i-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
