			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>a shtot vos iz gelegn a shpitol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
