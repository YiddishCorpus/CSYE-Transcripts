		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>un zaynen mir shoyn gehat, bay undz iz geven a dokter a rusisher, un s'iz geven bay mir</ANNOTATION_VALUE>
