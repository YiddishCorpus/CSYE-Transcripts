		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>ale shrayen: bay dem felt a fus, bay dem felt a hant. m'shrayt, me lyaremt.</ANNOTATION_VALUE>
