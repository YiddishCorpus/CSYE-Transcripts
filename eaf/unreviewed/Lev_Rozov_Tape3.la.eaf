			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a962" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>nor dan in t&lt;UNK&gt;. its- itster vel ikh aykh dertseyln,</ANNOTATION_VALUE>
