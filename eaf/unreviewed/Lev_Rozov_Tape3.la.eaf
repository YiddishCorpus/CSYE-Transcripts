		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>ikh hob shoyn durkhgemakht a lebn. ikh hob shoyn, ikh bin dokh, shoyn, shoyn...</ANNOTATION_VALUE>
