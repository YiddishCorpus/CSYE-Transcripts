		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a954" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
				<ANNOTATION_VALUE>ts- uh, t- uh, tsvey tekhter</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
