		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>hot men bald gebrakht.... d&lt;UNK&gt; gedoyert nokh efsher a tog...</ANNOTATION_VALUE>
