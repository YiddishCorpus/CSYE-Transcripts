			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1004" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>gevezn azoy. zaynen mir avekgeforn, nor dos, kurts darf men makhn, vayl dos iz nokh &lt;ot do&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1005" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts549">
				<ANNOTATION_VALUE>avekgeforn ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts548" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>zaynen mir, hot men undz avekgeshikt, tsugeforn bizn Tashkent. kh'hob Rusland gezen fun ale zaytn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>tsugeforn bizn Tashkent, bin ikh mitn foter aropgekrokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1006" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>un dortn epes hot men gearbet, ikh &lt;veys&gt; vos, zog ikh, "me kon bay aykh arbetn?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1007" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts557">
				<ANNOTATION_VALUE>zogn zey, "POZHALUYSTA, POZHALUYSTA!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts556" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>iz zog ikh, "&lt;gu- gut, me zol&gt; do aropzetsn UNK &lt;nemen&gt; arbetn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>zogt, &lt;es iz g-&gt; untergegangen &lt;a&gt; N.K.V.D.:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>fun di vagones zol keyner nit aroys,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
