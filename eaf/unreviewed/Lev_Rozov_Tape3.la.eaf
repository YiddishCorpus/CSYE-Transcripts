			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>iz shoyn, az eyner volt shoyn veln... dos iz geven der,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a988" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts435">
				<ANNOTATION_VALUE>dos hot zikh gerufn der punkt KINEL'.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts434" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>&lt;e-&gt; dortn hot men gekont gefinen mentshn, vayl dortn iz shoyn geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
