		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>ikh veys &lt;dokh nit&gt; vuhin me firt. a- uh, ikh kon aykh zogn vuhin me firt. me firt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>&lt;m'iz aro-&gt; un me shtelt op, darf &lt;me&gt;n nokh epes, uh, aropgeyn. uh, es iz dokh nit azoy...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
