		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>zog ikh, "gey bet, d- du gey bet..." ikh bin avekgegangen in restoran &lt;efsher&gt;...</ANNOTATION_VALUE>
