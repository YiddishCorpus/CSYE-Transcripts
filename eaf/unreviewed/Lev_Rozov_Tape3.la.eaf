			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a961" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>oder bay hayntikn tog, volt men dos vayzn, lakht men derfun.</ANNOTATION_VALUE>
