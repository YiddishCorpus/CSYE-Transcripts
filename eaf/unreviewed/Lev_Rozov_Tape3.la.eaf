		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1029" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>di lage fun dem antloyfn iz geven punkt vi bay Hitlern zayn.</ANNOTATION_VALUE>
