		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>darf men zikh haltn eyner tsu di andere.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>s'iz nit geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
