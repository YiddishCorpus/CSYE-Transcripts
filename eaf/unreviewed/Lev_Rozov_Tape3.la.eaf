		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a981" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>az s'iz geven aza lage: nit esn,</ANNOTATION_VALUE>
