		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>&lt;oybn, un&gt; gezogt, "gey!" vifl mentshn? mistome arayngegangen tsvantsik mentshn, finf un tsvantsik.</ANNOTATION_VALUE>
