		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>oyfn veg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>der ban hot zikh avekgeshtelt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>un m'hot bombirt, zaynen mir ale tselofn. der bruder hot gekhapt beyde kinder, arayngelofn in a vald nit vayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a163" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>dos hot gedoyert efsher tsvey, dray sho.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>s'iz nokh geven likhtik. bizn s'iz gevorn nakht, nito der bruder mit di kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts394" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>nito der bruder mit di kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>ongehoybn shrayen UNK shrayen, "Gedalye! Gedalye! &lt;le-&gt; shray!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a985" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>bizn es, fun vaytn hot er undz derzen. er iz gekumen tsu loyfn. er iz farkrokhn in vald, hot er nit gevust vi azoy aroystsukrikhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>&lt;m'iz&gt; gekumen mit di kinder, iz shoyn, di khalesht, UNK. ikh'l aykh zogn, s'iz dokh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>dos kon men nit derts-... az ikh zol dos veln rikhtik zitsn, darf men zitsn tsvey teg un trakhtn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>ot dos iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>&lt;hot er&gt; gekumen, mir hobn zikh avekgezetst... itster vil ikh aykh endikn... m'hot undz gebrakht biz KUYBYSHEV.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>KUYBYSHEV, dos iz shoyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a986" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
