		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a955" TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>mit pitslekh tsvey kinder un nokh di...</ANNOTATION_VALUE>
