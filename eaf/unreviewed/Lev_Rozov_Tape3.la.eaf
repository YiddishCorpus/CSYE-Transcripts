		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>mir zaynen gekumen in V&lt;yaznye&gt;. me hot shoyn geshtelt di ferd un gekumen bay drit.</ANNOTATION_VALUE>
