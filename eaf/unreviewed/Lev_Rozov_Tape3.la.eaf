		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>un mir zaynen geforn, un m'hot undz opgefirt, opgefirt. vuhin firt men undz?</ANNOTATION_VALUE>
