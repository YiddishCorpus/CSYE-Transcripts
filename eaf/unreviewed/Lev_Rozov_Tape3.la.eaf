		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>Tashkent, Tashkent. firt men undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
