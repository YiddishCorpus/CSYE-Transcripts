		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts476" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>o, dos iz shoyn geven, ikh, ikh, ikh gedenk nit genoy, nor s'iz geven av- a-</ANNOTATION_VALUE>
