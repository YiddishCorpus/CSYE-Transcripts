		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>a dokumen-... ikh hob nit gehat keyn eynem mit a bild.</ANNOTATION_VALUE>
