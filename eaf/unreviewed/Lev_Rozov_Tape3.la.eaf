	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Lev Rozov">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts6">
				<ANNOTATION_VALUE>&lt;ye&gt;. itster &lt;vil ikh aykh zogn&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>itster vil ikh aykh zogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>mir zaynen gekumen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>ikh vil aykh zogn vi azoy mir zaynen gekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>in a shtot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>Smolensk. farshraybt, dos iz eyne fun di groyse shtet in Rusland, Smolensk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>fun Smolensk zaynen mir vayter gegangen. dortn hobn mir shoyn getrofn oyfn veg</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>a sakh mentshn. m'hot shoyn ge- ki getribn, di kolkhozn gefirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a941" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
				<ANNOTATION_VALUE>di mashines aroysgefirt fun Rusland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>zayn- un ale zaynen gelofn. un mir hobn shoyn geforn oyf a ferd, vayl ikh hob gekhapt a ferd bay eynem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
				<ANNOTATION_VALUE>&lt;fun bakante&gt;. er hot gevolt opgebn in militer. zog ikh, "ikh bin militer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a942" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
				<ANNOTATION_VALUE>gib mir dem ferd, vel ikh forn. zoln zey mir araynzetsn!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>&lt;ah,&gt; s'iz dokh nit geven keyn ordenung.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>ikh hob genumen un mir zaynen geforn, mir zaynen geforn, mir zaynen geforn oyf Moskeve.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a16" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>di veg vos es geyt a hoypt-veg fun Smolensk oyf Moskeve.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>Moskeve zaynen mir gekumen in</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>V&lt;yaznye&gt;, a shtot V&lt;yaznye&gt;, hinter Moskeve.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>hot men undz gezogt, "stop!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
				<ANNOTATION_VALUE>ahin, der veg, mer forn tor men nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts46">
				<ANNOTATION_VALUE>biz keyn Moskeve? kh'kon, ikh kon es nit zogn afile.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a943" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>efsher hundert kilometer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a968" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
				<ANNOTATION_VALUE>s'iz geven di hunderter kilometers!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a944" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
				<ANNOTATION_VALUE>s'iz dokh nit geven...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a945" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>un mir zaynen gegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a946" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts57">
				<ANNOTATION_VALUE>gegangen. dos iz vokhn; dos iz, dos iz nit teg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>gegesn? iz oyfn veg voltst zikh opshteln, voltstu do epes koyfn, do epes nemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a947" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>di gantse frage iz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a948" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>mit arumvashn zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a949" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>volt men vu s'iz a taykh nekhtikn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>bayn tog vashn, bay nakht geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>s'iz nit geven a, eh, antloyfn fun, antloyfn fun Hitlern iz nit geven antloyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a951" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts73">
				<ANNOTATION_VALUE>fun eynem a mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>un vu er iz gegangen, hob ikh aykh d- ot itster vel ikh aykh dertseyln eyn zakh:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>vu ikh bin gegangen volt men varfn f- bombes, un di muter volt lign, volt men ir darfn oyfheybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>fun shrek aleyn!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>s'volt zayn azetike oyfraysn, shrek aleyn, volt...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a952" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts83">
				<ANNOTATION_VALUE>itster gib ikh aykh eyn epizod kedey tsu makhn gikher di zakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>mir zaynen gekumen in V&lt;yaznye&gt;, hot men undz farhaltn un &lt;me&gt; zog&lt;t&gt;, di yugntlekhe darfn geyn in militer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>iz hob ikh gelo- tsugefirt di eltern tsu a derfl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>gelozn zey shteyn mit alts mit an ander,</ANNOTATION_VALUE>
