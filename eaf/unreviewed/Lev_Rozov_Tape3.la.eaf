		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>UNK do iz nito keyn ort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
