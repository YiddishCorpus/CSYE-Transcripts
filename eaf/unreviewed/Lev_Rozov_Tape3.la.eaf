		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>&lt;zog ikh, uh,&gt; zog ikh, "un vi vet men lozn di eltern?"</ANNOTATION_VALUE>
