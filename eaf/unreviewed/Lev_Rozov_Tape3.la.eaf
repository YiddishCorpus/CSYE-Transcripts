		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts468" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>mitgenumen di ga- &lt;n-&gt; zet ir, alts hot er, dem eygenem mantl gevorfn;</ANNOTATION_VALUE>
