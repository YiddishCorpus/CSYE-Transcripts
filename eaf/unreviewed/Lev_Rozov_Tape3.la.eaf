		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>un m'hot undz avekgefirt vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>vayter, gebrakht in a shtot LOYISH...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>ikh gedenk &lt;nit&gt;, darf dokh gedenken ale</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1008" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts573">
				<ANNOTATION_VALUE>shtet mit nemen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts572" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>dos iz geven UZBEKISTAN. UZBEKISTAN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>oto dos iz UZBEKISTAN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>in LOYISH, dortn hot men shoyn undz aropgelozn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>un gezogt, "z- farnemt zikh an ort."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>&lt;es iz do?&gt; do zitsn, do zitsn d&lt;UNK&gt; farnumen a vinkl oyfn gas.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>nito, keyn shtub iz nito,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>n&lt;or&gt; oyfn gas farnumen an ort. dortn iz der klimat varem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>pakhozhe oyf Erets-Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>s'iz mitl-Azye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>nu, dortn hobn mir zikh opgeshtelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>bay undz iz shoyn geven a STOLOVe, m'hot UNK farshraybn. nor vos? es iz shoyn geven a SHUK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>avekgegangen, hot men gekoyft, di ershte zakh hot men alemen tsekoyft</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1009" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts599">
				<ANNOTATION_VALUE>dekes, az me zol zikh hobn oyf vos tsu leygn oyf der erd.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts600" TIME_SLOT_REF2="ts603">
				<ANNOTATION_VALUE>&lt;m-&gt; ikh hob gehat &lt;gelt&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1010" TIME_SLOT_REF1="ts604" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>&lt;ikh hob gehat gelt&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>kh'hob gehat, ikh hob gehat, ikh hob gekont hobn mer gelt; ikh hob di froy ibergelozt gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts611">
