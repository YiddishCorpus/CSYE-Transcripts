			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a959" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>ale dokumentn zaynen geven gornisht: on bilder, on gornisht. s'iz nit geven dokumentn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
