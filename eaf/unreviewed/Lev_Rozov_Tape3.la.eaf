			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a992" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>shoyn rusishe, vos shoyn, fun umetum zaynen geven dortn.</ANNOTATION_VALUE>
