		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts526" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>az ikh bin shoyn geven bay zey oykh an elterer;</ANNOTATION_VALUE>
