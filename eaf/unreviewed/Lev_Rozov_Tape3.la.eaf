		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1000" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>mentshn in di fertsiker yorn, a man un vayb, mit a por kinder, mit an alte mame,</ANNOTATION_VALUE>
