		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts688">
				<ANNOTATION_VALUE>ir farshteyt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts690">
				<ANNOTATION_VALUE>ot dos, oto dos iz geven undzer antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1031" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts693">
				<ANNOTATION_VALUE>derfar zog ikh, der antloyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>un der rateven zikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1032" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>iz geven di zelbe zakh vi antloyfn fun Hitlern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1033" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>tsu zayn bay Hitlern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1034" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>vemen s'hot opgegoltn, der &lt;iz&gt; in geto geblibn; vemen s'hot opgegoltn, iz der in,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
