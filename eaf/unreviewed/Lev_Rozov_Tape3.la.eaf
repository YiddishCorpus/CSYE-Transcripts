		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a989" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>geshribn pleytim. s'iz nit geven mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
