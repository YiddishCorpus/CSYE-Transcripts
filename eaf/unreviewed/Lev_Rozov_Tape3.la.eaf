		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts118" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>ikh hob gehat a dokument vos ikh bin geven in UNK in der NARODNOE SOBRANIE oysgeklibn. a papirl! a pa-...</ANNOTATION_VALUE>
