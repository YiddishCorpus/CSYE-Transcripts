		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>bin ikh avekgegangen. nor ikh hob gehat a dokument epes vos...</ANNOTATION_VALUE>
