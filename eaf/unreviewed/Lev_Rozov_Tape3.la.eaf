		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts482" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>s'hot shoyn ongehoybn geyn tsum vinter, hot ongehoybn geyn.</ANNOTATION_VALUE>
