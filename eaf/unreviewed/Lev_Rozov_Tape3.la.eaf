		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1011" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>tsvey, &lt;d-&gt;... hert azoy: dray kilometer nokh mir, veys ikh nit vos s'tut zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>far vos? di militer veys oykh nit vos s'tut zikh.</ANNOTATION_VALUE>
