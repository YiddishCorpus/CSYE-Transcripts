		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts525">
				<ANNOTATION_VALUE>nor yugntlekhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
