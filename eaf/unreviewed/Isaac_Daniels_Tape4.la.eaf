		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts361">
				<ANNOTATION_VALUE>dortn hobn gevoynt di geshlosene fun zibn un draysikstn in yor. zey hobn men avekgeshikt vayter un ir vet darfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts360" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>farnemen di pletser. vu m'vet aykh veln shikn, zolst dikh oysbahaltn. zolst nisht forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>un az vest hern az m'vil shikn oyf punkt numer eyns, do zolstu forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>ikh nem iber dem magazin dortn, eh WE WILL DO BUSINESS."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>ikh bin krik aroyf un shtel dikh der-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>derfreyt eh farn kind a bisl milkh, un un zey m'shaft shoyn tsunoyf epes a tepl mit farsh- m'kokht shoyn di POTATO.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>vu m'shikt, m'bahalt zikh oys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>teyl hot men shoyn avekgeshikt, ober di MOST iz nokh do do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>darf men forn nokh broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>broyt iz nishto do, m'darf forn s'bay a finef mayl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts381">
				<ANNOTATION_VALUE>fort men mit a mit a TRUCK, der komendant fort, un m'nemt fun dortn broyt. keyner vil nisht forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts380" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>s'do eyn un zibetsik kinder, un keyn eyn elter vil nisht forn mitn komendant nokh broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>Yizak, ikh bin do. aroyf oyfn TRUCK, m'fort avek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>azoy vi m'kumt tsu forn krik, mitn broyt, iz nishto keyn lebediker nefesh. ale zenen tseforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>mayn froy, mitn kind, un ikh shtey mit tsvey zek broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>vu hin zenen zey geforn vu ahin?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts393">
				<ANNOTATION_VALUE>zogt men shoyn, zenen geforn oyf fir un tsvontsikstn utshastok.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts392" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>fir un tsvontsikstn punkt, s'vert mir nisht gut. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>ober ikh far- di kinder zenen dokh on broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>ikh bet zikh barn komendant m'hey- m'shaft shoyn a a vagonetke vos geyt oyf reder, m'dershlept zikh dortn ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts401">
				<ANNOTATION_VALUE>dortn di vos zenen geforn frier hobn farnumen tsimern fun di geshlosene,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts400" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>holts hot nisht gefelt, m'hot ayngeheytst, s'geven varem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>zey hobn shoyn gehat vos tsu kokhn, mit dem mit mayns gesheft. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>un mayn froy zitst in droysn un veynt mit bitere trern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>zi hot nisht vu arayntsugeyn. "vos dernemstu zikh bloyz mit gornishe gesheftn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>zey ale hobn hobn nisht gekent geyn keyner nisht nor du?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>un vos zol ikh t- yetst tun? mit ikh hob nisht vu arayntsugeyn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>un dos iz shoyn gevezn dos iz shoyn gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>ende oygust, azoy mitl oygust, ende oygust, s'geven kalt. Sibir! nisht gut!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>zog ikh in komendant, "ikh bin mit a kleyn kind, vos tut men?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
				<ANNOTATION_VALUE>vayzt er mir on oyf a hayzkele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>ikh gey arayn un di vent zenen ofene. zogt er, "vest nemen breter, farklapn m'vet makhn a a KITCHEN do."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>zog ikh, "vu do vel ikh do gefroyrn vern mitn kind, vos redstu?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>"du vest geyn mit mir oyfn ershtn utshastok." fun ershtn punkt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>un er kloybt oys tsen FAMILIES. azoy mer veyniker mer mentshlekhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>vayl s'dokh geven a rov, s'geven mentshn farshidnartike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>ANYWAY, m'hot di nakht ibergezesn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>un in der fri iz geven a fur un ikh hob oyfgezetst di froy mitn kind,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>un un nokh andere. un der komendant zogt, "du kum mit mir nokhn vald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>az m'vet geyn nokhn vald vet zayn kirtserer veg, mir veln mir zayn frier vi zey."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>m'iz gegangen iz men ongekumen oyfn plats dortn, hobn di geshlosene, ven zenen geven yorn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>hobn zey oyfgeboyt fun holts a HOSPITAL, geven akht tsimern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts445">
				<ANNOTATION_VALUE>prekhtik, mit gem- mit gefarbte FLOORS, mit mayses.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts444" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>ikh bin arayn, farnumen a tsimer, ikh hob nokh arayngebrengt a shenkl, dos un dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>ikh hob epes gehat a por tsent bay zikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>bin ikh geven in droysn, eyder zey zenen ongekumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts453">
				<ANNOTATION_VALUE>iz geshtanen a kristin, un ikh hob bay ir gekoyft epes a bisl milkh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts452" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>a por POTATOES, un zi hot gehat shvomen. MUSHROOMS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>un do hob ikh shoyn gezukht, hob ikh shoyn gefunen a tepl, a dos, mayses, ikh kokh shoyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>un in shank ikh hob oyfgehongen mayn mantl mitn SUIT mit mayses gesheftn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>zey zenen ongekumen. mayn mayn froy iz ongekumen, zi iz geven farshtendlekh zi iz geven tsufridn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>s'nokh gevezn a COUPLE vos er hot gevolt arayngebn a pa- zayn's a mantl tsu mir in CUPBOARD arayn, breng arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>bay nakht, m'iz gegangen shlofn, zogt der komendant az do tor men nisht farmakh- farmakhn keyn tirn. ale tirn darfn zayn ofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>ikh hob im nisht gedorfn folgn? ikh hob gedorfn farmakhn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>un er hot zikh oyfgekhapt in mitn der nakht hob ikh derhert az men geyt ver aroys fun tsimer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>s'hot zikh mir gedokhtn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a418" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>ikh gey arop fun bet, ikh geb a kuk arayn in CUPBOARD arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>iz dem fraynt vos er hot arayngenumen zayn mantl, er hot gehongen in der front, ze ikh az dos mantl hengt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>shpeter tsu az s'gevorn azoy arum akht a zeyger, her ikh a gevalt, m'hot im baganvet, dem baga-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>ikh gey nokh a mol tsu tsum CUPBOARD.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>dem fraynt's pel- mantl hengt, mayn's hot men tsu geganvet. a SUIT un dem m'hot tsu geganvet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>shoyn vayter baganvet. oy biter iz biter eh, ikh hob gepanikt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
