		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts352" TIME_SLOT_REF2="ts355">
				<ANNOTATION_VALUE>s'do a punkt akhtsn, s'do a punkt fir un tsvontsik,</ANNOTATION_VALUE>
