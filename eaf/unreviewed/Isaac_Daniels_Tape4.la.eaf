		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts487">
				<ANNOTATION_VALUE>vifl tsayt zent ir dort gevezn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts488" TIME_SLOT_REF2="ts490">
