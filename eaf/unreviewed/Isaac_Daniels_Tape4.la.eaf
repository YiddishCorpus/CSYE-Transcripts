		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts354" TIME_SLOT_REF2="ts356">
				<ANNOTATION_VALUE>s'do a punkt, nokh epes a punkt, ikh gedenk nisht genoy dem NUMBER.</ANNOTATION_VALUE>
