		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>"vet men tseshikn aykh.</ANNOTATION_VALUE>
