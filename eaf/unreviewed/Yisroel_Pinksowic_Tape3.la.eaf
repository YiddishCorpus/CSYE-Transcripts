		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts200" TIME_SLOT_REF2="ts202">
				<ANNOTATION_VALUE>dray eyniklekh hob ikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a103" TIME_SLOT_REF1="ts204" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>der eltster Bentsion, er iz hitstert in CHEIL AVIR dint er, CHAYAL. </ANNOTATION_VALUE>
