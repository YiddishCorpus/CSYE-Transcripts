		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>un nokh ikh hob nokh a kleyntshik eynikl fun dray a halb yor.</ANNOTATION_VALUE>
