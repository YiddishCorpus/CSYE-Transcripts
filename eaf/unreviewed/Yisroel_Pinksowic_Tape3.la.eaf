		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a99" TIME_SLOT_REF1="ts194" TIME_SLOT_REF2="ts196">
				<ANNOTATION_VALUE>di tokhter Rifke hot khasene gehat dem tsveytn november zeks un zibetsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
