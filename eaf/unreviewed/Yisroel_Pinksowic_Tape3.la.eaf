		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>ikh kon gebn a a vort far di kinder, un farn gantsn AM-YISRAEL,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>m'zol ophitn deys kleyne land vos undz ho'mir vi di oygn vos m'kon ophitn in kop.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a130" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
