		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>deys bin ikh, Yisrael Pinkasovitsh, ikh bin gevezn a CHAYAL in der sovetisher armey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>s'gevezn in nayn un fertsiker yor in Vostoshnik oder Stalin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>un deys iz fun links mayn vayb Zheni, mayn tokhter Roza,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>un ikh Yisrael. dos iz geven in fir un zekhtsiker yor. in Khust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>deys iz mayn eynikl, der BRIT-MILA fun mayn eynikl Bentsion,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>dos iz gevezn der zekhtstn detsember toyznt nayn hundert zibn un zibetsiker yor in Haulam in Rishon Letsion.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>deys iz mayn tokhter Roza, mit mayn eydem Yitskhok Moyshe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>di khasene in Tal-Aviv in Haulam, in toyznt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>dem tsveytn november, toyznt nayn hundert zeks un zibetsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>deys tsind mir undz mit mayn vayb Zheni di NEYROT fun barmitsve baym eynikl. fun der linker zayt di tokhter Roza,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>eh Sarit, der eydem Yitskhok Moyshe, dos eynikl Bentsion, un ikh mit mayn vayb.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a156" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>un deys iz oyfn barmitsve barn eynikl Bentsion,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>mayn froy git a prezent farn eynikl, a goldn i- zay- SHARSHERET, zi tut es far Bentsionen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>un ikh fun der rekhter zayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a162" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>deys iz oyfn, a mishpokhe bild oyfn barmitsve,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts303">
				<ANNOTATION_VALUE>fun der linker zayt bin ikh, mayn froy Zheni, mayn eydem Yitskhok Moyshe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts302" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>dos eynikl Bentsion, mayn tokhter Roza, un mayn eynikl Sarit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>deys iz mayn eynikl, er dint itstert baym militer in CHEIL AVIR, Bentsion Yonavitsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>un deys iz a bild fun mayn eynikl velkher iz gekumen nokhn barmitsve,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>fun der linker zayt mayn vayb Zheni, dos eynikl Aloni, un ikh Yisrael.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>un deys iz mayn eynikl, er iz shoyn groys gevorn, Aloni, er redt shoyn in telefon.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>dem briv, dey shrift hob ikh bakumen fun Zhenev, fun Arolzon, funem Roytn Kreyts,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>vos ikh bin rikhtik durkhgegangen, in velkhe lagers fun di SHOAH.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>ikh heys Pinkasovitsh Yisrael, mayn heftlings numer iz finef un fuftsik nul nayn un akhtsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>ikh bin gekumen oyf Bukhnvald in finef un tsvontsikstn may fir un fertsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>oyf Dora dem ha- eh dem nayn un tsvontsikstn may fir un fertsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>oyf Hartsungen in yuli fir un fertsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>oyf Erlikh lager oykhet in fir un fertsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>un tsurik zikh fun Erlikh umgekert oyf Hartsungen in akhtstn merts finef un fertsiker yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>deys iz a papir funem arkhiv fun Yad Vashem, a kopi fun dem papir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
				<ANNOTATION_VALUE>fun mayn vayb, dem meydlshn nomen Berman,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>Zheni, zi hot zikh geshribn oyf ungarish Shari,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>vos iz bafrayt gevorn in Bergn-Belzn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>un deys iz a papir velkhe s'vayzt oyf vos ikh geher tsu a IR- IRGUN</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
