		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts173">
				<ANNOTATION_VALUE>ober ikh bin nokh alts geblibn dray tog in der vokh hob ikh nokh gearbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts174" TIME_SLOT_REF2="ts176">
				<ANNOTATION_VALUE>in di zelbe TACHANA, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
