			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts253">
				<ANNOTATION_VALUE>mer ho'mir nisht keynem dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
