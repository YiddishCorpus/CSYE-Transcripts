		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>dos meydele Sarit, iz zibetsn yor alt gevorn, zi zi ar- zi lernt zikh in shule nokh.</ANNOTATION_VALUE>
