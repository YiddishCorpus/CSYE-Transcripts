		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>in fir un zibetsiker yor bin ikh a- avek arbetn oyf a TACHANA DELEK, oyf velkher ikh hob gearbet</ANNOTATION_VALUE>
