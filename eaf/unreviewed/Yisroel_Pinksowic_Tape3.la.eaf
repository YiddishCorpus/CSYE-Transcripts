			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>un azoy hot men mikh gerufn dem tsvontsikstn merts oyf Uzhgorod,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>ikh hob nisht gehat keyn kroyvim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
