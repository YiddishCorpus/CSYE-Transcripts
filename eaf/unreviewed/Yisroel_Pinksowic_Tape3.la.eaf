		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts168" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>ikh bin aroys oyf pensye in dray un nayntsiker yor,</ANNOTATION_VALUE>
