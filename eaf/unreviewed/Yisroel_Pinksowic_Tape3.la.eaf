		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts187">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts188" TIME_SLOT_REF2="ts190">
				<ANNOTATION_VALUE>ikh bakumen BITUACH LEUMI, ikh bakumen MIVTACHIM,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
				<ANNOTATION_VALUE>un bakumen a kleyne pensye fun Daytshland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
