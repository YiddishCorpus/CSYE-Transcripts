		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>m'hot mikh nisht gevolt lozn avek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts180">
				<ANNOTATION_VALUE>un in dray un, deys in zeks un nayntsiker yor in merts,</ANNOTATION_VALUE>
