			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts248" TIME_SLOT_REF2="ts250">
				<ANNOTATION_VALUE>mit der froy tsuzamen ze'mir gevezn. zi iz geven oyf ir bruder's keyver un ikh oyf mayn bruder's keyver.</ANNOTATION_VALUE>
