			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts223">
				<ANNOTATION_VALUE>er iz geshtorbn in zibn un zibetsiker yor.</ANNOTATION_VALUE>
