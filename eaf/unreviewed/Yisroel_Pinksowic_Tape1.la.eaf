				<ANNOTATION_VALUE>un dort ze'mir gevezn, ober oyfn tsveytn ober oyfn dritn tog hot men undz genumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a608" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
