			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts426" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>a shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>dos iz shoyn geven tsvishn tog un nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>nor ze'mir vi s'kumt a yid mit a langer bord, un geyt mit der MADRICHA</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>in der zayt, un shrayt oyf undz, "raboysim, nokh mir!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts437">
				<ANNOTATION_VALUE>azoy ze'mir gegangen, un der linker,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts438" TIME_SLOT_REF2="ts441">
				<ANNOTATION_VALUE>ikh hob nisht a an aynvoyner fun dem shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts442" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>vayl di yidn hot men nokh nisht genumen fun der heym. zey zenen nokh geven in der heym, di yidn fun dem shtetl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>er hot undz arayngefirt oyf links in a gas,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts449">
				<ANNOTATION_VALUE>dort in a BET-KNESET, in a shul, un dort hot men undz bahaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts450" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts459">
				<ANNOTATION_VALUE>m'hot nokh dem hot men eh ho'mir ongehoybn tsu hern az dort ver s'dergeyt ahin, harget men oys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts458" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>vegn dem hot men undz bahaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>di eltern, elter mentshn zenen fun dort keyn mol nisht aroysgegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>un undz kinder ze'mir shoyn geven on peyes, m'hot nisht gevust tsi undz ze'mir yidn ober kristn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>flegn mir aroysgeyn, mir fleg avekgeyn in dem SHUK,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>vos m'hot aroysgevorfn un genumen tsu esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>un azoy ze'mir undz dort geven a gantsn zumer, biz far rosheshone.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts472" TIME_SLOT_REF2="ts475">
				<ANNOTATION_VALUE>in Boshtshava.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts476" TIME_SLOT_REF2="ts479">
				<ANNOTATION_VALUE>far rosheshone.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts480" TIME_SLOT_REF2="ts483">
				<ANNOTATION_VALUE>in eyn un fertsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts484" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>far rosheshone, ho'mir zikh genumen tsurikgeyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>iz dortn, der yid mit der langer bord, un nokh a reb eyner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts491">
				<ANNOTATION_VALUE>hobn undz baleyt tsurik etlekhe kilometer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts490" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>un zey hobn undz gebentsht mir zol'mir besholem zikh umkern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts494" TIME_SLOT_REF2="ts497">
				<ANNOTATION_VALUE>NO, nor in shul. m'iz geshlofn oyf der erd, ver, vu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts498" TIME_SLOT_REF2="ts501">
				<ANNOTATION_VALUE>bahaltn, keyner hot nisht gevust far undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts502" TIME_SLOT_REF2="ts505">
				<ANNOTATION_VALUE>mir ze'mir tsurikgekumen oyf Klust,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts506" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts511">
				<ANNOTATION_VALUE>dort ze'mir gez-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts512" TIME_SLOT_REF2="ts515">
				<ANNOTATION_VALUE>Klust Klust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>in dem shtetl ho'mir gehaltn rosheshone tsvey teg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts520" TIME_SLOT_REF2="ts521">
				<ANNOTATION_VALUE>in Klust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>dernokh dem ze'mir gegangen vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>dem heylikn tog ho'mir genumen in a veldl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>dort, m'hot nisht farfast, un m'hot nisht oyfgefast, a gantsn tog hot men gedavnt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts530" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>yomkiper.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts535">
				<ANNOTATION_VALUE>un dernokh dem ze'mir gegangen, mir ze'mir gekumen tsum Dnyester,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts536" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>di akht mishpokhes ale.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a403" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>ikh veys nisht fun vu di eltern hobn genumen dem TOCHNIT,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a404" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>nor m'iz gegangen ales mit zaytn-gasn, di daytshn zoln undz nisht pakn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>mir ze'mir gekumen biz tsum Dnyester nisht mit der brik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a406" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>a- dortn hot men undz mit a shifl, a- m'hot gegebn vos m'hot gehat far a goy</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts549">
				<ANNOTATION_VALUE>hot er undz aribergefirt mit a shifl oyfn andern breg funem Dnyester,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>neyn a shifl, s'hot, a por mol. s'hot zikh alts tsu zeks zibn mentshn zikh oyfgezitst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts556" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>un azoy ze'mir gegangen tsu fus tog-teglekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a411" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>mir ze'mir gekumen biz far der grenets shoyn, far di berg fun di Karpatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>ikh gedenk nisht vi azoy s'hot geheysn, dort hobn undz gekhapt di daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts566" TIME_SLOT_REF2="ts569">
				<ANNOTATION_VALUE>dos iz gevezn far der grenets aza dorf, un zey hobn undz genumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a418" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>s'hot zikh shoyn ge- getsoygn tsu di grenetser fun di Karpatn, di berg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts575">
				<ANNOTATION_VALUE>un dort hobn zey undz farlodnt, di tsvey daytshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts574" TIME_SLOT_REF2="ts577">
				<ANNOTATION_VALUE>oyf a aza shmole ayzn-ban, vos azelkhe vagondlekh vos m'hot gefirt holts,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts576" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>un m'hot undz aroyfgefirt biz oyf der grenets, dort vu s'geshtanen azelkhe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts581">
				<ANNOTATION_VALUE>azelkhe ayz- deys fun beton, azolkhes deys. fun eyn zayt hot geshribn POLSKA, fun der anderer zayt hot geshribn CESKOSLOVENSKO, vu di grenets iz geven. yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts582" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>un m'hot ongehoybn tsu zogn tilim, m'hot gemeynt az zey viln undz oyshargenen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>ober dos iz geven zeyer orntlekhe tsvey daytshn, alte,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>zey hobn undz gezogt, zey hobn gevizn vu arum m'zol geyn, in velkhn rikhtung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>un mir zol'mir zikh nisht umkern, vayl andere veln undz khapn, vet men undz oysshisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>azoy ze'mir undz gegangen a sakh tsayt, mir ho'mir zikh farlorn in di velder, mir ho'mir nisht gevust vu arum tsu geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>s'iz shoyn di negl gel gevorn fun hunger, m'hot shoyn nor gevolt shlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a441" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>un nokh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts600" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>tsurik oyf Negrovits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>dernokh dem, mayn bruder, Hersh Meylekh, Tsvi Meylekh, hot zikh oyfgehoybn oyf a hoykhn boym un er hot derzen az dortn in a rikhtung vu s'do a shtub, iz er avekgegangen ahin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>un dort iz geven a goyte, velkhe zi hot opgekokht fun tiras mel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a450" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>aza deys, un er hot gebetn far yedern hot men gegebn azoy fil eyn mol in moyl eh nemen iz oysgekumen, iz men oyfgelebt gevorn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>un mir ho'mir ongehoybn tsu geyn vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a452" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>tsk azoy ho'mir undz aribergeshvertst durkh der grenets un mir ze'mir gekumen oyf Negrovits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts619">
				<ANNOTATION_VALUE>in Ne- tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a454" TIME_SLOT_REF1="ts620" TIME_SLOT_REF2="ts622">
