		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>dort hot men oys geshisn. undz ze'mir dergangen gegangen, ikh veys nisht vifl BEDIYUK,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>a tog tsvey, ober vifl, ze'mir ongekumen tsun a shtetele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
