		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a622" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>yedes hot oysgetun di kleyder, naket iz men dort geshtanen a gantse nakht.</ANNOTATION_VALUE>
