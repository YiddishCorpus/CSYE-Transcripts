		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts320" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>azolkhe ofene vagonen vos m'hot gefirt nor holts,</ANNOTATION_VALUE>
