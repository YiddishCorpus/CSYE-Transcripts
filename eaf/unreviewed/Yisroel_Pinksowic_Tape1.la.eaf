		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
				<ANNOTATION_VALUE>eyn vokh alts bayn a TALMID in der heym gelernt.</ANNOTATION_VALUE>
