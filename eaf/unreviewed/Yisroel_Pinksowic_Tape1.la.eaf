			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>un dort hobn di daytshn, zofort, ven undz ze'mir gekumen ahin,</ANNOTATION_VALUE>
