		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a597" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>un dort hot men undz gegebn kleyder, azelkhe kleyder hot men gegebn vi pizhames,</ANNOTATION_VALUE>
