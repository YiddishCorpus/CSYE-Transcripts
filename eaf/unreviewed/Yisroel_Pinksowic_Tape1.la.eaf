		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts321">
				<ANNOTATION_VALUE>m'hot undz zofort tsurik farlodnt, nokh a mol in vagonen, in RAKEVET,</ANNOTATION_VALUE>
