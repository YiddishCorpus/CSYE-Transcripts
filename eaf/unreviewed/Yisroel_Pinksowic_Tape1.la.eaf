		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>ze'mir gevezn, eltere mentshn zenen geven in bord un peyes, yinglekh ze'mir ale geven, ikh hob oykh getrogn peyes.</ANNOTATION_VALUE>
