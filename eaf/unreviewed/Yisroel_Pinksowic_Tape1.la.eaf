			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a567" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>ikh veys mir ze'mir teg geforn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
				<ANNOTATION_VALUE>ze'mir ongekumen keyn Aushvits, ho'mir gevust az mir ze'mir in Aushvits. eyn mol hot men a makh oyf der tir, un m'hot ongehoybn tsu shrayen oyf daytsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1363" TIME_SLOT_REF1="ts865" TIME_SLOT_REF2="ts868">
				<ANNOTATION_VALUE>"AUSSTEIGEN! SCHNELLER SCHNELLER! LOS LOS!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a569" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>azoy iz men aroysgegangen. s'hot zikh gemakht zeyer a groyser balagan.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a571" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>di mame hot nokh gehat a shtikl broyt, hot zi far mir arayngeshtupt in der hant, zogt zi, "du darfst nokh lebn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a572" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts874">
				<ANNOTATION_VALUE>azoy hot men undz tseteylt. ikh bin gegangen in rikhtung oyf rekhts, nokh der shtatsyon,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a574" TIME_SLOT_REF1="ts875" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>mayn tate iz in der mit geven. mikh hot er ongekhapt unter eyn hant, mir zol'mir zikh nisht tseraysn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>dem bruder Avrom in der anderer hant, un Moyshe der bruder iz lebn undz gegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>un mir ze'mir gegangen, biz vi lang mir ze'mir nisht gekumen oyf eyn ort, s'geven fun dort tsu geyn links, rekhts,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1364" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts883">
				<ANNOTATION_VALUE>dort s'iz an ofitsir geshtanen, ikh hob nisht gevust demolts ver der der ofitsir iz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1365" TIME_SLOT_REF1="ts884" TIME_SLOT_REF2="ts886">
				<ANNOTATION_VALUE>nokh dem, ven ikh hob gezen Mengelen, hob ikh farshtanen az dos iz gevezn Dokter Mengele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts888">
				<ANNOTATION_VALUE>hot der ta- hot er dem tate a freg getun oyf mir vi alt ikh bin, ikh bin alt geven zekhtsn yor. hot der tate gezogt akhtsn yor, hot er mir geheysn rekhts, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a580" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>oyfn andern bruder, hot er freg getun vi alt ikh bi- er iz, hot der tate gezogt tsvontsik yor, hot er geheysn rekhts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a582" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>yenem bruder, er iz geven far dray un tsvontsiker a geborener, hot er nisht gefregt gornisht, er hot im geheysn rekhts, vayl er iz geven groys,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a584" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>un dem tate hot er gefregt vi alt bistu? hot der tate gezogt akht un fertsik yor. "links".</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a585" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>mit dem iz mir geblibn in zikorn, azoy oyf links iz geshtanen a daytsh un er hot gehalt a sider in di hent,</ANNOTATION_VALUE>
