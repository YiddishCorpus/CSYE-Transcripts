		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a563" TIME_SLOT_REF1="ts852" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>in yedn vagon hot men beerekh arayngeshtupt tsu zibetsik mentshn.</ANNOTATION_VALUE>
