		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a629" TIME_SLOT_REF1="ts981" TIME_SLOT_REF2="ts982">
				<ANNOTATION_VALUE>dort, dernokh dem, m'hot genumen di key- di kleyder oyskokhn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a632" TIME_SLOT_REF1="ts983" TIME_SLOT_REF2="ts984">
				<ANNOTATION_VALUE>mikh hot men genumen, az ikh zol geyn aroysvarfn di kleyder vu m'hot es oysgekokht. vi lang ikh bin gekumen iz shoyn mayn bruder Avrom dort nisht gevezn.</ANNOTATION_VALUE>
