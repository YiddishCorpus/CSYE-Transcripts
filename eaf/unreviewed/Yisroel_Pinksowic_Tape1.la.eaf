			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
				<ANNOTATION_VALUE>m'hot gehat feld, m'hot gehat ferd. a mol hot men gefirt skhoyres</ANNOTATION_VALUE>
