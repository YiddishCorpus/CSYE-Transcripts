		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>di daytshn hobn ongehoybn tsu flikn far mentshn di bord, mit di peyes, un m'hot geharget un m'hot geshlogn,</ANNOTATION_VALUE>
