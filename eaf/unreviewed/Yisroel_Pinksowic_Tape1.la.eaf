		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a616" TIME_SLOT_REF1="ts956" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>azoy eyner farn andern iz gezesn tsvishn di fis. azoy hot men farlodnt. in der mit iz geshtanen tsvey S.S.layt.</ANNOTATION_VALUE>
