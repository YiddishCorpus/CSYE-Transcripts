		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a566" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>ze'mir geforn, ikh veys nisht vifl tsayt, vayl ikh gedenk nisht,</ANNOTATION_VALUE>
