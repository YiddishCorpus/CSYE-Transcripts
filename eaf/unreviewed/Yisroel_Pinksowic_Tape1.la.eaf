		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>s'geven beerekh a fertsik fuftsik mishpokhes hobn gevoynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts212" TIME_SLOT_REF2="ts215">
				<ANNOTATION_VALUE>NO. bayn undz iz geven fun beyde zaytn iz gevezn yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
