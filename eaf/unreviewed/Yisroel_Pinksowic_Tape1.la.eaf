			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts194">
				<ANNOTATION_VALUE>vayl koydem iz geven an alte shul, hot men gelernt in der alter shul. un dernokh dem, yede vokh, hot men bay</ANNOTATION_VALUE>
