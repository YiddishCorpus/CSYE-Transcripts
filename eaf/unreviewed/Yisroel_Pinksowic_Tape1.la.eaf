		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>m'hot gezogt az m'hot gehert keile m'vil mir zol'mir tsu di rusn aribergeyn.</ANNOTATION_VALUE>
