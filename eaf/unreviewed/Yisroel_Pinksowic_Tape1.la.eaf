		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a587" TIME_SLOT_REF1="ts900" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>a daytshisher soldat. er hot a sider genumen un er hot zikh gemakht keilu er hot gedavnt.</ANNOTATION_VALUE>
