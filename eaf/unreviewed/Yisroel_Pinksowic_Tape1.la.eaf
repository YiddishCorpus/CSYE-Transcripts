				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a612" TIME_SLOT_REF1="ts949" TIME_SLOT_REF2="ts951">
