			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts333">
				<ANNOTATION_VALUE>un mir ze'mir geforn ikh veys nisht vu biz vu, un biz Kolomoy.</ANNOTATION_VALUE>
