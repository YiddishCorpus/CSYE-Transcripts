		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a561" TIME_SLOT_REF1="ts850" TIME_SLOT_REF2="ts853">
				<ANNOTATION_VALUE>dort iz geven a shtatsyon, a ban shtatsyon, un dort hot men undz farlodnt in vagonen.</ANNOTATION_VALUE>
