		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a621" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>bay nakht hot men geheysn, m'hot undz arayngefirt oykhet in aza groys gebay, mir ho'mir gemeynt az s'iz tsu bodn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
