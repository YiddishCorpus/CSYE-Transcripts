		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a592" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts915">
				<ANNOTATION_VALUE>dort hot men oysgetun ale kleyder vos m'hot gehat. eyn zakh vos m'hot gemegt aribertrogn, di shikh.</ANNOTATION_VALUE>
