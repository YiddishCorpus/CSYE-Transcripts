			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a618" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>vi m'hot undz gegebn dort tsu shtikele broyt un m'hot undz farlodnt in vagon,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a619" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts962">
				<ANNOTATION_VALUE>vifl tsayt s'hot genumen, veys ikh nisht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a620" TIME_SLOT_REF1="ts963" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>mir ze'mir ongekumen keyn Bukhnvald. ze'mir ongekumen bay nakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
