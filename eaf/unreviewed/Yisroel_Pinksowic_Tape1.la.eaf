			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a599" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>un aza lang aza vi a rekl, a langs, un a hitl. deys zenen geven di gantse kleyder.</ANNOTATION_VALUE>
