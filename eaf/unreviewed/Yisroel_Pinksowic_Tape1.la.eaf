			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>der emes iz gevezn az m'iz dergangen biz in Kaminits-Padolsk, ver s'iz dergangen, dort hot men oysgeshosn.</ANNOTATION_VALUE>
