		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts392" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>in Klust az mir zol'mir geyn tsu fus, alts foroys, nisht zayn dortn.</ANNOTATION_VALUE>
