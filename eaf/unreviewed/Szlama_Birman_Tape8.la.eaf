		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a560" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts131">
				<ANNOTATION_VALUE>ikh d- ikh dank dikh oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a561" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts135">
