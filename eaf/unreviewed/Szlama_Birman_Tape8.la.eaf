		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a559" TIME_SLOT_REF1="ts84" TIME_SLOT_REF2="ts85">
				<ANNOTATION_VALUE>mi- milkhome tsayt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>du kenst mir zogn far vos du ir hot eh detsidirt tsu fartseyln dayn mayse haynt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts123">
				<ANNOTATION_VALUE>host epes ehm nokh vos du vilst zogn oyf VIDEO TAPE?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
