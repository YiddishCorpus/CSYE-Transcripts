				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts143">
				<ANNOTATION_VALUE>MR BIRMAN, CAN YOU PLEASE INTRODUCE ME TO YOUR FAMILY?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>THANK YOU.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>MAX, CAN I JUST ASK YOU A FEW QUESTIONS? IS THERE ANYTHING THAT YOU WOULD LIKE TO SAY EHM ABOUT YOUR MOTHER AND FATHER ON A VIDEO TAPE?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
				<ANNOTATION_VALUE>JUST WHAT SORT OF PEOPLE THEY ARE TO YOU IN YOUR MIND.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>WERE YOU AWARE OF WHAT YOUR PARENTS EXPERIENCED WHILE YOU WERE GROWING UP?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts176">
				<ANNOTATION_VALUE>RIGHT, THEN HOW DID THOSE EHM IDEAS MANIFEST THEMSELVES?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
				<ANNOTATION_VALUE>TSK HOW HAVE YOUR PARENTS' EXPERIENCE INFLUENCED THE WAY YOU'VE RAISED YOUR OWN CHILD?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
				<ANNOTATION_VALUE>IS THERE ANYTHING ELSE YOU'D LIKE TO SAY TO YOUR PARENTS? OR JUST GENERALLY?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>THANK YOU VERY MUCH. AND I'D LIKE TO THANK ALL OF YOU FOR COMING TODAY, AND IN PARTICULAR MR BIRMAN FOR</ANNOTATION_VALUE>
