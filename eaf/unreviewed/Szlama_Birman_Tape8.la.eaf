		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>du klerst oyf di tsayt a sakh?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
