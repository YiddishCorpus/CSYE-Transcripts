		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts60" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>vos? vos vos far a vort?</ANNOTATION_VALUE>
