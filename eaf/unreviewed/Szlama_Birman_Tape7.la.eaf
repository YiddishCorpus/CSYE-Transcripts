		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts257">
				<ANNOTATION_VALUE>ven ikh bin arayn shoyn keyn &lt;Doln un Shlosn&gt;, der bruder iz tsurikgekumen keyn Nidershlezye mikh zukhn,</ANNOTATION_VALUE>
