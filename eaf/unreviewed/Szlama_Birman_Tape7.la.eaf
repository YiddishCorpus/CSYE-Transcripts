		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts278" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>un zey hobn zikh dort bazetst,</ANNOTATION_VALUE>
