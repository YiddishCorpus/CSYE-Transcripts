			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>hot shtudirt als advokat, als eh SOLICITOR, oykhet a inteligenter khevre.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
