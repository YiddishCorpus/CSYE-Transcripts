			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1265" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts919">
				<ANNOTATION_VALUE>un di kinder, vos hobn di kinder gemakhn do?</ANNOTATION_VALUE>
