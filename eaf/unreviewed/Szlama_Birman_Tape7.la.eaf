			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>di andere halb, nokh nisht di andere alb hot zi shoyn gehaltn bay endikn, un di krig hot oysgebrokhn.</ANNOTATION_VALUE>
