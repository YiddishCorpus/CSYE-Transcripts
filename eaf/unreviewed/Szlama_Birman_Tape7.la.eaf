			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1254" TIME_SLOT_REF1="ts748" TIME_SLOT_REF2="ts751">
				<ANNOTATION_VALUE>vos vos far a keyn arbet hostu ir gemakht do?</ANNOTATION_VALUE>
