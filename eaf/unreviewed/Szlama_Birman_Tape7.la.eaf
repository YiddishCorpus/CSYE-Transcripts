			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1249" TIME_SLOT_REF1="ts408" TIME_SLOT_REF2="ts411">
				<ANNOTATION_VALUE>gevolt kumen tsu AUSTRALIA?</ANNOTATION_VALUE>
