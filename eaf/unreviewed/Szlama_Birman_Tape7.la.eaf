			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts223">
				<ANNOTATION_VALUE>er hot shoyn gehat a shtikl pozitsyon, a po- po- po- POSITION. farshteyst?</ANNOTATION_VALUE>
