			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1271" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts974">
				<ANNOTATION_VALUE>a frume heym, a khsidishe heym,</ANNOTATION_VALUE>
