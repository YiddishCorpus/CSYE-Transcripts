			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a553" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>un raykhe koynim, zey hobn geboyt hayzer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a554" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>un zey hobn nisht gekukt oyf dem oyf der matbeye zey hobn aroysgenumen zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a555" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>ikh hob gehat a gevelb bay zikh fun kol-tuv, fun alemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a556" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>farshteyst, az s'hot gekent araynkumen a greyte</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a557" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>ovnt broyt makhn far gest. s'ongekumen gest &lt;oystsushteyn&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a558" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>&lt;arayn tsu mir&gt; fil fish fun fun</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a559" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>geviklte kroyt un ale sortn geven fertik tsu nemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a560" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
				<ANNOTATION_VALUE>azoy zey hobn zikh gekloybt, a tort, a eh ruzhne CAKEn gemakhte,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a561" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts906">
				<ANNOTATION_VALUE>azoy az zey hobn zikh ayn geven, zey hobn bay undz gemotlt a bisl, arayngekumen farmotlen dos shabes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a562" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>azoy az s'iz geven bay a heymishn arayngeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a563" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts910">
				<ANNOTATION_VALUE>un azoy oykh m'hot dortn fardint a por dolar.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a564" TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts912">
				<ANNOTATION_VALUE>m'hot fun undz alts ayngekoyft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a565" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts915">
				<ANNOTATION_VALUE>un azoy iz geven dos lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a566" TIME_SLOT_REF1="ts918" TIME_SLOT_REF2="ts920">
				<ANNOTATION_VALUE>di kinder hobn zikh gelernt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a567" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>hobn di gantse tsayt zikh gelernt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>zey hobn a sakh mol undz eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a569" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>geheysn far a vokh aroysforn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a570" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts928">
				<ANNOTATION_VALUE>un zey hobn ibergenumen dos gevelb beyde.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a571" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
				<ANNOTATION_VALUE>zey hobn zikh fun di shkole, ven s'geven di HOLIDAY,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a572" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>aroys fun di SCHOOL,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a573" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>un zey hobn zeyer sheyn bahandlt. ven undz zenen nokh tsurikgekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a574" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>hobn di koynim gezogt s'hot nokh gekent zitsn a por monatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a575" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts939">
				<ANNOTATION_VALUE>zey hobn undz pre- zenen, neyn, zenen zeyer kinder, voyle kinder, tokhters gor eh ibergegebene kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts938" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>azoy az zey hobn a mol ibergenumen, m'iz avekgeforn oyf HOLIDAYS, in a pensyonar.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts943">
				<ANNOTATION_VALUE>farshteyst, zenen azoy iz gegangen dos gantse lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts944" TIME_SLOT_REF2="ts946">
				<ANNOTATION_VALUE>der der zun hot geendikt ELECTRONIC inzhenirye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a580" TIME_SLOT_REF1="ts947" TIME_SLOT_REF2="ts948">
				<ANNOTATION_VALUE>un di tokhter hot etlekhe fakultetn, zi</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts949" TIME_SLOT_REF2="ts950">
				<ANNOTATION_VALUE>zi hot geendikt, koydem iz zi geven SCIENCE TEACHER, un hot gelernt in di HIGH SCHOOLS,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a583" TIME_SLOT_REF1="ts951" TIME_SLOT_REF2="ts953">
				<ANNOTATION_VALUE>nokh dem hot zi gemakht eh MASTER OF HIGHER EH OF SCIENCE. MASTER OF SCIENCE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a585" TIME_SLOT_REF1="ts952" TIME_SLOT_REF2="ts955">
				<ANNOTATION_VALUE>nokh dem iz zi arayn, yo in in in dos, in BIOCHEMIST.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a588" TIME_SLOT_REF1="ts954" TIME_SLOT_REF2="ts956">
				<ANNOTATION_VALUE>zi hot gearbet in der HOSPITAL a lengere tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a590" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>veyst dokh, genumen di testn fun blut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a591" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>iz di dray ho- hot zi geendikt. dos heyst, yents hot zi nisht geendikt, dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a593" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts962">
				<ANNOTATION_VALUE>SCIENCE OF MASTER OF SCIENCE hot zi gemakht far zikh aleyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a594" TIME_SLOT_REF1="ts963" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>mer visn. ober nokh dem hot zi nokh gevolt makhn doktorat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a595" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>zi hot nor gevolt shtudirn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a596" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>shoyn un eh zey hobn beyde zikh gelernt, zey hobn beyde geendikt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a598" TIME_SLOT_REF1="ts972" TIME_SLOT_REF2="ts973">
				<ANNOTATION_VALUE>zeyer a frume heym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a599" TIME_SLOT_REF1="ts976" TIME_SLOT_REF2="ts979">
				<ANNOTATION_VALUE>vos get men yetst?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a600" TIME_SLOT_REF1="ts980" TIME_SLOT_REF2="ts981">
				<ANNOTATION_VALUE>di eyntsike vel ikh zogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a601" TIME_SLOT_REF1="ts982" TIME_SLOT_REF2="ts984">
				<ANNOTATION_VALUE>di di dos yidishkeyt tsu zey, zey hobn lib di traditsye di yidishe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a602" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts988">
				<ANNOTATION_VALUE>ikh hob geflegt a mol &lt;filn a tam&gt;, ober m'vert opgekilt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a605" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>neyn a tradi- a traditsyoneln tish nisht azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a607" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts992">
				<ANNOTATION_VALUE>eh fish iz geven, azelkhe zakhn, ober</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a608" TIME_SLOT_REF1="ts993" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>di tsore iz geven, di avle iz geven fun mayn zayt vos ikh hob zey nisht gelernt yidish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a609" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>zey zenen arayn in der englisher shprakh arayn azoy vi yunge khevre,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a610" TIME_SLOT_REF1="ts997" TIME_SLOT_REF2="ts998">
				<ANNOTATION_VALUE>un eh ikh hob gekent in der shtub mit zey redn yidish, un dos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a611" TIME_SLOT_REF1="ts999" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>dos biz hay- un zey zenen hobn tsu mir a groyse</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a612" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1002">
				<ANNOTATION_VALUE>dos, far vos du host undz nisht gelernt keyn yidish. zey hobn gevolt yidish kenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a613" TIME_SLOT_REF1="ts1003" TIME_SLOT_REF2="ts1004">
				<ANNOTATION_VALUE>un bay undz in shtub hobn mir geredt sof poylish mit der froy,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a614" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1006">
				<ANNOTATION_VALUE>a bisl yidish, di froy iz geven ender in poylish a bisl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a615" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>farshteyst, azoy,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a616" TIME_SLOT_REF1="ts1010" TIME_SLOT_REF2="ts1012">
				<ANNOTATION_VALUE>spn BOY!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a617" TIME_SLOT_REF1="ts1013" TIME_SLOT_REF2="ts1014">
				<ANNOTATION_VALUE>ye s'iz der iker, di tokhter iz yetst in Yizrael avekgeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a618" TIME_SLOT_REF1="ts1015" TIME_SLOT_REF2="ts1016">
				<ANNOTATION_VALUE>dortn zi vet kumen, in akhtn darf zi kumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a619" TIME_SLOT_REF1="ts1017" TIME_SLOT_REF2="ts1018">
				<ANNOTATION_VALUE>un zi iz shoyn etlekhe mol in Yizrael.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a620" TIME_SLOT_REF1="ts1019" TIME_SLOT_REF2="ts1020">
				<ANNOTATION_VALUE>un undz undz ze'mir shoyn geven tsvey mol in Yizrael, eyn mol far fir monat, eyn mol zeks monat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a621" TIME_SLOT_REF1="ts1021" TIME_SLOT_REF2="ts1022">
				<ANNOTATION_VALUE>shoyn forndik als turist fun danet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a623" TIME_SLOT_REF1="ts1023" TIME_SLOT_REF2="ts1024">
				<ANNOTATION_VALUE>tsu di familyen, tsu di froy's familyen, ikh hob gehat dem kuzin dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a624" TIME_SLOT_REF1="ts1025" TIME_SLOT_REF2="ts1026">
				<ANNOTATION_VALUE>ikh hob gehat dem bruder dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a625" TIME_SLOT_REF1="ts1027" TIME_SLOT_REF2="ts1028">
				<ANNOTATION_VALUE>azoy UNK m'farbrengt biz hayntike tog. ikh bin hersht RETIRED</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a626" TIME_SLOT_REF1="ts1029" TIME_SLOT_REF2="ts1030">
				<ANNOTATION_VALUE>shoyn a geshikhte akhtsn yor tsi tsvontsik yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a628" TIME_SLOT_REF1="ts1031" TIME_SLOT_REF2="ts1032">
				<ANNOTATION_VALUE>ikh bin shoyn in di yorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a629" TIME_SLOT_REF1="ts1034" TIME_SLOT_REF2="ts1036">
				<ANNOTATION_VALUE>zeyer tsufridn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a630" TIME_SLOT_REF1="ts1037" TIME_SLOT_REF2="ts1038">
				<ANNOTATION_VALUE>ikh bin ahergekumen fun Poyln</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a631" TIME_SLOT_REF1="ts1039" TIME_SLOT_REF2="ts1040">
				<ANNOTATION_VALUE>a khotshik ikh hob nisht gehat keyn gearbet, di ershte hob ikh mikh arum gevalgert, gevezn zeyer shver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a632" TIME_SLOT_REF1="ts1041" TIME_SLOT_REF2="ts1042">
				<ANNOTATION_VALUE>nor di froy hot gearbet in a HOSPITAL.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a633" TIME_SLOT_REF1="ts1043" TIME_SLOT_REF2="ts1044">
				<ANNOTATION_VALUE>hot zi oykhet geroymt TOILETS, dos iz geven ir arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a634" TIME_SLOT_REF1="ts1045" TIME_SLOT_REF2="ts1046">
				<ANNOTATION_VALUE>un ir gevoynt tsu aza arbet geven?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a635" TIME_SLOT_REF1="ts1047" TIME_SLOT_REF2="ts1048">
				<ANNOTATION_VALUE>un m'hot zi hot mir gegebn a bisl parnose. dos ershte yor hot men gevoynt tsuzamen mit nokh a porfolk,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a636" TIME_SLOT_REF1="ts1049" TIME_SLOT_REF2="ts1050">
				<ANNOTATION_VALUE>oyf a dire, un m'hot beyde getsolt dire gelt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a637" TIME_SLOT_REF1="ts1051" TIME_SLOT_REF2="ts1052">
				<ANNOTATION_VALUE>un nokh un nakher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a638" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1054">
				<ANNOTATION_VALUE>hob ikh ongehoybn tsu krign arbet bay dem KNITTING, bay di tsvey yidn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a639" TIME_SLOT_REF1="ts1055" TIME_SLOT_REF2="ts1056">
				<ANNOTATION_VALUE>un s'geven a bisl laykhter, m'hot shoyn gedungen a besere dire, on shutfim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a640" TIME_SLOT_REF1="ts1057" TIME_SLOT_REF2="ts1058">
				<ANNOTATION_VALUE>AND THAT'S ALL.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a641" TIME_SLOT_REF1="ts1060" TIME_SLOT_REF2="ts1062">
				<ANNOTATION_VALUE>dank dir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
