		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts234">
				<ANNOTATION_VALUE>s'nokh a mol ongekumen nokh a shvoger iz ongekumen fun Rusisher militer.</ANNOTATION_VALUE>
