		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a147" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>un er iz nishto do, hot gezogt er vet kumen in a kurtser tsayt.</ANNOTATION_VALUE>
