			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
				<ANNOTATION_VALUE>un zukhn adresn, zukhn a Birman, zukhn efsher ver iz geblibn.</ANNOTATION_VALUE>
