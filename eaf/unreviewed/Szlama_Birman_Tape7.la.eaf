			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1269" TIME_SLOT_REF1="ts942" TIME_SLOT_REF2="ts945">
				<ANNOTATION_VALUE>ye, un zog mir, vos hobn zey geendikt in der shule?</ANNOTATION_VALUE>
