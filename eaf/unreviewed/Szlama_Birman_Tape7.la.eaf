			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts270" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>fun dem zitsn in kokh in kokhn a bisl mitog ken men nisht eybik zitsn.</ANNOTATION_VALUE>
