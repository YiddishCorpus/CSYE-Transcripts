			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>zi hot ongehoybn, zi hot a zi hot a bisl, zi hot EDUCATION.</ANNOTATION_VALUE>
