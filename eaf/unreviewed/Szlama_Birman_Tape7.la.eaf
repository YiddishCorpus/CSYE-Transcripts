		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>un hobn gezogt m'vet adurkhforn keyn keyn Nidershlezye dort. dort vet men gefinen a dire, m'vet hobn biz dos, zenen dokh gelign oyf nares, oyf militer nares.</ANNOTATION_VALUE>
