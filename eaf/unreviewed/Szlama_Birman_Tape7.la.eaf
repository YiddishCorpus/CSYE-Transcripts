		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>ikh hob fardint bay dem arumloyfn tsvishn di dos, zey hobn mir gut batsolt, vayl zey hobn mikh badorfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>hob ikh ongeklibn a sheyn bisl gelt, ikh hob opgekoyft bay eynem a varshtat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>vos er iz geforn keyn Yizrael,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>ikh hob es opgekoyft in bay dem varshtat hob ikh gemakht zeyer sheyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>ikh hob ongehoybn tsu handlen mit di kristn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>avekgeshikt skhoyre in ruzhne shtet arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>azoy az s'iz geven, oyb es geyt materyelns iz undz geven zeyer gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>di froy hot gehat a dinst bay zikh, a kristlekhe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>un m'geforn avek oyf HOLIDAYS, zeyer oyf tsvey monatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>azoy az m'hot gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>a b- a bisl tsayt hot men gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>zeyer gut. no- nokh dem hot zikh gemakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>di antisemitn, di antisemitishe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>iz geven zeyer groys. far vos? vayl demolt hot zikh getoysht, in zibn un fuftsikst- heyst es in zibn un</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>in zibn un, yo un zibn un fuftsikstn yor,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>hot zikh getoysht regirung in Poyln. s'iz aropgekumen an antisemit er hot ibergenumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>un er hot gevolt di yidn patern di yidn aroys fun Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>s'zol zayn JUDENREIN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>er hot ongehoybn tsu UNK velkhe zenen gezitsn oyf groyse pozitsyes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>tsvishn andere, mayn shvoger, ir shvester's man,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>hot men gezitsn, er iz geven a direktor in takesh in a groyser fabrik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>er er hot zikh ayngeshribn in der partey, in der komunistisher partey, tsu krign a groyse pozitsye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>er iz vayt geven fun komunizm,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>hot er ayngeshribn zikh, m'hot im gegebn aza hoykhe pozitsye. er iz geven a direktor fun a groyser fabrik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>azoy vi s'ongekumen di antisemitizm, ven s'hot ibergenumen di makht, der firer hot geheysn Gormunka.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>un der Gormunka hot aroysgegebn azelkhe bafeln, er hot azoy gemordevet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>un un s'hot zikh ongehoybn, di Endekes hobn ongehoybn oyftsuheybn dem kop,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>barn komunizm hot men gelozt nokh undz lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>m'hot undz ge&lt;UNK&gt;, m'iz geven glaykh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>m'hot gekent makhn kleyntshike fabrikelekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>private, vos m'ken nor haltn a mentsh oder tsvey, nisht keyn groyse, kleyntshike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>far zikh, m'hot badorfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>baleygn an ekzamen tsu kenen dem fakh arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>farshteyst, un dos bin ikh geven eyner fun dem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts543">
				<ANNOTATION_VALUE>un yo, hot men eh m'hot gut gelebt, m'iz geforn zikh aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts542" TIME_SLOT_REF2="ts545">
				<ANNOTATION_VALUE>iz der shvoger, hot men genumen, m'hot aroysgevorfn, nisht aroy- geheysn im aheymgeyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts544" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>m'hot zey kimat, m'hot gezogt az m'hot zey aroysgefirt mit azelkhe vegelekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>dos iz vayzn far der velt vos far</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>vos far a d- sort mentsh er iz, azoy vi di doytshn hobn gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>un aza direktor, aza kop!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts555">
				<ANNOTATION_VALUE>geven va- un dos iz geven ale fabrikn, hobn ongehoybn aroys tsuhakn. undz ze'mir oykhet gevoyer gevorn fun derfun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts554" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>un zey hobn zikh ongehoybn tsu dertloyfn, veln tsu dertloyfn, lomir shoyn nisht do zitsn in dem fayer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>vayl tsu mir iz arayngekumen in varshtat arayn a mol a POLICE man khapn ikh zol im gebn in der hant arayn epes gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>ikh hob im gegebn a mol a shnepsele a bisl bronfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>zoln zikh nisht tshepen tsu mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>hobn zey ge- zogt er az hersht iz enker sof.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>tsu tsu mir azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>hot er gezogt az in gas shmuest men</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>az dos iz di yidn der sof fun di yidn, az Gormunka iz do bay der makht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>oder m'vet undz aroys hakn, oder m'vet enk</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>ikh veys ruzhne zakhn ontun aza.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>m'hot dos gehert, un zey hobn gehert,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>hot men zikh ongehoybn tsu arbetn. peser hot men aroysgegebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>vos mer kedey m'zol aroys hakn di yidn fun Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>un takesh, di gantse mishpokhe hot zikh arayngekhapt keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>ikh bin geblibn nokh in Poyln,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>vayl ikh hob nisht gekrign, ikh hob epes tsvey mol opgegebn un m'hot mir opgerufn. a sakh mentshn hot men opgezogt aroysforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>mir hot men opgezogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>oft hot men opgezogt di ershte mol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>nokh a mol un nokh a mol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>azoy zey zenen aroys epes in zibn un fuftsikstn dakht zikh mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>zey zenen aroys frierte fun undz, tsu a yor frierte, ikh gedenk nisht genoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>zey zenen aroys aroysgegangen, in Yisroel iz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>azan onloyf fun di poylishe emigratsye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>az m'hot zey gegebn azelkhe erter vu tsu zayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>azelkhe blekhene hayzkes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>di zun zi di zun hot gebrent in aza</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>a dos in vi nokh heyst es, a kr- a land vos iz heys brent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts611">
				<ANNOTATION_VALUE>un eh hobn undz eh ge- zey hobn undz geshikt a briv, zey hobn gehat undzere adres,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>hot men hobn zey undz ge- m'hot geshribn azoy, her oys, ikh hob mir dortn oysgearbet zikh, zayendik in Lodzh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>hob ikh mir aroys gearbet fun a Bundishn mentsh, vos er iz geven in Bund,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts616">
				<ANNOTATION_VALUE>er iz geven mayn's a shokhn fun dem varshtat vu ikh hob gearbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts618">
				<ANNOTATION_VALUE>zo- un un in Frankraykh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>iz der balbos fun land iz geven a yid,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
				<ANNOTATION_VALUE>a geviser Blum ver es veyst,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
				<ANNOTATION_VALUE>er iz geven der der der premyer, vi der PRIME MIN- der onfirer fun land.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
				<ANNOTATION_VALUE>er hot gekrign dos benkl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>far der arbeter partey, er iz gekumen tsu der makht, un er iz geven in Bund, der der Blum,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>iz er aroyfgezetst gevorn oyfn hekhstn benkl, vayl yidn zenen feik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
				<ANNOTATION_VALUE>un m'ken zey zetsn oyf a hoykh benkl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
				<ANNOTATION_VALUE>iz der der tsulib dem vos er iz dortn gezisn, aza</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts636">
				<ANNOTATION_VALUE>ts- a yidn, un oyfn hekhstn amt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts638">
				<ANNOTATION_VALUE>hob ikh gebetn dem Bundist er zol efsher arop shraybn tsun im </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>az ikh vil araynforn keyn Frankraykh. er hot bakant mit a groy mit tsvey kinderlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts643">
				<ANNOTATION_VALUE>tsu er kenen undz oysarbetn a PERMIT arayntsuforn keyn Frankraykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts642" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>s'hot nisht lang gedoyert,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>ikh hob gekrign a a shte- a a langn, s'geven arayntsuforn keyn Frankraykh nor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>a CHWILOWY, oyf zayn oyf a yor, oyf a halb yor un arbetn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>un s'geven mentshn vos hobn gekent voynen shtendik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>mir hot er oysgearbet a pas shtendik tsu zayn in Frankraykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>nu un ikh hob sh- ikh hob shoyn gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>ikh hob shoyn gehat a Yisroel pas oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
				<ANNOTATION_VALUE>ikh hob gehat dr- ikh hob gehat tsvey peser.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a403" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>zitst men un m'trakht, m'trakht vos m'tut, tsi in Frankraykh, tsi Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts662">
				<ANNOTATION_VALUE>dervayl krigt men a briv fun Yisroel, shraybn zey azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a406" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>zi heyst dokh Klara. Klara,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>zolst visn, tomer hostu an ort vu tsu forn ergets andersh oyf dervayl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts667" TIME_SLOT_REF2="ts668">
				<ANNOTATION_VALUE>vayl s'a shver lebn. tsvey kleyne kinderlekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a411" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>vest erdishet vern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>di imigratsye groys, fun ale zaytn kumt men.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>farshteyst. hob ikh shoyn gehert azan briv,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>zi hot gevoynt in a kleyn shtetl, Pinsk, fun far der krig.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>s'hot a mol gehert nokh tsu Rusland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>nakher iz es geven in poylishe hent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a418" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>Pinsk, zi hot dortn shtudirt in Pinsk, der tate hot dortn shtudirt nokh ven der tsar iz geven der Rusisher tsar,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>azoy az eh der tate irer hot gehat a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>a CHEMIST, a a er iz geven oyfzeer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts688">
				<ANNOTATION_VALUE>er hot geendikt a a CHEMIST iz er geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts690">
				<ANNOTATION_VALUE>er hot gehat a sheyn gevelb dort, zey zenen geven WELL OFF,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts693">
				<ANNOTATION_VALUE>du farshteyst, iz hot men ariber geshribn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts695">
				<ANNOTATION_VALUE>keyn in dem Pinsk shtetl arayn, az ikh zukh oys,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts694" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>zolstu visn, ikh heys Ayznberg, zi heyst Ayznberg fun der heym,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>ikh heys Ayznberg, mistam kenst ets dem tatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>vayl in aza kleyn shtetele,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>iz geven bakant a CHEMIST. er hot gemakht aleyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>meditsinen, ikh meyn s'nisht a mol geven amolike tsaytn azoy vi do fabrikn vu m'hot gemakht meditsinen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>m'shikt arayn. er hot aleyn oysgearbet, un der</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1290" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts708">
				<ANNOTATION_VALUE>der yidntum m'hot im lib gehat, er iz gekumen. er hot a mol gekent</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1291" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>tun a toyve a yid, far vos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>eyner iz arayngefaln, eyner fun di politsey eynem hot men arestirt eyner vos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>hot er gekent aroys arbetn m'zol a mentsh bafrayen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>hot er gehat a shtikl, vi nokh zogt men dos, a shtikl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>er hot gekent eh, er iz geven bakant in shtetele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a444" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>hot zi gegebn a shrayb ahine,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts723">
				<ANNOTATION_VALUE>az s'zolt az s'zolt vemen oyfzukhn an Ayznberg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a447" TIME_SLOT_REF1="ts722" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>un ikh vel zogn ver der tate mayner iz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a448" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>efsher vet dos kenen oysarbetn a PERMIT arayntsukumen in land arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>un s'hot nisht lang gedoyert. m'hot undz geshikt a vize arop,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a453" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>undz hobn do dervayl do oysgearbet bay di englisher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a455" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>vayl s'hot nokh gehert ven m'hot,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a456" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>eh s'nokh di englisher zenen do UNK, m'hot badorfn, zey hobn nisht gehat keyn direkte</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a457" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>eh opteylung in in Poyln,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a458" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>nor s'gegangen nokh der englisher nokh der englisher ambasade tsi vi azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a460" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>un m'hot dortn, m'hot undz genumen tsu doktoyrim un m'hot undz ge&lt;malet&gt; ir un mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a461" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>m'hot aroysgegebn a pas, un ale dray peser hot men bashtetikt tsu forn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a463" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>keyn Australye. m'hot farshtanen az do iz a vild land, a farvorfn land,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a465" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>nor s'beser. Frankraykh iz oykh nisht geven keyn aza laykht lebn nokh der krig,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a466" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts749">
				<ANNOTATION_VALUE>azoy az m'hot, m'iz do ahergekumen in zekhtsikstn yor in der ende.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a467" TIME_SLOT_REF1="ts750" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>do? ikh bin geven in der KNITTING.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
