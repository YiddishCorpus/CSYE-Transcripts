		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts294" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>un der shvoger vos er iz gekumen fun Rusland, ir's a shvester's a man,</ANNOTATION_VALUE>
