			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>UNK zi di HIGH SCHOOL hot zi gekrogn UNK, zi hot shoyn bald gehaltn bay UNIVERSITY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>zi iz alt geven zibetsn yor ven di krig hot oysge&lt;UNK&gt; in akhtstn yor, azoy az zi hot shoyn geendikt </ANNOTATION_VALUE>
