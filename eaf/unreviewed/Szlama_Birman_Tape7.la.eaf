		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>un un ikh hob geredt mit dayn ba- bakanter, mit di heyst zi, mit dem GIRLFRIEND,</ANNOTATION_VALUE>
