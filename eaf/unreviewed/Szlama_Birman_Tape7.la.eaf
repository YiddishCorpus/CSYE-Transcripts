			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1272" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>ehm vos far a yidishkeyt gebstu iber in in der heym tsu dayne kinder haynt?</ANNOTATION_VALUE>
