		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>ze'mir ongekumen vintertsayt. s'iz gevezn zeyer, zeyer kalt. vintertsayt zenen mir gekumen in BERGEN BELSEN.</ANNOTATION_VALUE>
