			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>"vu zenen zey?" hot zi gezogt "zenen in Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>zenen in Tshekhn," hot zikh oyfgehoybn oyf, oyf, demolts gevezn last vogns, nisht gevezn nokh keyn &lt;tsig&gt;, oyf di last vogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts874">
				<ANNOTATION_VALUE>iz zi gekumen tsu forn keyn Tshekhn. iz zi gekumen dort in JOINT arayn, un zi iz gekumen in di kaserne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts875" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>in kaserne, ikh bin UNK gevezn avek. zi hot zikh &lt;mir&gt; nisht gevust vu ikh bin. ABER yendfal, iz, s'hot gedoyert a bisele, zi hot mikh getrofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>un azoy vi zi hot zi mikh getrofn, hot zi gezogt "ikh for tsu di mame keyn Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>vilst mitforn?" zog ikh "neyn. ikh for n- di mame hot gezogt neyn, ikh for nisht. ikh blayb do"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts882">
				<ANNOTATION_VALUE>un zi iz geforn keyn Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts883" TIME_SLOT_REF2="ts884">
				<ANNOTATION_VALUE>un dort hot zikh getrofn mit di mame, un shpeter iz zi gekumen tsurik tsu mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts885" TIME_SLOT_REF2="ts886">
				<ANNOTATION_VALUE>un mir, ikh bin gevezn IMMER di BABY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts889">
				<ANNOTATION_VALUE>tsurik tsu mir iz zi gekumen, un zi hot mikh tsurikgenumen keyn Poyln, ze'mir gevezn in Poyln a tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts890" TIME_SLOT_REF2="ts893">
				<ANNOTATION_VALUE>biz, in Kroke. di mame hot gedungen zikh a WO-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts894" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>neyn, dort eh undzer hoyz hot gevoynt a goye, hobn mir nisht geke- nor mir hobn gedungen a WOHNUNG</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>oyf di lange gas</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>un di mame hot gehat farmegns UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>hot zi gevolt di farmegns zol likvidirn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts905">
				<ANNOTATION_VALUE>un zi hot takesh got zay dank likvidirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>neyn, zi hot gehat hayzer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts910" TIME_SLOT_REF2="ts911">
				<ANNOTATION_VALUE>fun UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts912" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>hot es farkoyft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>zi hot dos farko- m'hot ir nisht tsurikgegebn, nor m'hot es farkoyft</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts919">
				<ANNOTATION_VALUE>oyf a shpot, ober vifl hot men gegebn iz gevezn UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts920" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>yo, vayl zi iz gevezn yorshim. di mentshn zenen nishto, iz zi iz di yoyresh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>gevezn di yoyresh, un eyn papir hot zi gehat ir eygns do, gevezn in Makev</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>bin ikh mitgeforn, azoy vi ikh bin stabil geforn keyn Makev, hob ikh zeyer gut gekent Makev</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts928">
				<ANNOTATION_VALUE>un di bobe zeydes hobn zey mir gegebn di bobe's pelts mantlen, un der zeyde hot gehat aza pelts oyf, oyfn mantl, kh'veys nisht vos se heyst</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
				<ANNOTATION_VALUE>un azoy vi hot mikh keyner nisht gekent, bin gevezn a fremde dort, hot men gegebn tsu a lerer, tsu a lererin tsu trogn di zakhn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>un ikh bin geganen, ikh hob arayngetrogn. ikh bin gekumen keyn Makev nokh di krig mit di mame tsuzamen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>zogt zi, bin ikh geganen tsu di goye, zogt zi UNK "fort avek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>anisht ruf ikh di politsey."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>iz ze'mir geganen tsu a advokat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>undz ho'mir bashribn dos o, er hot alts geshribn. undz ze'mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
				<ANNOTATION_VALUE>untergeshribn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts943" TIME_SLOT_REF2="ts944">
				<ANNOTATION_VALUE>un er hot gezogt "haynt bay nakht zolstu tsurikforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts945" TIME_SLOT_REF2="ts946">
				<ANNOTATION_VALUE>vayl azoy vi di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts947" TIME_SLOT_REF2="ts948">
				<ANNOTATION_VALUE>di goye veyst az ets zent do, vet zi rufn di N.K.V.D.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts949" TIME_SLOT_REF2="ts950">
				<ANNOTATION_VALUE>un m'vet kumen enk hargenen," un mir ze'mir bay nakht bald tsurikgeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts951" TIME_SLOT_REF2="ts952">
				<ANNOTATION_VALUE>azoy zenen gevezn di polyakn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts956" TIME_SLOT_REF2="ts959">
				<ANNOTATION_VALUE>neyn, zey zenen gut gevezn. zey, di go- vos zey hobn, undz ho'mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>&lt;veyst&gt; vos hobn zey gezogt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>eh oyf poylish eh zogt men &lt;WSZY JEZYJESZCE&gt;?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>"du lebst nokh?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>farshteyst dos vort? oyf poylish iz dokh andersh oysdrikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts972">
				<ANNOTATION_VALUE>d- vi eyner zogt "du lebst nokh?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts973" TIME_SLOT_REF2="ts974">
				<ANNOTATION_VALUE>s'iz nokh gevezn, dos vos ikh bin geblibn lebn iz nokh gevezn tsu fil</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts976">
				<ANNOTATION_VALUE>hobn zey gezogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts981">
				<ANNOTATION_VALUE>vu? in Poyln?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts982" TIME_SLOT_REF2="ts984">
				<ANNOTATION_VALUE>di Poyln iz azoy, leyder, leyder. azoy vi zey kumen keyn Poyln, iz bald ongekumen di papirn fun MAUTHAUSEN</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>un iz gekumen di papirn fun ale lager, ver lebt yo, ver lebt, di yekes zenen geven zeyer in ordenung. yedn mentsh hot er ayngeshribn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts988">
				<ANNOTATION_VALUE>vemen m'hot &lt;zey&gt; geleygt in krematoryum arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts989" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>hot di mame bald getrofn leyder az der tate iz nisht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts992">
				<ANNOTATION_VALUE>nifter gevorn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts993" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>un eh iz gevezn dort, hobn zey oysgerekhnt, es iz a tog for khanike iz di yortsayt fun im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>demolts iz azoy gevezn. haynt iz shoyn andersh. UNK eybik yednfal me halt mir a tog for khanike yortsayt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts997" TIME_SLOT_REF2="ts998">
				<ANNOTATION_VALUE>un shpeter iz zi tsurikgekumen a shvester fun di, takesh fun RAVENSBRUCK. zi iz nebekh gevorn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts999" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>farvundet oyfn toyte marsh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1002">
				<ANNOTATION_VALUE>mit a, fun a munitsyon fun FLUGZEUG iz arayngefaln UNK do in di hant un di brust</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts1003" TIME_SLOT_REF2="ts1004">
				<ANNOTATION_VALUE>iz zi gekumen tsu di mame</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1006">
				<ANNOTATION_VALUE>un m'hot gevust fun di liste az der shvoger lebt nokh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>azoy hot zi &lt;di&gt; mame bald geshikt, es hot zi oysgeheylt di shvester in shpitol</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1010">
				<ANNOTATION_VALUE>un zi hot bald geshikt UNK keyn MAUTHAUSEN</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts1011" TIME_SLOT_REF2="ts1012">
				<ANNOTATION_VALUE>iz zenen geblibn beyde tsuzamen lebn, got zay dank. zi hot gehat nokh dray kinder nokh di krig.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts1014" TIME_SLOT_REF2="ts1016">
				<ANNOTATION_VALUE>undz ho'mir nisht geklert tsu forn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts1017" TIME_SLOT_REF2="ts1018">
				<ANNOTATION_VALUE>der frumer oylem hot keyn mol nisht geklert tsu forn keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts1019" TIME_SLOT_REF2="ts1020">
				<ANNOTATION_VALUE>undz ho'mir geklert tsu forn keyn Amerike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts1021" TIME_SLOT_REF2="ts1022">
				<ANNOTATION_VALUE>yednfals eh hobn mir gehat a kuzin vos hot undz erleydikt a AFFIDAVIT</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts1023" TIME_SLOT_REF2="ts1024">
				<ANNOTATION_VALUE>keyn Amerike, fun Amerike &lt;oys&gt; glaykh geshikt a AFFIDAVIT</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts1025" TIME_SLOT_REF2="ts1026">
				<ANNOTATION_VALUE>nokh keyn Poyln</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts1027" TIME_SLOT_REF2="ts1028">
				<ANNOTATION_VALUE>ABER s'hot zikh ongehoybn mit di pogromen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
