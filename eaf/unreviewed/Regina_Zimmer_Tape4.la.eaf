		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>far vos iz gevezn a luksus? vayl gevezn a pritshe</ANNOTATION_VALUE>
