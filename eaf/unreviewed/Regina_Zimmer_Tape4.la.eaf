				<ANNOTATION_VALUE>hot men shoyn geklert az s'vet zayn nokh di krig vet men esn an ey, esn a shtikele broyt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
