			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts1015" TIME_SLOT_REF2="ts1016">
				<ANNOTATION_VALUE>hot men gedarft vashn groyse &lt;KAZANIM&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
