		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>di, hm, Royte Kreyts, di TSLAV ADOM, ven er hot geshikt di pekl, tsuker mit a SMIKHA,</ANNOTATION_VALUE>
