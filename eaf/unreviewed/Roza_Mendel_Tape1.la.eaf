		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts963" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>iz gekumen demls a naye transport bay undz in, in lager, un er hot bakant a BAKHURA, a sheyne, a hoykhe YEHUDIYA. ERZSI hot zi geheysn. dos gedenk ikh, afile ir nomen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>zi iz gegan- gegangen sheyn ongetun, mit a tikhele,</ANNOTATION_VALUE>
