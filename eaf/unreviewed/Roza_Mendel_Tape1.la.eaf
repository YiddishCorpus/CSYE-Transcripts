		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>uh, EKH OMRIM? a shirtsl, fartekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts988">
				<ANNOTATION_VALUE>UNK er hot khasene gehat. ven s'&lt;iz&gt; geendikt di MILKHAMA, ven s'iz gevorn SHIKHRUR, er hot khasene gehat mit ir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts989" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>er iz geven a HOMOSEKSUAL. er hot gehat koydem a yingl, a BAKHUR fun POLANYA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts992">
				<ANNOTATION_VALUE>er hot gehat a TSRIF lebn di kikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts993" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>un er hot geh- er iz geven HOMOSEKSUAL, un dernokh dem, PITOM, er &lt;hot&gt; khasene gehat mit di ERZSI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>&lt;mir ale&gt;, kh'gedenk, "vos iz dos?" nu, er hot gevolt heyratn mit ir.</ANNOTATION_VALUE>
