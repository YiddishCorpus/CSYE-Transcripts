			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts1079" TIME_SLOT_REF2="ts1082">
				<ANNOTATION_VALUE>nor zey hobn dokh geharget oykhet, di ukraynishe hobn geharget mayn bruder.</ANNOTATION_VALUE>
