			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts1017" TIME_SLOT_REF2="ts1019">
				<ANNOTATION_VALUE>s'iz geven a&lt;rb-&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts1020" TIME_SLOT_REF2="ts1022">
				<ANNOTATION_VALUE>vos, voser...? LO. vosere esn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
