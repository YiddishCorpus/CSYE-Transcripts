			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts997" TIME_SLOT_REF2="ts998">
				<ANNOTATION_VALUE>er iz geven a goy; vegn POLITIKA m'hot im genemen. er iz nisht geven keyn YEHUD, a yid.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts999" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>un, spn, nor dos. ikh hob gearbet in kikh zeyer shver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1003">
				<ANNOTATION_VALUE>&lt;in kikh&gt; UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1006">
				<ANNOTATION_VALUE>m'hot gedarft helfn far di GERMANIM, &lt;uh, g-&gt; far di GERMANIM, hobn gehat a ungarishe kukher.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>di ungarishe kenen zeyer gut kokhn, zogt men.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1010">
				<ANNOTATION_VALUE>zey hobn gevolt a HUNGARI, iz er hot gekokht. ho'mir gedarft sheyln kartofl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts1011" TIME_SLOT_REF2="ts1012">
				<ANNOTATION_VALUE>mit, ikh vey- kh'gedenk shoyn nisht vos BEEMET m'hot gedarft dortn...</ANNOTATION_VALUE>
