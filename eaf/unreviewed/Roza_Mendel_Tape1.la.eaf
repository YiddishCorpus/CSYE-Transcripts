			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts1013" TIME_SLOT_REF2="ts1014">
				<ANNOTATION_VALUE>un far groyse &lt;KAZANA&gt; vos m'hot gekokht far di yidn,</ANNOTATION_VALUE>
