				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts1029" TIME_SLOT_REF2="ts1031">
				<ANNOTATION_VALUE>&lt;dernokh dem&gt;, m'hot gearbet, uh, als SABALIT, SABAL.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts1032" TIME_SLOT_REF2="ts1034">
				<ANNOTATION_VALUE>yo, eyn mol dos un eyn mol, uh, SABAL, getrogn milekh far di... gegangen in dorf, dray kilometer, in TÜRKHEIM. iz geven a kleyne TNUVA dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts1035" TIME_SLOT_REF2="ts1036">
				<ANNOTATION_VALUE>&lt;mir hobn&gt; gebrengt mit di AGALA. m'hot nisht ge- undz ze'mir geven di SUSIM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts1037" TIME_SLOT_REF2="ts1038">
				<ANNOTATION_VALUE>etlekhe froyen ze'mir gef- geshtupt, uh, eyne hot geshtupt fornt, eyne hintn, ho'mir gebrengt KHALAV.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts1040" TIME_SLOT_REF2="ts1044">
				<ANNOTATION_VALUE>yo, S.S. nor dos vil ikh zogn: di S.S. iz a bisl aroysgegangen, un der iz gev- dort iz geven a alte mentsh, hot gearbet bay di TNUVA. ikh hob gevoynt, nokh di SHIKHRUR hob ikh gevoynt bay im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts1045" TIME_SLOT_REF2="ts1046">
				<ANNOTATION_VALUE>zey hobn gegebn, uh, dires tsu voynen. zey hobn gemeynt, az di AMERIKAIM zenen arayngekumen, m'vet makhn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts1047" TIME_SLOT_REF2="ts1048">
				<ANNOTATION_VALUE>TSAROT far zey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts1049" TIME_SLOT_REF2="ts1050">
				<ANNOTATION_VALUE>hobn zey gezukht YEHUDIM, zey zoln voynen bay zey, az KEILU az zey hobn geholfn far undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts1051" TIME_SLOT_REF2="ts1052">
				<ANNOTATION_VALUE>iz ven di GERMANI iz aroysgegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1054">
				<ANNOTATION_VALUE>fleg er undz ale mol gebn far ale BAKHUROT dortn a bisele milekh tsu trinken. dos iz geven gut BEEMET.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts1055" TIME_SLOT_REF2="ts1057">
				<ANNOTATION_VALUE>KEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts1058" TIME_SLOT_REF2="ts1064">
				<ANNOTATION_VALUE>LO, dos nisht. ikh hob gevoynt bay zey, ober... er hot gehat a froy, oykhet a alte froy, er a alter mentsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts1065" TIME_SLOT_REF2="ts1066">
				<ANNOTATION_VALUE>di nomen nisht, ober s'iz geven zeyer sheyn az er hot geholfn a bisl...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts1067" TIME_SLOT_REF2="ts1069">
				<ANNOTATION_VALUE>un &lt;BE- do-&gt; un BEEMTSA HADEREKH iz geven gute daytshn oykhet. zey hobn a vorf gegebn a kleyne broyt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts1068" TIME_SLOT_REF2="ts1070">
				<ANNOTATION_VALUE>ho'mir in der heym gemakht KHALUKA fun dos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts1071" TIME_SLOT_REF2="ts1072">
				<ANNOTATION_VALUE>gegebn yedn a shtikele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1074">
				<ANNOTATION_VALUE>KEN, s'iz geven gute GERMANIM oykhet. zey hobn gehat RAKHMANUT oyf undz. &lt;ober GE-&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts1075" TIME_SLOT_REF2="ts1076">
				<ANNOTATION_VALUE>veyst ver iz geven di GERMANIM? ukraynIM zenen geven ongetun alts, uh, S.S.n,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts1077" TIME_SLOT_REF2="ts1078">
				<ANNOTATION_VALUE>S.S. kleyder, ukraynishe BAKHURIM,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
