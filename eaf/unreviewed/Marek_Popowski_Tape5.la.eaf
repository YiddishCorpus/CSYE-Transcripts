		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>fun yene p- gantse provints.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
