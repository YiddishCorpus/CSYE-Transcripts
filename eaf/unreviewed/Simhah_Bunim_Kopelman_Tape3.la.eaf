		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a971" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>hot er getseylt, hot men dort gemakht, un m'hot gemolt. m'hot gemakht in ordenung.</ANNOTATION_VALUE>
