		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>iz gekumen tsu geyn UNK &lt;eyn molt&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>her ikh, farshteystu, mayn bruder hot men genumen aroyf in di KRIPO.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
				<ANNOTATION_VALUE>eh m'hot im gut tsehakt, farshteystu, mit gornisht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
