		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>UND eh, er hot bakumen an arbet, farshteyst, a dank &lt;tsu&gt; mayn shver, hot er bakumen an arbet, hot zikh gegrindet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
