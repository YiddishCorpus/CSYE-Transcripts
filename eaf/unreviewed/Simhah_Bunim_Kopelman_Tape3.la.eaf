			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>s'iz gekumen tsu mir tsu geyn der un der man</ANNOTATION_VALUE>
