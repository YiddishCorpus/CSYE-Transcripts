		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>eh mayn shvoger's mit f- mitn shver, UNK zayn frier</ANNOTATION_VALUE>
