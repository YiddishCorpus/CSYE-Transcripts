		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a972" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>m'hot bahaltn, zey hobn bahaltn alts oyfn boydem</ANNOTATION_VALUE>
