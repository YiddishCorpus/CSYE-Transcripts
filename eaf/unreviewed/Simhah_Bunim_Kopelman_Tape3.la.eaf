			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1049" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>"breng arayn der pol- UNK" mayn bruder. hot men arayngebrengt mayn bruder, tsehakt, tseshlogn</ANNOTATION_VALUE>
