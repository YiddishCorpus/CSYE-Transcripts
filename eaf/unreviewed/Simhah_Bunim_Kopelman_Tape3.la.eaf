		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a958" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>a &lt;Poyln&gt; yugnt farvayl lager far di geto.</ANNOTATION_VALUE>
