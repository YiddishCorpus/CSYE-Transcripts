		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1051" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>az ikh bin UNK ot di UNK az d'host oysbahaltn alts vos ikh hob gegebn</ANNOTATION_VALUE>
