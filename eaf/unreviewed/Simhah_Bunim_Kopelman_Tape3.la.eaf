		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>hot mayn shver gezen, er zol krign dort an arbet, er iz gevezn, der tate hot gehat a groyse ve- verkshtel. er hot gemakht mebl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>UND er iz gevorn UNK iz er dort gevorn oyser di geto bay dem &lt;POLEN&gt; yugnt farvayl lager, iz er gevorn a instruktor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
