			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a973" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>UNK gelt mit alts, un ayngemoyert in keler</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
