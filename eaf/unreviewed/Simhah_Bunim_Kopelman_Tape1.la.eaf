		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a32" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>eh zeks un tsvontsik, akht un tsvontsik hot men gegat der zeyde tsvey hayzer.</ANNOTATION_VALUE>
