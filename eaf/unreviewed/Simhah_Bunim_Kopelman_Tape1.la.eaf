		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>un dort zenen mir gevezn.</ANNOTATION_VALUE>
