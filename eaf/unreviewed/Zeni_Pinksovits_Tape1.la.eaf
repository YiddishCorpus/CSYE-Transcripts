		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>uh, fabrik fun tsigl, fun di,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>un dort ze'mir oykhet gevezn a, an etlekh- a por tog, nisht lang.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts787">
				<ANNOTATION_VALUE>un fun dort...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts788" TIME_SLOT_REF2="ts791">
				<ANNOTATION_VALUE>fun blokn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1304" TIME_SLOT_REF1="ts792" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>dort hot men shoyn ongehoybn tsu firn tsu bislekh, uh, a tsvey, d- oyf tsvey mol ober oyf dray mol hot men shoyn avekgefirt di, ale yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>m'hot ayngevagonirt in di vagonen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>un fun dort hot men undz gefirt oyf Oyshvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts800" TIME_SLOT_REF2="ts803">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a430" TIME_SLOT_REF1="ts804" TIME_SLOT_REF2="ts807">
				<ANNOTATION_VALUE>s'hot genumen a por teg. tog un nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts808" TIME_SLOT_REF2="ts810">
				<ANNOTATION_VALUE>tog un nakht hot men undz gefirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts811" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>un farmakht ze'mir gevezn azoyns vi,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts813" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>uh, vi azoy, vi ven me firt beheymes, ferd, m- azolkhe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1300" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts819">
				<ANNOTATION_VALUE>ober undz ho'mir moyre gehat aroystsukukn oykhet, vayl zey hobn gekent i durkhshtekhn oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts818" TIME_SLOT_REF2="ts820">
				<ANNOTATION_VALUE>z- m'hot geflegt tsu veynen, me zol gebn a bisl vaser. m'hot nisht gegebn gornisht undz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts822" TIME_SLOT_REF2="ts825">
				<ANNOTATION_VALUE>keyn... on esn un on trinken.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts826" TIME_SLOT_REF2="ts828">
				<ANNOTATION_VALUE>vos mir ho'mir gehat, dos ho'mir gegesn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts830" TIME_SLOT_REF2="ts833">
