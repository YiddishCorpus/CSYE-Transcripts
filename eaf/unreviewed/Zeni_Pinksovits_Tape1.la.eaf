			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts764" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>funem geto? demolts hot men ongehoybn, s'iz gevezn a tsu fri,</ANNOTATION_VALUE>
