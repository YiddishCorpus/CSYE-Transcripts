			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a489" TIME_SLOT_REF1="ts981" TIME_SLOT_REF2="ts982">
				<ANNOTATION_VALUE>un vemen, az s'iz nisht oysgekumen, ober zi hot zikh tsekokht, &lt;iz zikh&gt; tsegangen in di zakhn,</ANNOTATION_VALUE>
