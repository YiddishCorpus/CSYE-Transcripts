			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a528" TIME_SLOT_REF1="ts1083" TIME_SLOT_REF2="ts1084">
				<ANNOTATION_VALUE>un ikh hob ir gezogt az zekhtsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a529" TIME_SLOT_REF1="ts1085" TIME_SLOT_REF2="ts1086">
				<ANNOTATION_VALUE>hot zi gezogt, "zolst nisht zogn zekhtsn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a530" TIME_SLOT_REF1="ts1087" TIME_SLOT_REF2="ts1088">
				<ANNOTATION_VALUE>vayl az tomer du vest zogn zekhtsn, vestu avekgeyn tsishn di kinder in, in gaz-kamer. zolst zogn akhtsn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a531" TIME_SLOT_REF1="ts1089" TIME_SLOT_REF2="ts1090">
				<ANNOTATION_VALUE>un s'iz azoy gevezn. i-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a533" TIME_SLOT_REF1="ts1091" TIME_SLOT_REF2="ts1092">
				<ANNOTATION_VALUE>iz ze'mir geshtanen oysgeshuret.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a534" TIME_SLOT_REF1="ts1093" TIME_SLOT_REF2="ts1094">
				<ANNOTATION_VALUE>mikh hot men alts oyf hintn geshtelt, di shvesters, vayl ikh bin kleyn gevezn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a535" TIME_SLOT_REF1="ts1095" TIME_SLOT_REF2="ts1097">
				<ANNOTATION_VALUE>un er iz...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a536" TIME_SLOT_REF1="ts1099" TIME_SLOT_REF2="ts1101">
				<ANNOTATION_VALUE>ikh bin krank oykhet gevezn, ober m'hot nokh nisht gekent azoy zen oyf mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a537" TIME_SLOT_REF1="ts1103" TIME_SLOT_REF2="ts1104">
				<ANNOTATION_VALUE>fun hunger,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a538" TIME_SLOT_REF1="ts1105" TIME_SLOT_REF2="ts1107">
				<ANNOTATION_VALUE>dos ken men nisht zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a539" TIME_SLOT_REF1="ts1110" TIME_SLOT_REF2="ts1112">
				<ANNOTATION_VALUE>hu- hunger hot...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a540" TIME_SLOT_REF1="ts1113" TIME_SLOT_REF2="ts1115">
				<ANNOTATION_VALUE>geshlogn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1311" TIME_SLOT_REF1="ts1116" TIME_SLOT_REF2="ts1119">
				<ANNOTATION_VALUE>&lt;kh'hob,&gt; ikh hob bakumen eyn mol a patsh, vos ikh bin geshtanen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a541" TIME_SLOT_REF1="ts1118" TIME_SLOT_REF2="ts1120">
				<ANNOTATION_VALUE>un gekukt oyfn drot, oyfn elektrye-drot,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a542" TIME_SLOT_REF1="ts1121" TIME_SLOT_REF2="ts1122">
				<ANNOTATION_VALUE>un s'hot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a543" TIME_SLOT_REF1="ts1123" TIME_SLOT_REF2="ts1124">
				<ANNOTATION_VALUE>gevezn, s'iz geven &lt;in,&gt; geregnt. ikh hob nisht in akht genumen az di S.S.ke kumt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a544" TIME_SLOT_REF1="ts1125" TIME_SLOT_REF2="ts1126">
				<ANNOTATION_VALUE>nor plutsling shpir ikh a patsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a545" TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1129">
				<ANNOTATION_VALUE>az di gantse zayt iz mir geshvoln gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1312" TIME_SLOT_REF1="ts1130" TIME_SLOT_REF2="ts1133">
				<ANNOTATION_VALUE>stam. far gornisht. zi hot mir gegebn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1313" TIME_SLOT_REF1="ts1134" TIME_SLOT_REF2="ts1137">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a546" TIME_SLOT_REF1="ts1138" TIME_SLOT_REF2="ts1141">
				<ANNOTATION_VALUE>un... a patsh in ponem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a547" TIME_SLOT_REF1="ts1142" TIME_SLOT_REF2="ts1148">
				<ANNOTATION_VALUE>ikh hob es gefilt in oyer, un ikh meyn az oyfn hayntikn tog fil ikh dos, vos ikh her nisht azoy gut oyfn oyer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a548" TIME_SLOT_REF1="ts1149" TIME_SLOT_REF2="ts1150">
				<ANNOTATION_VALUE>tsk, nu, un demolts iz tsugekumen Mengele, un kh'hob im gezogt... er hot mikh aroysgeshlept,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a549" TIME_SLOT_REF1="ts1151" TIME_SLOT_REF2="ts1152">
				<ANNOTATION_VALUE>un ikh hob im gezo- er fregt mikh, "vifl yor bist alt?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1315" TIME_SLOT_REF1="ts1153" TIME_SLOT_REF2="ts1154">
				<ANNOTATION_VALUE>zog ikh, "akhtsn." zogt er, "du host a mazl. gey tsurik."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a550" TIME_SLOT_REF1="ts1155" TIME_SLOT_REF2="ts1157">
				<ANNOTATION_VALUE>un azoy bin ikh tsurikgegangen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a551" TIME_SLOT_REF1="ts1158" TIME_SLOT_REF2="ts1161">
				<ANNOTATION_VALUE>nu, di andere zenen dokh shoyn geven groyse.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a552" TIME_SLOT_REF1="ts1163" TIME_SLOT_REF2="ts1165">
				<ANNOTATION_VALUE>un azoy ho'mir undz zikh gehaltn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a553" TIME_SLOT_REF1="ts1168" TIME_SLOT_REF2="ts1172">
				<ANNOTATION_VALUE>zi hot shoyn gehat. zi iz &lt;oy-&gt; zeyer a shvakhe gevezn. zi hot gef&lt;r&gt;egt khotshik ven...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a554" TIME_SLOT_REF1="ts1173" TIME_SLOT_REF2="ts1174">
				<ANNOTATION_VALUE>vayl zi hot nisht gekent esn deys esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a555" TIME_SLOT_REF1="ts1175" TIME_SLOT_REF2="ts1176">
				<ANNOTATION_VALUE>m'hot undz gegebn a sup,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a556" TIME_SLOT_REF1="ts1177" TIME_SLOT_REF2="ts1178">
				<ANNOTATION_VALUE>vos mir ho'mir getrofn fun mentshn di negl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a557" TIME_SLOT_REF1="ts1179" TIME_SLOT_REF2="ts1181">
				<ANNOTATION_VALUE>f- mentshn-fleysh, di negl, fingers ho'mir getrofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a559" TIME_SLOT_REF1="ts1183" TIME_SLOT_REF2="ts1184">
				<ANNOTATION_VALUE>un zi hot dos gezen... dos iz nokh geven onfang... hot zi geflegt khaleshn, un zi hot dos nisht gekent esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a560" TIME_SLOT_REF1="ts1185" TIME_SLOT_REF2="ts1186">
				<ANNOTATION_VALUE>ober s'iz nisht geven keyn andere breyre;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a561" TIME_SLOT_REF1="ts1187" TIME_SLOT_REF2="ts1188">
				<ANNOTATION_VALUE>m'hot zikh gemuzt nemen esn alding.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a562" TIME_SLOT_REF1="ts1189" TIME_SLOT_REF2="ts1190">
				<ANNOTATION_VALUE>tsk, azoy vos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a563" TIME_SLOT_REF1="ts1191" TIME_SLOT_REF2="ts1192">
				<ANNOTATION_VALUE>mir ho'mir zikh zeyer a sakh ongelitn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a564" TIME_SLOT_REF1="ts1193" TIME_SLOT_REF2="ts1194">
				<ANNOTATION_VALUE>in Oyshvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a565" TIME_SLOT_REF1="ts1195" TIME_SLOT_REF2="ts1197">
				<ANNOTATION_VALUE>m'hot undz gefirt arbetn. mir ho'mir zeyer shver gearbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a566" TIME_SLOT_REF1="ts1199" TIME_SLOT_REF2="ts1202">
				<ANNOTATION_VALUE>s'iz geven arbet vos mir ho'm- m'hot undz gegebn groyse b- uh, beymer... ir v- ETS... tsu trogn, f-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a567" TIME_SLOT_REF1="ts1203" TIME_SLOT_REF2="ts1204">
				<ANNOTATION_VALUE>dray, fir meydlekh, vos mir ho'mir zikh unter dem untergerisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts1205" TIME_SLOT_REF2="ts1207">
				<ANNOTATION_VALUE>s'iz gevezn, vos zey zenen gegangen, zey hobn UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a569" TIME_SLOT_REF1="ts1208" TIME_SLOT_REF2="ts1212">
				<ANNOTATION_VALUE>trogn fun eyn plats oyfn andern. nor mutshen undz, plogn undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a570" TIME_SLOT_REF1="ts1213" TIME_SLOT_REF2="ts1214">
				<ANNOTATION_VALUE>un dernokh dem iz gevezn, vos zey zenen gegangen, zey hobn oysgeshnitn azolekhe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a571" TIME_SLOT_REF1="ts1215" TIME_SLOT_REF2="ts1216">
				<ANNOTATION_VALUE>k- kestelekh, vi do iz oykhet, vi &lt;g-&gt; mit groz, azolekhe leymen trogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a572" TIME_SLOT_REF1="ts1217" TIME_SLOT_REF2="ts1219">
				<ANNOTATION_VALUE>zey hobn undz geplogt vi azoy zey hobn nor gekent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a573" TIME_SLOT_REF1="ts1223" TIME_SLOT_REF2="ts1225">
				<ANNOTATION_VALUE>in Oyshvits ze'mir geven an etlekhe khadoshim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a574" TIME_SLOT_REF1="ts1228" TIME_SLOT_REF2="ts1230">
				<ANNOTATION_VALUE>ale mol ze'mir undz in eynem geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a575" TIME_SLOT_REF1="ts1231" TIME_SLOT_REF2="ts1233">
				<ANNOTATION_VALUE>dos hot keyner nisht gevust az undz ze'mir shvesters,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a576" TIME_SLOT_REF1="ts1234" TIME_SLOT_REF2="ts1238">
				<ANNOTATION_VALUE>vayl ven me veyst az ze'mir shvester, tseteylt men undz, tut men UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts1239" TIME_SLOT_REF2="ts1240">
				<ANNOTATION_VALUE>m- keyner hot dos nisht gevust, nor ven ze'mir shoyn aroysgekumen fun Oyshvits in arbets-lager,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts1241" TIME_SLOT_REF2="ts1242">
				<ANNOTATION_VALUE>demolts zenen gekumen di meydlekh, oykhet vos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts1243" TIME_SLOT_REF2="ts1244">
				<ANNOTATION_VALUE>undz kukn, vunder:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a580" TIME_SLOT_REF1="ts1245" TIME_SLOT_REF2="ts1246">
				<ANNOTATION_VALUE>"vu zenen dey fir shvester&lt;n&gt; vos zenen aroysgekumen funem lager?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts1247" TIME_SLOT_REF2="ts1248">
				<ANNOTATION_VALUE>fun demolts on hot men undz shoyn nisht gev- tseteylt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a582" TIME_SLOT_REF1="ts1249" TIME_SLOT_REF2="ts1250">
				<ANNOTATION_VALUE>az, &lt;uh, me z-&gt; m'hot gezogt, az undz ho'mir gekent fun Oyshvits aroyskumen fir shvesters, tor men undz shoyn nisht tseteyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a583" TIME_SLOT_REF1="ts1255" TIME_SLOT_REF2="ts1256">
				<ANNOTATION_VALUE>BESEDER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
