		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a500" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1009">
				<ANNOTATION_VALUE>uh, m'hot ir, uh, m'hot zi nisht geshikt arbetn, ober dernokh dem hot men ongehoybn shoyn tsamtsunemen dey, vos zey hobn...</ANNOTATION_VALUE>
