		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts696" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>un s'iz eyn mol shabes, ze'mir: s'iz shoyn shpet, er iz nishto, &lt;er iz&gt; nishto.</ANNOTATION_VALUE>
