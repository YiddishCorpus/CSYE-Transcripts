			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>demolts iz men arayngegangen dort in shil un m'hot zey geharget un geshlogn, di yidn.</ANNOTATION_VALUE>
