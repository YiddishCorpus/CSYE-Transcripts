			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>un m'iz arayngekumen. m'hot ongehoybn tsu shrayen,</ANNOTATION_VALUE>
