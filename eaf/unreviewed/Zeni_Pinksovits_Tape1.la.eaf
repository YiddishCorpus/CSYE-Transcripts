		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a526" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1075">
				<ANNOTATION_VALUE>slovakish meydl. zi hot geredt a bisl ungarish.</ANNOTATION_VALUE>
