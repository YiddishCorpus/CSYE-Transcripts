		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts703">
				<ANNOTATION_VALUE>der tate hot gehat a bord, iz er gekumen aheym mit a halbe bord; a halb hot men im oysgeflikt.</ANNOTATION_VALUE>
