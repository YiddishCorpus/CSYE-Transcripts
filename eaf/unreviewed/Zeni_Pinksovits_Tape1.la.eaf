		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a527" TIME_SLOT_REF1="ts1081" TIME_SLOT_REF2="ts1082">
				<ANNOTATION_VALUE>un zi hot mikh demolts a freg getun, "vifl yor bistu alt?"</ANNOTATION_VALUE>
