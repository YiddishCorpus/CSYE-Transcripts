		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>di groyse iz geven nor, m'hot im genemen, di HUNGARIM hobn im genemen oyf arbet nor,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>nisht in a MAKHANE, lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>ikh bin nokh ge-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>kh'hob nisht gevust vu er voynt afile. kh'hob gefregt dort fun mentshn, fun yidn, vu may- azoy un azoy, di nomen, Lakhmanovitsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts745">
				<ANNOTATION_VALUE>vu voynt? hot men mir gezogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
