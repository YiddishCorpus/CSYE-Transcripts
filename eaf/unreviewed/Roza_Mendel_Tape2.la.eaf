		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts655">
				<ANNOTATION_VALUE>&lt;un zey hobn&gt; geshosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>yo, ikh hob gekent geyn, KEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts666" TIME_SLOT_REF2="ts667">
				<ANNOTATION_VALUE>voynen, yo, bay dem altn mentsh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts668" TIME_SLOT_REF2="ts671">
				<ANNOTATION_VALUE>ober nisht a sakh tsayt ze'mir gezesn dortn. nokh dem hot men gezogt, s'iz do a transport TSHEKHI. s'iz geven ungarishe transport,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts672" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>nor ikh hob nisht gevolt, uh, blaybn dortn, un nokh dem aleyn ikh'l darfn forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>ikh hob nisht gevolt forn mit di ungarishe transport.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>ikh hob gehert az di tshekhishe transport nemt men,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>un bin ikh oykh gegangen. m'hot undz gefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>m'hot undz gefirt in MÜNCHEN,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts689">
				<ANNOTATION_VALUE>un ikh gedenk nisht nokh vu. m'hot undz shoyn, uh, gefirt oyf aheym, oyf aheym,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts690" TIME_SLOT_REF2="ts691">
				<ANNOTATION_VALUE>oyf TSHEKHYA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>zog ikh, oyf, uh... a! koydem bin ikh geforn in Budapest. ikh bin geblibn shteyn in Budapest. ikh bin arayn bay mayne BOSIT,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>un zi hot gevolt, zol ikh teykef kumen arbetn, ober ikh hob gezogt, "ikh vil geyn zen MISHPAKHA. ULAY UNK geblibn lebn. ikh muz geyn zen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>ver iz geblibn lebn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>hot zi gezogt, "BESEDER." zi iz farshtanen; zi iz oykh geven in lager, zi iz oykh geven a YEHUDIYA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>iz hot zi gezogt, "kum tsurik. gey, zits a bisl, a por vokhn BABAYIT, un dernokh dem, kum tsurik." un azoy iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts713">
				<ANNOTATION_VALUE>ven ikh bin shoyn avekgeforn fun di shtot MUKAČEVO, nokh tsvey vokhn, di RUSIM, RUSYA hot tsugemakht di GVUL. ven ikh zits nokh tsvey vokhn, ikh ken nisht aroysgeyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts714" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>darf ikh blaybn dortn, o, a sakh yorn biz ven me lozt aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts718" TIME_SLOT_REF2="ts721">
				<ANNOTATION_VALUE>a por vokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts722" TIME_SLOT_REF2="ts727">
				<ANNOTATION_VALUE>&lt;dernokh&gt; bin ikh geforn tsurik arbetn dortn bay mayn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts728" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>nu, hob ikh getrofn mayn groyse bruder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>mayn groyse bruder. un di kleyne bruder iz gekumen oykh fun di MA- fun di lagern. er iz geven in AUSCHWITZ,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
