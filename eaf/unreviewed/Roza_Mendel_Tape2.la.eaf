				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts778" TIME_SLOT_REF2="ts781">
				<ANNOTATION_VALUE>nor di... neyn! koydem &lt;di,&gt; eyn bruder, vemen kh'hob gezukht vu er voynt.</ANNOTATION_VALUE>
