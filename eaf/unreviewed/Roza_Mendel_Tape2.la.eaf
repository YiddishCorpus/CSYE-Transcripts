				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a406" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>ales aroysgeganvet. ikh veys nisht ver hot avekgenemen di meblen mit di zakhn,</ANNOTATION_VALUE>
