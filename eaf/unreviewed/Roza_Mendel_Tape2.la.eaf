			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>amerikanishe soldatn iz geven, KHAYALIM AMERIKAIM,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>UNK zey zenen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>gekumen oykhet dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
