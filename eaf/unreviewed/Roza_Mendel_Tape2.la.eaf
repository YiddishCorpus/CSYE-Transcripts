			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts782" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>di andere iz gekumen oykhet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts787">
				<ANNOTATION_VALUE>fun di MAKHANE. &lt;KEN&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts788" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>yo, iz er oykhet aheymgekumen, ho'mir zikh ale dortn getrofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>oykh mayne shvegerin's shvester zenen gekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>mayn bruder's froy...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>a! di bruder's froy iz oykh geblibn lebn. zi iz geven in a lager, in AUSCHWITZ.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>zi iz gekumen oykh aheym, &lt;azoy vos, ven,&gt; zi iz geven, d- geven di KHATUNA ven mayn IMA hot nokh gelebt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts799" TIME_SLOT_REF2="ts801">
				<ANNOTATION_VALUE>ober zey zenen gek- er iz gekumen aheym fun di arbet vu m'hot im genemen, un zi iz gekumen fun AUSCHWITZ a-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts802" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>yo. zey hobn zikh getrofn tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>zenen, zi iz oykh geven do. zi iz do geshtorbn; zi iz geven krank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts809">
				<ANNOTATION_VALUE>un ZEHU.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts810" TIME_SLOT_REF2="ts817">
				<ANNOTATION_VALUE>mhm, kh'hob getrofn di MORE, di MORE vos ikh bin gegangen in shule UKRAINIT, hob ikh getrofn, geredt mit i-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts821">
				<ANNOTATION_VALUE>ver, er?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts822" TIME_SLOT_REF2="ts823">
				<ANNOTATION_VALUE>yo, yo, er hot zikh gefreyt, KEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts824" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>kh'hob nokh gekent demls UKRAINIT redn. yetst ikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts830">
				<ANNOTATION_VALUE>ken nisht mer azoy. uh, finef, tsvey, dray verter ikh ken nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts831" TIME_SLOT_REF2="ts832">
				<ANNOTATION_VALUE>un vemen nokh? neyn, azoy nisht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts833" TIME_SLOT_REF2="ts835">
				<ANNOTATION_VALUE>nor di MORE UK- fun UKRAINIT.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a429" TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts841">
				<ANNOTATION_VALUE>vi azoy m'hot zikh gefilt az m'iz gekumen tsurik?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a430" TIME_SLOT_REF1="ts843" TIME_SLOT_REF2="ts844">
				<ANNOTATION_VALUE>nu, &lt;me&gt;, m'hot zikh nisht gefilt gut. az m'iz gegangen bay di shtub fun di HORIM un m'hot nisht getrofn keynem, hot men nisht gefilt gut, oder vos hot men gekent makhn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts846">
				<ANNOTATION_VALUE>UNK gegangen bodn. dort iz ge- ikh ken gut shvimen; ikh bin gegangen shvimen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts847" TIME_SLOT_REF2="ts848">
				<ANNOTATION_VALUE>un mayn shvegerin iz geven a shnayderin. ikh hob ir geholfn a bisele neyen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts849" TIME_SLOT_REF2="ts850">
				<ANNOTATION_VALUE>un bay di shtub, ikh hob ir geholfn, di parketn gemakht, uh reyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts853">
				<ANNOTATION_VALUE>KVISA ikh hob ir gemakht. kh'hob ge- farnemen zikh a bisele, fargesn fun di TSAROT. KEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts856">
				<ANNOTATION_VALUE>far vos?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>ikh hob tsugezogt far mayne mayster, far di BOSIT, az ikh kum tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
