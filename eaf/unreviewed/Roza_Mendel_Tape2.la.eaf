			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts746" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>azoy hob ikh getrofn mayn bruder, un</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
