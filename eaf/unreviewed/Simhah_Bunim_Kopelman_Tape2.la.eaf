			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>UNK mit di bilder &lt;zits ikh&gt; in drinen</ANNOTATION_VALUE>
