		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1222" TIME_SLOT_REF1="ts958" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>zi hot shoyn nit getrakht az zi vet mikh shoyn keyn mol nisht zen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts962" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>nu, zi hot gevust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
