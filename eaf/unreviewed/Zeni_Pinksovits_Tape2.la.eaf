				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts954" TIME_SLOT_REF2="ts957">
				<ANNOTATION_VALUE>zi hot nit a mol ge-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
