		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts910">
				<ANNOTATION_VALUE>er hot mikh dos, un demolts hot er mir gegebn, er hot zikh opgezegnt, un azoy iz er avek.</ANNOTATION_VALUE>
