			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1234" TIME_SLOT_REF1="ts914" TIME_SLOT_REF2="ts917">
				<ANNOTATION_VALUE>neyn, neyn, neyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts916" TIME_SLOT_REF2="ts918">
				<ANNOTATION_VALUE>ikh gedenk nisht, nor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>er hot zikh mit mir az-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>azoy vi a tate hot er zikh mit mir banumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>un ikh bin aheymgekumen. undz ho'mir gehat a bisl zakhn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts928" TIME_SLOT_REF2="ts930">
				<ANNOTATION_VALUE>zi iz aheymgekumen un ikh bet fun ir, zog ikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>az ikh vil mikh opvashn, ikh vil mikh iberton, vayl ikh bin shmutsik. zogt zi, "do host dokh nisht in vos ibertsuvashn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>vayl," zogt zi, "m'hot aropgeshikt, di rusishe hobn aropgeshikt az m'vet roymen dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>tsug, un m'hot ales tsugenumen. s'iz nishto gornisht."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>azoy vi ze'mir geblibn on alem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
