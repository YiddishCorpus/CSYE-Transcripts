			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts968" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts972">
				<ANNOTATION_VALUE>ikh bin gekumen oyf MUNKÁCS, hob ikh zi getrofn, v&lt;i&gt; zi iz oykhet gevezn mit andere meydlekh, in eynem gevoynt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts973" TIME_SLOT_REF2="ts974">
				<ANNOTATION_VALUE>un dort ho'mir geshlofn in eynem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts976">
				<ANNOTATION_VALUE>a shtikl tsayt, un dernokh dem ho'mir zikh vayter tseteylt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts977" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>nisht mit Miryemen UNK mit di andere meydlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts983" TIME_SLOT_REF2="ts984">
				<ANNOTATION_VALUE>in MUNKÁCS hot men undz gegebn dray mol in tog tsu esn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>m'hot undz dernokh gebn shikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts988">
				<ANNOTATION_VALUE>un ikh gedenk nisht tsi m'hot bakumen tsi nisht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts989" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>epes hilf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts993">
				<ANNOTATION_VALUE>dernokh dem hot zikh getrofn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts997">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts998" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>dernokh dem hot zikh getrofn, der bruder vos er iz in Amerike,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1003">
				<ANNOTATION_VALUE>er hot undz shoyn geholfn a sakh. er hot undz gevolt avekfirn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1010">
				<ANNOTATION_VALUE>er iz gevezn do. koydem iz er do gevezn, ober er iz shoyn dort a sakh yorn, fun Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1225" TIME_SLOT_REF1="ts1012" TIME_SLOT_REF2="ts1015">
				<ANNOTATION_VALUE>Moyshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts1020" TIME_SLOT_REF2="ts1021">
				<ANNOTATION_VALUE>er iz gevezn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1227" TIME_SLOT_REF1="ts1022" TIME_SLOT_REF2="ts1025">
				<ANNOTATION_VALUE>er iz aheymgekumen, hot er nit a mol ge-... er hot gehert az s'iz Rusnland. er hot azoy moyre gehat fun di rusn vos er hot nit a mol gevolt kumen tsu di rusn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts1024" TIME_SLOT_REF2="ts1027">
				<ANNOTATION_VALUE>nor er iz grod avek oyf Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1228" TIME_SLOT_REF1="ts1028" TIME_SLOT_REF2="ts1031">
				<ANNOTATION_VALUE>er iz nisht gekumen oyf MUNKÁCS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts1032" TIME_SLOT_REF2="ts1035">
				<ANNOTATION_VALUE>er iz geblibn in Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1229" TIME_SLOT_REF1="ts1036" TIME_SLOT_REF2="ts1039">
				<ANNOTATION_VALUE>yo. dernokh dem iz er gekumen, ober nor azoy, un er iz tsurikgegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts1041" TIME_SLOT_REF2="ts1043">
				<ANNOTATION_VALUE>er iz avek oyf Amerike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts1051" TIME_SLOT_REF2="ts1052">
				<ANNOTATION_VALUE>m'hot ongehoybn tsu arbetn, ober v- spn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1054">
				<ANNOTATION_VALUE>zi hot khasene gehat, ikh bin krank gevorn, ikh bin geblibn lign,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts1055" TIME_SLOT_REF2="ts1057">
				<ANNOTATION_VALUE>un ikh bin...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts1059" TIME_SLOT_REF2="ts1060">
				<ANNOTATION_VALUE>ikh bin gelegn fir yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts1062" TIME_SLOT_REF2="ts1065">
				<ANNOTATION_VALUE>mitn rukn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts1068" TIME_SLOT_REF2="ts1070">
				<ANNOTATION_VALUE>s'iz nisht gevezn keyn, uh, demolts keyn medikamentn iz dokh gornisht nisht gevezn. s'iz nokh nisht gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts1071" TIME_SLOT_REF2="ts1072">
				<ANNOTATION_VALUE>dernokh dem in, shpeter, in a etlekhe yor arum,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1074">
				<ANNOTATION_VALUE>ze'mir gevor gevorn az der bruder iz in Amerike,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts1075" TIME_SLOT_REF2="ts1076">
				<ANNOTATION_VALUE>un er hot mir ongehoybn tsu shikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts1077" TIME_SLOT_REF2="ts1078">
				<ANNOTATION_VALUE>medikamentn, un azoy iz mir beser gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts1081" TIME_SLOT_REF2="ts1083">
				<ANNOTATION_VALUE>fir yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts1086" TIME_SLOT_REF2="ts1088">
				<ANNOTATION_VALUE>neyn. dos iz gevezn nor aza forem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts1089" TIME_SLOT_REF2="ts1091">
				<ANNOTATION_VALUE>un in dem hob ikh mikh araynge- arayngeleygt. ikh hob gekent fun dem oyfshteyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts1092" TIME_SLOT_REF2="ts1095">
				<ANNOTATION_VALUE>ober dos iz geven, der kop, alding, aza forem, in aza forem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts1096" TIME_SLOT_REF2="ts1098">
				<ANNOTATION_VALUE>UNK nu, spn, ikh hob nisht getort, ober</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts1099" TIME_SLOT_REF2="ts1101">
				<ANNOTATION_VALUE>kh'hob gemuzt oyfshteyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1231" TIME_SLOT_REF1="ts1102" TIME_SLOT_REF2="ts1104">
				<ANNOTATION_VALUE>fir yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts1107" TIME_SLOT_REF2="ts1109">
				<ANNOTATION_VALUE>in MUNKÁCS.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts1110" TIME_SLOT_REF2="ts1114">
				<ANNOTATION_VALUE>yo. zi hot khasene gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts1116" TIME_SLOT_REF2="ts1119">
				<ANNOTATION_VALUE>ikh bin geven bayn ir, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts1120" TIME_SLOT_REF2="ts1122">
				<ANNOTATION_VALUE>zi hot mikh gehaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts1127" TIME_SLOT_REF2="ts1129">
				<ANNOTATION_VALUE>vos hob ikh gekent tun? gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts1130" TIME_SLOT_REF2="ts1132">
				<ANNOTATION_VALUE>UNK ikh hob gehat shmertsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts1133" TIME_SLOT_REF2="ts1134">
				<ANNOTATION_VALUE>vos heyst shmertsn? d- dos... a! s'iz beser nisht tsu redn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts1135" TIME_SLOT_REF2="ts1136">
				<ANNOTATION_VALUE>di nervn zenen tsu grunt gegangen un s'iz nishto keyn nervn haynt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
