				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a167" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>ober ze'mir gevezn mit ukrainishe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>&lt;un&gt; zey zenen zeyer gezunt geven. vu zey hobn genumen dos esn, dos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a169" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>veys ikh nisht, nor ikh veys, eyn mol iz gekumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a170" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>un zi hot gesheylt kartofl, an ukrainke,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts485">
				<ANNOTATION_VALUE>un zi fregt mikh, tsi ikh vil di sholekhts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1202" TIME_SLOT_REF1="ts486" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>yo. zog ikh, "yo!" iz zi gegangen, mir gegebn aza patsh, az nor...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>dos iz antisemitn. dos iz UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts493">
				<ANNOTATION_VALUE>oykh punkt azolekhe antisemitn, nokh efsher argere vi di daytshn, di Ukrainers.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts494" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>oykhet, ober zi iz geven mit di hor, mit ongetun. zey hobn gearbet ergets, ikh veys nisht vu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1203" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts499">
				<ANNOTATION_VALUE>zey hobn gehat ales.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts506" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>s'iz&lt;, uh, g-&gt; arayngekumen englishe UNK soldatn. m'hot ongehoybn tsu shrayen, "ze'mir bafrayt, ze'mir bafrayt!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>un demolts hobn ongehoybn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>m'hot zeyer ongehoybn tsu khapn esn, un di &lt;sh-&gt; demolts zenen zeyer gefaln di mentshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>azoy vi flign.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>azoy iz &lt;e- un zenen zey tsam-&gt; oyf,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts519">
				<ANNOTATION_VALUE>oyfn hoyf un iberol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts520" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>undz ze'mir dokh tsamgetriknt geven; m'hot ongehoybn tsu esn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts527">
				<ANNOTATION_VALUE>un azoy vos...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts528" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>tsk, may- di fir shvester, iz eyne geshtorbn oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts534" TIME_SLOT_REF2="ts539">
				<ANNOTATION_VALUE>farn bafrayen. nisht lang farn bafrayen, efsher a tsvey vokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts542" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>Rivke iz geshtorbn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>vayl zi iz gegangen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>zi hot zikh oykh nebekh ge- getoysht, &lt;un, un&gt; zi hot,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts553">
				<ANNOTATION_VALUE>nu, di oyfgeyoyrene esns,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts554" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>un, un zi hot zikh bahaltn, undz zol'mir nisht zen, mir zol'mir fun ir nisht tsunemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts558">
				<ANNOTATION_VALUE>un dernokh &lt;dem iz zi,&gt; mir ho'mir zikh mit ir geplogt vi lang mir ho'mir gekent. mir ho'mir zi geshlept oyf di arbet, m'hot...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts559" TIME_SLOT_REF2="ts561">
				<ANNOTATION_VALUE>vifl mir ho'mir gekent, ober dernokh dem iz shoyn gekumen a tsayt vos...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1204" TIME_SLOT_REF1="ts562" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>yo. un vos zi hot zikh shoyn nisht gekent, uh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>hm, zi hot shoyn nisht gekent oyfshteyn, zi hot shoyn nisht gekent gornisht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>hot men undz geheysn, mir zol'mir zi nemen in a kots... ir veyst dokh vos a kots iz? in aza laylekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>in a dek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts575">
				<ANNOTATION_VALUE>in a dek araynleygn zi,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1205" TIME_SLOT_REF1="ts576" TIME_SLOT_REF2="ts579">
				<ANNOTATION_VALUE>un mir zol'mir zi avektrogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts578" TIME_SLOT_REF2="ts581">
				<ANNOTATION_VALUE>mir ho'mir zi avekgetrogn tsishn toyte. dort iz geven toyte, lebedike, un zi hot nokh geshrign, ober shoyn nisht oyf ir kol...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts582" TIME_SLOT_REF2="ts587">
				<ANNOTATION_VALUE>neyn, neyn! dos iz geven tsamgeleygt oyf tsum brenen di mentshn. neyn, dos iz nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts588" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>hot zi nokh gerufn di eltste shvester UNK zol zi nisht iberlozn, vayl az zi lozt zi iber, geyt zi oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>ober shoyn nisht oyf ir kol hot zi geredt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>un undz ho'mir dos gebroykht avektrogn un kumen tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>kent ir zikh forshteln az, vi azoy s'iz undz geven oyfn harts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>yetst, ven ze'mir bafrayt gevorn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>hot di eltste shvester ongehoybn tsu krenken,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>un m'hot oykhet... ikh hob shoyn nisht gehat keyn koyekh; ikh hob shoyn nisht gekent geyn helfn ir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts605">
				<ANNOTATION_VALUE>un d&lt;UNK&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts606" TIME_SLOT_REF2="ts607">
				<ANNOTATION_VALUE>di eltste shvester.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts608" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>dos iz shoyn geven bay di Engl&lt;e&gt;nder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts615">
				<ANNOTATION_VALUE>Sore.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts618">
				<ANNOTATION_VALUE>un zi iz gegangen un zi hot zikh geplogt un ge- gef-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>-trogn zi un geshlept zi,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1206" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
				<ANNOTATION_VALUE>un s'iz geforn&lt;, hot, zi&gt; hot dertseylt, englishe soldatn mit mashinen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1207" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts625">
				<ANNOTATION_VALUE>un keyner hot ir nisht geholfn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts624" TIME_SLOT_REF2="ts626">
				<ANNOTATION_VALUE>me zol ir helfn, me zol zi geven nemen ober ergets avekfirn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>azoy vi zi iz oykh ergets unter vegns geblibn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>un vos s'hot mit ir pasirt veys'mir keyn mol nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts633">
				<ANNOTATION_VALUE>zi iz geshtorbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts634" TIME_SLOT_REF2="ts637">
				<ANNOTATION_VALUE>yo. shoyn nokhn bafrayen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts641">
				<ANNOTATION_VALUE>un undz tsvey ze'mir geblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts642" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>ober ikh bin oykhet zeyer krank gevezn. ikh hob oykh, m'hot nisht gekent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>nisht oyf di fis shteln, nisht...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>ikh bin shoyn oykh gevezn azoy... m'hot nit a mol geklert az ikh'l lebn blaybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts652" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>tsk, nisht lang.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts656" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>nisht lang. m'hot undz... a tsvey vokhn, ikh veys... m'hot undz &lt;tsamge-&gt; m'hot undz ibergetun, m'hot undz gegebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts663">
				<ANNOTATION_VALUE>andere zakhn, m'hot opgebodn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1215" TIME_SLOT_REF1="ts664" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>di engl- englishe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1209" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts668">
				<ANNOTATION_VALUE>un m'hot undz avekgefirt oyf BERGEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>dos iz gevezn, BERGEN, aza groys,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>uh, UNK, ikh meyn az dos hot gekent zayn efsher aza shtal ober vos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>ikh gedenk dos oykhet, s'iz geven shvues, vi azoy s'iz gekumen an englisher ofitsir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>mit k- kinder, mit a tales ongetun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts679">
				<ANNOTATION_VALUE>un er hot gedavnt...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1210" TIME_SLOT_REF1="ts680" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>a yidisher. dos iz shoyn nokhn bafrayen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>un mir dakht zikh dos alts tsu,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>az dos, er iz oykhet dort gevezn, Hertse- Hertsog, &lt;ts-&gt; der m-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a242" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts689">
				<ANNOTATION_VALUE>er hot bafrayt BERGEN-BEL&lt;ts&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts690" TIME_SLOT_REF2="ts692">
				<ANNOTATION_VALUE>Khaim Hertsog. un mir hot zikh alts tsugedakht az aza mentsh un aza mentsh hot dos gevezn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>ver s'iz geshtanen mitn tales un gege- un gedavnt undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts696" TIME_SLOT_REF2="ts699">
				<ANNOTATION_VALUE>in BERGEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts700" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>er, er iz gevezn hintn. s'iz geven aza, hintn oyf di gas,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>un undz ho'mir gekukt aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>epes aza voynung, ober ikh meyn az dos hot gekent zayn azolekhe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts715">
				<ANNOTATION_VALUE>fun, fun ferd ober fun vos. dos iz gevezn hoykh oykhet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1212" TIME_SLOT_REF1="ts716" TIME_SLOT_REF2="ts719">
				<ANNOTATION_VALUE>ob-... esn hot men, esn hot men undz gegebn, yo. zey hobn undz shoyn dernokh gegebn esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts720" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>&lt;y- f-&gt; yo. zey hobn gekokht un,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts725">
				<ANNOTATION_VALUE>u- un zey hobn UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts726" TIME_SLOT_REF2="ts729">
				<ANNOTATION_VALUE>s'iz geven farshidene.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1213" TIME_SLOT_REF1="ts730" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>s'iz geven, ikh gedenk, s'iz geven tsigayners oykhet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>ver s'iz geblibn lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts740" TIME_SLOT_REF2="ts741">
				<ANNOTATION_VALUE>shvues,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts742" TIME_SLOT_REF2="ts745">
				<ANNOTATION_VALUE>erev shvues...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1214" TIME_SLOT_REF1="ts746" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>ikh veys nisht. ikh veys nisht. nor v- loyt vi azoy er hot dertseylt... ikh hob gehert in televizor, in dos...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts755">
				<ANNOTATION_VALUE>azolekhe ofitsirn zenen geven, groyse ofitsirn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts756" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>ikh veys, er hot bafrayt, er hot gezogt, er hot bafrayt BERGEN-BEL&lt;ts&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>dort ze'mir nisht geven tsu lang,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>vayl dernokh dem hot men shoyn ongehoybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>undz, m- me zol geyn aheym, firn undz aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts768" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>&lt;eh,&gt; m'hot &lt;undz&gt; shoyn gegebn, spn, mashinen, m'hot undz shoyn aribergefirt oyf, uhm,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>Daytshnland, oyf Tshekhay, &lt;d-&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts774">
				<ANNOTATION_VALUE>un fun dort hot men undz oyf</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>vagonen shoyn, oyf tseger, un m'hot undz gefirt durkh Pest.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>ikh hob nisht gevolt geyn tsurik. ikh hob gevolt geyn &lt;v-&gt;... vayl ikh bin aropgeblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>ikh bin aropgegangen funem tsug,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>un der tsug hot avekgerirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>un ikh bin aropgeblibn in gantsn aleyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>zi iz geven oyvn, in, in vago- in tsug, un ikh bin arop,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>un s'iz avek der</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>tsug... avek, yo, avek &lt;ts-&gt; avekgefo- -forn, un i- un ikh bin dort geblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>a! s'iz beser zikh nisht tsu dermanen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>&lt;vi azoy&gt; ikh bin dort geblibn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts810">
				<ANNOTATION_VALUE>in voser... keyner iz nisht geven. dos iz gevezn nor aza p-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts811" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>pustenish, nor azoy fil a dos, un vi azoy...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts813" TIME_SLOT_REF2="ts814">
				<ANNOTATION_VALUE>ikh bin gegangen, kh'hob zeyer geveynt, un gegangen fregn ven s'vet vayter forn a tsug.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts820">
				<ANNOTATION_VALUE>hot men mir gezogt, "do forn nisht keyn tseger, nor azolekhe last..." vos firt dos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>eyn mol in a vokh, tsi ikh veys. "n-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts823" TIME_SLOT_REF2="ts824">
				<ANNOTATION_VALUE>nor," zogt er, "dort remontirt men a tsug."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts825" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>&lt;un vi z-&gt; spn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts829">
				<ANNOTATION_VALUE>tsk, spn, tsishn rusishe soldatn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1217" TIME_SLOT_REF1="ts830" TIME_SLOT_REF2="ts833">
				<ANNOTATION_VALUE>zi iz geven oyfn tsug,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1218" TIME_SLOT_REF1="ts834" TIME_SLOT_REF2="ts837">
				<ANNOTATION_VALUE>un... ikh hob yo gevolt f-... ikh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1219" TIME_SLOT_REF1="ts838" TIME_SLOT_REF2="ts843">
				<ANNOTATION_VALUE>ikh bin aropgegangen vayl m'hot dokh gebroykht aropgeyn&lt;, hm&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts846">
				<ANNOTATION_VALUE>ikh bin a sakh shpeter aheymgekumen vi Miryem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts848" TIME_SLOT_REF2="ts851">
				<ANNOTATION_VALUE>zi aleyn iz aheymgeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts852" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>ikh hob, es iz geforn der tsug, un der tsug...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts856">
				<ANNOTATION_VALUE>un er hot ongehoybn tsu shrayen, der, vos er hot gefirt dem tsug,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>un rufn mikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>un eyner iz a shprung arop getun, un er hot mikh aroyfgeleygt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>un m'hot mikh gefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
				<ANNOTATION_VALUE>z- zey hobn ongehoybn tsu gebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts865" TIME_SLOT_REF2="ts866">
				<ANNOTATION_VALUE>zey hobn mir gegebn esn un ales. un eyner iz gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts867" TIME_SLOT_REF2="ts869">
				<ANNOTATION_VALUE>aza voyler mentsh. eyner iz geven a bisl aza...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts870" TIME_SLOT_REF2="ts873">
				<ANNOTATION_VALUE>tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1220" TIME_SLOT_REF1="ts874" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>un vi azoy er hot mikh nisht gelozt... er hot mir gezogt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>er vet mir nemen in Preshborg, vet er mir nemen a kart far zayn gelt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts883">
				<ANNOTATION_VALUE>un er vet mikh oysrikhtn biz aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts884" TIME_SLOT_REF2="ts887">
				<ANNOTATION_VALUE>ikh zog dokh aykh, dort vu ikh bin aropgeblibn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>un vi azoy, dernokh ze'mir geforn, un er hot &lt;dernakh&gt; genumen a transport</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>yidn vos zenen geforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>er hot geshtelt dem tsug vu m'hot nit a mol getort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>er iz aropgekumen mit mir. er hot gevolt zen vu,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>bay vemen ikh'l blaybn, mit vemen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>vayl di rusn zenen zeyer shlekht gevezn. di rusishe soldatn hobn getun azolekhe zakhn vos dos iz geven geferlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
				<ANNOTATION_VALUE>un er iz gekumen mit mir; er hot erleydikt ales</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts906">
				<ANNOTATION_VALUE>baym dem vos er hot, baym transport-firer,</ANNOTATION_VALUE>
