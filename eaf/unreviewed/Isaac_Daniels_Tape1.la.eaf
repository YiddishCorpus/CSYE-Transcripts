		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a488" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>ikh hob shoyn nisht geyn shlofn tsu mayn kuzine, vayl ikh tsol nisht, ikh ho- ikh hob nisht gekent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a490" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>iz do hot zi geveynt in di zayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a491" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>un di andere zayt hot men dortn ayngeleygt feser kroyt, ugerkes, dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a495" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>hob ikh zikh arayngeganvet dortn, un s'gelign aza shtikl plandeke,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a498" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts688">
				<ANNOTATION_VALUE>hob ikh avekgeleygt, do bin ikh geshlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a499" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts690">
				<ANNOTATION_VALUE>eyn nakht, nokh a nakht. vos vet zayn di ende?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a500" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts692">
				<ANNOTATION_VALUE>in Prage, ir veyst ir hot gehert vegn Prage?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a502" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>s'geven a brik fun Varshe arayntsugeyn, iz geven adurkhtsugeyn der brik hot men</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a503" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>iz geven a forshtot hot es geheysn Prage.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a504" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>in Prage hot gevoynt mayns a kuzin a kuzine, fun der raykher mume's a tokhter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a506" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts701">
				<ANNOTATION_VALUE>un er hot gehat WHOLESALE flegt er farkoyfn mel TO THE bekers.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a508" TIME_SLOT_REF1="ts700" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>geven a raykher, oykh nisht keyn oreman, a raykher man.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a509" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>hot er di TRAIN flegt arayngeyn dortn in der sklad arayn mit mel brengen mel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a510" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>zi hot zikh dervust vegn mayn lage. vi ariber veys ikh dokh nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a512" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts708">
				<ANNOTATION_VALUE>hot zi geshikt a BOY vos er hot mikh gekent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>un er hot zi hot im gezogt er zol mikh mit koyekh brengen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a515" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>az zi hot mir tsugegreyt an antsug, un m'hot gehat shikh mit mit altsding.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a517" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>der BOY iz gekumen, er hot mikh opgezukht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a519" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>un er hot mir dertseylt di ale mayses,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a520" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>un zogt er, un gerufn hobn zey mikh in Varshe Yizak.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a522" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>"du muzt geyn." hot er mikh genumen oyf koyekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a524" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>ikh bin aribergegangen. ikh bin aribergekumen dortn ahin, zi hot mikh ongekukt hot zi UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
