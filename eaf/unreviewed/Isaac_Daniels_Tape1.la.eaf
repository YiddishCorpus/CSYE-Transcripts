		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a452" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>ikh hob zikh oyf finef far tog kukn di PAPER efsher zukht men a shnayder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a454" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts643">
				<ANNOTATION_VALUE>epes eyn mol hob ikh gefunen eynem bin ikh gegangen, ober iz er nokh geshlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a456" TIME_SLOT_REF1="ts642" TIME_SLOT_REF2="ts645">
				<ANNOTATION_VALUE>azoy fri hob ikh gevart, ikh hob gehert az er vasht zikh, hob ikh shoyn ongeklapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a458" TIME_SLOT_REF1="ts644" TIME_SLOT_REF2="ts647">
				<ANNOTATION_VALUE>ANYWAY, ikh hob ge- hob ikh gearbet a tog, er hot nisht gehat mer keyn arbet far a, bloyz far eyn tog.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a460" TIME_SLOT_REF1="ts646" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>hob ikh opgearbet UNK. un hot zikh ongehoybn arum tse dreyen leydik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a462" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>ikh hob ongehoybn tsu hungern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a463" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>vi ikh hob aykh dertseylt, hob ikh gehungert eyn tog, tsveytn tog, bloyz a bisl vaser.</ANNOTATION_VALUE>
