			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a467" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>in dritn tog spn ze ikh s'biter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a469" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>un keyn seykhl hob ikh nisht gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a470" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
				<ANNOTATION_VALUE>ikh volt arayngegangen keyn, azoy vi ikh hob aykh gezogt, ikh volt arayngegan in a restoran, in a, a vashn di FLOOR, ikh vel aroystrogn a bi- eh s'blaybt genug esn in a restoran. BUT</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a471" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>hot mir nisht gegebn, bin ikh nisht gegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a472" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts662">
				<ANNOTATION_VALUE>hob ikh gehat a fraynt, trakht ikh mir, ven ikh tref dem fraynt, volt ikh bay im geborgt a halbe zlote.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a475" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>un ikh gey aroys,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a476" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>ikh hob gevoynt oyf Valinske, in Zamenhof iz geven azoy vi do in der front aroystsugeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a478" TIME_SLOT_REF1="ts667" TIME_SLOT_REF2="ts668">
				<ANNOTATION_VALUE>gib a kuk, er geyt do. un ikh gey tsu im tsu, zog ikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a480" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>Khenyek hot er geheysn, zog ikh, er iz arumgegangen mit mayn's a vayte kuzine.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a482" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>zey hobn gezolt geyn khasene hobn, azoy vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
