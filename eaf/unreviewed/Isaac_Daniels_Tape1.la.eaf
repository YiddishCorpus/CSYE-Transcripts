			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a178" TIME_SLOT_REF1="ts292" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>vos heyst orem? orem iz m'hot ehm</ANNOTATION_VALUE>
