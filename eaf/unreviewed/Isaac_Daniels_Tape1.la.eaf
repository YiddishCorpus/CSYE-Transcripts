			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a406" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>iz tsvelef a zeyger bin ikh gelofn dortn ahin, tsu di tsu di kuzine. ikh zol dort opesn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>ikh kum oyfn hoyf shteyt a meydl, vos ikh hob ir gekent fun hoyf, vos ikh hob ir gezen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a411" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>zogt zi mir, zi hot geheysn Malkele, zogt zi Malkele, iz er fargangen avektrogn mayn esn in der fabrik arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>er hot gemakht di, gedenk dokh m'hot getrogn getres.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts597" TIME_SLOT_REF2="ts598">
				<ANNOTATION_VALUE>nu az er iz avekgegangen un un un do di tsayt loyft, vi vayt hob ikh tsu geyn? zog ikh, ikh vel nisht esn mi- mitog.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>bin ikh gelofn krik tsu der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a418" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>ikh arbet sh- m- tsk epes epes darf geshen mit mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>un UNK nokh der arbet UNK. ikh gey nisht. ikh loyf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>un azoy vi ikh kum arayn, a geveyn! m'hot baganvet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>ikh hob nisht keyn SUIT, ikh hob nisht keyn, ikh bin geblibn a por PENCE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts611">
				<ANNOTATION_VALUE>mit der do vu ikh hob gearbet, hot er mir tsugezogt, m'hot zikh mashve gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts610" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>ir veyst vos mashve, m'hot zikh badungen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>er darf mir gebn fertsik zlotes a vokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts616">
				<ANNOTATION_VALUE>opgearbet di ershte vokh, get er mir tsvontsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts618">
				<ANNOTATION_VALUE>vayl er arbet arayn in a gesheft arayn, un in der heym iz geven a a aza STYLE, m'hot gegebn vekslen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>un dos hot men gedarft geyn diskontirn farlirn dray protsent, s'a gants gesheft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
				<ANNOTATION_VALUE>zogt er, er hot vekslen gekrign, er darf geyn diskontirn, er da- darf oykhet, SO er vet mir batsoln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
				<ANNOTATION_VALUE>iz gekumen di andere vokh dervayl, er hot gearbet mit mir azoy vayter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
				<ANNOTATION_VALUE>un dervayle krig ikh nisht di gelt, un fraytik git er mir vayter tsvontsiker dolar, blaybt shoyn fertsiker dolar shteyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>"montik vestu krign di gelt."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>ikh kum tsu geyn montik tsu der arbet, hengt a shlos oyf der tir, s'farshlosn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts633">
				<ANNOTATION_VALUE>un der shokhn di shkheynim zogn mir, az zenen avekgeforn oyf di linye, oyf di zumer voynung ergets.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a447" TIME_SLOT_REF1="ts632" TIME_SLOT_REF2="ts634">
				<ANNOTATION_VALUE>er hot mitgenumen a kepl fun der mashin, un iz avekgeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
