		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>flegt zi makhn kinderishe zakhn, a DRESS UNK, flegn aroysgeyn oyfn mark un farkoyfn.</ANNOTATION_VALUE>
