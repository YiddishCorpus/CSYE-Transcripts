		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts280" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>hobn zey im tsugenumen dos gantse gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
