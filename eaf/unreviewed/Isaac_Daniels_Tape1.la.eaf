		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>iz er geven an oreman an evyen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
