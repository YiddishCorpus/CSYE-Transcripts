		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a158" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>tsk er hot nisht gevoynt in Varshe. er hot gevoynt oyf di provintsn.</ANNOTATION_VALUE>
