		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a483" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>zog ikh tsu im, borg mir a halbe zlote.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
