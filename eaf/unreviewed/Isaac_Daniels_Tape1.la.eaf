		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>hob ikh im gegebn, hot er ongehoybn makhn a lebn.</ANNOTATION_VALUE>
