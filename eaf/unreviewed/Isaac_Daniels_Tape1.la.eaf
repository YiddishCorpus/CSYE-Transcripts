		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>oykh take oyf di statsye vos ikh hob aykh gezogt.</ANNOTATION_VALUE>
