		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a484" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>nemt aroys un get mir. ikh loyf arayn in di BAKERY,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a485" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>ikh koyf mir a halb broyt, mit a zo- dos mit a zoyerer uger- s'gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
