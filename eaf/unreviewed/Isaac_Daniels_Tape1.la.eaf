			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>un eh er hot gehandlt mit ehm hering, mit beheymes, kelbelekh, dos iz geven zayn d-</ANNOTATION_VALUE>
