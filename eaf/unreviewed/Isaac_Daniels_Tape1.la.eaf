		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts296" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>un m'hot yedn ayngeteylt a shtikl eh korn,</ANNOTATION_VALUE>
