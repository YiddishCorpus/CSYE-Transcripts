		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>un di froy hot gearbet zi iz geven shnayderin.</ANNOTATION_VALUE>
