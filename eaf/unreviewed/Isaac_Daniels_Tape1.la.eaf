			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>geven iz er shnayder, er hot nisht gevolt zayn keyn shnayder.</ANNOTATION_VALUE>
