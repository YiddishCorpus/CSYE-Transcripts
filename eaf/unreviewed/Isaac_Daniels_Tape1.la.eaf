		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>vos s'nisht geven aza min gehoybener COSTUMER,</ANNOTATION_VALUE>
