		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>ze'mir gekumen&lt;, eh,&gt; bin ikh gekumen shoyn. az ikh bin gekumen hob ikh dokh nisht&lt;, uh,&gt;</ANNOTATION_VALUE>
