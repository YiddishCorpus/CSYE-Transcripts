			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1115" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts83">
				<ANNOTATION_VALUE>koydem geven in geto B,</ANNOTATION_VALUE>
