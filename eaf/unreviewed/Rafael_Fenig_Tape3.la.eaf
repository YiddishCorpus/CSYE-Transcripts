		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>vayl kh'hob dokh nor mikh arumgedreyt ahin, aher, a-...</ANNOTATION_VALUE>
