		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
				<ANNOTATION_VALUE>UNK &lt;hob ikh&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts64" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>tsv- s'hot, heyst tsvey get- geto A un geto B.</ANNOTATION_VALUE>
