		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>&lt;ehm,&gt; yidishe P- s'iz geven yidishe POLICE.</ANNOTATION_VALUE>
