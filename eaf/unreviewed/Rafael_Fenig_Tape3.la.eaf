		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>dos geto B iz geven di tsveyte, &lt;dos o&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1121" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts71">
				<ANNOTATION_VALUE>dort hot men mikh gekent</ANNOTATION_VALUE>
