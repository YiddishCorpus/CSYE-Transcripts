		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>khapn oder d&lt;o-&gt;... do, geto, uh, A,</ANNOTATION_VALUE>
