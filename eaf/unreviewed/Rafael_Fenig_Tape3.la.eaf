		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>un, uh, un di yidishe POLICE hobn gehitn di geto,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
