	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Mary Baker">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>NO. ikh bin shoyn nisht geven demolt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts19">
				<ANNOTATION_VALUE>di shvester zenen geven mitn tatn mit di mame.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts25">
				<ANNOTATION_VALUE>ale dray, ale dray UNK. ye, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts31">
				<ANNOTATION_VALUE>in Rusland, in Vaysrusland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>in yanuar</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts40" TIME_SLOT_REF2="ts43">
				<ANNOTATION_VALUE>fertsikstn yor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts47">
				<ANNOTATION_VALUE>mit &lt;mayn man&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts49">
				<ANNOTATION_VALUE>ye</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>zey hobn gevolt &lt;BUT&gt; nisht gekent. UNK avek mit aza moyre, m'hot UNK ganen bagrenetsn, m'hot UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1152" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>UNK oykh bazunder, vi ken men iberlozn di mame &lt;mitn&gt; tatn aleyn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>az oyf der veg keyn Shidlovtse vu m'hot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>hot men zikh farshribn nakher tsu geyn arbetn barn daytsh. m'hot gezogt me geyt shikn oyf arbet. ver es vil zol &lt;zikh&gt; farshraybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>iz di eltste gelofn. zi hot zikh farshribn, gezogt az "ikh gey arbetn undz aheym brengen a shtikl broyt &lt;in shtub&gt; UNK"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>hot di yingere nokhgelofn. zi hot oykh gevolt zikh farshraybn. hobn zikh beyde geshlogn, di UNK aheym tsu di mame. di mame iz aleyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>ober zi iz geganen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts68" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>di shvester lebt &lt;az zi&gt; hot mir dertseylt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts72" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>mir hobn in gantsn gornisht gevust</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>ABSOLUTELY gornisht. eyn briv UNK fun mayn foter</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>AND THAT'S ALL.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1153" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>ven der daytsh iz ongefaln oyf Rusland</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1154" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>hot men aropgenumen di ale</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1155" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>in lager bin ikh geven di, di, di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1156" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>UNK gornisht gevust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts89">
				<ANNOTATION_VALUE>bin geven in a lager nakher. fun tfise hot men undz gefirt in a lager arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts90" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>der tate hot undz gefirt. ikh bin aheymgeganen nokh ontuekhts</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>in fertsikstn yor bin ikh tsurik aheymgan oyf di grenets</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>bin arayn UNK &lt;lomir&gt; epes a kleydl, a vos. bin geven naket un borves. kh'hob nisht gehat vos &lt;ontsutun&gt;, bin ikh avek azoy antlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>ikh bin tsurikgeganen nokh di grenets.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>hot der tate undz gefirt in di DWORZEC</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>GLOWNY in Varshe. hot undz, m'hot gezogt "antloyfts, kinder, vi vayt ets kent nor"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>ven me zetst nisht mayn tatn &lt;an&gt; PAWIAK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
				<ANNOTATION_VALUE>volt er oykhet antlofn. er hot shoyn nisht gekent geyn oyf di fis.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts111">
				<ANNOTATION_VALUE>in fertsikstn yor bin ikh tsurikgeganen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>gedenk nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts116" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>dos letste mol vos ikh hob gezen mayn foter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts123">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>ikh bin tsu zey geven in BAKERY bay mayn HUSBAND</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a219" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>&lt;nu, zi hot&gt; fun mir gelakht. "ets fort avek, ets fort avek. ze nor, me handlt un fardint. m'hot broyt tsu esn." zey hobn nisht gevust vos geyt &lt;in&gt; UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>ober ikh hob nisht gevolt zen &lt;dem&gt; daytsh. m'iz avek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>nokh ZAREBY KOSCIELNE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts141">
				<ANNOTATION_VALUE>keyn Malkin. zenen mir dos ershte. keyn Malkin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts142" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>in Malkin</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>iz geshtanen daytshn mit gruz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1157" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>un geshlogn di yidn in eyn zayt, di polyakn in andere zayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1158" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
				<ANNOTATION_VALUE>&lt;di&gt; polyakn &lt;hobn gevolt&gt; handlen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>nakher fun Malkin zenen mir geganen in ZAREBY KOSCIELNE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts160">
				<ANNOTATION_VALUE>s'iz geven a fal in Gritse, UNK bald dershosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
				<ANNOTATION_VALUE>m'hot UNK dershosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
				<ANNOTATION_VALUE>n-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts166">
				<ANNOTATION_VALUE>es iz geshtanen tsvey TRUCKn, groyse TRUCKn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
				<ANNOTATION_VALUE>eyns far mener, eyns far froyen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1159" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>UNK iz geshtanen a koleyke. hunderter mentshn zenen geganen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
				<ANNOTATION_VALUE>m'hot oysgetun gants naket.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
