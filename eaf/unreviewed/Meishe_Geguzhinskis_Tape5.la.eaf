			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>un gegebn a kuk oyf mir, oysgeshtelt di UNK tsu mir,</ANNOTATION_VALUE>
