		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a161" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts236">
				<ANNOTATION_VALUE>ikh bin aroysgelofn a naketer durkhn tirl, a kuk tun ver vos dortn iz.</ANNOTATION_VALUE>
