		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts192">
				<ANNOTATION_VALUE>zikh arayngeshtupt zikh durkhn fentster un hobn gekhapt di kartofl. di daytshn hobn shoyn dan keyn zakh mit zey nit gekent makhn mit di,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts195">
