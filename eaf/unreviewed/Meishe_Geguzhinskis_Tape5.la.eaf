			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>ikh bin arayngefaln tsu der arbet dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
