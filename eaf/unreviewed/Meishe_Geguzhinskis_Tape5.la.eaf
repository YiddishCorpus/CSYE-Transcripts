		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>un ikh hob zikh un ikh hob zikh a bisl opgerut. ikh bin ayngeshlofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>ikh hob fun zikh aruntergevorfn di aruntergevorfn di zakhn farshteyt zikh, un ikh bin ayngeshlofn azoy o. fardekt zikh mit a koldere</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
