				<ANNOTATION_VALUE>ikh, zogt er, ken shoyn mer nit arbetn. ikh vel oder ikh vel krign, zogt er, a ilfakt, oder a insut. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts599" TIME_SLOT_REF2="ts600">
				<ANNOTATION_VALUE>un azoy hot pasirt. ikh hob zikh fun der arbet nit opgelozn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts601" TIME_SLOT_REF2="ts602">
				<ANNOTATION_VALUE>un ikh hob der- der- dertsoygn di arbet bizn bizn tog, bizn tsvantsikstn yuli. di arbet iz geven fartik, UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts603" TIME_SLOT_REF2="ts604">
				<ANNOTATION_VALUE>ikh hob ongeklungen dem shef maynem, yener iz geven UNK, hot gearbet der shef, UNK, ikh hob im ongeklungen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts605" TIME_SLOT_REF2="ts606">
				<ANNOTATION_VALUE>ikh hob im gedarft yedn t- yedn tog ibergebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a350" TIME_SLOT_REF1="ts607" TIME_SLOT_REF2="ts608">
				<ANNOTATION_VALUE>dem raport, vi di arbet gefirt vert vert oysgefirt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>kling ikh im on, un ikh UNK iz geven in kabinet un s'geven di sekretarshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
				<ANNOTATION_VALUE>zog ikh tsu ir, git iber UNK az di arbet iz fartik, Geguzhinski hot geklungen az er er iz hot oysgefirt di arbet bizn sof.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts613" TIME_SLOT_REF2="ts614">
				<ANNOTATION_VALUE>zogt zi, eyn minut, ot bald ot iz er arayn in kabinet. ikh vel ir shoyn zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts615" TIME_SLOT_REF2="ts616">
				<ANNOTATION_VALUE>s'avek iber a minut, zogt ent- eh eh entfert zi tsu mir, er vil mit dir nit reydn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts617" TIME_SLOT_REF2="ts618">
				<ANNOTATION_VALUE>er iz farnumen. mit yidn, zogt er, hob ikh UNK tsum ton.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>mir iz gevorn, ikh hob gehert di reyd, iz mir gevorn shlekht. ikh bin geshtanen baym telefon bay mir in kabinet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts621" TIME_SLOT_REF2="ts622">
				<ANNOTATION_VALUE>un ikh hob aro- s'aruntergefaln bay mir di trubke fun hant,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a858" TIME_SLOT_REF1="ts623" TIME_SLOT_REF2="ts624">
				<ANNOTATION_VALUE>un ikh bin aruntergefaln avek ni- ikh hob zikh nit gekent oyf. mir s'hot zikh zeyer shtark fardrosn, ikh hob arayngeleygt azoy fil arbet in dem un do mit a yidn vil er shoyn nit reydn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a859" TIME_SLOT_REF1="ts625" TIME_SLOT_REF2="ts626">
				<ANNOTATION_VALUE>meglekh er iz geven shtark nervirt, meglekh er iz geven, ober er hot dermont er iz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts627" TIME_SLOT_REF2="ts628">
				<ANNOTATION_VALUE>az mayn mayn natsyonal dos heyst mayn mayn mayn mayn shtamung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts629" TIME_SLOT_REF2="ts630">
				<ANNOTATION_VALUE>hot mir zeyer shtark fardrosn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
				<ANNOTATION_VALUE>un ikh hob genumen, ikh hob zikh arayngezetst in mayn mashin, ikh hob gehat aza mashin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
				<ANNOTATION_VALUE>an eygene mashin, a Zhigoli numer dray. un gekumen tsu forn aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts636">
				<ANNOTATION_VALUE>un s'mir gevorn zeyer shlekht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts638">
				<ANNOTATION_VALUE>ikh hob zikh geleygt shlofn. oyf morgn in der fri bin ikh oyfgeshtanen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>un gevorn paralizirt. bay mir iz paralizirt gevorn di linke hant un di linke fus.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>nu men hot mir arayngeleygt glaykh in shpitol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts645">
				<ANNOTATION_VALUE>ot der zelber Yane-Noyekh hot geton far mir a groyse toyve, er hot mir genumen loyt zayn onvayzung tsu heyln in di Shpets shpitol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts644" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>in a palate a bazundere palate hot men mir dortn geheylt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>un er iz gekumen tsu mir eyn mol eyn mol tsu gast a kuk ton vi ikh leb. vayl er hot farshtanen dem, er hot farshtanen az er iz shuldik in dem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>vayl bay mir iz geven a guter dokter Shutrauskes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>Stolpinyenye velkhe hot mir zeyer fil geholfn. zi hot zikh genumen tsu mir punkt vi a muter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>un zi hot gezogt zi vet mir oysheyln, zi vet makhn fun mir a mentshn. un take azoy iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>ikh hob zikh avekgeshtelt oyf di fis, ikh hob ongehoybn makhn di ershte trit,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
