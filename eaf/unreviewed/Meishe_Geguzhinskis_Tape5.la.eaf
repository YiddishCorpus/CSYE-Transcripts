		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a168" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>zayn zayn zayn uniform. ikh hob gekhapt dem uniform oyf zikh mitn mitn shinel, un ikh hob aroysgelofn a kuk ton in vald vos far a royshn dortn, vos kumt dortn vos kumt dortn for.</ANNOTATION_VALUE>
