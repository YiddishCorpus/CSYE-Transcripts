		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a854" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>mit mit azelkh- sh- mit a sheynem mit kikhn farsheydene, mit mit a baseyn, mit</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
