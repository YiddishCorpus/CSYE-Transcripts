		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>nu di gantse troym fun mayn eh fun mayn lebn iz geven fun dest vegn nit keyn tsu zayn keyn te-</ANNOTATION_VALUE>
