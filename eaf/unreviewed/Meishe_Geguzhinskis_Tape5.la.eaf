			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>m'iz arayngelofn in shtibl, eyder m'hot undz arayngelofn in shtibl, iz fun shtibl aroysgelofn eyner der vekhter der der der eh vald vekhter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
