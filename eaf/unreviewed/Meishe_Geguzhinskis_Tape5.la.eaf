		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts565">
				<ANNOTATION_VALUE>ot di hoyz hot gerufn hot zikh ongerufn di Brezhev hoyz. un mir hot men dortn genumen als dekorator, ikh zol do forn un ikh zol dortn in ordenung brengen alts</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
