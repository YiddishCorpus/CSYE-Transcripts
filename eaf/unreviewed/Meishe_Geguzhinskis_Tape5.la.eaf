		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>ikh hob genumen genumen di dreystkeyt un ikh hob genumen dem matrats, ikh hob im ikh hob im oysgeshnitn dortn di sh- di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
