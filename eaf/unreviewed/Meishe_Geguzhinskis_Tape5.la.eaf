		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a303" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>nu vayter bin ikh eh sof kol sof hob ikh gef- getrofn zikh mit a eynem a direktor vos fun fun a kambinat,</ANNOTATION_VALUE>
