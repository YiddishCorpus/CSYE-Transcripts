			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a842" TIME_SLOT_REF1="ts509" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>velkher hot mir forgeleygt aleyn, az er hot a lokal tsum arbetn, tsu efenen a varshtat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>a varshtat fun veykhe meb- fun remont fun veykhe mebl. oyf eh Gortshe gas iz dos geven. dortn iz geven eh mit a groyse vitrine,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>un dortn hot er mir tsugezogt er vet mir aynordenen, mir zoln nemen di initsyativ tsu makhn, in der tsayt iz dokh geven geven in yener tsayt iz geven zeyer veynik azelkhene varshtatn fun veykhe mebl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
