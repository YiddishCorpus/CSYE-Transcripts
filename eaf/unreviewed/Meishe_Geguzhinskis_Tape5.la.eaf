				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
				<ANNOTATION_VALUE>ikh vel dir helfn. kum, varf avek, zogt er, dem shmutsikn shinel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts268" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>ikh vel dir gebn a amerikaner uniforme. un bist mistome hungerik, ikh vel dir on- on- on- onkormenen, ikh vel dir alts gebn. ze, mir veln dir nemen tsu zikh. er hot mir arayngezetst in tank,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>un m'hot mir gegebn esn. glaykh do hot zikh hot zikh gefunen hot zikh gefunen dortn a a sanitar tsi a dokter. m'hot mir gegebn glaykh opholn, ikh zol kumen tsu zikh, vayl ikh bin geven zeyer shvakh opgeshvakht oyf di fis, un m'hot mir avekgefirt in di shtetele Zumergarten.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts273" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>dortn bin ikh dortn hot men ayngeord- hot er ayngeordnt mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>in a daytshisher mishpokhe, eltere mishpo- eltere mentshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>zey hobn mir gegebn a tsimerl a bazundern. zey hobn mit mir zikh zeyer gut bahandlt, zey hobn mir gegebn tsum esn, zey hobn mir gegebn eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>ontsuton zikh farshteyt zikh un un un un eh un mir gegebn yedn tog iz gekumen di eltere froy un iberbin- iberbi- iberbindn di vundn vos ikh hob gehat oyf di oyf di fi- oyf di hent nokh fun fun fun mayn hengen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>ikh ken nit zogn zey hobn UNK, zaynen do fun dest vegn daytsher daytshisher loytere mentshn velkhe ke- velkhe hobn geholfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>ikh veys nit vos far a tsil zey hobn gehat. zey hobn dertseylt az zeyer zun iz gefaln oyfn va- oyfn oyfn front oyfn oyfn mizrekh front in Rusland. az dem eyntsikn zun hobn zey farlorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>iz kentik az zey hobn derzen in mir efsher a mol dem zun zeyern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>un in vinkl fun tsi- fun tsimer iz geshtanen zayne tsvey kabkes, tsvey</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>eh shtek-shikh. hot zi mir geozgt, her tsu, liber froynt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>ale, du bist eyn, du bist a balebos in in dem tsimer, ober di shtek-shikh zolstu nit tshepenen. zogt er, s'a ondenkung far undzer gefalenem undzern, bay undz iz es a min traditsye</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>tsu haltn di shtek-shikh. ikh hob di shtek-shikh nit tsu- zikh tsugerirt tsu zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>un ikh hob gelebt bay zey in dem tsimer hob ikh gelebt a lange lengere tsayt, a por monatn tsayt in di.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>fun dortn dortn in dem in di zelbe shtetl hobn gelebt nokh oykh fa- eh fa- bafrayte yidn. ikh hob zikh mit zey ba- mit zey bakent un mir hobn bashlosn tsu forn, mir hobn gehert az in Minkhn gefinen zikh kazarmes un in di kazarmes gefinen zikh yidn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>tsunoyfgezamlte yidn fun farsheydene lagern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
				<ANNOTATION_VALUE>un dortn eh fun dortn vet men vet men kenen onforn tsurik aheym in undzer foterland, in Lite.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>in Minkhn zenen mir geven a kurtse tsayt. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a822" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>m'hot undz dortn zeyer gut gegebn esn, m'hot undz ongeton, di amerikaner hobn zikh zeyer gut tsu undz batsoygn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a823" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts309">
				<ANNOTATION_VALUE>un eh yedn tog flegn mir krign shokolad, fleg krign farsheydene produktn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a824" TIME_SLOT_REF1="ts308" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>biz, far undz iz geven a groyse zakh, vayle gevezn gemutshete mentshn fun lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>hob ikh zikh gikh a bisl gekumen tsu zikh, zikh a bisl shoyn far- far- bapravet azoy tsu zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>un eh emesn zenen gekumen tsu forn dortn forshteyer fun Yisroel, fun Erets-Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>un zey ongehoybn tsum onagatirn, zogn, "khevre, yidishe khevre, ir darft forn in eygene land. vu fort ir aheym? vu fort ir? iz es ayere heym? ir hot dortn dokh farlorn ayere eltern, farlorn ayere ayere</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a209" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>f- bakante, ayere fraynt, ayere kroyvim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts319" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>kumt tsu forn mit undz in Erets-Yisroel, dortn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>dortn vet vet keyn lagern shoyn mer nit zayn far aykh."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a212" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>nu ikh bin nokh dan geven in gantsn nayntsn yor. ikh hob nokh alts gelebt mitn gayst fun dem eh sovetishn azoy tsu zogn umpartizanishn gayst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a214" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
				<ANNOTATION_VALUE>vos heyst, ikh hob dokh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts327" TIME_SLOT_REF2="ts328">
				<ANNOTATION_VALUE>fun dest vegn geven, oyf mir hot dokh alts gevust az ikh darf zayn in der in der organizatsye in der partizanisher organizatsye fun geto, un der der un der unternemen in in der aktiver unternemen in zayn arbet hot mir alts getsoygn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
				<ANNOTATION_VALUE>tsu tsu dortn in shtot in Kovne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts331" TIME_SLOT_REF2="ts332">
				<ANNOTATION_VALUE>un mir hobn zikh eh ikh hob dortn getrofn eh Dime Galpe- Dime Gelpern, ikh hob getrofn dortn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts335">
				<ANNOTATION_VALUE>Grinbergn, oykh a un- a aktiver unternemer fun eh fun der organizatsye fun der eh fun der un- </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts334" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>di partizanisher geto organizatsye. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts337" TIME_SLOT_REF2="ts338">
				<ANNOTATION_VALUE>ikh hob getrofn dortn nokh azelkhe khevre velkhe, un mir hobn bashlosn tsu forn aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts339" TIME_SLOT_REF2="ts340">
				<ANNOTATION_VALUE>yedn tog zenen gekumen tsu forn ruzevikes, m'hot undz arayngezetst in di in di in di last oyto- last-oytos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a223" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>un m'hot undz gefirt tsum grenets tsu Khelmits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts343" TIME_SLOT_REF2="ts344">
				<ANNOTATION_VALUE>dortn iz geven der grenets tsvishn di amerikaner un di sovetn, un sovetishe armey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts345" TIME_SLOT_REF2="ts346">
				<ANNOTATION_VALUE>ven m'hot undz gebrakht in Khelmits,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
