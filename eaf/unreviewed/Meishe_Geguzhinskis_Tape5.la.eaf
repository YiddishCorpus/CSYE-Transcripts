		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>hobn mir nit gevust vu tsum vu zikh tsum kern, vu tsum geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>zenen mir gelofn durkhn vald zukhn vos nit iz oyf a ort, efsher veln mir gefinen vu s'a shtibele oder vos nit iz. un grod hobn mir getrofn a oyfn veg hobn mir gezen a kleyninke shtibele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
