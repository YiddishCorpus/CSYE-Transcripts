		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>mit ale luks un ale azelkhene zakhn vos iz in Viln- in gants Viln- in Vil- in Rotn- in Ratn-Farband iz dos nito.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
