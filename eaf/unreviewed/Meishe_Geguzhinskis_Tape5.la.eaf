		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a850" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>in Palangen farsheydene ru-hayzer, fleg ikh kumen tsu forn dortn, fleg ikh makhn gantsn fun groyser arbet.</ANNOTATION_VALUE>
