			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>ikh bin geven farlayzikt, ikh bin geven shmutsik, ikh bin geven oysgematert. ikh hob kam kam zikh derkrokhn tsum tsum tsum a vinkl fun fun fun shti- fun tsimerl, ikh hob zikh avekgeleygt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
