				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a148" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>un eyn koyl hot getrofn mayn khaver. im UNK dem dem yat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
				<ANNOTATION_VALUE>dos heyst bay lebn mir iz er gefaln. ikh bin tsugelo- ikh bin tsugegangen tsu, un der un der vekhter iz antlofn vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>vayl er hot shoyn geshpirt az di amerikaner armey iz shoyn geven nit vayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
				<ANNOTATION_VALUE>ikh bin tsugegangen tsu mayn khaver, ikh hob a kuk geton, ikh hob gezen di koyl hot im getrofn direkt glaykh in kop, er iz shoyn geven toyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts224">
				<ANNOTATION_VALUE>nu ikh hob keyn zakh nit gekent im helfn. ikh bin arayngegangen in shtibl,</ANNOTATION_VALUE>
