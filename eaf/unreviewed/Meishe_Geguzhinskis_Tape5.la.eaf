			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a836" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>mebler mebls-arbeter, efsher vestu oykh zikh kenen mit dem farnemen. kum makh di ershte profit tsu makhn.</ANNOTATION_VALUE>
