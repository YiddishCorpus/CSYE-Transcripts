		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a838" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>vu ikh vu ikh shlof, er iz a gelekherter, shoyn in gantsn mit a mit tife grub,</ANNOTATION_VALUE>
