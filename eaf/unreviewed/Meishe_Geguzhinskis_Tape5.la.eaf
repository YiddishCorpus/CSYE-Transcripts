		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a839" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>du shpongatn mit di pruzhines, m'hot zey avekgeshtelt alts oyf an ort,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a840" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>ikh hob im batsoygn mit di mit a shtik shtof aza min,</ANNOTATION_VALUE>
