		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>hob ikh ongehoybn tsu shrayen, ikh bin eyn JUDE! shist nit!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>ikh bin eyn JUDE! WAS, zogt er, bist a JUDE? ikh bin, zogt er, oykh a yid!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a180" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>dos iz geven a kapitan fun der a- fun der amerikaner armey.</ANNOTATION_VALUE>
