				<ANNOTATION_VALUE>eyn mol hot er mir gezogt, Urbanas, tsu mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>Geguzhinskis, vi kenstu arbetn in azelkhene badingungen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>durkh aza min kurtser tsayt oyftsuboyen aza min hoyf, a tsvey etazhn hoyz, mit mit mit mit vifl dortn e- etlekhe un tsvantsik tsimern, mit mit</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
