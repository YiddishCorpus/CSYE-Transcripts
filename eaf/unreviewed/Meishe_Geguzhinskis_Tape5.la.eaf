		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>hot men undz glaykh oyfn grenets</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts349" TIME_SLOT_REF2="ts350">
				<ANNOTATION_VALUE>hobn di sovetishe soldatn undz glaykh tsugenumen azoy tsu zogn tsu zikh, un geheysn in der ershter rey geyn in bod.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts351" TIME_SLOT_REF2="ts352">
				<ANNOTATION_VALUE>un undzer, mir hobn gehat, ikh hob gehat bay zikh a ruk-zak hob ikh dortn gehat bay zikh azelkhe zakhn fun di daytshn vos ikh hob fun zey gekrogn a matone dortn a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a825" TIME_SLOT_REF1="ts353" TIME_SLOT_REF2="ts354">
				<ANNOTATION_VALUE>a por hoyzn iberike, a por shikh hobn zey mir gegebn dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a826" TIME_SLOT_REF1="ts355" TIME_SLOT_REF2="ts356">
				<ANNOTATION_VALUE>nokh eh UNK ikh gedenk shoyn nit velkhe zakhn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a827" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>velkhe zenen geven in yener tsayt a groyser vert.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>hobn mir gehey- hobn zey geheysn di rusishe soldatn hobn undz gezogt az mir zoln iberlozn lebn ban lebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a828" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>lebn dem bod iberlozn undzere rukzek,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a829" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts364">
				<ANNOTATION_VALUE>un mir veln arayngeyn in bod, un geye- aroysgeyendik fun tsurik veln mir krign demolts tsurik di zakhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a830" TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
				<ANNOTATION_VALUE>mir zenen arayn in bod, un mir hobn zikh oysgebodn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a831" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>mir geyen aroys fun bod, mir gebn a kuk do, undzere spn rukzek zenen shoyn nito. farfaln gevorn undzere ale zakhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a832" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>ot dos hobn undz ge- azoy hobn undz getrofn di sovetishe soldatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
				<ANNOTATION_VALUE>hob ikh glaykh farshtanen vu mir zenen shoyn arayngefaln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>nor un ikh hob alts nokh getrakht az fun dest vegn es vet nokh kumen di tsayt az kumen azoy tsu zogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts376">
				<ANNOTATION_VALUE>fun dest vegn vet men zikh farrekhenen mit di mentshn velkhe zenen geven in lager un m'vet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts377" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>un UNK mit di velkhe zenen hobn zikh untergenumen in di farsheydene</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>partizanishe bavegungen un azoy vayter. efsher vet efsher vet men undzer mit undz di unter&lt;UNK&gt; zey zey bahandlen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a236" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>hobn mir bashlosn eh geyn tsu fus aheym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a238" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts384">
				<ANNOTATION_VALUE>m'hot undz gevolt mobilizirn in otryadn arayntsugeyn arayntsugebn in eh in di rusishe armey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts385" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>oder ikh veys nit vu m'zogn vu m'hot undz gevolt, oder m'hot undz gevolt dortn farpshe- haltn avekfirn in Sibir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a240" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>velkhe derfar vos vos mir zenen geven in di lagern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a241" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>nor ikh bin tsu in di otryadn nit gegangen, mir hobn zikh opgeteylt a bazundere grupe, mir zenen gegangen tsu fus oyf tsu Kovne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>farshteyt zikh, tsu fus hobn mir nit gekent dergeyn azoy vayt. mir zenen geforn, teyl zenen mir teylvay- teylvayz zenen mir geforn, teyl zenen mir gegangen tsu fus,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>mit mir iz gegangen eh Belinke Kremerman,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>oykh a UNK, a untererdisher, mit zayn shvoger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>er iz gegangen zukhn zayn froy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>ikh bin gegangen zukhn ke- nor mayne fraynt. ikh hob gevust az mayn gantse mishpokhe iz umgekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>mir zenen gegangen biz Berlin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>do geforn nit gegangen, nor oykh geforn farshteyt zikh, in Berlin hobn mir getrofn nokh khaveyrim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>a teyl zey hobn shoyn gevust dem gantsn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts408">
				<ANNOTATION_VALUE>dem gantsn rezhim fun dem sovetisher sovetisher rezhim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a833" TIME_SLOT_REF1="ts409" TIME_SLOT_REF2="ts410">
				<ANNOTATION_VALUE>hobn zey zikh a nit gekert in Kov- nit umgekert Kovne, zenen geblibn arbetn in Berlin dortn, bay eynem a general Marshak, dortn geven eyner Marshak er hot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a834" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>oyf- oyfgenumen bay zikh yidn tsu arbetn in zayn in zayn teyl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts413" TIME_SLOT_REF2="ts414">
				<ANNOTATION_VALUE>nor ikh bin mit di khevre gekumen tsurik in Kovne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts415" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>in Kovne farshteyt zikh hob gevolt ikh a kuk ton vu ikh leb, vu iz undzer gevezener gas, mir hobn gelebt oyf Vayse gas, oyf Yamner gas, nokh oyf andere gasn, hob ikh a kuk geton, di shtot iz pust,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>mentshn zenen andere, groy in gantsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts419" TIME_SLOT_REF2="ts420">
				<ANNOTATION_VALUE>ikh hob zikh forgeshtelt az m'vet undz oyfnemen a bisl andersh. ikh hob gedarft aroysnemen a pasport khotshabe, ober m'hot keyn pasport nit gegebn mit di mentshn velkhe zenen gekumen, di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts421" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>yidn velkhe zenen gekumen fun di lagern hot men UNK gehaltn far far mentshn fun tsveytn sort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>m'hot undz m'hot undz UNK pasn pa- keyn pasn nit gevolt aroysgebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>un s'geven a eh dike di groysedike diskriminatsye fun di fun di mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>ikh hob getrofn mayne khaveyrim velkhe zenen gekumen fun partizanik- fun partizanishe bavegung. ikh hob getrofn dortn Shimke Blokh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>ikh hob getrofn Meyske Mutshelis, Nekhemke Englin, Leyzerke Zilber,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>ikh bin arayn tsu zey in shtub, zey hobn mir dertseylt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts433" TIME_SLOT_REF2="ts434">
				<ANNOTATION_VALUE>az eh der der rezhim iz do aza min der sovetisher rezhim iz nit geneygt tsu di yidn velkhe zenen geven in di lagern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts435" TIME_SLOT_REF2="ts436">
				<ANNOTATION_VALUE>vayter, hob ikh zikh bakent mit eyn a froy,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts438">
				<ANNOTATION_VALUE>velkhe hot mir geratn tsu forn in Vilne, zi vet mir araynnemen mit der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts439" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>ire ire bakanter, guter bakanter, Shperling iz geven do a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>onfirer fun a aptey- fun apteyke-sklad,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>fun apteykn eh volt ikh gezogt UNK vi azoy heyst dos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>farvaltung, un bay im, ikh hob gekrogn fun ir a tsetele tsu im, er zol mir araynnemen in der arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>ikh bin arayngeforn in Vilne,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>ikh bin arayn tsu im in shtub. er hot zikh zeyer interesirt, er hot zikh zeyer shtark interesirt vegn di yidn velkhe zenen geven in lager. ikh hob im dertseylt vegn zikh, vegn mayne eltern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>un er hot mir gegeb- forgeleygt tsu arbetn im, er hot mir gegebn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts453" TIME_SLOT_REF2="ts454">
				<ANNOTATION_VALUE>eh a li- halb litviner karteshke iz dan geven in Ko- in in yener tsayt nokhn krig. dos heyst m'hot gekent far a halb litviner karteshke flegt men zikh shoyn kenen kam kam durkhlebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>un er hot mir bazorgn an ort vu tsum vu tsu vu tsum shlofn. tsu zikh in shtub hot er mir nit genumen. er hot mir gegebn an ort in zayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>in zayn UNK, heyst in zayn eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>eh algemeynem va- voynung, ye, az dortn zol ikh ibernekhtikn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>un ikh hob bashlosn az far mir iz dortn keyn ort nit, ikh vil eh zikh prubirn aleyn on a- aynordenen on keyn hilf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts465" TIME_SLOT_REF2="ts466">
				<ANNOTATION_VALUE>nu in Vilne hob ikh eh getrofn bakante,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>velkhe hobn mir, eh iz geven iz geven di familye Silkiner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>Shmuel un Khave Silkiner, velkhe hobn mir arayngenumen tsu zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>un zey hobn mir bashlosn oykh tsu mir helfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>ikh fleg dortn a mol opesn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>oystrinken a gloz tey mit a mit a shtikl eh mit a mit a konfekt flegt men spn flegt men oyf broyt iz dan geven oyf oyfn oyf di oyf a karteshke iz geven zeyer shver.</ANNOTATION_VALUE>
