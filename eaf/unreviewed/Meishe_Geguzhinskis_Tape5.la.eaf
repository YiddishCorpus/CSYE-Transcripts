		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>er hot gezen mayn, in oyf uniform fun a daytsher,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
