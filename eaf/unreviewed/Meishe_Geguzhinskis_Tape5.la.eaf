			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts237" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>un ikh gib a kuk ikh bin dokh naket, darf men onton zikh vos nit iz. oyfn oyfn vant iz gehangen a shinel</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts240">
				<ANNOTATION_VALUE>a a shn- nit keyn shinel nor a a a fun a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
				<ANNOTATION_VALUE>iz gehangen a fun fun dem vekhter. kentik hot der vekhter er iz antlofn, hot gehat, er iz geven avek- er iz geven a ofitsir kentik. hot er iber- zikh gikh ibergeton mit tsivil,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
