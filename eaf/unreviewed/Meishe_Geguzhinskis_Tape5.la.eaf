		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a841" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>un s'gevorn a vunderbarer matrats. trakht ikh, oy, ikh bin dokh shoyn bald a a shpetsyalist, ikh ken shoyn bald arbetn.</ANNOTATION_VALUE>
