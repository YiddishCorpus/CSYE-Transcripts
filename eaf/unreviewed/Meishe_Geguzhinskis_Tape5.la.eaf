		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts176">
				<ANNOTATION_VALUE>s'iz shoyn geven nakht, un ikh hob der ershter aroysgeshprungen, un er hinter mir.</ANNOTATION_VALUE>
