		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a856" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>un durkh aza min kurtser tsayt, zogt er, zolst kumen yedn tog, zolst geyn ot o di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a857" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>di di minist- minister iz geblibn der Shimo- der eh eh Shinetski iz shoyn geven geshtorbn dan.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts595" TIME_SLOT_REF2="ts596">
				<ANNOTATION_VALUE>es kumen tsu geyn, zogt er, di ale natshalstve ibern kop un zey lozn dir nit arbetn, yeder yeder eyntsikster zogt zayne zogt dir direktivn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
