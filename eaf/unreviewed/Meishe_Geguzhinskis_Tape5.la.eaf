				<ANNOTATION_VALUE>di kartofl hobn mir hobn gehat genumen gefunen zeye- zayendik in lager fir, hobn di yidn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a132" TIME_SLOT_REF1="ts188" TIME_SLOT_REF2="ts190">
				<ANNOTATION_VALUE>di letste shoyn di letste hobn geshpirt az s'shoyn nito vos ontsuvern, hobn a groys hobn di yidn fun di la- fun fun di barakes aro- arayngekhapt zikh in dem kartofl lager fun kikh, un hobn im</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
