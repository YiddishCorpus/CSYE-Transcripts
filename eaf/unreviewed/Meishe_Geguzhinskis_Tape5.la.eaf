		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>hot er gevolt mir shisn glaykh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
