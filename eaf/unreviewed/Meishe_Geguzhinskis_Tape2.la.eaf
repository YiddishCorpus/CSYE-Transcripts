	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Meishe Geguzhinskis">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
				<ANNOTATION_VALUE>vaytert vi ikh gedenk</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a3" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
				<ANNOTATION_VALUE>ven s'hot bay mir pasirt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>der &lt;umendlekhe&gt; ume- ume- ume- um- um- spn der u- der der nit keyn ven s'hot nit ayngegebn tsu arbetn vayter in dem ze- magazin,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>un ikh bin nokh dertsu geven a komyugist,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>ikh hob gehert tsu a komyugisher organizatsye fun dem handls-opteylung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>hot men mir aroysgerufn oyf a farzamlung fun Komyug.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>der sekretar fun Komyug iz bay undz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>a yidisher yat, vifl ikh gedenk Yankl Zhin hot er geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>er hot gehat a feikeyt er hot a feikeyt tsum sheyn tsum redn, er iz geven a vunderbar orator.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
				<ANNOTATION_VALUE>un di khevre, di komyugistn, flegn im kukn poshet in moyl arayn, vi azoy er flegt reydn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>vi azoy oys- oysnutsn zayne oratorishe feikeytn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a19" TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
				<ANNOTATION_VALUE>di farzamlung iz geven a spetsyele. m'hot aroysgerufn mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>m'hot, un der Zhidn, Yankl Zhidn, hot bashlosn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>er hot shoyn gekrogn onvayzungen mistome fun dem Shtromen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>az ikh hob gehat a &lt;feler&gt; heyst tsu zogn, ikh hob es ikh hob s'hot bay mir gefelt in magazin un m'darf mikh bashtrofn derfar.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a24" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
				<ANNOTATION_VALUE>hot er forgeleygt az m'zol mir oysshlisn fun Komyu- fun Komyug.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>m'hot mikh poshet aroysgevorfn fun Komyug.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>er hot geredt aroysgeshtelt er hot er hot aroysgetrotn mit aza min sharfe rede kegn mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>un gezogt "&lt;vot&gt; vi azoy ken a sovetisher komyugist zikh farnemen mit azelkhene zakhn? vu iz farfaln gevorn di gelt?" un azoy vayter. ikh hob zikh farentfert az</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a956" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
				<ANNOTATION_VALUE>ikh bin geven poshet, ikh hob nit gehat keyn derfarnkeyt in dem,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a957" TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
				<ANNOTATION_VALUE>un ikh hob nit gevust vi ontsuhoybn handlen, vi tsum ton, vi tsum firn a magazin, un s'hot pasirt mit mir aza min faln, nit mit mayn eygenem viln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
				<ANNOTATION_VALUE>nor s'hot keyn zakh nit geholfn, kentik er hot shoyn gekrogn a sh- gevise onvayzungen m'zol mir fun dem Komyug aroystraybn. m'hot mir fun dortn aroysgetribn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>ikh ibn aroys fun der farzamlung a farfintsterter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
				<ANNOTATION_VALUE>geferlekh, mit a geferlekher mit a geferlekher shtimung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
				<ANNOTATION_VALUE>ikh gedenk ikh bin arayngegangen in kafe Asta, un ikh hob dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>far kaas oder far far far far iberlebung, oysgetrunken dray kufl bir un tsvey un tsvey portsyes &lt;tshashiskes&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>un in shtub bin ikh gekumen un ikh hob keynem dertseylt, vayl es iz geven a shande far mayne famil vi azoy ikh hob</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>nit oysgenutst azoy tsu zogn mayn mayn mayn arbet, mayn mayn mayne karyere vos ikh hob gemakht in dem magazin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>mir hobn dan gelebt oyf Vayse gas, oyfn UNK oyfn grinem barg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>derbay iz bay undz geven a shokhn a beker. Glabin hot er geheysn. Abe Glabin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts65">
				<ANNOTATION_VALUE>er hot gehat tsvey zin, vifl ikh gedenk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a49" TIME_SLOT_REF1="ts64" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>eyn zun iz geven, der elterer zun, iz geven a sportler.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>a rayter, er flegt zikh farnemen mit rayter sport.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>un er iz geven a sheyner hoykher yung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>mit a fayne figur, er flegt zeyer holt hobn zikh onton in zayn uniform fun der rayter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a958" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>aroysgeyn farn gas lebn toyer, zikh avekshteln az mentshn zoln kukn oyf im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>ikh vel shpeter dertseyln dem di tragedye fun dem fun dem zelbn Globin zun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>der tsveyter zun, a yingerer, iz geven hot geheysn Dodik Glabin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>er iz oykh geven a komyugist, oykh a umlegaler komyugist,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a62" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>mir flegn zikh mit im trefn in di in zayendik in Komyug nokh. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>un ven s'gekumen di sovetn makht hot men im oykh bashtimt als komisar</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>fun a groysn magazin in Kovne, Arkus, dos magazin hot geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>di firme Arkus iz geven barimt in Kovne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>oyf &lt;Layses Aleye&gt; oyfn tsenter shtot iz geven a magazin fun manufaktur,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>un der zelber Dodik, der yunger Dodik, iz gevorn der komisar.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>nu vegn zikh ken ikh nor zogn vegn dem az nokh dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>ven m'hot mir aroysget- aroysgetribn fun Komyug,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>hob ikh gevelt zikh fun dest vegn vayter aynordenen un arbetn vayter, UNK arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>ikh bin avek arbetn, UNK ersht bin ikh, hob ikh zikh bin ikh avek ler- lernen oyf kursn,oyf tekhnishe kursn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>als tekhnik, als mekhanik volt ikh gezogt, beser oprufn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>zikh tsugreytn tsu, di tekhnishe kursn flegn tsu- tsugreytn zeyer shiler tsu di fabrikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>velkhe hobn velkhe eh hobn ekzistirt dan in Kovne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts109">
				<ANNOTATION_VALUE>ikh hob geendikt di kursn un m'hot mir avekgeshikt arbetn in a fabrikl aza min,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts108" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>a mekhanishe fabrik in Lishantshey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>s'hot zikh ongerufn Mekhanishe Fabrik, azoy hot es geheysn, Mekhanishe Fabrik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a89" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>ikh hob zikh glaykh genumen mitn fayer in hant, ikh hob shoyn farshtanen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>a UNK tsu zogn, vi ruft men oyf yidish?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>a a tseykhenung.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>ikh hob eh zikh farinteresirt vegn shloseray arbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>un mir iz es shoyn bald gefeln gevorn. in ovnt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a97" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>fleg ikh nokh geyn oyf kursn, farsheyde kursn, eh ovnt kursn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>tsu derlernen zikh vos ikh hob nit derlernt zikh in gimnazye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
