			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>azoy iz geven der metod fun di yidn fun di yidishe arbayter, edro- erodromshiks azoy tsu zogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a403" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts529">
				<ANNOTATION_VALUE>in geto zayendik in geto hob ikh zikh getrofn mit khevre </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a975" TIME_SLOT_REF1="ts528" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>velkhe ikh hob zikh frier velkhe ikh hob zikh mit frier mit zey</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a976" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>gehat gekhavert iber hoypt fun der Yidisher Komers-Gimnazye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a405" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>di Yidishe Komers-Gimnazye iz geven a volt ikh gezogt a yidish a yidishe link-geshtimte</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>komers-gimnazye. vayl ye- di lerer di lerer velkhe hobn dortn gelernt zenen ale geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a977" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts539">
				<ANNOTATION_VALUE>zeyer progresiv geshtimt un zey hobn ge- oysge-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a978" TIME_SLOT_REF1="ts538" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>oysge- volt ikh gezogt, oysgekhovet di shiler in a linkn gayst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>hob ikh getrofn aza min khaver vi Elke Tenko in geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a412" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>Elke Tenko iz geven a &lt;ernster&gt; yung, a basketbolist,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts545" TIME_SLOT_REF2="ts546">
				<ANNOTATION_VALUE>mit a kaltn ponem azoy, m'hot im gerufn Elke der Kalter hot men im gerufn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts547" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>er hot mir arayn- er hot arayngerufn mir tsu zikh in shtub,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts549" TIME_SLOT_REF2="ts550">
				<ANNOTATION_VALUE>er hot gelebt in a kleyn tsimerl, un er hot mir gezogt, veyst Meyshke,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts551" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>dos iz geven in dray un fertsikstn yor shoyn, in tsvey un f- tsvey un fe- oder dray un fertsikstn yor,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts553" TIME_SLOT_REF2="ts554">
				<ANNOTATION_VALUE>mir viln zikh organizirn mir viln mir viln zikh organizirn in a vidershtand kegn di daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts555" TIME_SLOT_REF2="ts557">
				<ANNOTATION_VALUE>vi s'vet oyszen der vidershtand hobn mir nokh nit bashlosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts556" TIME_SLOT_REF2="ts559">
				<ANNOTATION_VALUE>nor di ershte zakh vos bay mir iz do, ikh hob, zogt er, a pistolet arayngetrogn &lt;in tog fun&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a425" TIME_SLOT_REF1="ts558" TIME_SLOT_REF2="ts560">
				<ANNOTATION_VALUE>mitgenumen mit zikh. un er hot mir aroysgenumen, mir gevizn dem pistolet mit etlekhe koyln. zogt er, ot iz undzer </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a426" TIME_SLOT_REF1="ts561" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>gever velkhe mir hobn haynt tsum tog.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a427" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>ikh hob genumen dem ershtn mol in hant dem pistolet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>un ikh hob farshtanen az m'darf, az s'vet zayn mit vos zikh tsu farteydikn kegn di fashistn, kegn di daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts569">
				<ANNOTATION_VALUE>mir hobn or- organizirt a kleyninkn kemerl azoy tsu zogn fun a krayzl fun etlekhe man bay Elke Tenko</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts568" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>in shtub flegn mir zikh mir trefn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a434" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>undzer arbet iz geven vegn dem ershtn zakh hobn mir batrakht dem gantsn konstruktsye fun dem pistolet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a979" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts575">
				<ANNOTATION_VALUE>m'iz di kin- di khevre zoln kenen zikh m'kenen farshteyn vi zikh tsu farteydikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a980" TIME_SLOT_REF1="ts574" TIME_SLOT_REF2="ts577">
				<ANNOTATION_VALUE>oder vi ontsugrayfn di daytshn in fal fun a fun eh letstn moment.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a981" TIME_SLOT_REF1="ts576" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>un mir f- un mir flegn eh oft eh zikh trefn dortn bay im hern a umlegale radyo hot er gehat, a a radyo aparat fun Moskve.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>mir flegn firn a min eh arbet azoy tsu zogn agitatsyone ar- agitatsye arbet tsvishn di khevre.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a440" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>nor do in a gutn frimorgn ven ikh bin gekumen tsu Elken in shtub,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>hob ikh gefunen farmakht di farmakht far- farklapt di tir. ikh hob nokhgefregt di shkheynim, vos kumt do for? vu iz der Elke farfaln gevorn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>vayzt zikh aroys, in der tsayt iz geven a aktsye, m'hot gefirt yidn toyznt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>tsi zibn hundert dakht zikh yidn, zibn hundert yidn hot men avekgefirt in Estland.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a447" TIME_SLOT_REF1="ts589" TIME_SLOT_REF2="ts590">
				<ANNOTATION_VALUE>un Elke iz arayngefaln tsvishn der tsvishn der tsvishn di khe- tsvishn di mentshn di &lt;ashirim&gt; fun geto</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a450" TIME_SLOT_REF1="ts591" TIME_SLOT_REF2="ts592">
				<ANNOTATION_VALUE>mistome mit zayn pistolet tsuzamen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a451" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>azoy bin ikh ge- zenen mir geblibn vider on a on a hofenung vayter tsum ton in geto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
