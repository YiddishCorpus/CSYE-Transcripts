			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts867" TIME_SLOT_REF2="ts868">
				<ANNOTATION_VALUE>hot men zikh ibergedreyt. s'hot geheysn a &lt;PERESKIP&gt;</ANNOTATION_VALUE>
