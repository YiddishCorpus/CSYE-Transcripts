		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1157" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>un azolkhe geven dray keslen</ANNOTATION_VALUE>
