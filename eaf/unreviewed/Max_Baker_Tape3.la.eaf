		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>ober dortn iz geven farvorfn ort</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a391" TIME_SLOT_REF1="ts997" TIME_SLOT_REF2="ts998">
				<ANNOTATION_VALUE>tsurikgeshtanen. s'iz nisht geven keyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts999" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>keyn, zey hobn prubirt tsu makhn aza min vogn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
