		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>shtrik vos &lt;eyner&gt; WAGON iz geganen arop un eyner aroyf &lt;fun&gt; di heykh</ANNOTATION_VALUE>
