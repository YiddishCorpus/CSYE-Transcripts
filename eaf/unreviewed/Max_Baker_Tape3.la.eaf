		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts1019" TIME_SLOT_REF2="ts1020">
				<ANNOTATION_VALUE>un di mo- di tekhnik ergets andersh iz do, geyen azolkhe CONVEYERS</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
