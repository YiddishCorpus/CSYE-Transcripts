		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts1067" TIME_SLOT_REF2="ts1068">
				<ANNOTATION_VALUE>hot zi mir dos nakher farneyt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a422" TIME_SLOT_REF1="ts1069" TIME_SLOT_REF2="ts1070">
				<ANNOTATION_VALUE>un m'hot mikh tsurikgebrengt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts1071" TIME_SLOT_REF2="ts1072">
				<ANNOTATION_VALUE>hob ikh gezen s'iz oykh nisht keyn gute zakh do tsu arbetn als KOCHEGAR</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a424" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1074">
				<ANNOTATION_VALUE>hob ikh nakher gegat epes dortn a bisl gelt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
