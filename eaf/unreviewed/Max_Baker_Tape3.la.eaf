		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a446" TIME_SLOT_REF1="ts1117" TIME_SLOT_REF2="ts1118">
				<ANNOTATION_VALUE>iz gev- dos iz geven a laykhtere arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
