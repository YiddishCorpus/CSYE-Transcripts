		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1149" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>ferd. ale ferd zenen geven blind dort.</ANNOTATION_VALUE>
