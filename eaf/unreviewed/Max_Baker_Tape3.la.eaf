		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1163" TIME_SLOT_REF1="ts1052" TIME_SLOT_REF2="ts1054">
				<ANNOTATION_VALUE>&lt;s'iz&gt; dortn geven a lager fun UNK</ANNOTATION_VALUE>
