		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>un, un s'iz geganen tsvey azolkhe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
