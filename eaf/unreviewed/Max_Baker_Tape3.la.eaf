				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a436" TIME_SLOT_REF1="ts1097" TIME_SLOT_REF2="ts1098">
				<ANNOTATION_VALUE>dos iz shoyn gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a437" TIME_SLOT_REF1="ts1099" TIME_SLOT_REF2="ts1100">
				<ANNOTATION_VALUE>nisht shver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a438" TIME_SLOT_REF1="ts1101" TIME_SLOT_REF2="ts1102">
				<ANNOTATION_VALUE>ikh hob gehat a bazunder tsimerl in di &lt;KOTEL'NAYA&gt; als UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a439" TIME_SLOT_REF1="ts1103" TIME_SLOT_REF2="ts1104">
