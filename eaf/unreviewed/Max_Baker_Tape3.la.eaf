		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a397" TIME_SLOT_REF1="ts1013" TIME_SLOT_REF2="ts1014">
				<ANNOTATION_VALUE>aroyssharn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts1015" TIME_SLOT_REF2="ts1016">
