		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts976" TIME_SLOT_REF2="ts980">
				<ANNOTATION_VALUE>NO, dos iz geven di TOP UNK shakht, dos eh, derfar UNK </ANNOTATION_VALUE>
