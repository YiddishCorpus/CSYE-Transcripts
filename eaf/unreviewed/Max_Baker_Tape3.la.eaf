				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1164" TIME_SLOT_REF1="ts1065" TIME_SLOT_REF2="ts1066">
