				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a442" TIME_SLOT_REF1="ts1109" TIME_SLOT_REF2="ts1110">
				<ANNOTATION_VALUE>az ikh hob gehat a telefon, m'hot mir ge&lt;PHONED&gt; UNK ikh darf dos tun. bay di nakht bin ikh aroysgeganen kukn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a443" TIME_SLOT_REF1="ts1111" TIME_SLOT_REF2="ts1112">
				<ANNOTATION_VALUE>tsu di, zenen gelign di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a444" TIME_SLOT_REF1="ts1113" TIME_SLOT_REF2="ts1114">
				<ANNOTATION_VALUE>rern, PIPES, vos hobn gegebn di hits, zen s'iz nisht farfroyrn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a445" TIME_SLOT_REF1="ts1115" TIME_SLOT_REF2="ts1116">
				<ANNOTATION_VALUE>azoy hob i- dos hob ikh gearbet als shloser shoyn biz ikh bin aheymgeforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
