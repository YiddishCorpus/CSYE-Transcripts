		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>un nemen di koyln aroysshitn. zenen farforn vegelekh, azolkhe vagones</ANNOTATION_VALUE>
