		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1158" TIME_SLOT_REF1="ts981" TIME_SLOT_REF2="ts982">
				<ANNOTATION_VALUE>ikh hob moyre gehat, zenen forgekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts983" TIME_SLOT_REF2="ts985">
				<ANNOTATION_VALUE>katastrofes dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
