				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a431" TIME_SLOT_REF1="ts1087" TIME_SLOT_REF2="ts1088">
				<ANNOTATION_VALUE>in di KOSH- in di &lt;KOTEL'NAYA&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
