		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
				<ANNOTATION_VALUE>zenen geganen tsu tsu aza gevisn plats</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
