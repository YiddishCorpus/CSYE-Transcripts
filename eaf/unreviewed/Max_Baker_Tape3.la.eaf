		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1160" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1006">
				<ANNOTATION_VALUE>azoy az m'hot gemuzt geyn tsu fus, iz shreklekh tsu arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>un ikh hob gevust az dortn iz UNK shoyn bakumen, bin ikh aroys in di, &lt;hob&gt; gearbet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1010">
				<ANNOTATION_VALUE>tsvey monatn als KOCHEGAR. s'iz zeyer a shver arbet. ir shteyt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts1011" TIME_SLOT_REF2="ts1012">
				<ANNOTATION_VALUE>un ir sh- ven me darf dem oyvn oysreynikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
