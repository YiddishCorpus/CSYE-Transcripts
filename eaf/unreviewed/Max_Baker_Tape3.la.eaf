		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts1035" TIME_SLOT_REF2="ts1036">
				<ANNOTATION_VALUE>un dos hot gegebn a rays oyf, un s'hot gegebn a zets aroys, un es hot mir getrofn do</ANNOTATION_VALUE>
