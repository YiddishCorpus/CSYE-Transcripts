		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a393" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1002">
				<ANNOTATION_VALUE>mit azolekhe hakes az me zol kenen aroyfforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1159" TIME_SLOT_REF1="ts1003" TIME_SLOT_REF2="ts1004">
				<ANNOTATION_VALUE>un zey &lt;hobn&gt; geganen prubirn, hot zikh dos ibergedreyt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
