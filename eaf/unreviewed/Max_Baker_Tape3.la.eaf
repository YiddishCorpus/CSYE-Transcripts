			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1155" TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts921">
				<ANNOTATION_VALUE>un ikh hob im gezogt, "&lt;LEGUTKI&gt;, ikh hob a gutn paltn mit a"</ANNOTATION_VALUE>
