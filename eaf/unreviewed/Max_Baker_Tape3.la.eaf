		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts1023" TIME_SLOT_REF2="ts1024">
				<ANNOTATION_VALUE>un do iz nisht geven. &lt;iz geblibn&gt; lign, s'hot aykh gebrent</ANNOTATION_VALUE>
