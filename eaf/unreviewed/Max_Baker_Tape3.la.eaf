		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a428" TIME_SLOT_REF1="ts1081" TIME_SLOT_REF2="ts1082">
				<ANNOTATION_VALUE>ken nisht, az s'iz shver far mir"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
