		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts973" TIME_SLOT_REF2="ts975">
				<ANNOTATION_VALUE>geven tsvey rusn, un, un ikh bin geven der driter.</ANNOTATION_VALUE>
