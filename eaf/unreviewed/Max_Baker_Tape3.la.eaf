		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts988" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>dos, vos heyst UNK ir hot dokh gemuzt. ir &lt;zent&gt; aropgeganen in a shakht, iz dortn di, di vaser geven UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts992">
				<ANNOTATION_VALUE>ikh denk oyf vifl ikh hob shoyn gezen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts993" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>di geferlekhste arbet iz in, in Amerike di tekhnik oder in England iz UNK iz dokh a besere</ANNOTATION_VALUE>
