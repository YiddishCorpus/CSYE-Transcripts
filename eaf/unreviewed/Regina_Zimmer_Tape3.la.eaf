		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts956" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>dos iz gevezn fir un fertsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts961">
				<ANNOTATION_VALUE>biz eh, biz vinter tsayt zenen mir geganen keyn BERGEN BELSEN.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts962" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>vi UNK  s'iz nokh nisht geve- vi- vider, vider gevezn, gekumen mentshn. zey hobn gedarft</ANNOTATION_VALUE>
