		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a900" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts770">
				<ANNOTATION_VALUE>ikh vel dir zogn, ikh bin oykhet aleyn gevezn a khaye.</ANNOTATION_VALUE>
