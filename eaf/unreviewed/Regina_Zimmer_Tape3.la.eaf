		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts976">
				<ANNOTATION_VALUE>iz vider gevezn a, iz gevezn do di selektsye</ANNOTATION_VALUE>
