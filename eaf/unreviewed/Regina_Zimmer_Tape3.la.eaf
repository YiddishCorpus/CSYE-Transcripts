			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>vos der tate hot ir gegebn a sakh gelt, iz zi gekumen mikh UNK keyn, in geto arayn, un m'hot mikh avekgefirt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
