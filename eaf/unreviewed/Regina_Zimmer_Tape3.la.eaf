		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a885" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>hot zi gegebn a shpring aroyf mit, mit di fis, un di sh-</ANNOTATION_VALUE>
