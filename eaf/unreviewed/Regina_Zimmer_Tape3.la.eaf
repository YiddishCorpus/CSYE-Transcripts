			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>nisht genumen, nor zey hobn shoyn likvidirt shoyn di lager, di OSWIECIM, m'hot zi shoyn likvidirt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>hobn zey undz geshikt vayter keyn yeke land. dos iz BERGEN BELSEN</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
