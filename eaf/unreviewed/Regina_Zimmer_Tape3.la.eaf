			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a883" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>a ku iz zeyer klug</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
