		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>hot men dokh gevust az m'iz, dos hot men nokh gevust epes yomkiper, az der gantser lager hot gefast.</ANNOTATION_VALUE>
