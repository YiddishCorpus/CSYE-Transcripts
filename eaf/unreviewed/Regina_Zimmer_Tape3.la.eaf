		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>iz gevezn gemakht azolkhene gloz shtiklekh, un durkh dem gloz bay nakht hot men gezen dos fayer</ANNOTATION_VALUE>
