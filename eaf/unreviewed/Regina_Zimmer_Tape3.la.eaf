				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a380" TIME_SLOT_REF1="ts990" TIME_SLOT_REF2="ts991">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a381" TIME_SLOT_REF1="ts992" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>bay di s- eybik ven bist aroysgeganen, bistu gan in a selektsye.</ANNOTATION_VALUE>
