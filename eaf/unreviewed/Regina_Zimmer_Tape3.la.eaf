		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>dos vos hob ikh geribn di fis UNK un gesheylt di kartofl un UNK iz gevezn alts tsu veynik</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>un a stodole hob ikh gevashn un ale hob ikh &lt;getun&gt;. stodole heyst vu di khayes zenen. dos heyst a stodole.</ANNOTATION_VALUE>
