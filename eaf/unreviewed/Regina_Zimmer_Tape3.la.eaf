			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a878" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts465">
				<ANNOTATION_VALUE>keyn flash hot men nisht gehat. vos hostu gekent mitnemen? host dokh gornisht gekent mitnemen. m'iz azoy geganen.</ANNOTATION_VALUE>
