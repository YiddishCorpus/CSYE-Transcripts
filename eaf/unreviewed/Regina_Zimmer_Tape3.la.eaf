			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a881" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>halt zi bay di shtrik, un zolstu geyn, zolstu zi nisht &lt;nokhlozn&gt;." ikh hob zi takesh nisht nokhgelozt</ANNOTATION_VALUE>
