		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>tsi bist gezunt, tsi geyst in di arbet, &lt;tsi&gt; nisht bald UNK farbrenen</ANNOTATION_VALUE>
