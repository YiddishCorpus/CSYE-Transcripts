		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a918" TIME_SLOT_REF1="ts943" TIME_SLOT_REF2="ts944">
				<ANNOTATION_VALUE>un bay nakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a919" TIME_SLOT_REF1="ts945" TIME_SLOT_REF2="ts946">
				<ANNOTATION_VALUE>eh mitog shtunde gevezn di zup, hobn mir oykhet nisht gegesn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
