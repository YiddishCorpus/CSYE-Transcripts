			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts691">
				<ANNOTATION_VALUE>eh brent.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts695">
				<ANNOTATION_VALUE>m'hot UNK gevust UNK shoyn di kapos hobn shoyn gevust, vayl di kapos zenen shoyn dort gevezn fun frier, nisht UNK letstn gekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts696" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>di yidn zenen gevezn di kapos, fun Tshekhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>zey zenen nokh frier leyder gekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts705">
				<ANNOTATION_VALUE>vi undz. undz ze'mir shoyn gevezn di letste, di shpetste.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts706" TIME_SLOT_REF2="ts708">
				<ANNOTATION_VALUE>S.S. manen zenen gevezn. farshidene mentshn, fun Ungarn un fun Tshekhn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>fun farshidene. zey leyder hot men shoyn bald genumen fun Ungarn glaykh arayn in lager, in, keyn OSWIECIM.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>zey zenen gekumen nokh gut ongetun, mit esn ongetun. ale, zey hobn azoy vi zey zenen aropgeganen fun tsug</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>hobn zey gemuzt ales lozn shoyn shteyn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>hobn gornisht gekent mitnemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>mit valizen zenen ongekumen nebekh. zey hobn gemeynt az zey forn nebekh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>&lt;tsu undz&gt; tsu arbetn, zoln zey hobn mit tsu esn. ales hobn zey gelozt shteyn, gornisht. undz ze'mir gekumen shoyn fun lager. undz ho'mir  gornisht gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>ABER zey hobn gehat, un m'hot ales dos tsugenumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>dos iz ales in di yekishe hent geganen, ales.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts726" TIME_SLOT_REF2="ts729">
				<ANNOTATION_VALUE>gornisht, gornisht gearbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts730" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>azoy hot zikh UNK, a gantsn tog gornisht gearbet, gedreyt zikh oyf di gas.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>in barak hot men nisht gemegt zayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>vayl m'hot oyfgeroymt dem barak, hot men nisht gemegt zayn a gantsn tog UNK s'hot ge&lt;UNK&gt; un s'iz ge&lt;UNK&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>geregnt tsi kalt, s'hot nisht geshpilt keyn role. mir ho'mir gezitsn, gemuzt zayn in droysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>eyn mol bin ikh mikh geganen bodn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>nisht bodn, nor vashn, opvashn mayn kop, hob nisht gehat keyn hor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts746">
				<ANNOTATION_VALUE>nor ikh bin dokh gevezn a mentsh, hob ikh &lt;geganen&gt; opvashn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a892" TIME_SLOT_REF1="ts747" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>hob ikh gehat di bluzke vos hob ikh getrogn, di bluz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a893" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>hob ikh oyfgehongen oyf dem ayzn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a894" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>oyf eyn mol hot men geganvet di bluz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a895" TIME_SLOT_REF1="ts753" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>un ikh hob gedarft aroysgeyn zeks a zeyger oyf di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a896" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>apel plats, un di bluz iz nisht gevezn. nu, vos tut men? loyf ikh tsum barak, tsu di mame</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a899" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>un di mame iz tsugan tsu di lager ALTESTE un hot gezogt "her tsu, m'hot zi geganvet di bluz. vos zol zi tun? zi ken dokh nisht aroysgeyn yetst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a898" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>di yeke &lt;vet zi&gt; dokh bald hargenen."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>hot zi mir gegebn a sh- a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a296" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>a, fun a pizhame, fun a mener pizhame a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts766">
				<ANNOTATION_VALUE>a bluz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts767" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>di mentshn zenen nisht gevezn nebekh keyn mentshn, zenen ales gevezn vi khayes. </ANNOTATION_VALUE>
