		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>un dort hot men undz geshikt, s'iz nisht gevezn afile keyn barakn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
