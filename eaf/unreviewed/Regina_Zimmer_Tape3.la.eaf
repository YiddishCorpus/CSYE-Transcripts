		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>zog ikh "mame, vu &lt;vel&gt; ikh geyn? ikh hob dokh nisht vu tsu geyn.</ANNOTATION_VALUE>
