		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a179" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>m'hot shoyn gevust iz shoyn biter. m'hot shoyn gehert fun dem. m'hot shoyn gevust az s'iz shoyn biter, vayl mentshn zenen gekumen tsu loyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
