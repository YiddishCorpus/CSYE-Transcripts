				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>zenen mir arayngekumen keyn OSWIECIM</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
