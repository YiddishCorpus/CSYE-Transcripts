		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a920" TIME_SLOT_REF1="ts947" TIME_SLOT_REF2="ts948">
				<ANNOTATION_VALUE>nor bay nakht hobn mir gehat ersht dem tsveytn tog dos shtikele broyt tsu esn</ANNOTATION_VALUE>
