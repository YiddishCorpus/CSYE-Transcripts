			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>UNK nokh alts gevezn &lt;tsu heym&gt;. UNK hot zi mikh gegebn a shik aroys</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
