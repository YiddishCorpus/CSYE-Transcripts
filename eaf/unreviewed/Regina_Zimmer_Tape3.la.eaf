		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>bin ikh gevezn dort a tsvey vokhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
