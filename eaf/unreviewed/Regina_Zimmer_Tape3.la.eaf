		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a916" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts929">
				<ANNOTATION_VALUE>tog oys un tog ayn, tog oys un tog ayn esn un trinken un shlofn, esn un trinken un UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts930" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>gorni- yo, s'iz gevezn. s'iz gevezn yomkiper</ANNOTATION_VALUE>
