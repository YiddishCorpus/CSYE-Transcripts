			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>hot, shpeter az undz ho'mir gehat tsurikshteln tsu dem tran- tsu undzer blok, hot er gezen az s'iz geblibn finef zeks mentshn vos zey hobn zikh bahaltn</ANNOTATION_VALUE>
