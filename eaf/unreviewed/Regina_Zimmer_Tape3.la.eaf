			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>gantse lager hot gefast, nor vos iz geven? zenen mir UNK bay nakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>hobn mir gedarft nemen dos shtikele broyt, hot men dokh nisht genumen dos shtikele broyt oykhet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>hobn zey UNK tsugenumen dos shtikele broyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a917" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
				<ANNOTATION_VALUE>bay tog hobn zey nisht gegebn di kave, vayl UNK nisht trinken</ANNOTATION_VALUE>
