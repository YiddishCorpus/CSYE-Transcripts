		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts977" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>un do, az bist arayngeganen in UNK in a, tsu bodn zikh, un do arum un arum bistu yene zayt aroysgeganen</ANNOTATION_VALUE>
