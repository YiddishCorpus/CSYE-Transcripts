		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>shoyn in Visoke Litovsk</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
