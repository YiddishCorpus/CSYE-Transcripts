		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>yetst geheyrat a froy mit a kleyn kind.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
