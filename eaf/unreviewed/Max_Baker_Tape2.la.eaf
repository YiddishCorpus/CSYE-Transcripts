		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts697" TIME_SLOT_REF2="ts698">
				<ANNOTATION_VALUE>dos iz a shtot</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts699" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>fun ZAPADNA Vaysrusland</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>di, dos hot a mol balangt tsu Poyln, nor ven di sovyetn zenen arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>hobn zey dos farnumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>un ikh mit mayne brider zenen geven in di shtot Visoke Litovsk bar a fraynt in, undzers</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts708">
				<ANNOTATION_VALUE>vos er iz geven a lerer bay undz in shule shpeter vos er hot geshtamt fun di shtot, zenen mir dort ahin</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts709" TIME_SLOT_REF2="ts710">
				<ANNOTATION_VALUE>un er hot far undz geshaft arbet dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
