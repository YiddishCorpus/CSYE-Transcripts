		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>der Moyshe MINSTER hot ibergelozt, gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
