		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>un eyner a beker a polyak, un m'hot zey tsugefirt, nisht vayt iz geven di turme</ANNOTATION_VALUE>
