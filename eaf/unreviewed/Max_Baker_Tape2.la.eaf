		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>shpeter hobn mir gekrign a briv fun der heym</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
