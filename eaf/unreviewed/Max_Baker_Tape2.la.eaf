			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>nor mayne tsvey brider, ven mir zenen geven in Rusland</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
