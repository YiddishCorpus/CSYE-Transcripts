		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts689">
				<ANNOTATION_VALUE>ikh hob gevoynt bazunder in a tsimer vu ikh hob gefirt mayn varshtat.</ANNOTATION_VALUE>
