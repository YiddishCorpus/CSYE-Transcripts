				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a723" TIME_SLOT_REF1="ts609" TIME_SLOT_REF2="ts610">
				<ANNOTATION_VALUE>in, vi me zogt in EUROPA in di grestn goles. zey zenen tsu noent bay undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts611" TIME_SLOT_REF2="ts612">
