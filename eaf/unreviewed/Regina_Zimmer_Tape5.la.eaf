			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>un ikh hob mikh azoy ongerufn der vos hot ongetun a hitele oyfn kop</ANNOTATION_VALUE>
