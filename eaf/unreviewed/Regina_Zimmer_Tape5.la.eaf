				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>gegebn a zog, er iz &lt;dokh&gt; nisht gevezn in krig, un EBERSTARK, er hot zikh dokh nisht gekent onrufn</ANNOTATION_VALUE>
