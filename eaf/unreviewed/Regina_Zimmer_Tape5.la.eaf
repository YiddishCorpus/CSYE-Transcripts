		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts501" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>un er hot eybik gebrengt UNK mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts507">
				<ANNOTATION_VALUE>neyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts508" TIME_SLOT_REF2="ts510">
				<ANNOTATION_VALUE>neyn. ikh bin shoyn nisht mer tsurikgeforn. dos iz UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>di kinder betn mir. "mame, k- for, mame for." d- mayn zun iz gevezn, eyner, der tsveyter iz shoyn gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>nisht gevezn tsulib onkukn Poyln, nor iz gekumen forn oyf di kvorim, oyf di heylesh- heylike pletser</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts516">
				<ANNOTATION_VALUE>ABER nisht durkh dem onkukn Poyln, vayl dos interesirt im nisht, der Poyln</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a204" TIME_SLOT_REF1="ts517" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>nor iz geforn oyf heylike pletser zenen zey geforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>der, mayn eltster zun &lt;iz&gt; gevezn dos ershte mol vu der Bobover rebe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts521" TIME_SLOT_REF2="ts522">
				<ANNOTATION_VALUE>hot oyfgefrisht zayn zeyde matseyve</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts523" TIME_SLOT_REF2="ts524">
				<ANNOTATION_VALUE>vayl zayn tate hot men gesh- geshosn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts525" TIME_SLOT_REF2="ts526">
				<ANNOTATION_VALUE>nor zayn zeyde matseyve iz er geforn oyffrishn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>i- er iz gevezn eyner fun di ershte vos zey zenen mit im mitgeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
