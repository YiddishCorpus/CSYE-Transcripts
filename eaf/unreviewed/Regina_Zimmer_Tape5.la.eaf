			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>iz nisht gevezn keyn, &lt;kaza&gt; yidishkeyt do</ANNOTATION_VALUE>
