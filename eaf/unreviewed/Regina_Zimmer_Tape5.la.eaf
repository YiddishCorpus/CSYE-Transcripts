			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>un shpeter ruft mikh tsu Arn der kuzin, ruft men im tsu, zogt er "veyst ver &lt;do iz do&gt; gezesn?" zog ikh "vo- i- ver iz gezesn, KNOBLOCH?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
