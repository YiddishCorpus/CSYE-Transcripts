		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a689" TIME_SLOT_REF1="ts88" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>ikh bin tsu zey gekumen keyn, kh'hob gevust az zenen in, zey zenen fun Ungarn shoyn s- gekumen keyn Tshekhn</ANNOTATION_VALUE>
