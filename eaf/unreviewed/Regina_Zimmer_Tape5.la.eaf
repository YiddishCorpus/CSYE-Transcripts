				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>s'iz azoy gevezn. fun dort, fun BRATISLAVA, zenen mir geforn keyn PRAG.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a57" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>in PRAG zenen mir vider gevezn a tsayt, a bisele in JOINT. shpeter hot men zikh gedungen a shtub bay goyim, ze'mir gevezn &lt;vayl in&gt; JOINT ken men nisht azoy lang zitsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
