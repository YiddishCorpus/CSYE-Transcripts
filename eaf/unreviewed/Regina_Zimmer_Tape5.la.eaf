			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>un dort hot men opgekoyft a goye mit a mentsh vos hot gefirt, un hot oyfgehoybn di drotn, zenen mir aroyf- adurkhgeganen keyn BRATISLAVA</ANNOTATION_VALUE>
