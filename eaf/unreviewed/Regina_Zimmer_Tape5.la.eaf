		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>vayl do in Antverpn iz nisht gevezn demolts nokh azoy fil</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
