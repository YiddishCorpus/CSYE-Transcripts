		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>un ikh bin gekumen tsu zey keyn Tshekhn, bin ikh dort a</ANNOTATION_VALUE>
