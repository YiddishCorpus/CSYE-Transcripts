		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a691" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>hot &lt;ongetun&gt;, &lt;ot der&gt; man muz tsushteln mentshn, un az er hot tsugeshtelt mentshn, hot er dem mentsh oyf di nemones</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a692" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>darf men im shisn, azoy UNK vi der yeke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
