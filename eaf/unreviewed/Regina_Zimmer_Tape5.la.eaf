		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>nokh di krig hob ikh gehat dos ershte kind.</ANNOTATION_VALUE>
