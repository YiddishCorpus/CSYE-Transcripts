		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>greyt oyf, vider oyf a ye- oyf a eh dos do, oyf a khurbn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>vos tu ikh? s'iz nisht keyn, undz dos do greyt men keyn kinder, ober dos velt geyt vayter. me muz boyen undzer dor.</ANNOTATION_VALUE>
