			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>vayl dos iz undzer plats, un dos vet zayn eybik undzer plats.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts585" TIME_SLOT_REF2="ts586">
				<ANNOTATION_VALUE>er hot zikh baym lebn gekoyft a plats in Yisroel tsu lign</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>un ikh hob a plats in Yisroel tsu lign</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
