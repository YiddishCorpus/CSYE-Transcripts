			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>eh g- eh dort gevezn di yidishe gegnt, un dort gekumen, un vemen hobn zey getrofn, hobn zey dort geshosn fun di yidn vos zenen tsurikgekumen nebekh fun di lagers.</ANNOTATION_VALUE>
