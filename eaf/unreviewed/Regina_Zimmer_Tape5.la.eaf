			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts593" TIME_SLOT_REF2="ts594">
				<ANNOTATION_VALUE>un halt UNK di WOHNUNG. farkoyf zi nisht, vayl dos iz undzer plats dort tsu zayn.</ANNOTATION_VALUE>
