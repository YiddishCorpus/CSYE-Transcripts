				<ANNOTATION_VALUE>zogt er "vos zogstu azoy o?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>vayl der vos hot dort getrogn a hitele</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
