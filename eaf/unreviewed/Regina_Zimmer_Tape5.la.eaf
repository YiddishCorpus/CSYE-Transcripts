		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>zeks un, kh'hob gezen mentshn baym tish, un hot men ongehoybn ts- azoy tsu redn fun di krig, ahin un aher</ANNOTATION_VALUE>
