		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>ho'mir &lt;zikh&gt; gezogt m'vet forn vayter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
