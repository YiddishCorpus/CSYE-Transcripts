		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>ershtn veys ikh nisht ver iz der KNOBLOCH. ikh hob gevust velekhe kapo, vi er heyst, der kapo?</ANNOTATION_VALUE>
