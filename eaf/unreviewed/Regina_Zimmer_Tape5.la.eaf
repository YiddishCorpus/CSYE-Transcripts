			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a690" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>a por tog gevezn, biz di mame iz gekumen tsu forn, vayl ikh bin tsun ersht gekumen fun Poyln aroys</ANNOTATION_VALUE>
