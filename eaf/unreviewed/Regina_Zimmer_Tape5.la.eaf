				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts468">
				<ANNOTATION_VALUE>a krankeyt. iz gekumen fun Yisroel a yid vos er darf heyln a yid, &lt;darft&gt; er tsuzamennemen gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>hot mayn man hot dos gebrengt in mir in shtub arayn mit fir kinder, a mentsh mit k- a kind mit POLIO krankeyt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a185" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>un ikh hob es genumen bay mir in shtub arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts473" TIME_SLOT_REF2="ts474">
				<ANNOTATION_VALUE>un ikh hob es opgehit, un der yid iz ganen nokh gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts475" TIME_SLOT_REF2="ts476">
				<ANNOTATION_VALUE>iz er geforn keyn Daytshland heyln dos kind</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts478">
				<ANNOTATION_VALUE>un stabil gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts479" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>di mentshn. ikh hob gevoynt tsveyte tir fun UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a190" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>un eh, hot er gezogt azoy, "vi azoy makhstu, mit dayne fir kinder, vi azoy makhstu dos do, az kenst</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a191" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>kumt, az der mentsh brengt a oyrekh in shtub arayn, hostu eybik"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a192" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>zog ikh "vel ikh nisht fray- zuntik nisht esn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>fun shabes, vet men es unterkokhn frish."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>un eybik gevezn far mentshn esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a193" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>eybik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>nisht UNK, vayl haynt az</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>az me f- kumt a mash- mashgiekh nokh gelt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>kumt nisht in a shtub arayn esn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts499" TIME_SLOT_REF2="ts500">
				<ANNOTATION_VALUE>nor geyt tsu eh a reb Yankele, do, dort. demolts iz nisht gevezn. demolts iz men geganen in shtub arayn, un yeder eyner iz arayngekumen ersht in TERLIST shtibl arayn, TERLIST shul</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
