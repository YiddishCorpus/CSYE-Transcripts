		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>un m'iz geven bay im, iz gevezn etlekhene tekhter, di tsveyte tokhter hot er genumen far a froy, un beyde lebn nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>ober es lebn tsvey kinder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts115">
				<ANNOTATION_VALUE>di nemen fun eh fun mayn shver, dos heyst fun mayn man's tatn, un mayn mayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts114" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>un di andere, neyn, di un a tokhter oykhet, heyst zi nisht nokh eh nokh der mame. nokh der mame heyst mayn tokhterl Sara. mayn man's.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>dos iz geven dos kumen aher. un dos iz geven m'hot zi mer nisht ongekukt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>m'iz gekum- m'iz farforn tsu zey, ze'mir geshlofn bay dem shvoger, oyf, nokh nenter tsu tsu</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>oyf a oyf a gas Zrubavel, nokh mer vi Zrubavel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>far nokh Zrubavel nokh. nenter tsum tsum eh tsum metshet vos shteyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a71" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>ze'mir geshlofn, m'hot ongehoybn zukhn a dire.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>geven ze'mir mitglider in der linker politsye in Bergn-Belzn, hot er gegebn finef toyznt dolar,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>Shmetenet, Smetana hot er geheysn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>er iz dafke nisht er iz nisht gekumen keyn Yisroel, nor ergets farforn keyn Zid-Amerike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a75" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>un eh ikh ikh hob mikh gevondn oyf eh keygn iber</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a566" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>in eh in Histadrut eh ts- binyen oyf Brener iz gevezn di linke politsye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a567" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>ikh bin aroyfgekumen, ikh hob getrofn epes a hoykerl,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts141">
				<ANNOTATION_VALUE>ikh hob mikh for- ikh hob nokh a legitimatsye, az m'iz geven mitglider in Bergn-Belzn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a569" TIME_SLOT_REF1="ts140" TIME_SLOT_REF2="ts142">
				<ANNOTATION_VALUE>zogt er, eh eh iz ruf ikh mikh on, zog ikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a570" TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>ikh hob gehert az eh, SHIKUNIM hob ikh nisht gekent zogn, ikh hob nisht gevust in gantsn keyn UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a571" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>vi azoy zog ikh, iz ho'mir ho'mir nisht keyn dire, un az m'hot eh m'hot gornisht genumen barn Sokhnut oykh gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a572" TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>m'veyst nisht vu iz der Sokhnut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
				<ANNOTATION_VALUE>zogt er, undz boyen mir, ober vos, zogt er, s'hot a, vos iz der vider fun vanet du kumst yetst geyn darfstu bald hobn a BAYIT MESHUTAF hot er gerufn. zey hobn geboyt oyf Aleksander Yanay.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>sheyne tsvey eh tsvey eh anderthalbn tsimern, heyst tsvey tsimern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>a sheyne voynung, ikh bin dernokh gekumen in ir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a80" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
				<ANNOTATION_VALUE>zogt er, ir zent naye OLIM, darf men zen fun vanet tsu fardinen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
				<ANNOTATION_VALUE>s'take nisht ge- mayn man hot take nisht gekent fardinen keyn keyn lire tsen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
				<ANNOTATION_VALUE>s'iz take geven zeyer shver. alzo vos m'hot gehat, di brilantn gedekt oyf Kuba tsu forn, iz gevorn farkoyft,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
				<ANNOTATION_VALUE>ikh hob arayngeleygt alts in der dire, zekhtsik shtign,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
				<ANNOTATION_VALUE>punkt keygn iber dem metshet, di ershte koyln, eyder s'nokh geven a melukhe, eyder s'geven a regirung, hob ikh gehat in shtub, zekhtsik shtign heykh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a86" TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts167">
				<ANNOTATION_VALUE>un dernokhn in a tsayt eh m'hot oysgegebn dos gelt un aroysnemen punkt in tog fun tsvelef yor dortn voynen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a573" TIME_SLOT_REF1="ts166" TIME_SLOT_REF2="ts168">
				<ANNOTATION_VALUE>hot men fun UNK tsen toyznt dolar, toyznt eh eh eh shekl opgekrign dray hundert. tsu di dire tsu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts171">
				<ANNOTATION_VALUE>nu dos iz dos, ets vilt mit dem farendikn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts172" TIME_SLOT_REF2="ts174">
				<ANNOTATION_VALUE>yo, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a93" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts177">
				<ANNOTATION_VALUE>ober, yo, ober vos un ven, ir ir muzt mir, az nisht vel ikh nisht untershraybn gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a574" TIME_SLOT_REF1="ts178" TIME_SLOT_REF2="ts181">
				<ANNOTATION_VALUE>n- neyn, ikh, ober ikh vel nisht untershraybn oyb ets vet mir nisht oysmekn dos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a94" TIME_SLOT_REF1="ts182" TIME_SLOT_REF2="ts184">
				<ANNOTATION_VALUE>zi vil nisht hern. ikh hob opgenu- z- zi iz oysergeveyntlekhe tip.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a96" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
				<ANNOTATION_VALUE>azoy vi, i- ikh ken azelkhe vos zenen geven in Rusland,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a575" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
				<ANNOTATION_VALUE>un z- di eltern hobn nisht vos tsu dertseyln, un di kinder viln nor hern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a576" TIME_SLOT_REF1="ts189" TIME_SLOT_REF2="ts190">
				<ANNOTATION_VALUE>zi vil keyn mol nisht hern. gornisht vil zi gedenken, un gornisht gedenkt zi.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a98" TIME_SLOT_REF1="ts191" TIME_SLOT_REF2="ts193">
				<ANNOTATION_VALUE>un zi vil nisht gedenken. un zi iz tsu mir shlekht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts197">
				<ANNOTATION_VALUE>ikh hal- i- i- ikh ikh ikh makh ikh ikh hob tsu klern oyf nokh der milkhome. ikh hob mit dem man opgelebt akht un draysik un a halb yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a101" TIME_SLOT_REF1="ts198" TIME_SLOT_REF2="ts200">
				<ANNOTATION_VALUE>yo, iz az s'kholemt zikh makho- iz er geven a zeyer a shverer eser.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a577" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts203">
				<ANNOTATION_VALUE>trots dem vos er iz geven a yosem fun der ershter velt milkhome, hot er lib gehat herlekh gegesn sheyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts202" TIME_SLOT_REF2="ts204">
				<ANNOTATION_VALUE>vayl in di restoranen, er iz ge- m'iz geblibn a shtub mit yesoymim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a102" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>kholem red ikh nor vegn esn. oy, ikh hob gornisht in shtub.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a105" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>vayl bay mir kent ir take, far mir iz genug, nor ikh zol darfn oyfnemen mentshn azoy shtendik s'geven, eh hob ikh nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a107" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts210">
				<ANNOTATION_VALUE>un der man shtendik mit esn ku- hot kumt er mir kapoyers, mit a gezelshaft mit farshidene zakhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a108" TIME_SLOT_REF1="ts211" TIME_SLOT_REF2="ts212">
				<ANNOTATION_VALUE>un ikh shlof nisht azoy shle- azoy fil ikh zol hobn ven tsu kholemen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a109" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
				<ANNOTATION_VALUE>az ikh z- ikh az az ikh her her ikh ikh nayes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a110" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts216">
				<ANNOTATION_VALUE>gey ikh shlofn eynse, halb eyns, mit a NUMBER nokh azoy fil tabletn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a579" TIME_SLOT_REF1="ts217" TIME_SLOT_REF2="ts218">
				<ANNOTATION_VALUE>haynt finef un ikh hob shoyn badorfn nemen dos tsveyte mol, hob ikh shoyn genumen tsvelef tabletn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>eyder ikh nem di tabletn, eyb- i- eyder ikh derken, s'iz oys- s'iz oyssortirt, oyfn tish dortn zenen alts mayne retseptn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a112" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts225">
				<ANNOTATION_VALUE>un far vegn dem kind vegn, ir tort nisht, ir muzt mir tsuzogn ayer ern-vort er vet nisht dermanen zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a113" TIME_SLOT_REF1="ts226" TIME_SLOT_REF2="ts227">
				<ANNOTATION_VALUE>rayst oys di bletlekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts231">
				<ANNOTATION_VALUE>vayl ikh hob ir gegebn epes haynt a zog, ikh ken aykh nisht forshteln, ikh shem mikh tsu dertseyln vi vosere sof ikh hob gehat.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a116" TIME_SLOT_REF1="ts232" TIME_SLOT_REF2="ts233">
				<ANNOTATION_VALUE>ikh kokh in gantsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts236" TIME_SLOT_REF2="ts237">
				<ANNOTATION_VALUE>dos vil ikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts238" TIME_SLOT_REF2="ts240">
				<ANNOTATION_VALUE>yo, koydem vil ikh zogn far di gelernte, far di profesorn. s'do a profesor Bauer, a u- a a a ungarisher.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a121" TIME_SLOT_REF1="ts241" TIME_SLOT_REF2="ts242">
				<ANNOTATION_VALUE>er hot nokh, zey hobn in gantsn di ungarn, er hot dokh zey gedekt, der keyser,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts243" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>zey hobn dokh fir, zenen dokh arayngeforn keyn Bergn-Belzn fir vokhn farn endikn di milkhome.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a122" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>zey hobn d- di rumener mer a bisl. di ungarisher hobn dokh in gantsn nisht ge- un hobn zikh gekent oysbahaltn, ikh ken a sakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a123" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
				<ANNOTATION_VALUE>eh zogt er az er hot nokh gornisht gevust. a halbe milyon yidn iz hot gelebt in gantsn a sho. ikh hob aykh gevolt dertseyln, az dos gantse lebn keyn Treblinke hot gedoyert a sho. fun di transportn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
				<ANNOTATION_VALUE>m'hot zey nisht s'nisht s'bald geven a toytn-lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts251" TIME_SLOT_REF2="ts252">
				<ANNOTATION_VALUE>yetst dos m'ruft on az s'iz geven eh tsum ersht, s'iz geven bald keyn shum ander zakh in Varsheve, bald a toytn lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts253" TIME_SLOT_REF2="ts254">
				<ANNOTATION_VALUE>bald tsu shtarbn. un s'iz take ge- ale vegelekh mit alding. undz ho'mir gehat a shokhn voynen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a582" TIME_SLOT_REF1="ts255" TIME_SLOT_REF2="ts256">
				<ANNOTATION_VALUE>vos hot gearbet oyfn beys-almen, oyfn algemeynem fun Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a583" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>hot er gefirt, in di kantselarye iz er geven an ongeshtelter. a frumer mentsh nor a eleganter azoy fun di sheyn geputste.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>hobn undz geha- un mayn man iz geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a584" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts263">
				<ANNOTATION_VALUE>der vos hot tsunoyf genumen di dos gelter vi lang s'geven a por pyaster yede eh yedes mol</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a585" TIME_SLOT_REF1="ts262" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>oyf tsu kenen bagrobn, oder aroyshelfn azelkhe vos zenen shtar- eh geshtanen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a586" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>azoy az m'hot gev- geven gut bakant.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a587" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
				<ANNOTATION_VALUE>di mindst vos m'hot ongefirt in masn-kvorim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a588" TIME_SLOT_REF1="ts268" TIME_SLOT_REF2="ts270">
				<ANNOTATION_VALUE>iz geven tsuzamen dos on registratsyes, zey hobn nisht gekent zdonzhen tsu makhn keyn registratsyes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts271" TIME_SLOT_REF2="ts273">
				<ANNOTATION_VALUE>tsvey hundert un zibetsik, tsvey hundert un akhtsik toyte, dray hundert toyte iz geven yedn tog. fun hunger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a589" TIME_SLOT_REF1="ts272" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>un koydem zenen geganen di vos zenen gevorn arayngeyogt oykhet. ober bald fun ershtn tog</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a590" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>iz dokh gev- funem bombardirn fir fir vokhn zikh nisht untergebn iz dokh bald geven a hunger.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a591" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>meyle dos hobn di polyakn oykhet, ober zey hobn zikh ender an eytse gegebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a592" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>hobn zikh aroysgekrign oyf a provints, gebrengt fun fun di fun di derfer epes, ober yidn hobn dokh bald gelitn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a593" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>nor nokh dem vi m'hot undz farmakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a594" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>un eh un nisht vayl, eh ven s'hot zikh geendikt di bombardi- di di di un zey hobn zikh er hot zikh untergegebn Stazhinski.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a595" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts287">
				<ANNOTATION_VALUE>iz bald geven toyt. nisht geven vi tsu fardinen, nisht gevezn keyner hot gornisht farmogt, alts iz geven bombardirt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a596" TIME_SLOT_REF1="ts286" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>zeltn s'geblibn a gantse shtub, dos iz bald geven a toytn lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts290" TIME_SLOT_REF2="ts293">
				<ANNOTATION_VALUE>o. bay Kshyevitskin hob ikh gezdonzhet, eh Varshe iz dokh geven in gantsn, yeder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a597" TIME_SLOT_REF1="ts292" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>dos der poylisher gegnt iz oykh geblibn nor a por hayzer vu di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a598" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>vu di di daytshn hobn zikh farhaltn biz der letster minut vi zey hobn opgetretn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a599" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>eh oyf a oyf der gro- oyfn poylishn gegnt iz es gevezn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a600" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>ikh bin dort geven take, s'geven der oysern MINISTERSTWO, ikh bin gegangen gevoyer vern vegn Kuba,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a601" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
				<ANNOTATION_VALUE>ven s'mir geven akte- aktuel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a602" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>bin ikh eyn mol adurkhgeyendik eh adurkh geganen oyf der dire vu er hot gevoynt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>di tsveyte dire vos ikh bin mit zey geshlofn in shlof-tsimer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>iz keyner nisht geven, di tir eh dire geven ofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a142" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>s'geshtanen nisht keyn me- di ikh hob aykh dertseylt az di shlof-tsimer iz geven azoy mit gold azoy vi dos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>bay a raykhe hayzer, ver hot gehat tsvey azelkhe groyse tsimern in Varshe, yidn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a144" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>zeyer raykhe mentshn gemuzt zayn. vayl in Varshe a a dire iz geven MASHEHU, nisht tsutsukumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a145" TIME_SLOT_REF1="ts315" TIME_SLOT_REF2="ts316">
				<ANNOTATION_VALUE>bin ikh aroyfgeganen, s'keyner nisht geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts319">
				<ANNOTATION_VALUE>eyns hob ikh gevust take fun Vroblevskin, az der bruder iz gefaln. in oyfshtand, ir bruder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts318" TIME_SLOT_REF2="ts320">
				<ANNOTATION_VALUE>un s'fun zey lebt ver s'geven a zun vos iz geganen in TICHON arayn, ge- zey hobn gelernt um- umlegal,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a150" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>di polyakn, s'hot dokh nisht getort zayn keyn shum shule nisht, gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts323" TIME_SLOT_REF2="ts324">
				<ANNOTATION_VALUE>iz eh a zun mit a tokhter. un a mame zayne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a153" TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
