		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>zi hot tsvey kinder, zi hot geboyrn a tsviling.</ANNOTATION_VALUE>
