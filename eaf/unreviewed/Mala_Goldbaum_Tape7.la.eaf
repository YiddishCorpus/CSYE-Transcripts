		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>zey hobn shoyn kinder nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
