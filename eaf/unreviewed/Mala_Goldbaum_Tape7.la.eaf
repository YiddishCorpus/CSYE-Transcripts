		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
				<ANNOTATION_VALUE>eh z- eh Marta. Marta.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
