		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts92" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>Alberto voynt eh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
