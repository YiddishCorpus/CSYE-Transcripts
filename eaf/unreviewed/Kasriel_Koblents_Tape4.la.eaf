			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts121">
				<ANNOTATION_VALUE>bay dray monat, ershte OTDELENye, oyf, oyf DAUKŠOS gas.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts122" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>ershte opteylung, ye. oyf DAUKŠOS gas.</ANNOTATION_VALUE>
