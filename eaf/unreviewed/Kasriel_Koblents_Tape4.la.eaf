		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts511" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>nu, azoy hob ikh zikh opgemutshet, un nokh dem &lt;hot zikh&gt; ongefangen, Tsherne hot mir zeyer fil geholfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
