			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>hot men undz genumen, hot men gegebn a bafel, me zol otpravenen dortn fun Kovne,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>uh, n- naye kadern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>hot men mir otpravet, mir un dortn nokh tsu mir iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>mir zaynen ongekumen nit vayt fun Klaypede in GARGŽDAI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>dortn geven &lt;a-&gt; zeyer groyse kamfn. mir hobn gezen az me ken dortn nokh nit blaybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>zeyer f- etlekhe zaynen gekumen tsurik in Kovne,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts141">
				<ANNOTATION_VALUE>ober ikh un nokh zaynen dortn geblibn vartn biz, uh... s'flegn poshet svishtshenen di SNARYADn ibern kop hin un tsurik. azoy iz geven dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a649" TIME_SLOT_REF1="ts142" TIME_SLOT_REF2="ts145">
				<ANNOTATION_VALUE>azelkhe, azelkhe BOY iz geven, azelkh-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a650" TIME_SLOT_REF1="ts146" TIME_SLOT_REF2="ts148">
				<ANNOTATION_VALUE>kamfn geven in Klaypede.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a352" TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
				<ANNOTATION_VALUE>nu, nokh dem, &lt;m'hot shoyn&gt; farnumen Klaypede,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
				<ANNOTATION_VALUE>hot men undz otpravet, hot men undz a- hm, a- avekgeshikt arbetn in Shilute.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
				<ANNOTATION_VALUE>Shilute bin ikh geblibn dortn arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts157">
				<ANNOTATION_VALUE>dortn hob ikh opgearbet fun fir un fertsiktn bizn tsvey un fuftsiktn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a356" TIME_SLOT_REF1="ts158" TIME_SLOT_REF2="ts160">
				<ANNOTATION_VALUE>mayn gantse, di gantse yorn, ken men zogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts163">
				<ANNOTATION_VALUE>&lt;zaynen&gt; geven in vald mit di, mit di, uh, mit di, uh, litvishe...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts164" TIME_SLOT_REF2="ts166">
				<ANNOTATION_VALUE>banditn, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
				<ANNOTATION_VALUE>bizn tsvey un fuftsiktn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts169" TIME_SLOT_REF2="ts170">
				<ANNOTATION_VALUE>yedn nakht, yedn nakht fleg zayn TREVOGes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts174">
				<ANNOTATION_VALUE>TREVOGes. fleg men geyn &lt;PRICHЁS-&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts175" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>vi, nu, durkh, uh, di vald durkh-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a653" TIME_SLOT_REF1="ts179" TIME_SLOT_REF2="ts182">
				<ANNOTATION_VALUE>hm?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts181" TIME_SLOT_REF2="ts185">
				<ANNOTATION_VALUE>durkhkamen di vald, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a651" TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts189">
				<ANNOTATION_VALUE>ale mol.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts190" TIME_SLOT_REF2="ts192">
				<ANNOTATION_VALUE>s'fleg zayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a366" TIME_SLOT_REF1="ts193" TIME_SLOT_REF2="ts194">
				<ANNOTATION_VALUE>eyn mol hobn mir, uh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts195" TIME_SLOT_REF2="ts196">
				<ANNOTATION_VALUE>zey flegn zikh azoy farmaskirn, di banditn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts197" TIME_SLOT_REF2="ts198">
				<ANNOTATION_VALUE>mir hobn eyn mol getrofn, a boym shteyt, a trukener boym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts199" TIME_SLOT_REF2="ts200">
				<ANNOTATION_VALUE>nu, geyt tsu eyner, zogt er,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts201" TIME_SLOT_REF2="ts202">
				<ANNOTATION_VALUE>"&lt;me darf do&gt; a kuk gebn" UNK er git a shtup der boym un der boym falt anider. untn iz geven a bunker untern boym gemakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts203" TIME_SLOT_REF2="ts204">
				<ANNOTATION_VALUE>dortn, un grade iz geven dortn iz geven di banditn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a373" TIME_SLOT_REF1="ts205" TIME_SLOT_REF2="ts206">
				<ANNOTATION_VALUE>nu, m'hot zey glaykh bafeln, zey zoln aroysgeyn;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a375" TIME_SLOT_REF1="ts207" TIME_SLOT_REF2="ts208">
				<ANNOTATION_VALUE>anit &lt;veln&gt; UNK dershisn. a por zaynen aroys, oyfgehoybn di hent, opgegebn di gever, un andere</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts209" TIME_SLOT_REF2="ts211">
				<ANNOTATION_VALUE>zaynen nit aroys, hot men zey bavorfn mit granatn un zey zaynen dortn geharget gevorn ale.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts213" TIME_SLOT_REF2="ts214">
				<ANNOTATION_VALUE>dos iz geven bay tog. mir flegn geyn bay tog UNK in di velder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a379" TIME_SLOT_REF1="ts215" TIME_SLOT_REF2="ts217">
				<ANNOTATION_VALUE>mir hobn zeyer fil erter gefunen in hayzer. fleg zayn doplte vent gemakht, uh, far m- nu, malines far, far di banditn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a382" TIME_SLOT_REF1="ts218" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>oysgefinen, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts221" TIME_SLOT_REF2="ts222">
				<ANNOTATION_VALUE>eyn mol zaynen mir gegangen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a384" TIME_SLOT_REF1="ts223" TIME_SLOT_REF2="ts225">
				<ANNOTATION_VALUE>uh, oykhet, uh, m'hot undz gemoldn az in dem dorf gefint zikh, gefint zikh a grupe fun partizaner, fun di banditn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts226" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>fun di litvishe, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a386" TIME_SLOT_REF1="ts229" TIME_SLOT_REF2="ts230">
				<ANNOTATION_VALUE>nu, zaynen mir avekgeforn, un mit undz iz geforn eyner a mayor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a387" TIME_SLOT_REF1="ts231" TIME_SLOT_REF2="ts232">
				<ANNOTATION_VALUE>er iz durkhgegangen dem gantsn front.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a388" TIME_SLOT_REF1="ts233" TIME_SLOT_REF2="ts235">
				<ANNOTATION_VALUE>nu, hobn mir genumen geyn fun shtub tsu shtub zukhn dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts236" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>in a dorf, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts241">
				<ANNOTATION_VALUE>nokh dem zaynen mir tsugegangen tsu a, tsu a SARAY. vi ruft men...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a392" TIME_SLOT_REF1="ts242" TIME_SLOT_REF2="ts244">
				<ANNOTATION_VALUE>shayer. tsugegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a394" TIME_SLOT_REF1="ts245" TIME_SLOT_REF2="ts246">
				<ANNOTATION_VALUE>nu, zogt men dortn, ho&lt;t men&gt; im gezogt, "zay forzikhtik!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a395" TIME_SLOT_REF1="ts247" TIME_SLOT_REF2="ts248">
				<ANNOTATION_VALUE>iz er tsugegangen, geefnt di tir. zogt er, "ha! &lt;ba," zogt er,&gt; "ikh bin durkhgegangen dem gantsn front. ikh bin UNK &lt;hot mir&gt; keyn zakh nit geshat. &lt;ikh'l nit&gt; do moyre hobn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts251">
				<ANNOTATION_VALUE>vi nor er hot geefnt di, di tir, hot men im glaykh gegebn a otshered un er iz gefaln...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts252" TIME_SLOT_REF2="ts255">
				<ANNOTATION_VALUE>ye. a rey fun AVTOMAT, un er iz glaykh gefaln bayn tir a toyter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a400" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>nu, vos hobn mir gekent ton? UNK un dan, hm, geyendik, di operatsye iz geven vider gemakht UNK in fir erter mit fir koyln-varfers,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts261">
				<ANNOTATION_VALUE>un m'hot alemen &lt;nokh dem, alemen&gt; oysge- oysgeharget&lt;, vos...&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a657" TIME_SLOT_REF1="ts262" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>&lt;ha?&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a402" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>m'hot geefnt oyf im a fayer, oyf dem shayer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a658" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts269">
				<ANNOTATION_VALUE>un er hot genumen brenen, &lt;un m'hot&gt; farvorfn mit granatn, un s'iz geendikt di operatsye geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a403" TIME_SLOT_REF1="ts270" TIME_SLOT_REF2="ts272">
				<ANNOTATION_VALUE>mir flegn keyn lebedi&lt;k-&gt; keynem nit aroyslozn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a404" TIME_SLOT_REF1="ts274" TIME_SLOT_REF2="ts276">
				<ANNOTATION_VALUE>tsk, fun der milits, ikh hob, ikh bin arayngefaln, vi me zogt, tsufelik;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a407" TIME_SLOT_REF1="ts277" TIME_SLOT_REF2="ts278">
				<ANNOTATION_VALUE>ikh bin dokh a shnayder fun fakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a408" TIME_SLOT_REF1="ts279" TIME_SLOT_REF2="ts280">
				<ANNOTATION_VALUE>kh'hob afile nit gevust mit vos m'est es, uh, di mil- milits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a409" TIME_SLOT_REF1="ts281" TIME_SLOT_REF2="ts282">
				<ANNOTATION_VALUE>m'hot mir bashtimt; ikh bin geven dan,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts283" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>uh, m'hot mir geshikt. vuhin m'hot mir geshikt, dortn bin ikh geforn. nu,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts286">
				<ANNOTATION_VALUE>ikh hob opgearbet in militsye dray, fir yor. kh'hob gezen az do iz far mir keyn ort nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts287" TIME_SLOT_REF2="ts288">
				<ANNOTATION_VALUE>beshas ikh bin arayn in militsye hob ikh gedarft shraybn a, mayn gantse AVTOBIOGRAFye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts289" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>hob ikh, uh, gesh- hob ikh, uh, nit geshribn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
				<ANNOTATION_VALUE>dan, far Stalin's tsaytn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a417" TIME_SLOT_REF1="ts293" TIME_SLOT_REF2="ts294">
				<ANNOTATION_VALUE>der vos hot gehat a fraynt in oysland hot nit getort arbetn in di ORGANAKH.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a419" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>ikh hob nit, uh, ikh hob nit gevust az ikh hob a bruder in Amerike.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a420" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>nu, un kh'hob nit geshribn, a- azoy az ikh bin geblibn arbetn. s'iz avekgegangen a dray, fir yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a421" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>mit a mol kumt on a briv fun bruder. er hot zikh dervust az ikh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a423" TIME_SLOT_REF1="ts301" TIME_SLOT_REF2="ts302">
				<ANNOTATION_VALUE>gefin zikh in Shilute.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
