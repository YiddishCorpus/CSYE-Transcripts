		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts105">
				<ANNOTATION_VALUE>m'hot geshikt eynem in turme far a NADZIRATEL', a tsveytn UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>oyfzeer, ye. tsveytn oyfn b- ayznban-stantsye dortn in, uhm...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts110" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>vakh-man... UNK ongerufn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>mir hot men bashtimt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
