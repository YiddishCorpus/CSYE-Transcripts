		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a564" TIME_SLOT_REF1="ts619" TIME_SLOT_REF2="ts620">
				<ANNOTATION_VALUE>un er hot mir geshafn di dire.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
