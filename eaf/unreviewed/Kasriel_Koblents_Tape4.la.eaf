		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>di partizaner, vu me darf geyn arbetn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
