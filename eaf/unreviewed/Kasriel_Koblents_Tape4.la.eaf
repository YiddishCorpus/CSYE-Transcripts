		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a568" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts637">
				<ANNOTATION_VALUE>u- Elke, un der tsveyter zun lebt in Klaypede, Ruvke, mit, mit, uh, mit di froy un di tsvey kinder, tsvey meydlekh.</ANNOTATION_VALUE>
