		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a565" TIME_SLOT_REF1="ts622" TIME_SLOT_REF2="ts625">
				<ANNOTATION_VALUE>biz hayntikn tog. ot di dire hob ikh bakumen a dank Vilenskin, dem GEROY SOVETSKOGO SOYUZ&lt;A&gt;...</ANNOTATION_VALUE>
