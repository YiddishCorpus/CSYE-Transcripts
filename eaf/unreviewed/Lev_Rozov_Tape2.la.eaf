		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a396" TIME_SLOT_REF1="ts1049" TIME_SLOT_REF2="ts1050">
				<ANNOTATION_VALUE>di muter hot nit gekont mer geyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a398" TIME_SLOT_REF1="ts1051" TIME_SLOT_REF2="ts1052">
				<ANNOTATION_VALUE>zaynen mir a bisl geshtanen, avek, opgevart...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
