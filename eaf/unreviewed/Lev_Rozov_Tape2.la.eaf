			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>me nemt arop di yidn fun di arbet, un me faryogt, un andere zetst men arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>dos iz shoyn geven in di tsaytungen, un me leyent dokh tsaytungen, hot men gevust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>nu, hobn zey gemeynt az dos iz nor, er tut di yidn &lt;un&gt; es vet azoy zayn; m'hot dokh nit gevust.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>az er vet geyn koylen di yidn ot azoy vi, uh, ot v- ot vi</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1040" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts649">
				<ANNOTATION_VALUE>shof, ver hot dos getrakht?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts648" TIME_SLOT_REF2="ts650">
				<ANNOTATION_VALUE>mir hot men dos in Rusland gezogt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts651" TIME_SLOT_REF2="ts652">
				<ANNOTATION_VALUE>in, in yor, in yor...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts653" TIME_SLOT_REF2="ts654">
				<ANNOTATION_VALUE>dray un fertsik tsi fir un fertsik?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts655" TIME_SLOT_REF2="ts656">
				<ANNOTATION_VALUE>plenikes zaynen antlofn, hobn zey dertseylt &lt;dortn, dertseylt&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1041" TIME_SLOT_REF1="ts657" TIME_SLOT_REF2="ts658">
				<ANNOTATION_VALUE>zog- zogt mir</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts659" TIME_SLOT_REF2="ts660">
				<ANNOTATION_VALUE>mayn shvester, &lt;az ikh zog ir,&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts661" TIME_SLOT_REF2="ts662">
				<ANNOTATION_VALUE>zogt zi, "dos makht men propagande."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>ir, ir farshteyt? mir hobn dos nit gegleybt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>v&lt;os&gt; ikh hob nit g- derzen mit di eygene oygn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1042" TIME_SLOT_REF1="ts667" TIME_SLOT_REF2="ts668">
				<ANNOTATION_VALUE>hob ikh nit gegleybt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>az, az dos hot zikh gornit gelozn leyenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>in der historye hob ikh dos nit geleyent. me zol azoy oyskoylen a folk?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>geven in Shpanye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>hot er oykh ge- ge- geheysn zey shmadn, dos, yents,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1043" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>oder er hot nit gekoylet glaykh ale yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts679" TIME_SLOT_REF2="ts680">
				<ANNOTATION_VALUE>dos iz geven erger vi in Shpanye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a278" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>kh'hob geleyent in Shpanye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>ir farshteyt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a280" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>ot dos hot zikh undz nit gegl- afile in Rusland;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1044" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts688">
				<ANNOTATION_VALUE>mir hobn gemeynt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1045" TIME_SLOT_REF1="ts689" TIME_SLOT_REF2="ts691">
				<ANNOTATION_VALUE>az dos makhn di rusn propagande, az me zol zey...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1046" TIME_SLOT_REF1="ts692" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>ye, gegn, az mir zoln zey gl- -leybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1047" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>un zen az di rusn nor haltn undz oys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts698" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>iz in eyn un fertsiktn yo-... itster gib ikh f- eyn un fertsiktn yor. eyn un fertsiktn yor</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>hot men gegebn krik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>di rusn hobn bay undz in shtetl oysgeklibn etlekhe hige yugntlekhe, gegebn zey biksn hitn di shtot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts707">
				<ANNOTATION_VALUE>un ale zaynen genumen antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts708" TIME_SLOT_REF2="ts709">
				<ANNOTATION_VALUE>antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts710" TIME_SLOT_REF2="ts712">
				<ANNOTATION_VALUE>hitn di shtot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts713" TIME_SLOT_REF2="ts714">
				<ANNOTATION_VALUE>iz &lt;hi-&gt; hitn di shtot iz azoy, akura- ikh bin gor geven gegn dem.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>&lt;s'-&gt; hob ikh batrakht... hot men mir gezogt, zogt der bruder, "du darfst antloyfn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a289" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>"vayle du host gearbet bay zey," zogt er, "darfst antloyfn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1115" TIME_SLOT_REF1="ts720" TIME_SLOT_REF2="ts723">
				<ANNOTATION_VALUE>&lt;v-...?&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a290" TIME_SLOT_REF1="ts724" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>&lt;de- de-&gt; eyn bruder iz nit geven; &lt;im hot men&gt; tsugenumen in fertsiktn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1048" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>zey hobn in fertsiktn yor shoyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1049" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>in, in eyn un fertsiktn hobn zey gemakht a mobilizatsye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1050" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>hot men shoyn genumen eltere.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a291" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>hot men tsugenumen, un zey hobn gezogt oyf dray monat. ir veyst dokh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1051" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts737">
				<ANNOTATION_VALUE>un m'hot tsugenumen, un oto di zaynen nit gekumen tsurik, keyn eyner nit, v-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a292" TIME_SLOT_REF1="ts738" TIME_SLOT_REF2="ts741">
				<ANNOTATION_VALUE>der, uh, Shmu- &lt;uh, z- dos, er&gt; hot geheysn Shmule Ber.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a293" TIME_SLOT_REF1="ts742" TIME_SLOT_REF2="ts745">
				<ANNOTATION_VALUE>keyn mol nit. mir hobn &lt;im f-&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1052" TIME_SLOT_REF1="ts746" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>zint er iz avekgegangen, nit gezen, un zayn froy mit der kind</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1054" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>iz mit undz gelofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a294" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts752">
				<ANNOTATION_VALUE>iz zayn kind iz geblibn lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a295" TIME_SLOT_REF1="ts753" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>itster hob ikh di kind,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1055" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>un di kind hot kha- itster geven, bay a bar-mitsve</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1056" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>bin ikh geven fun dem kind's an eynikl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts761">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a298" TIME_SLOT_REF1="ts762" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>mir hobn gezukht, mir hobn gefregt, &lt;he&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1057" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts767">
				<ANNOTATION_VALUE>nit nor er. itster mayn, der elterer shvester's</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a299" TIME_SLOT_REF1="ts766" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>a, a, der man.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a300" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts771">
				<ANNOTATION_VALUE>iz di eltere shvester's man hot men oykh tsugenumen in yener tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1058" TIME_SLOT_REF1="ts772" TIME_SLOT_REF2="ts777">
				<ANNOTATION_VALUE>oykh, oykh nit gekumen. DORA, UNK DVORA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a301" TIME_SLOT_REF1="ts778" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>un zi iz shoyn geven farheyrat for mir nokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a302" TIME_SLOT_REF1="ts782" TIME_SLOT_REF2="ts785">
				<ANNOTATION_VALUE>&lt;ah,&gt; zi iz geven for, for der, for der krig iz zi geven farheyrat, un...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a304" TIME_SLOT_REF1="ts786" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>oykh tsugenu- avekgenumen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1060" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>un zi hot geha- gelozn ir mit a kind,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1061" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>iz zi gekumen lebn bay undz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a305" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>in Dokshits. zi hot gelebt in Glubok frier, a ander shtot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1062" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>gekumen lebn bay undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a306" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>&lt;hot zi&gt; gelebt bay undz mit di kind, &lt;un zi iz&gt; avekgega- un zi iz mit UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1063" TIME_SLOT_REF1="ts799" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>iz i- nit ikh hob tsugenumen di eltern; dos iz nokh a frage nit azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1064" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
				<ANNOTATION_VALUE>ikh bin mitn bruder avekgegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a307" TIME_SLOT_REF1="ts804" TIME_SLOT_REF2="ts807">
				<ANNOTATION_VALUE>neyn, der bruder hot gemuzt, uh, hobn mir gevust az mir muzn antloyfn, vayle ikh hob gearbet...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a308" TIME_SLOT_REF1="ts808" TIME_SLOT_REF2="ts811">
				<ANNOTATION_VALUE>UNK in Rusland!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a309" TIME_SLOT_REF1="ts812" TIME_SLOT_REF2="ts814">
				<ANNOTATION_VALUE>keyn Rusland. mir hobn nit gev&lt;ey&gt;st vuhin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a310" TIME_SLOT_REF1="ts816" TIME_SLOT_REF2="ts818">
				<ANNOTATION_VALUE>mir hobn... in vald. mir hobn nit gevust vuhin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1066" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts820">
				<ANNOTATION_VALUE>a&lt;z,&gt; mir hobn nit gevust vos s'heyst loyfn; mir hobn gemeynt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1067" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>az dos vet zikh bald umkern krik. s'iz dokh a milkhome.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1068" TIME_SLOT_REF1="ts823" TIME_SLOT_REF2="ts824">
				<ANNOTATION_VALUE>mir hobn zikh nit forgeshtelt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1069" TIME_SLOT_REF1="ts825" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>az der rus vet lozn im geyn fray.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a311" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts828">
				<ANNOTATION_VALUE>ir farshteyt? s'iz dokh a milkhome, &lt;iz&gt; ver veyst</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1070" TIME_SLOT_REF1="ts829" TIME_SLOT_REF2="ts830">
				<ANNOTATION_VALUE>tsi zey veln loyfn, tsi mir veln zikh umkern tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a312" TIME_SLOT_REF1="ts831" TIME_SLOT_REF2="ts832">
				<ANNOTATION_VALUE>hob ikh genumen, ikh hob genumen di froy oykh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a313" TIME_SLOT_REF1="ts833" TIME_SLOT_REF2="ts834">
				<ANNOTATION_VALUE>mit di kind. di froy iz geven nit in ordenung; bay ir iz geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a314" TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts836">
				<ANNOTATION_VALUE>oyf di brist hot zi gehat a UNK. m'hot dos gemakht a NITUAKH.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a315" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts838">
				<ANNOTATION_VALUE>s'iz, dos iz oykh geven a historye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a316" TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts840">
				<ANNOTATION_VALUE>un mir zaynen opgegangen tsen kilometer, hot zi genumen veynen, zogt zi, "fir mir avek tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a317" TIME_SLOT_REF1="ts841" TIME_SLOT_REF2="ts842">
				<ANNOTATION_VALUE>vuhin vel ikh loyfn? ikh'l shtarbn oyfn veg."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a318" TIME_SLOT_REF1="ts843" TIME_SLOT_REF2="ts844">
				<ANNOTATION_VALUE>hob ikh genumen a ferd... ale zaynen antlofn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a319" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts846">
				<ANNOTATION_VALUE>ikh hob genumen a, arayn in a dorf, genumen a ferd, opgefirt ir krik</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1071" TIME_SLOT_REF1="ts847" TIME_SLOT_REF2="ts848">
				<ANNOTATION_VALUE>tsu ir... aheym iz shoyn bay undz gornisht nit geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1072" TIME_SLOT_REF1="ts849" TIME_SLOT_REF2="ts850">
				<ANNOTATION_VALUE>ir muter iz shoyn oykh nit geven in der heym.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1073" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts852">
				<ANNOTATION_VALUE>zey zaynen ale geven bay zeyere a tokhter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a320" TIME_SLOT_REF1="ts853" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>un di tokhter dortn, er iz geven, er, mit ferd, hobn zey gehat a...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a321" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts856">
				<ANNOTATION_VALUE>gepakt, geforn ergets aroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a322" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>"gut", z- zo&lt;g&gt;n zey, "gut UNK &lt;ge&gt;kumen." zog ikh, "ikh gey avek.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>ikh blayb do nit."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a324" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>zog&lt;t zi, "d-"&gt; zogn zey take, "du gey avek, vayle tsulib dir konen mir oykh laydn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts865">
				<ANNOTATION_VALUE>ir farshteyt dokh, vayle kh'hob gearbet bay di rusn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts866" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>az zey veln laydn tsulib mir, vayle ikh, vayle ikh hob gearbet bay di rusn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>bin ikh avekgegangen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts874">
				<ANNOTATION_VALUE>un hob ikh keynem nit gefunen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts875" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>keynem nit. ale zaynen shoyn geven avek in vald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>mit mir iz nokh ge&lt;zo-&gt; a, gekumen eyner a khaver mayner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a331" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>zogt er... er l- zayn shve- zayn shvester &lt;iz&gt; avekgelofn, mit alts...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a332" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts882">
				<ANNOTATION_VALUE>"mir vel'n geyn, tsuzamen gey&lt;n." zog ikh,&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a333" TIME_SLOT_REF1="ts883" TIME_SLOT_REF2="ts884">
				<ANNOTATION_VALUE>"itster geyn konen &lt;mir nit." s'iz&gt; zeyer fintster geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts885" TIME_SLOT_REF2="ts886">
				<ANNOTATION_VALUE>zog ikh, "kum tsu undz in shtub," vu mir hobn &lt;a,&gt; gelebt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a335" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts888">
				<ANNOTATION_VALUE>mir zaynen avekgegangen oyfn veg un mir hobn zikh avekgeleygt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>in di groz. &lt;mir hobn shoyn...&gt; un, un dortn iz shoyn geven daytshn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1075" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>nor di zelner nokh mitn fuln parad iz nit arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a337" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>un mir hobn dortn gemakht bizn a zeyger dray &lt;in d-&gt; far tog,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1076" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>un s'iz dokh geven, dray iz shoyn likhtik vayle s'iz geven zumer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>s'iz geven IYUN'.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a339" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>iz zaynen mir avekgegangen durkh di velder. mir zaynen gekumen in vald un avekgegangen in vald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>mir zaynen, i&lt;ts-&gt; vil ikh aykh nokh dertseyln:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a341" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
				<ANNOTATION_VALUE>geyendik oyfn veg gegenen mir on forn krik tsvey furn mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts905" TIME_SLOT_REF2="ts906">
				<ANNOTATION_VALUE>er git a kuk: zayn shvester</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a343" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>mit, mit a khosn, hot zi gehat,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1077" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts910">
				<ANNOTATION_VALUE>un nokh yugntlekhe forn krik. zey zogn, "vos,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1078" TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts912">
				<ANNOTATION_VALUE>&lt;m-...&gt;" in vald iz nit azoy geven gut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a344" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>"vos &lt;zoln mir&gt; dokh lign hungern?" zogn zey, "vos vet zayn mit alemen vet zayn mit undz."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a345" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>un zaynen avek krik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a346" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts918">
				<ANNOTATION_VALUE>ikh bin avek foroys.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a347" TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts920">
				<ANNOTATION_VALUE>kh'bin gekumen in vald ersht bay nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1079" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts923">
				<ANNOTATION_VALUE>kh'hob getrofn tsvey shvester dortn un dem bruder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a348" TIME_SLOT_REF1="ts922" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>un ful khevre, a fule vald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a349" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>zey zogn az der foter mit di muter iz oykh do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a351" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts928">
				<ANNOTATION_VALUE>zog ikh, "vos &lt;hot ir zey&gt; geton?" ikh aleyn trakht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a353" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
				<ANNOTATION_VALUE>"vos... v-..." &lt;az&gt; ikh hob dos nit forgeshtel-... ir farshteyt? azoy nit...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a354" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>UNK zog&lt; ikh&gt; zey, "vu zaynen zey?" zogn zey, "do in a dorf."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a355" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>in a dorf gekumen. &lt;iz&gt; bald zaynen gekumen di, di makht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>un hobn undz gezogt azoy:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>"fun danet muzt ir geyn foroys. far vos?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a359" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>vayle mir raysn oyfet di brikn fun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
				<ANNOTATION_VALUE>fun BEREZINA."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a361" TIME_SLOT_REF1="ts943" TIME_SLOT_REF2="ts944">
				<ANNOTATION_VALUE>tsvey groyse brikn dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts945" TIME_SLOT_REF2="ts946">
				<ANNOTATION_VALUE>zaynen mir geven bay yene tsvey brikn dortn i- in vald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts947" TIME_SLOT_REF2="ts948">
				<ANNOTATION_VALUE>"muzt ir ibergeyn di brikn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a365" TIME_SLOT_REF1="ts949" TIME_SLOT_REF2="ts950">
				<ANNOTATION_VALUE>vayle anit blaybn mir ale do."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts951" TIME_SLOT_REF2="ts952">
				<ANNOTATION_VALUE>un zey hobn shoyn undz, nit gekont fun undz antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a368" TIME_SLOT_REF1="ts953" TIME_SLOT_REF2="ts954">
				<ANNOTATION_VALUE>geven der predsyedatel fun &lt;RAY- uh,&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts955" TIME_SLOT_REF2="ts956">
				<ANNOTATION_VALUE>Vilenski, oykh a yid,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a370" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>&lt;n-&gt; nor er iz geven der firer fun di rusn bay undz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>iz hot er, un tsug- mir, zaynen mir ale avekgegangen, mit khevre, mi- geven a por ferd, etlekhe ferd iz geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts962">
				<ANNOTATION_VALUE>mir zaynen ibergeforn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
