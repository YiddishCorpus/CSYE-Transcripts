			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a413" TIME_SLOT_REF1="ts1097" TIME_SLOT_REF2="ts1098">
				<ANNOTATION_VALUE>n&lt;u,&gt; mir zaynen gelofn. es, vos ikh hob g- ongegegnt, es fort a last-oyto.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a414" TIME_SLOT_REF1="ts1099" TIME_SLOT_REF2="ts1100">
				<ANNOTATION_VALUE>a last-oyto. "T-" zog ikh im, "TOVARISHCH"... ikh hob opgeshtelt im.</ANNOTATION_VALUE>
