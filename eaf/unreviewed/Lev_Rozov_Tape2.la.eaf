		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1106" TIME_SLOT_REF1="ts1103" TIME_SLOT_REF2="ts1104">
				<ANNOTATION_VALUE>hot er undz ibergevorfn mistome tsvantsik kilometer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
