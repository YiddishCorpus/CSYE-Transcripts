		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a415" TIME_SLOT_REF1="ts1101" TIME_SLOT_REF2="ts1102">
				<ANNOTATION_VALUE>er hot zikh opgeshtelt. zog ikh, "fir mir, undz tsu oto do."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
