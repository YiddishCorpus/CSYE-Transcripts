			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1105" TIME_SLOT_REF1="ts1095" TIME_SLOT_REF2="ts1096">
				<ANNOTATION_VALUE>UNK ikh bin gekumen krik... do iz do a frage, ikh bin gekumen krik, vel ikh aykh zogn...</ANNOTATION_VALUE>
