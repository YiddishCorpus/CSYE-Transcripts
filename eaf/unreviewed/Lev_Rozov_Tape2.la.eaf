		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a399" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1055">
				<ANNOTATION_VALUE>nokh in a shtetl, nor ikh &lt;g-&gt; ale shtetlekh ge- kon ikh nit ge- s'iz geven shtetlekh, ikh gedenk nit</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
