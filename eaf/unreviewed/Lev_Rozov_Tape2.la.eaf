		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a433" TIME_SLOT_REF1="ts1139" TIME_SLOT_REF2="ts1140">
				<ANNOTATION_VALUE>hob ikh, bin ikh geblibn ot azoy vi ikh bin itster.</ANNOTATION_VALUE>
