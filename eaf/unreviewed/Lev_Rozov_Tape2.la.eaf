		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a416" TIME_SLOT_REF1="ts1105" TIME_SLOT_REF2="ts1106">
				<ANNOTATION_VALUE>zogt er, mer hot er keyn benzin nit, un undz geheysn geyn.</ANNOTATION_VALUE>
