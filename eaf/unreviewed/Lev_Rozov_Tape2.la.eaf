		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1107" TIME_SLOT_REF1="ts1107" TIME_SLOT_REF2="ts1108">
				<ANNOTATION_VALUE>mir zaynen arop un mir zaynen vi es iz farkrokhn keyn Vitebsk.</ANNOTATION_VALUE>
