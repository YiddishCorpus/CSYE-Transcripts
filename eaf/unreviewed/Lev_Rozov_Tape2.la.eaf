		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a410" TIME_SLOT_REF1="ts1089" TIME_SLOT_REF2="ts1090">
				<ANNOTATION_VALUE>&lt;n- nokh dem&gt; zaynen di poyerim gegangen mit di zek un m'hot genumen fun di yidn.</ANNOTATION_VALUE>
