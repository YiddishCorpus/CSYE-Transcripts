			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a435" TIME_SLOT_REF1="ts1143" TIME_SLOT_REF2="ts1144">
				<ANNOTATION_VALUE>zaynen gegangen, gekumen in Vitebsk, zog ikh... a kuk geton vos s'tut zikh in Vitebsk, mit mentshn oyfn gas, do, dortn, ful in ale gasn...</ANNOTATION_VALUE>
