		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a432" TIME_SLOT_REF1="ts1137" TIME_SLOT_REF2="ts1138">
				<ANNOTATION_VALUE>ir farshteyt? &lt;zaynen nit geven; er hot&gt; tsugenumen alts.</ANNOTATION_VALUE>
