			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a401" TIME_SLOT_REF1="ts1058" TIME_SLOT_REF2="ts1060">
				<ANNOTATION_VALUE>un gegangen zaynen mir, hobn mir shoyn gevust loytn, loyt der karte az mir geyn</ANNOTATION_VALUE>
