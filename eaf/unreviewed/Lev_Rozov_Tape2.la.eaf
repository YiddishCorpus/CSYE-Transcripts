		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts972">
				<ANNOTATION_VALUE>mir hobn genumen undzer mishpokhe un mir zaynen gelofn. mir hobn gehat tate-mame,</ANNOTATION_VALUE>
