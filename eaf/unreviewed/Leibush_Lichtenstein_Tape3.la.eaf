		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a600" TIME_SLOT_REF1="ts1321" TIME_SLOT_REF2="ts1322">
				<ANNOTATION_VALUE>un er hot zikh nisht gekent oyshaltn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a601" TIME_SLOT_REF1="ts1323" TIME_SLOT_REF2="ts1324">
				<ANNOTATION_VALUE>hot er</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a602" TIME_SLOT_REF1="ts1325" TIME_SLOT_REF2="ts1326">
				<ANNOTATION_VALUE>hot er genumen a, geshribn a briv, er iz krank</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a603" TIME_SLOT_REF1="ts1327" TIME_SLOT_REF2="ts1328">
				<ANNOTATION_VALUE>un der dokter hot im untergeshribn az er darf hobn a hilf</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a604" TIME_SLOT_REF1="ts1329" TIME_SLOT_REF2="ts1330">
				<ANNOTATION_VALUE>er darf hobn di froy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a605" TIME_SLOT_REF1="ts1331" TIME_SLOT_REF2="ts1332">
				<ANNOTATION_VALUE>nu, di froy &lt;er hot&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a606" TIME_SLOT_REF1="ts1333" TIME_SLOT_REF2="ts1334">
				<ANNOTATION_VALUE>iz aroysgeforn fun TEL AVIV, iz zi geforn dort UNK keyn BRAZIL</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a607" TIME_SLOT_REF1="ts1335" TIME_SLOT_REF2="ts1336">
				<ANNOTATION_VALUE>un zenen dortn farblibn a gevise tsayt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a608" TIME_SLOT_REF1="ts1337" TIME_SLOT_REF2="ts1338">
				<ANNOTATION_VALUE>un dortn keyn gesheftn hot er oykh nisht gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a609" TIME_SLOT_REF1="ts1339" TIME_SLOT_REF2="ts1340">
				<ANNOTATION_VALUE>vos er hot gemakht hot er ge-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a610" TIME_SLOT_REF1="ts1341" TIME_SLOT_REF2="ts1342">
				<ANNOTATION_VALUE>iz alts geganen mitn kop arop</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a611" TIME_SLOT_REF1="ts1343" TIME_SLOT_REF2="ts1344">
				<ANNOTATION_VALUE>un ikh hob im geshikt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a612" TIME_SLOT_REF1="ts1345" TIME_SLOT_REF2="ts1346">
				<ANNOTATION_VALUE>fun Yisroel hob ikh im geshikt a sakh gelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a613" TIME_SLOT_REF1="ts1347" TIME_SLOT_REF2="ts1348">
				<ANNOTATION_VALUE>kh'hob im a sakh geholfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a614" TIME_SLOT_REF1="ts1349" TIME_SLOT_REF2="ts1350">
				<ANNOTATION_VALUE>hot er alts bagrobn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a615" TIME_SLOT_REF1="ts1351" TIME_SLOT_REF2="ts1352">
				<ANNOTATION_VALUE>azoy lang</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a616" TIME_SLOT_REF1="ts1353" TIME_SLOT_REF2="ts1354">
				<ANNOTATION_VALUE>biz ikh bin do ahergekumen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a617" TIME_SLOT_REF1="ts1355" TIME_SLOT_REF2="ts1356">
				<ANNOTATION_VALUE>un ikh hob zikh ongehoybn do ayntsuordenen. s'iz mir geven zeyer, zeyer shver.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a618" TIME_SLOT_REF1="ts1357" TIME_SLOT_REF2="ts1358">
				<ANNOTATION_VALUE>ikh bin do ahergekumen, geven</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
