				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a599" TIME_SLOT_REF1="ts1319" TIME_SLOT_REF2="ts1320">
				<ANNOTATION_VALUE>URUGUAY. dortn iz er gevezn &lt;ergn&gt; un hot ongehoybn tsu arbetn epes in a firme</ANNOTATION_VALUE>
