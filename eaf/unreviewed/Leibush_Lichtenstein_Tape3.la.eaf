			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a595" TIME_SLOT_REF1="ts1311" TIME_SLOT_REF2="ts1312">
				<ANNOTATION_VALUE>er iz tsun ersht avekgeforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a596" TIME_SLOT_REF1="ts1313" TIME_SLOT_REF2="ts1314">
