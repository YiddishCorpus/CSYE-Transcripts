		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a100" TIME_SLOT_REF1="ts257" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>hob ikh un biz ikh hob mikh arumgekukt az zey nemen un esn dos oyf,</ANNOTATION_VALUE>
