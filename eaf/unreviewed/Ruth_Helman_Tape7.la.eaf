		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a151" TIME_SLOT_REF1="ts359" TIME_SLOT_REF2="ts360">
				<ANNOTATION_VALUE>un ikh veys er lebt zikher nisht, vayl m'hot gehert az zey hobn dershosn ofitsirn.</ANNOTATION_VALUE>
