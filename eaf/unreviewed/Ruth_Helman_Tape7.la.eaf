			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts361" TIME_SLOT_REF2="ts362">
				<ANNOTATION_VALUE>iz eh eh un zog ikh, ikh hob ibergelozt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
