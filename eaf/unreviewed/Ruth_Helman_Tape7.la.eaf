			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a166" TIME_SLOT_REF1="ts387" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>un zi hot ibergelebt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
