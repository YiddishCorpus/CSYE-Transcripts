		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a157" TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
				<ANNOTATION_VALUE>ikh hob nisht far- far- gevust vos tsu zogn, volt ikh volt ikh dokh ba- gevorn farshit in gantsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a159" TIME_SLOT_REF1="ts375" TIME_SLOT_REF2="ts378">
				<ANNOTATION_VALUE>HAIKAR, mir haltn bay vos? bay geyn eh oyf eh oyfn veg tsu mitn kind, yo, shoyn nokh der bafrayung.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a160" TIME_SLOT_REF1="ts379" TIME_SLOT_REF2="ts380">
				<ANNOTATION_VALUE>dos iz gevezn ikh gleyb in zibetsetn oder in akhtsetn yanuar finef un fertsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a164" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>vi iz, bay undz iz dos geven, s'nokh geven genug tsu eh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts385">
				<ANNOTATION_VALUE>ober eh in der tsayt vos ikh bin gelegn untern frayen himl, vu di andere zayt hobn zenen keseyder ale geganen, take di vos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a874" TIME_SLOT_REF1="ts384" TIME_SLOT_REF2="ts386">
				<ANNOTATION_VALUE>di vos ikh bin mit ir gevezn unter der erd mitn man, iz oykh geganen keyn Prushkov.</ANNOTATION_VALUE>
