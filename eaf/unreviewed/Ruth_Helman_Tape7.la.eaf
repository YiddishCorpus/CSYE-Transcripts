				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>barn bar di vakhn flegt er ma- masern eh un nisht veln nemen adurkh nokh in di a- oyf der arisher zayt adurkh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>farshidene zakhn. vi azoy hot er geheysn? ikh vel mikh dermanen. s'nisht vikhtik.</ANNOTATION_VALUE>
