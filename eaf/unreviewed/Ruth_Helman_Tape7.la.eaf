			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a873" TIME_SLOT_REF1="ts363" TIME_SLOT_REF2="ts365">
				<ANNOTATION_VALUE>dos kind, ikh bin gegangen do epes gevoyer, gebli- gegangen makhn a vizit, dervayl iz oysgebrokhn di oyfshtand.</ANNOTATION_VALUE>
