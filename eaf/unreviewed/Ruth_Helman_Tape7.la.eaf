			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a173" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts403">
				<ANNOTATION_VALUE>un vu halt men yetst?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a174" TIME_SLOT_REF1="ts404" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>yo. yo ikh gey tsurik tsu eh keyn Varshe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts407" TIME_SLOT_REF2="ts409">
