		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts347" TIME_SLOT_REF2="ts348">
				<ANNOTATION_VALUE>un geven a shtub mit kinder, s'geven a por mamzeyrim oykhet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
