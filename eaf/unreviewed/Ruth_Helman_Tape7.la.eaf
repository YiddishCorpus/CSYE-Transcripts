		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts335" TIME_SLOT_REF2="ts336">
				<ANNOTATION_VALUE>eh hob ikh es oysergeveyntlekh eh eh gut geven, s'iz gezunt geven tsu esn. s'epes geven geveykt broyt,</ANNOTATION_VALUE>
