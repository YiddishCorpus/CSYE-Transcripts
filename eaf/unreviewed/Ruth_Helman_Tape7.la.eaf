				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a140" TIME_SLOT_REF1="ts341" TIME_SLOT_REF2="ts342">
				<ANNOTATION_VALUE>un dos hobn zey gegesn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
