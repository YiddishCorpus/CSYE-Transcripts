			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a154" TIME_SLOT_REF1="ts367" TIME_SLOT_REF2="ts368">
				<ANNOTATION_VALUE>dertseylt a gantse zakh az ikh ken nisht khasene hobn mit im.</ANNOTATION_VALUE>
