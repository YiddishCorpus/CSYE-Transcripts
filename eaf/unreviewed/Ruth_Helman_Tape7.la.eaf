		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a871" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>un dort hot zi oysbahaltn a yidish kind oykhet vos ikh hob gekent.</ANNOTATION_VALUE>
