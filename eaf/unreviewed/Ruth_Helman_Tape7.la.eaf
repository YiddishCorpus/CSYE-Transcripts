		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a155" TIME_SLOT_REF1="ts369" TIME_SLOT_REF2="ts370">
				<ANNOTATION_VALUE>un ikh volt y- tomer volt ikh gekent mikh oysredn farn galekh,</ANNOTATION_VALUE>
