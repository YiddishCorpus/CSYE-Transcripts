		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts333" TIME_SLOT_REF2="ts334">
				<ANNOTATION_VALUE>ikh hob mir gekent an eytse ge- ikh hob gehat gezunt. der ZUREK, di vos zi hot gemakht di zup,</ANNOTATION_VALUE>
