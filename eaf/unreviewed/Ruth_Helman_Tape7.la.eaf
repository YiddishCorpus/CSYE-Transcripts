		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a149" TIME_SLOT_REF1="ts357" TIME_SLOT_REF2="ts358">
				<ANNOTATION_VALUE>ot derfar hob ikh ir dertseylt az mayn man iz a a ofitsir gevezn.</ANNOTATION_VALUE>
