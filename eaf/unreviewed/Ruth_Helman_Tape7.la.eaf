		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts310" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>zi hot zikh nisht zi hot zikh nisht meyid geven. ikh hob ir derkent glaykh.</ANNOTATION_VALUE>
