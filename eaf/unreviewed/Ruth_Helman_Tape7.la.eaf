			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts299" TIME_SLOT_REF2="ts300">
				<ANNOTATION_VALUE>vos es hert zikh. vayl s'dokh geven Varshever alding, opgelofn, vayl zey hobn gornisht gehat, alts iz dokh geven farbrent, polyakn.</ANNOTATION_VALUE>
