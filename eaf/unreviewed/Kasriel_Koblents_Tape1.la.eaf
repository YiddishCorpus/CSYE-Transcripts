				<ANNOTATION_VALUE>un s'iz geven zeyer a fayner tog, azoy vi itster, vi haynt. hobn mir zikh gehat ale tsuzamengeredt... geven a groyse, khaveyrim hob ikh gehat zeyer fil...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a755" TIME_SLOT_REF1="ts663" TIME_SLOT_REF2="ts664">
				<ANNOTATION_VALUE>hobn mir zikh opgeredt az mir veln forn oyf morgn in Katshergin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a756" TIME_SLOT_REF1="ts665" TIME_SLOT_REF2="ts666">
				<ANNOTATION_VALUE>nu, &lt;zikh&gt; farbrengen dem tog, opruen zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a757" TIME_SLOT_REF1="ts667" TIME_SLOT_REF2="ts668">
				<ANNOTATION_VALUE>opruen zikh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a758" TIME_SLOT_REF1="ts669" TIME_SLOT_REF2="ts670">
				<ANNOTATION_VALUE>nu, hobn mir opgeredt az mir veln geyn ale tsum damfer,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a759" TIME_SLOT_REF1="ts671" TIME_SLOT_REF2="ts672">
				<ANNOTATION_VALUE>un dortn veln mir zikh ale zetsn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a760" TIME_SLOT_REF1="ts673" TIME_SLOT_REF2="ts674">
				<ANNOTATION_VALUE>un mir veln avekforn un mir veln dortn farbrengen dem tog tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a761" TIME_SLOT_REF1="ts675" TIME_SLOT_REF2="ts676">
				<ANNOTATION_VALUE>ikh bin avekgegangen, s'iz geven a zeyger shoyn akht in der fri, iz dortn geven mayne ale khaveyrim, bakante.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a762" TIME_SLOT_REF1="ts677" TIME_SLOT_REF2="ts678">
				<ANNOTATION_VALUE>un dortn zaynen oykh geven rusishe ofitsern, politrukn, oykh geforn, s'iz geven zeyer a sheyner tog, zaynen geforn ale in Katshergin.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a763" TIME_SLOT_REF1="ts681" TIME_SLOT_REF2="ts682">
				<ANNOTATION_VALUE>s'iz geven a geveynlekhe zakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a764" TIME_SLOT_REF1="ts683" TIME_SLOT_REF2="ts684">
				<ANNOTATION_VALUE>geven &lt;a ge- vayle, nu, m'hot shoyn&gt; nit gedarft hobn keyn groyse gelt oyf derayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a765" TIME_SLOT_REF1="ts685" TIME_SLOT_REF2="ts686">
				<ANNOTATION_VALUE>nu, mir zaynen shoyn gezesn ale oyfn, uh, oyfn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a767" TIME_SLOT_REF1="ts687" TIME_SLOT_REF2="ts689">
				<ANNOTATION_VALUE>damfer UNK parakhod UNK, vi me zogt, uh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1112" TIME_SLOT_REF1="ts690" TIME_SLOT_REF2="ts692">
				<ANNOTATION_VALUE>damfer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a768" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>nu, opgezesn umgefer a fuftsn minut un mit a mol</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a769" TIME_SLOT_REF1="ts695" TIME_SLOT_REF2="ts696">
				<ANNOTATION_VALUE>mir zeen az s'flien onet...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a770" TIME_SLOT_REF1="ts698" TIME_SLOT_REF2="ts700">
				<ANNOTATION_VALUE>eroplanen, ye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a771" TIME_SLOT_REF1="ts701" TIME_SLOT_REF2="ts702">
				<ANNOTATION_VALUE>un zey hobn genumen bashisn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a772" TIME_SLOT_REF1="ts703" TIME_SLOT_REF2="ts704">
				<ANNOTATION_VALUE>dem erodrom.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a773" TIME_SLOT_REF1="ts705" TIME_SLOT_REF2="ts706">
				<ANNOTATION_VALUE>un s'zitsn lebn un- lebn mir zitsn di, uh, ofitsern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a774" TIME_SLOT_REF1="ts707" TIME_SLOT_REF2="ts709">
				<ANNOTATION_VALUE>freg ikh eynem, "vos, vos, vos kumt do for?" "a," zogt er, "s'iz manevers bay undz." manevers.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1113" TIME_SLOT_REF1="ts711" TIME_SLOT_REF2="ts713">
				<ANNOTATION_VALUE>oyf rusish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a776" TIME_SLOT_REF1="ts715" TIME_SLOT_REF2="ts716">
				<ANNOTATION_VALUE>ikh bin shoyn geven opgegebn, uh, in armey. hot men undz geshikt glaykh &lt;ru-&gt; oyf, uh, oyf kursn rusish zikh lernen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a778" TIME_SLOT_REF1="ts717" TIME_SLOT_REF2="ts718">
				<ANNOTATION_VALUE>nu, ikh hob nit gekent perfekt, nor hob ikh, fleg ikh shoyn kenen umgefer zikh tsuzamenreydn mit zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a779" TIME_SLOT_REF1="ts719" TIME_SLOT_REF2="ts720">
				<ANNOTATION_VALUE>ikh hob gefregt... lebn mir iz ge&lt;zes&gt;n a politruk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a780" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>&lt;kh'hob nokh&gt; DAZHE zayn, zayn tshin nit gevust vos se batayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a781" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>nu, hot er mir gezogt, "s'iz, dos iz manevers, dos iz keyn zakh nit."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a782" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>mir zitsn vayter. der, der damfer fort nokh nit opet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a783" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>s'iz avek nokh a fuftsn minut,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a784" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>ongefloygn a tsveyte e&lt;k&gt;skadrilye mit eroplanen, un m'hot genumen vider bombardirn, vider klapn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a785" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>mit a mol iz gevorn oyfn, a panik iz gevorn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a786" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>un m'hot geheysn alemen loyfn vos gikher fun, funem, fun, uh, damfer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a787" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>loyfndik... ikh hob dan gelebt oyf KALVIŲ gas...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a788" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>loyfndik aheym</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a789" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>hob ikh gehert, uh, s'iz geven, in eyn ort iz geven ofn a fentster, hob ikh gehert vi s'hot geredt Molotov.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a790" TIME_SLOT_REF1="ts741" TIME_SLOT_REF2="ts742">
				<ANNOTATION_VALUE>hot er gezogt az s'hot zikh ongefangen di krig;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a791" TIME_SLOT_REF1="ts743" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>di daytshn zaynen ongefaln</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a792" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts747">
				<ANNOTATION_VALUE>n- nit UNK nit, uh, gen-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a793" TIME_SLOT_REF1="ts748" TIME_SLOT_REF2="ts751">
				<ANNOTATION_VALUE>nit gevart. nu, V OBSHCHEM, nit, nit gevart zaynen ongefaln oyf Rusland. tsk...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a796" TIME_SLOT_REF1="ts752" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>oyf rusish &lt;geven&gt;. kh'hob farshtanen, vayle s'iz geven ofn der fentster UNK &lt;ikh bin&gt; grade farbaygegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a797" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>ikh bin ts- gekumen tsu loyfn aheym. in shtub iz keyner nit geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a798" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>kler ikh, "vos zol ikh do ton?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a799" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts761">
				<ANNOTATION_VALUE>mayn shvester hot gelebt, eyne, oyf ITALIJOS gas.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1114" TIME_SLOT_REF1="ts762" TIME_SLOT_REF2="ts765">
				<ANNOTATION_VALUE>Tsherne.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a800" TIME_SLOT_REF1="ts766" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>gelebt oyf ITALIJOS dray.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a801" TIME_SLOT_REF1="ts771" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>di tsveyte hot gelebt oyf, uhm,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a802" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts774">
				<ANNOTATION_VALUE>dan hot zikh gerufn, uh, &lt;ŠEŠIOLIKTA&gt; VASARIO,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a803" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>di tsveyte shvester.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a804" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
				<ANNOTATION_VALUE>azoy vi zi iz geven, Tsherne, nenter tsu mir... ITALIJOS fun KALVIŲ iz nit vayt... bin ikh gelofn tsu ir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a805" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts780">
				<ANNOTATION_VALUE>avekgelofn tsu ir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a806" TIME_SLOT_REF1="ts781" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>di shtub iz geven farshlosn; keyner iz shoyn nit geven in shtub.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a807" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>un ir man, Tsherne's... hot shoyn khasene ge- hm, khasene gehat... </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a808" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts787">
				<ANNOTATION_VALUE>hot gehat oyf UGNIAGESIŲ gas a masterskaye in a keler. er flegt makhn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1115" TIME_SLOT_REF1="ts790" TIME_SLOT_REF2="ts795">
				<ANNOTATION_VALUE>Abrashe. Avrom Kvartovski.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1116" TIME_SLOT_REF1="ts796" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>Kvartovski, ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a810" TIME_SLOT_REF1="ts800" TIME_SLOT_REF2="ts802">
				<ANNOTATION_VALUE>varkshtat. er flegt makhn ayzerne betn, farsheydene ayzerne z- uh, zakhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a811" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>nu, s'iz geven farshlosn di shtub. nu, hob ikh a kler gegebn, me darf geyn dortn vu er hot, vu er arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a813" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>ikh bin avek oyf UGNIAGESIŲ gas.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a814" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts808">
				<ANNOTATION_VALUE>dos iz umgefer punkt antkegn di MUZYKAL'NAYA SHKO- di MUZYKAL'NAYA...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1117" TIME_SLOT_REF1="ts810" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>shul, ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a816" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a817" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts818">
				<ANNOTATION_VALUE>ikh bin arayn in keler, hob ikh shoyn gefunen dortn ful: geven dortn mayn sh- uh, shvester, mayn bruder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a818" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts820">
				<ANNOTATION_VALUE>un dem, uh, dem, di shvester's man's, uh, dray shvester, zayn muter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a819" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>geven zeyer fil dortn geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a820" TIME_SLOT_REF1="ts824" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>in a keler, ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a821" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts829">
				<ANNOTATION_VALUE>tsk, dortn geven mayn bruder. der bruder yinger far mir iz geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a822" TIME_SLOT_REF1="ts830" TIME_SLOT_REF2="ts832">
				<ANNOTATION_VALUE>Meyer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a823" TIME_SLOT_REF1="ts833" TIME_SLOT_REF2="ts834">
				<ANNOTATION_VALUE>er iz geven yinger far mir iz er geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a824" TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts836">
				<ANNOTATION_VALUE>hot er glaykh genumen reydn tsu mir, "lomir forn in Zarasay."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a825" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts838">
				<ANNOTATION_VALUE>nu, er vil, hot gevelt zikh zayn mit di eltern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a826" TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts840">
				<ANNOTATION_VALUE>Tsherne iz geven oyf der tsayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a827" TIME_SLOT_REF1="ts841" TIME_SLOT_REF2="ts842">
				<ANNOTATION_VALUE>hot nit gekent, uh, zi iz geven in di letste monatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a828" TIME_SLOT_REF1="ts843" TIME_SLOT_REF2="ts844">
				<ANNOTATION_VALUE>uh, z- uh, zayn, uh, zayn, uh, ir man's a shvester iz geven a khasene-gehate far a politruk,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a829" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts846">
				<ANNOTATION_VALUE>hot zi moyre gehat, az di daytshn veln kumen, vet men &lt;ir di ershte&gt; derhargenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a830" TIME_SLOT_REF1="ts847" TIME_SLOT_REF2="ts848">
				<ANNOTATION_VALUE>iz ikh, zi un der bruder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a831" TIME_SLOT_REF1="ts849" TIME_SLOT_REF2="ts850">
				<ANNOTATION_VALUE>hobn mir opgeredt az mir veln loyfn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a832" TIME_SLOT_REF1="ts851" TIME_SLOT_REF2="ts852">
				<ANNOTATION_VALUE>aroysgeyn fun keler un loyfn tsum ban;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a833" TIME_SLOT_REF1="ts853" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>efsher vet undz gelingen tsu antloyfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a834" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>nu, oyf Zarasay, uh, vi me zogt, vu di oygn veln trogn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a835" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts860">
				<ANNOTATION_VALUE>mir zaynen a- vi nor mir zaynen aroys fun keler, hot men undz, oyf undz geefnt a fayer fun di MUZYKAL'Ne shul,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a836" TIME_SLOT_REF1="ts861" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>a URAGANNe fayer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a837" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
				<ANNOTATION_VALUE>undz iz gelungen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a838" TIME_SLOT_REF1="ts865" TIME_SLOT_REF2="ts866">
				<ANNOTATION_VALUE>zikh tsu fardreyen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a839" TIME_SLOT_REF1="ts867" TIME_SLOT_REF2="ts868">
				<ANNOTATION_VALUE>oyf KANTO</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a840" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts870">
				<ANNOTATION_VALUE>un mir zaynen aroys lebedikerheyt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a841" TIME_SLOT_REF1="ts871" TIME_SLOT_REF2="ts872">
				<ANNOTATION_VALUE>mir zaynen opgegangen umgefer a, nu, nit vayt fun TSENTRAL'NAYA POCHTA un s'iz gelegn gehargete soldatn, tsivile &lt;mentshn&gt; gehargete, &lt;zaynen&gt; gelegn oyfn, oyf LAISVĖS ALĖJA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a842" TIME_SLOT_REF1="ts873" TIME_SLOT_REF2="ts874">
				<ANNOTATION_VALUE>mir zaynen tsugegangen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a843" TIME_SLOT_REF1="ts875" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>nit vayt fun SOBOR.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a844" TIME_SLOT_REF1="ts877" TIME_SLOT_REF2="ts878">
				<ANNOTATION_VALUE>tsugelofn tsu undz dray soldatn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a845" TIME_SLOT_REF1="ts879" TIME_SLOT_REF2="ts881">
				<ANNOTATION_VALUE>Ka- di Kalmik&lt;er&gt; UNK vi, vi zogt men, mit di shmole eygelekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a846" TIME_SLOT_REF1="ts882" TIME_SLOT_REF2="ts884">
				<ANNOTATION_VALUE>nit keyn rusn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a847" TIME_SLOT_REF1="ts885" TIME_SLOT_REF2="ts886">
				<ANNOTATION_VALUE>mit biksn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a848" TIME_SLOT_REF1="ts887" TIME_SLOT_REF2="ts888">
				<ANNOTATION_VALUE>un zey heysn undz oyfheybn di hent,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a849" TIME_SLOT_REF1="ts889" TIME_SLOT_REF2="ts890">
				<ANNOTATION_VALUE>un zey zogn, "ir hot geshosn in undz; mir veln aykh shoyn, aykh alemen dershisn. ir hot in undz geshosn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a850" TIME_SLOT_REF1="ts891" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>hob ikh genumen tsu zey zikh betn un veynen: "mir zaynen yidn; mir loyfn punkt vi ir!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a851" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>gefaln oyf di kni tsu zey. kam-kam zikh, hob&lt;n mir zey b-&gt; ayngeredt un zey hobn gezogt, "loyft shnel fun danen un farshvindt fun undzere oygn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a852" TIME_SLOT_REF1="ts895" TIME_SLOT_REF2="ts896">
				<ANNOTATION_VALUE>&lt;mir zoln aykh&gt; mer nit zen!"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a853" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>azoy zaynen mir gel- tsugelofn biz &lt;di&gt; AVTOBUSn stantsye.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a854" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>&lt;BUSn&gt; stantsye. ongeforn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a856" TIME_SLOT_REF1="ts901" TIME_SLOT_REF2="ts902">
				<ANNOTATION_VALUE>Royte Armeyer mit, uh, UNK &lt;gerufn&gt; TACHANKes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a857" TIME_SLOT_REF1="ts904" TIME_SLOT_REF2="ts906">
				<ANNOTATION_VALUE>nu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a858" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>ongeforn. zaynen dortn gezesn fir kome- fir ofitsern.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a859" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts910">
				<ANNOTATION_VALUE>zi hot derzen az dortn zitst ofitsern. azoy vi, uh, zi hot gez-... ir man iz geven a politruk, di vos iz gelofn mit undz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a860" TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts912">
				<ANNOTATION_VALUE>dem shvoger's shvester...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a861" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>iz zi tsugelofn tsu zey un gevizn az ir man iz a VOENNer, a politruk, hobn zey &lt;ir&gt; ayngezetst oykh in vogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a862" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>un mir hobn genumen zogn zey, "gey avek, gey avek! s'iz far aykh keyn ort nito."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1119" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts918">
				<ANNOTATION_VALUE>ikh bin &lt;geblibn dortn&gt; mitn bruder aleyn un zi iz shoyn avekgeforn mit zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a863" TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts920">
				<ANNOTATION_VALUE>opgegangen umgefer nokh a tsvantsik, draysik meter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a864" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>m'hot vider genumen shisn; fun vanen veysn mir nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a865" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>mayn bruder iz arayngelofn in eyn hoyf, ikh in a tsveytn hoyf.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a866" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>ikh bin dort opgeven umgefer a tsvantsik minut.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a867" TIME_SLOT_REF1="ts927" TIME_SLOT_REF2="ts928">
				<ANNOTATION_VALUE>s'iz gevorn a bisele ruiker.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a868" TIME_SLOT_REF1="ts929" TIME_SLOT_REF2="ts930">
				<ANNOTATION_VALUE>ikh gey aroyset. der bruder iz nito.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a869" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>nu, tsk, kler ikh, vos tut men vayter?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a871" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>bashlosn, me darf geyn vayter. &lt;vu vel ikh geyn...?&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a872" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>azoy bin ikh avek vayter, &lt;d-&gt; tsug&lt;et-&gt; uh, tsugeyendik tsu nokh a kompanye, nokh, nokh khaveyrim yidishe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a873" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>un mir zaynen gegangen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a874" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>mir zaynen gegangen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a875" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
				<ANNOTATION_VALUE>biz U- biz Vilkomir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a877" TIME_SLOT_REF1="ts944" TIME_SLOT_REF2="ts947">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a878" TIME_SLOT_REF1="ts948" TIME_SLOT_REF2="ts950">
				<ANNOTATION_VALUE>ya. zaynen mir gegangen tsu fus.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a879" TIME_SLOT_REF1="ts951" TIME_SLOT_REF2="ts952">
				<ANNOTATION_VALUE>&lt;bi-&gt; avek biz Vilkomir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a880" TIME_SLOT_REF1="ts953" TIME_SLOT_REF2="ts954">
				<ANNOTATION_VALUE>un &lt;nokh&gt; umetum hobn &lt;mir nokh&gt; getrofn alts di rusishe s- di rusishe armey hobn mir nokh alts getrofn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a881" TIME_SLOT_REF1="ts955" TIME_SLOT_REF2="ts956">
				<ANNOTATION_VALUE>nu, zaynen zey shoyn kontik&lt;, uh, nokh zeyer gang,&gt; zaynen zey shoyn gelofn fun danen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a882" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>zey hobn keyn vidershtand kimat vi nit geshtelt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a883" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>far, uh, ni- hinter, nit vayt fun Vilkomir zaynen mir arayn in a vald</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a884" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts962">
				<ANNOTATION_VALUE>zikh opruen dortn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a885" TIME_SLOT_REF1="ts963" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>un mir flegn avekshteln oyfn, oyfn veg pos- uh, nu, vakh, me zol zen vi di lage iz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a886" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>un di iberike flegn lign in vald un zikh ruen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a887" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>ikh bin geshtanen lebn veg mit eynem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a888" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>a khaver mayner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a889" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts972">
				<ANNOTATION_VALUE>mir gibn a kuk...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a890" TIME_SLOT_REF1="ts973" TIME_SLOT_REF2="ts974">
				<ANNOTATION_VALUE>&lt;nu, s'&gt;hot gemuzt zayn mistome a zeyger</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a891" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts976">
				<ANNOTATION_VALUE>tsvelf, eyns bay tog...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a892" TIME_SLOT_REF1="ts977" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>mir gibn a kuk fun vaytn:</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a893" TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts980">
				<ANNOTATION_VALUE>vi es geyt di veg, iz in di zaytn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a894" TIME_SLOT_REF1="ts981" TIME_SLOT_REF2="ts983">
				<ANNOTATION_VALUE>geyen tsu undz soldatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a895" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>ikh hob, mir hobn nit gevust ver zey zaynen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a896" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts988">
