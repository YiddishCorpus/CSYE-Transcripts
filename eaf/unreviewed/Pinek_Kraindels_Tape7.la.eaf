		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>un hot zikh gebetn efsher ken men vayter mitforn, ikh zol vider zen, er vil mikh zen, er fort shpeter keyn Yisroel, zog ikh, mir forn oykh keyn Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
