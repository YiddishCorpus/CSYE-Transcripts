		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a114" TIME_SLOT_REF1="ts235" TIME_SLOT_REF2="ts238">
				<ANNOTATION_VALUE>poylish.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a115" TIME_SLOT_REF1="ts239" TIME_SLOT_REF2="ts241">
				<ANNOTATION_VALUE>in poylish. geredt a poylish, ikh hob zey gegebn, zenen geblibn shteyn, hobn zey dos nisht gehert keyn mol.</ANNOTATION_VALUE>
