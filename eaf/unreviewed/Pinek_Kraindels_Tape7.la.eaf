		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a696" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>un di khevre ven zey trefn zikh fun der gantser GROUP, nokh biz hayntikn tog, ven zey trefn mikh,</ANNOTATION_VALUE>
