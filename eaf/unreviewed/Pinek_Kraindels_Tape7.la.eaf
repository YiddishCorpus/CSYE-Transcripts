		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a690" TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>vil er ikh zol kumen tsu im in Yerusholaim. zog ikh gib a kuk on, mayn vayb hot di greste FAMILY in Yisroel.</ANNOTATION_VALUE>
