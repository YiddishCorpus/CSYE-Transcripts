		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts469" TIME_SLOT_REF2="ts470">
				<ANNOTATION_VALUE>in Kanade hob ikh nisht vos tsu zogn vos tsu z- kum vos tsu zogn, vayl ikh hob nisht vos tsu redn oyf Kanade. un Kanade hot mikh nisht shlekht bahandlt, ikh vel nisht zogn gornisht, keyn eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts471" TIME_SLOT_REF2="ts472">
				<ANNOTATION_VALUE>farkert, eh keyn Poyln volt ikh NEVER tsurikgeforn voynen, vayl dos iz geven dos argste folk fun der velt iz geven dos argste folk. ober in ikh hob nisht keyn shum taynes tsu Kanade,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
