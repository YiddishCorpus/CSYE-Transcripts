			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>du host mitgemakht azelkhes, der oylem iz shtark tsufridn. zogt er, yetst vet men khotsh visn vos s'hot dortn ongegangen, vos du host dertseylt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
