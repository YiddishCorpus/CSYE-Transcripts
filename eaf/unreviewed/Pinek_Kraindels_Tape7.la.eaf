		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts265" TIME_SLOT_REF2="ts266">
				<ANNOTATION_VALUE>ikh bin in Yisroel vayter, ir veyst dokh vi s'iz in Yisroel, hob ikh gearbet, gedos un di ales getun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts267" TIME_SLOT_REF2="ts268">
				<ANNOTATION_VALUE>un m'hot gelebt, m'hot nokh oyfgeboyt zikh a sheyne hoyz in Yisroel, ikh hob gevoynt in a zeyer a sheyn hoyz oyfgeboyt zikh a BEAUTIFUL in Rekhovot,</ANNOTATION_VALUE>
