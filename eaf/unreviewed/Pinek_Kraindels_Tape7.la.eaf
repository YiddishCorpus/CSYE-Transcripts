		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
				<ANNOTATION_VALUE>vil er er zol, vil er mikh aynladenen, er vet zayn in Yerusholaim, </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
