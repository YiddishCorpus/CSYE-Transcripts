				<ANNOTATION_VALUE>mikh hot ir gevolt avekhargenen, ikh bin antlofn bay nakht, zog ikh, aropgeshprungen fun tsvey shtok a FLOOR,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
