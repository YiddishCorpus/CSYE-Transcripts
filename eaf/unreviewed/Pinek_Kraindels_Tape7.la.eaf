		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>fertsn fuftsn yor, biz di kinder zenen geboyrn gevorn, nakher zenen zey do ahergekumen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a177" TIME_SLOT_REF1="ts402" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>di vos iz ot o do, zi iz a MANAGER fun Bney Brit,</ANNOTATION_VALUE>
