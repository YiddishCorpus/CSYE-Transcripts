			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a90" TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
				<ANNOTATION_VALUE>iz hot gevezn dortn zelbn hoyz iz geven a hoyz fun dray shtok.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
