				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a111" TIME_SLOT_REF1="ts219" TIME_SLOT_REF2="ts220">
				<ANNOTATION_VALUE>hob ikh ze gegebn vos di A.K. hobn gemakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
