		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a117" TIME_SLOT_REF1="ts249" TIME_SLOT_REF2="ts250">
				<ANNOTATION_VALUE>in dem hoyz. akht iz geven, hot men fir geharget. fir hobn zikh oykh bahaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a118" TIME_SLOT_REF1="ts252" TIME_SLOT_REF2="ts255">
				<ANNOTATION_VALUE>demolts bin ikh nisht geven lang, ikh bin nokh geven demolts, m'hot genumen dem bruder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a119" TIME_SLOT_REF1="ts256" TIME_SLOT_REF2="ts258">
				<ANNOTATION_VALUE>yetst, yo, bin ikh gevezn dortn bin ikh gevezn akht tog.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a120" TIME_SLOT_REF1="ts259" TIME_SLOT_REF2="ts260">
				<ANNOTATION_VALUE>hob ikh genumen mayn vayb, un dortn ikh hob gedungen bald a taksi in Varshe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts261" TIME_SLOT_REF2="ts262">
				<ANNOTATION_VALUE>un ikh bin geforn di gantse akht tog bizkale ikh bin tsurikgekumen keyn Varshe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts263" TIME_SLOT_REF2="ts264">
				<ANNOTATION_VALUE>arayngegangen in hotel arayn, genumen dort di peklekh un aropgeforn nakher tsum PLANE un geforn keyn Yisroel.</ANNOTATION_VALUE>
