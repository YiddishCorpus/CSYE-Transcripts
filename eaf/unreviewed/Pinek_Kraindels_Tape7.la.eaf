		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts307" TIME_SLOT_REF2="ts308">
				<ANNOTATION_VALUE>hob ikh getrakht zikh eyn zakh, ikh hob do gehat a feter, hot er mir gesh- hot er mir ongehoybn tsu shra- un ikh hob gehat khaveyrim do oykhet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a138" TIME_SLOT_REF1="ts309" TIME_SLOT_REF2="ts310">
				<ANNOTATION_VALUE>ikh hob kh- yo, ikh hob gehat do khaveyrim vos zey hobn geven in Oyshvits, vos ikh hob zey geholfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a139" TIME_SLOT_REF1="ts311" TIME_SLOT_REF2="ts312">
				<ANNOTATION_VALUE>hot er mir ongehoybn tsu shraybn LETTERS, Pinek, zogt er, vos ikh vel esn vestu esn, vos ikh tu vestu tun, kum aher. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a720" TIME_SLOT_REF1="ts313" TIME_SLOT_REF2="ts314">
				<ANNOTATION_VALUE>s'vet dir nisht gefeln vestu tsurikforn. kum nem dir CHOFESH un for aroys.</ANNOTATION_VALUE>
