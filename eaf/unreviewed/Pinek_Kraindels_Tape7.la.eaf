		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a707" TIME_SLOT_REF1="ts227" TIME_SLOT_REF2="ts228">
				<ANNOTATION_VALUE>m'hot gezogt far di ehm ALL far di imigrantn, far di farshlepte mentshn, vos m'hot zey geshlept, eh s'do mentshn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
