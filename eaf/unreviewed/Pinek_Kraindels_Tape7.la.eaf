		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a701" TIME_SLOT_REF1="ts177" TIME_SLOT_REF2="ts178">
				<ANNOTATION_VALUE>un dos, ikh hob zey ongehoybn tsu dertseyln, vos ir hot getun do enkere milkhome, vos ir hot gearbet mit di daytshn,</ANNOTATION_VALUE>
