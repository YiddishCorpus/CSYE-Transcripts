		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a136" TIME_SLOT_REF1="ts303" TIME_SLOT_REF2="ts304">
				<ANNOTATION_VALUE>di sibe iz gevezn eh iz azoy. eh eh ir veyst dokh, tsvontsik yor bin ikh gevezn in dort in Yisroel kimat in der ARMY, un do hob ikh mit gemakht Oyshvits dos gantse lebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a719" TIME_SLOT_REF1="ts305" TIME_SLOT_REF2="ts306">
				<ANNOTATION_VALUE>gevalgert zikh ahin, gevalgert zikh aher. nisht keyn mol nisht gekont shlofn a mol in a bet azoy vi s-darf, gelegn oyfn &lt;erd&gt; fun alde kholeres, fun ale tsores,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
