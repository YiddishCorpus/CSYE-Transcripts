		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a141" TIME_SLOT_REF1="ts317" TIME_SLOT_REF2="ts318">
				<ANNOTATION_VALUE>un ikh bin aroysgeforn. ir meynt az ikh hob gezen di militer az ikh for aroys? ikh vil CHOFESH.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
