		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a693" TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>ikh hob nisht gekent, ober er iz geven, er hot mir geshikt a PICTURE fun Oyshvits,</ANNOTATION_VALUE>
