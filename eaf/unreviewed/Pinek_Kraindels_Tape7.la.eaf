		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts185" TIME_SLOT_REF2="ts186">
				<ANNOTATION_VALUE>oyfn tsveytn shtok hobn di yidn gevoynt, un oykhet in der zayt un der zayt gevoynt a froy a goye vos hot mikh gekent. oy! panye Pinko! panye Pinko!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a92" TIME_SLOT_REF1="ts187" TIME_SLOT_REF2="ts188">
