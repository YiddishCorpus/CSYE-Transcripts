		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a700" TIME_SLOT_REF1="ts171" TIME_SLOT_REF2="ts172">
				<ANNOTATION_VALUE>do hot gebrent fayer, do hobn zikh farbrent yidn, do iz gevorn fargosn liters shvere liters mit blutn.</ANNOTATION_VALUE>
