			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a221" TIME_SLOT_REF1="ts513" TIME_SLOT_REF2="ts514">
				<ANNOTATION_VALUE>zayn hant iz nisht aropgefaln, mayn tate iz aropgefaln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a222" TIME_SLOT_REF1="ts515" TIME_SLOT_REF2="ts517">
				<ANNOTATION_VALUE>fun dem hob ikh hob ikh zikh opgezogt, s'hot gornisht geholfn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a728" TIME_SLOT_REF1="ts516" TIME_SLOT_REF2="ts518">
				<ANNOTATION_VALUE>vi ken zayn a got, az m'nemt kleyne kinder un m'varft zey arop fun shtokn, m'varft un m'hakt un m'brent un m'shekht un m'tut azelkhe zakhn vos di velt hot nokh dos nisht ibergelebt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a729" TIME_SLOT_REF1="ts519" TIME_SLOT_REF2="ts520">
				<ANNOTATION_VALUE>azelkhe zakhn. un az s'nishto gornisht, m'varft nisht keyn shum vunder. m'zol vayzn epes a shtikl vunder volt ikh farshtanen. gornisht! gornisht! un m'lot tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a224" TIME_SLOT_REF1="ts522" TIME_SLOT_REF2="ts525">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a225" TIME_SLOT_REF1="ts527" TIME_SLOT_REF2="ts528">
				<ANNOTATION_VALUE>di ertsiung fun mayne kinder, gits a kuk, oyb ikh hob zey gegebn a yidishn ertsiung,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a226" TIME_SLOT_REF1="ts529" TIME_SLOT_REF2="ts530">
				<ANNOTATION_VALUE>un ikh vil zey zoln hobn a yidisher ertsiung. vos zey ebn tun shpeter, kenen zey tun dos zelbe vos ikh tu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a227" TIME_SLOT_REF1="ts531" TIME_SLOT_REF2="ts532">
				<ANNOTATION_VALUE>e'mir zikh ibertsaygn shpeter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a228" TIME_SLOT_REF1="ts533" TIME_SLOT_REF2="ts534">
				<ANNOTATION_VALUE>ikh hob zey ibergetsoygn un un nokh bizn hayntikn tog, vi ikh gleyb nisht, az s'kumen fraytik tsu nakhts, yedn fraytik tsu nakhts, kumen tsu mir di kinder, di eyniklekh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a229" TIME_SLOT_REF1="ts535" TIME_SLOT_REF2="ts536">
				<ANNOTATION_VALUE>durkh zey tsind ikh op lekht un durkh zey makh ikh kidesh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a230" TIME_SLOT_REF1="ts537" TIME_SLOT_REF2="ts538">
				<ANNOTATION_VALUE>zoln gedenken az der zeyde vos er hot getun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a231" TIME_SLOT_REF1="ts539" TIME_SLOT_REF2="ts540">
				<ANNOTATION_VALUE>ver tsu vayzn do vos ver tsu vayzn az s'a shabes UNK, gekumen do aher, vayz ikh zey, ikh tu dos ales far zey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a232" TIME_SLOT_REF1="ts541" TIME_SLOT_REF2="ts542">
				<ANNOTATION_VALUE>zoln visn az yedn fraytik tsu nakhts makht kidesh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a233" TIME_SLOT_REF1="ts543" TIME_SLOT_REF2="ts544">
				<ANNOTATION_VALUE>m'tsindt on lekht, m'makht a a shabes, azoy vi m'hot gemakht bay mayn tatn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a234" TIME_SLOT_REF1="ts546" TIME_SLOT_REF2="ts548">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a235" TIME_SLOT_REF1="ts550" TIME_SLOT_REF2="ts552">
				<ANNOTATION_VALUE>no, Bet Ora bin ikh a mitglid. iz Bet Ora. in der shul, Bet Ora.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a237" TIME_SLOT_REF1="ts554" TIME_SLOT_REF2="ts556">
				<ANNOTATION_VALUE>ikh hob gevolt nokh tsugebn nokh eyn zakh. dos alts vos ikh hob do dertseylt, ligt mir azoy shver oyfn hartsn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a239" TIME_SLOT_REF1="ts557" TIME_SLOT_REF2="ts559">
				<ANNOTATION_VALUE>di gedanken vos ikh gey adurkh, vos ikh makh mit mit di ale khaloymes, volt ikh gevolt eyn zakh zogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts558" TIME_SLOT_REF2="ts561">
				<ANNOTATION_VALUE>far der gantser velt zol visn, az ikh vel keyn mol nisht kenen moykhl zayn di merders di natsis,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts560" TIME_SLOT_REF2="ts562">
				<ANNOTATION_VALUE>vos zenen bagangen undzer folk un undzer mishpokhe un far undzere kinder, vos zey hobn opgetun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts563" TIME_SLOT_REF2="ts564">
				<ANNOTATION_VALUE>dos iz dokh nisht tsu bagrayfn. m'ken shraybn tog un nakht, m'ken shraybn bikher, m'ken dos nisht ibergebn vos zey hobn opgetun. dos iz gornisht gloyblekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts565" TIME_SLOT_REF2="ts566">
				<ANNOTATION_VALUE>derfar zog ikh, ikh dertseyl yedes mol, un red mit di eyniklekh un red mit di kinder, ikh dertseyl zey dos iberlebenish vos ikh hob ibergelebt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a730" TIME_SLOT_REF1="ts567" TIME_SLOT_REF2="ts568">
				<ANNOTATION_VALUE>un ikh gleyb az zey ebn geyn oyf der zelber meyn vos ikh denk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts569" TIME_SLOT_REF2="ts570">
				<ANNOTATION_VALUE>NEVER NEVER NEVER ibergebn, un NEVER dos di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts571" TIME_SLOT_REF2="ts572">
				<ANNOTATION_VALUE>nisht iberg- s'nisht ibertsugebn, un nisht moykhl zayn far keyn eyntsikn daytsh. nishto keyn daytsh moykhl tsu zayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts573" TIME_SLOT_REF2="ts574">
				<ANNOTATION_VALUE>un dos vos ikh vil ibergebn fun mayn nomen. mayn nomen iz Pinek Kreyndels un nisht fargesn di merders vos zey hobn getun tsu undzer folk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts575" TIME_SLOT_REF2="ts576">
				<ANNOTATION_VALUE>zeks milyon yidn umtsubrengen! far gornisht!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a256" TIME_SLOT_REF1="ts577" TIME_SLOT_REF2="ts578">
				<ANNOTATION_VALUE>ikh drey zikh arum in di yomim-toyvim, ikh hob nisht keyn eltern, ikh hob nisht keyn feters, ikh hob nisht keyn mumes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a731" TIME_SLOT_REF1="ts579" TIME_SLOT_REF2="ts580">
				<ANNOTATION_VALUE>ikh hob nisht keyn shvestern, ikh hob nisht keyn bridern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a732" TIME_SLOT_REF1="ts581" TIME_SLOT_REF2="ts582">
				<ANNOTATION_VALUE>ikh hob nisht tsu vemen shraybn, ikh hob nisht tsu vemen tsu forn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts583" TIME_SLOT_REF2="ts584">
				<ANNOTATION_VALUE>vos far a lebn hobn zey mir do opgetun? zey hobn opgehakt mir dos lebn, dos gantse lebn opgehakt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts587" TIME_SLOT_REF2="ts588">
				<ANNOTATION_VALUE>DANKE sheyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
