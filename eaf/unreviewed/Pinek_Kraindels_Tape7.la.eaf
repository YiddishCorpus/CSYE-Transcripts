		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a171" TIME_SLOT_REF1="ts384" TIME_SLOT_REF2="ts387">
				<ANNOTATION_VALUE>YES,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a172" TIME_SLOT_REF1="ts388" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>eyner heyst Omer, zey hobn eh hebreisher nomen, zenen geboyrn gevorn in Yisroel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
