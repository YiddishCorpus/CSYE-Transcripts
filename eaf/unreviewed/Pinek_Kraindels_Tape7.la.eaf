	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Pinek Kraindels">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts7">
				<ANNOTATION_VALUE>ya. ya ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a3" TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts11">
				<ANNOTATION_VALUE>Yis- Yisroel, yo, in Rekhovot.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a4" TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a6" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>eh vos hob ikh tsu redn tsu dertseyln. eh m'hot zikh bakent, ir veyst dokh vi yunge khevre, un m'iz gegangen aroys a tsayt biz mir hobn geheyrat. mir hobn nisht geheyrat bald tsu morgns, s'hot genumen a yor anderthalbn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a7" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts21">
				<ANNOTATION_VALUE>m'iz gegangen aroys yedes mol ven ikh hob gehat CHOFESH bin ikh gekumen arayn keyn Rekhovot un m'hot farbrengt m'iz gegangen un un m'hot geheyrat nakher. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
				<ANNOTATION_VALUE>in eh eyn u- eyn un fuftsik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
				<ANNOTATION_VALUE>ya.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>o ya o ya, zi veyst ales. un ikh hob zi gefirt oykh keyn Oyshvits, eh iz zi geven mit mir in Poyln mit mit zeks yor tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
				<ANNOTATION_VALUE>hob ikh zi gefirt keyn Poyln un ikh hob ze gevezn eh ikh bin geven mit ir in Treblinke un ikh bin geven mit ir in Oyshvits, ikh bin geven iberal, un ikh hob ir gevizn mayn plats vu ikh bin geshlofn, vu ikh hob gegesn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts39">
				<ANNOTATION_VALUE>mit zeks yor tsurik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts40" TIME_SLOT_REF2="ts43">
				<ANNOTATION_VALUE>yo, ya, ikh hob ni- ven di rusn zenen aroys. ikh hob zey shoyn mer nisht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts47">
				<ANNOTATION_VALUE>ya?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts51">
				<ANNOTATION_VALUE>in NINETY eyn un NINETY.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a16" TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>bin ikh gevezn dortn in Poyln, un ikh bin arayngeforn, ikh hob nisht mer gekent oyshaltn, ikh hob geshrign tsu mayn vayb, gib a kuk op, ikh bin geblibn lebn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>far vos zol ikh nisht forn oyf keyver oves, zen dortn di gantse mishpokhe iz gevorn dortn oysgeharget in Treblinke?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a20" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>nu, un dos hot mikh gepaynikt, vayl sof kol sof yeder eyner do geyt oyf der UNK CEMETARY un m'geyt m'geyt un geyt aroyf</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a684" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>tsum keyver un m- un m'zogt kadesh, m'hot a mol a yortsayt, un zog ikh, far vos az ikh bin geblibn lebn far vos zol ikh nisht geyn zen dortn ale?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
				<ANNOTATION_VALUE>nu bin ikh arayngeforn, ze'mir geforn arayn keyn Treblinke, m'hot undz gevizn dem keyver oyf Treblinke. dos iz dos ershte mol vos in mayn lebn vos ikh hob gezogt kadesh barn keyver, ikh hob zikh gehat tsvey mol farkhalesht,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts65">
				<ANNOTATION_VALUE>m'hot mikh geratevet, ikh hob alts nisht gekent zogn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts64" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>ikh hob nisht gegleybt zikh az s'vet oyskumen a tsayt ikh vel darfn zogn kadesh, eh s'kumt a tsayt m'darf zogn, ober nokh aza fal nokh di gantse FAMILY,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a685" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>di shvester un brider, di shvesters zenen geven mit kinder, brider mit kinder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>un un un FAMILIES, un UNCLES, un ales, eh s'a veytik, m'farlirt azoy fil mentshn vos vos s'gevezn gebundn un geknipt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts73">
				<ANNOTATION_VALUE>nu. ya, un ikh bin geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
				<ANNOTATION_VALUE>di gantse undzer shtot iz gegangen keyn Treblinke.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>un dan nakher vayter iz geven nokh a zakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
				<ANNOTATION_VALUE>ikh nakher ikh bin geven in Poyln, ikh bin geven in Treblinke,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>ikh bin tsurikgekumen fun Treblinke, in a shabes far nakht kum ikh arayn in hotel arayn, tref ikh a KVUTZA, a GROUP, fun Montreal,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a34" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>fun fun fun Dole Dezamur, di RABBI fun Dole Dezamur, vu di gantse khevre a khevre fun yidn fun Dola Dezamur hobn gemakht a GROUP, oykhet a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a686" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>tsu zen Oyshvits, Treblinke,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a687" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>zogn zey, zey hobn shoyn gezen Treblinke. un eyner iz dortn geven tsvishn di yidn, eyner a LAWYER, vos er ken mikh, zogt er, Pinek, zog ter, vo- vo- vos tust du do? zog ikh, ikh bin do mit mayn vayb, er ken di vayb oykhet. </ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>hob ikh mikh zeyer shtark tsefreyt, hobn zey gezogt az zey forn morgn keyn Oyshvits.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>keyn Oyshvits VISITn. dos iz geven yidn vos zenen geboyrn gevorn do in Kanade, un zey forn mit dem RABBI.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>zogt er tsu mir, efsher vilstu geyn oyf shaleshudes? zog ikh, veystu vos? ikh ken arayngeyn oyf shaleshudes. vos iz do tsu redn? arayngeyn oyf shaleshudes, trefn zikh, mir veln redn a bisl.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>er iz avek, er hot gevust az ikh bin geven in Oyshvits. der zelber LAWYER.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>un geyt avek tsum RABBI, un dertseylt im, geb a kuk, ikh hob do, zogt er, a Montrealer yid, er iz geven in Oyshvits. un zey hobn tsu dorfn morgn forn di gantse GROUP keyn Oyshvits VISITn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>iz tsugegangen der RABBI, zogt er tsu mir azoy, zogt er, Pinek,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a43" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>ikh volt gevolt, eh bay bay dem, azoy vi ikh bin arayngegangen ersht zey hobn dokh zayn shul, in hotel iz geven aza shul far yidn tsu davenen, un dort hot men gemakht shaleshudes. di resht iz geven shabes far nakht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a44" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>kumt tsu der RABBI un zogt tsu mir, Pinek, ikh hob gehert, zogt er, dayn nomen, zogt er, er hot mir dertseylt mir,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a688" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
				<ANNOTATION_VALUE>du bist gevezn a yid in Oyshvits, zogt er, ikh volt gevolt, zogt er, nokhn shaleshudes,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a689" TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>oyb du kenst gebn a bisl a SPEECH. hob ikh gezogt, OK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a46" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>er hot zikh derfreyt, nokh shaleshudes</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>hot er mikh aroyf gerufn oyf zayn tish un er hot gemoldn der gantse khevre, mir hobn do, zogt er, a gast,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>zayn nomen iz Pinek Kreyndels, dos iz a yid vos hot ibergemakht, er iz a SURVIVOR fun Oyshvits,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>un er vet aykh ibergebn a barikht. hob ikh ongehoybn tsu dertseyln fun Oyshvits un ale lign, un zey hobn geklogt un geveynt un gekhalesht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a51" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>ikh hob dertseylt fun alem, dos esn badingen, fun shlofn badingen, fun yeder zakh, vos iz tsugekumen, fun alding, un vi azoy ikh hob zikh bafrayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a52" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>nokh dem iz tsugegangen der RABBI, zogt er tsu mir, geb a kuk, reb Pinkhes, ikh vel dir gebn, zogt er, nokh a nomen, Pinkhes Khaim. zolst lebn eybik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
