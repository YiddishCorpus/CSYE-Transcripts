			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a143" TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts322">
				<ANNOTATION_VALUE>a yor CHOFESH? zogt er neyn. vi ken ikh dir farlirn far a yor? ikh vel dir gebn a halb yor. zog ikh, veyst dokh, a halb yor ken ikh gornisht oyftun, ikh darf forn keyn Brazil, ikh hob mishpokhe in Brazil,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
