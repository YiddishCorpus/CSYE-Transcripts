				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a181" TIME_SLOT_REF1="ts410" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>di ander tokht- di andere tokhter vos zi voynt in Nyu Dzhursi, zi hot zeyer a gute postn, zi iz di kontrolir, zi makht a sakh gelt dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
