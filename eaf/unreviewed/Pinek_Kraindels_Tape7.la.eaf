			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts295" TIME_SLOT_REF2="ts296">
				<ANNOTATION_VALUE>ikh bin geven in Yisroel tsvontsik yor.</ANNOTATION_VALUE>
