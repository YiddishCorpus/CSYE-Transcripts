		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts269" TIME_SLOT_REF2="ts271">
				<ANNOTATION_VALUE>un m'hot gefirt a sheyn lebn, un un un un zet dokh azoy dos iz es.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a124" TIME_SLOT_REF1="ts272" TIME_SLOT_REF2="ts274">
				<ANNOTATION_VALUE>ikh hob gehat farshidene gesheftn, ikh hob gehat a gesheft un ikh hob gehat ikh hob gearbet, farshidene gesheftn hob ikh gemakht, ober,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a125" TIME_SLOT_REF1="ts275" TIME_SLOT_REF2="ts277">
				<ANNOTATION_VALUE>ikh hob gelebt. ikh hob gelebt sheyn. ikh hob gelebt sheyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a126" TIME_SLOT_REF1="ts278" TIME_SLOT_REF2="ts281">
				<ANNOTATION_VALUE>o a gut gezelshaft. o hob ikh gehat a zeyer gut gezelshaft. ikh hob gehat eynem a khaver,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a718" TIME_SLOT_REF1="ts282" TIME_SLOT_REF2="ts284">
				<ANNOTATION_VALUE>alts nay gekumene. alts nay gekumene. ikh hob a gezelshaft eyner vos hot gehat a KOLNOA,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a127" TIME_SLOT_REF1="ts285" TIME_SLOT_REF2="ts287">
				<ANNOTATION_VALUE>yo, hot men zikh getrofn tsuzamen, eyner vos hot gehat a fabrik fun tekstil, m- ikh hob gehat a gute CHEVRA, m'hot zikh getrofn yedn fraytik un shabes, un un afile in mitn der vokh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a128" TIME_SLOT_REF1="ts288" TIME_SLOT_REF2="ts290">
				<ANNOTATION_VALUE>ikh hob gehat bakante geboyrene, ober di MOST iz geven alts ayngevanderte. alts ayngevanderte frishe. fun Poyln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a131" TIME_SLOT_REF1="ts291" TIME_SLOT_REF2="ts292">
