		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a134" TIME_SLOT_REF1="ts297" TIME_SLOT_REF2="ts298">
				<ANNOTATION_VALUE>ikh bin aroysgeforn zibn un zekhtsik, ven ikh hob geendikt di z- di di milkhome, di zeks-tege milkhome,</ANNOTATION_VALUE>
