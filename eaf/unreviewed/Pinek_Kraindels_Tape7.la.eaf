		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a726" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>eh zayne zayne valn hot er farloyrn durkh di yidn, durkh di grekn, durkh di italyener,</ANNOTATION_VALUE>
