		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>zog ikh, k- un zey hobn undz derzen. ikh ken avekforn fun zey tsu dir? du farsh- zogt er, derbarem dikh,</ANNOTATION_VALUE>
