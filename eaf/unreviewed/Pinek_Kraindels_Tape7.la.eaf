		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a182" TIME_SLOT_REF1="ts414" TIME_SLOT_REF2="ts416">
				<ANNOTATION_VALUE>di andere vos zi lernt nokh eh muz ikh untershtitsn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts417" TIME_SLOT_REF2="ts418">
				<ANNOTATION_VALUE>nu eh zi iz nisht farheyrat. nokh a SINGLE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts420" TIME_SLOT_REF2="ts422">
				<ANNOTATION_VALUE>in do in Montreal, git a kuk, m'hot shoyn nisht vos tsu trakhtn, ikh bin shoyn a mentsh a pensyoner,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a187" TIME_SLOT_REF1="ts423" TIME_SLOT_REF2="ts424">
				<ANNOTATION_VALUE>un ikh hob shoyn nisht vos tsu trakhtn morgn vegn a tog arbet, eh m'lebt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
