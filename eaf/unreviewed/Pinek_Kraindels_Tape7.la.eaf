		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a175" TIME_SLOT_REF1="ts392" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>do bakent do dem BOY, der BOY fun danet iz geboyrn do,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a176" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>eh zayn NAME iz Mendlzon, zayn foter iz a dokter, Dokter Mendlzon's a zun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts397" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>un zey hobn geshtrebt tsuriktsuforn, oykh er un zi, tsuriktsuforn keyn Yisroel, hobn zey gelebt dortn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
