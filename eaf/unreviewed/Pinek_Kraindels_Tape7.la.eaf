			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts425" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>got tsu dank. ikh hob mayn hoyz, un ikh hob do mayne shkheynim,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
