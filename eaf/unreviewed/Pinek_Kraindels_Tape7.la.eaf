				<ANNOTATION_VALUE>un m'lebt do sheyn, m'lebt op krant bakvem UNK un fayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a202" TIME_SLOT_REF1="ts477" TIME_SLOT_REF2="ts480">
				<ANNOTATION_VALUE>ya, o ya, ikh bin gefo- ikh for dokh, yedes yor for ikh dokh keyn Yisroel, ze ikh mikh mit im.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a203" TIME_SLOT_REF1="ts481" TIME_SLOT_REF2="ts482">
				<ANNOTATION_VALUE>dos yor vos ikh for nor nisht, azoy, dos dos mol hot ir a mazl ir hot mir getrofn, ven nisht volt ikh shoyn geven in Yisroel.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a205" TIME_SLOT_REF1="ts483" TIME_SLOT_REF2="ts484">
				<ANNOTATION_VALUE>dos yor vos ikh for nisht, vayl ikh hob PROBLEM mit mayn vayb's BACK,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a206" TIME_SLOT_REF1="ts485" TIME_SLOT_REF2="ts486">
				<ANNOTATION_VALUE>zi darf geyn tsum dokter do dortn, zi letshket zikh yetst, zi m'hot optsutun mit ir BACK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a207" TIME_SLOT_REF1="ts487" TIME_SLOT_REF2="ts488">
				<ANNOTATION_VALUE>hob ikh dem dokter, do dokter, do darf ikh makhn a CHECKUP, dortn a CHECKUP. derfar for'mir nisht dos yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a208" TIME_SLOT_REF1="ts491" TIME_SLOT_REF2="ts492">
				<ANNOTATION_VALUE>a sakh mol. nisht vos ikh UNK, un kholem a sakh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a210" TIME_SLOT_REF1="ts493" TIME_SLOT_REF2="ts494">
				<ANNOTATION_VALUE>mayn vayb vekt mikh oyf yedes mol fun der fun der nakht vekt zi mikh oyf, Oyshvits Oyshvits! Oyshvits Oyshvits! ikh shray gevald, vek mikh oyf,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a211" TIME_SLOT_REF1="ts495" TIME_SLOT_REF2="ts496">
				<ANNOTATION_VALUE>m'shlogt mikh, m'harget mikh, biz yetst hob ikh nokh azelkhe zakhn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a213" TIME_SLOT_REF1="ts497" TIME_SLOT_REF2="ts498">
				<ANNOTATION_VALUE>ikh hob hersht hersht eyn eyn nakht hob ikh gekholemt, hot zi mikh oyfgevekt. ikh hob geshrign.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a215" TIME_SLOT_REF1="ts500" TIME_SLOT_REF2="ts502">
				<ANNOTATION_VALUE>fun di fun di yom-t- yomim-toyvim kumen on mer.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a216" TIME_SLOT_REF1="ts503" TIME_SLOT_REF2="ts504">
				<ANNOTATION_VALUE>fun der tsayt fun di yomim-toyvim kumt mir di eltern tsum kop, di mishpokhe, un tsu yeder eyner kumt men oyf di gedanken, ikh zits in di shul veyn ikh, kukn m'makh mentshn op,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a217" TIME_SLOT_REF1="ts505" TIME_SLOT_REF2="ts506">
				<ANNOTATION_VALUE>nu, un natirlekh, az m'hot m'hot farshteystu mikh Yisker bin ikh shoyn in gantsn fertik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a218" TIME_SLOT_REF1="ts507" TIME_SLOT_REF2="ts508">
				<ANNOTATION_VALUE>zog ikh far yedn eynem Yisker. far di brider un far di shvester un far tate mame, far di far far yedn eynem zog ikh Yisker.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a220" TIME_SLOT_REF1="ts510" TIME_SLOT_REF2="ts512">
				<ANNOTATION_VALUE>ya, dos dos di religye hot gevirkt. vayl ikh hob keyn mol nisht gevolt gleybn az s'vet tsugeyn an S.S. man tsu mayn tatn un shisn az zayn hant vet nisht aropfaln.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
