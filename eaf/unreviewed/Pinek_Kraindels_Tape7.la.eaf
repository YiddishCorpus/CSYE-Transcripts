		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a692" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
				<ANNOTATION_VALUE>kum arayn, zogt er, oyf shabes, s'vet zayn far mir aza fargenign, du vest haltn nor fraytik vestu zayn kum arayn, for avek shabes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
