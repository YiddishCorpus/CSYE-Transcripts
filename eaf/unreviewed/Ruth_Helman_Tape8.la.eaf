		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a755" TIME_SLOT_REF1="ts122" TIME_SLOT_REF2="ts123">
				<ANNOTATION_VALUE>ir hot mikh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a756" TIME_SLOT_REF1="ts186" TIME_SLOT_REF2="ts189">
				<ANNOTATION_VALUE>s'makht nisht, s'makht nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a757" TIME_SLOT_REF1="ts225" TIME_SLOT_REF2="ts226">
				<ANNOTATION_VALUE>OK undz ve'mir nisht, s- m- ir muzt es nisht vayzn dos bild, s'makht nisht. ikh volt aykh gevolt fregn vu hot ir getrofn ayer tsveytn man?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a761" TIME_SLOT_REF1="ts388" TIME_SLOT_REF2="ts391">
				<ANNOTATION_VALUE>un ven hot ets gehayratet?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a762" TIME_SLOT_REF1="ts392" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>bald.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a763" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts396">
				<ANNOTATION_VALUE>un eh ven hot ets farlozt Poyln? vi lang zent ets,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a764" TIME_SLOT_REF1="ts450" TIME_SLOT_REF2="ts453">
				<ANNOTATION_VALUE>keyn Kuba.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a765" TIME_SLOT_REF1="ts454" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>un fun der resht fun der mishpokhe, iz keyner nisht tsurikgekumen?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a766" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts465">
				<ANNOTATION_VALUE>hot der bruder geshribn az er vil aykh brengen nemen keyn Kuba.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a767" TIME_SLOT_REF1="ts466" TIME_SLOT_REF2="ts469">
				<ANNOTATION_VALUE>neyn neyn, er hot geshribn az er vil aykh breng- nemen keyn Kuba vi s'iz vi a bald ven s'vet zayn meglekh.</ANNOTATION_VALUE>
