			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a990" TIME_SLOT_REF1="ts1181" TIME_SLOT_REF2="ts1182">
				<ANNOTATION_VALUE>un di DEUTSCHEN hobn z- d- di DEUTSCHE froyen hobn nor gevolt az emetser &lt;volt&gt; dort zayn</ANNOTATION_VALUE>
