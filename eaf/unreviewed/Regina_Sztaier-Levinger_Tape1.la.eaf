		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a981" TIME_SLOT_REF1="ts1159" TIME_SLOT_REF2="ts1160">
				<ANNOTATION_VALUE>nakher hob ikh UNK kinder. undz UNK me ken mer UNK do zayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a982" TIME_SLOT_REF1="ts1161" TIME_SLOT_REF2="ts1162">
				<ANNOTATION_VALUE>lomir UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a983" TIME_SLOT_REF1="ts1163" TIME_SLOT_REF2="ts1164">
