			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a966" TIME_SLOT_REF1="ts1125" TIME_SLOT_REF2="ts1126">
				<ANNOTATION_VALUE>"vilt ets fridn? vilt ets fridn?" zey hobn nisht gevolt. in di fri hobn zey geshrign tsu undz az me zol UNK bahaltn zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
