		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a993" TIME_SLOT_REF1="ts1187" TIME_SLOT_REF2="ts1188">
				<ANNOTATION_VALUE>zenen mir geg- hot men getrofn oyfn veg, iz geganen a</ANNOTATION_VALUE>
