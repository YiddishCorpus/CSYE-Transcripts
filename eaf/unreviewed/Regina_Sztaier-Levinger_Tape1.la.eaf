		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a994" TIME_SLOT_REF1="ts1189" TIME_SLOT_REF2="ts1190">
				<ANNOTATION_VALUE>yunger sheygets mit a froy</ANNOTATION_VALUE>
