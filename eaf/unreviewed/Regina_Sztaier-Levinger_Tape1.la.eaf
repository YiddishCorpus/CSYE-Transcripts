			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1009" TIME_SLOT_REF1="ts1219" TIME_SLOT_REF2="ts1220">
				<ANNOTATION_VALUE>vi ken ikh di kop, bin ikh a yunge, volt ikh dir gevizn. vos zol ikh dir vayzn?</ANNOTATION_VALUE>
