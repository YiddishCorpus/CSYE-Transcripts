			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a984" TIME_SLOT_REF1="ts1165" TIME_SLOT_REF2="ts1166">
				<ANNOTATION_VALUE>UNK vet men zen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a985" TIME_SLOT_REF1="ts1167" TIME_SLOT_REF2="ts1168">
				<ANNOTATION_VALUE>zenen mir gelofn biz UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a986" TIME_SLOT_REF1="ts1169" TIME_SLOT_REF2="ts1170">
				<ANNOTATION_VALUE>bisl fintster, hot men zikh bahaltn in UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a987" TIME_SLOT_REF1="ts1171" TIME_SLOT_REF2="ts1172">
				<ANNOTATION_VALUE>mit di ferd, mit &lt;dem&gt;. s'iz geven shreklekh, dos gantse. nakher &lt;hobn mir, hot men&gt; getrofn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a988" TIME_SLOT_REF1="ts1173" TIME_SLOT_REF2="ts1177">
				<ANNOTATION_VALUE>a g- a, a</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a989" TIME_SLOT_REF1="ts1179" TIME_SLOT_REF2="ts1180">
				<ANNOTATION_VALUE>di shrek UNK undz shisn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
