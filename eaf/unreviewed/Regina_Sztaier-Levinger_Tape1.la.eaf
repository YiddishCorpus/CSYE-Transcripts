		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a978" TIME_SLOT_REF1="ts1153" TIME_SLOT_REF2="ts1154">
				<ANNOTATION_VALUE>"vos vil esn?" zog ikh "&lt;yoykh&gt;."</ANNOTATION_VALUE>
