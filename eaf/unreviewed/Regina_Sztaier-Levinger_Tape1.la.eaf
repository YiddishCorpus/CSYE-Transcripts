			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a968" TIME_SLOT_REF1="ts1129" TIME_SLOT_REF2="ts1130">
				<ANNOTATION_VALUE>zenen mir arayngekumen, gevezn dort der rusisher ambasador.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a969" TIME_SLOT_REF1="ts1131" TIME_SLOT_REF2="ts1132">
				<ANNOTATION_VALUE>az der gantser UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
