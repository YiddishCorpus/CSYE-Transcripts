		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1004" TIME_SLOT_REF1="ts1209" TIME_SLOT_REF2="ts1210">
				<ANNOTATION_VALUE>un mikh hot er nisht aroysgelozt UNK shtayer, iz zogt er "bistu a DEUTSCHke"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1005" TIME_SLOT_REF1="ts1211" TIME_SLOT_REF2="ts1212">
				<ANNOTATION_VALUE>nor POLNISCH hob ikh dokh gekent redn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1006" TIME_SLOT_REF1="ts1213" TIME_SLOT_REF2="ts1214">
				<ANNOTATION_VALUE>ober UNK gebn tsu farshteyn vi idyotish er iz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1007" TIME_SLOT_REF1="ts1215" TIME_SLOT_REF2="ts1216">
				<ANNOTATION_VALUE>zol gebn papirn. zog ikh "bist dokh der grester idyot vos Poyln hot UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1008" TIME_SLOT_REF1="ts1217" TIME_SLOT_REF2="ts1218">
				<ANNOTATION_VALUE>ikh gey fun &lt;dorf&gt; als yidishe, un du haltst mikh UNK vayl ikh bin a DEUTSCHE. vi vet men dos makhn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
