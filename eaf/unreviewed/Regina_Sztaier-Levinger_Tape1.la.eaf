		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a996" TIME_SLOT_REF1="ts1193" TIME_SLOT_REF2="ts1194">
				<ANNOTATION_VALUE>UNK hot men zey gekhapt vider ale tsu di arbet</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a997" TIME_SLOT_REF1="ts1195" TIME_SLOT_REF2="ts1196">
				<ANNOTATION_VALUE>m'hot ge&lt;UNK&gt; tsu di arbet. nakher hob ikh gezen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a998" TIME_SLOT_REF1="ts1197" TIME_SLOT_REF2="ts1198">
				<ANNOTATION_VALUE>az a k- a ferd ken men nemen an &lt;anderes&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
