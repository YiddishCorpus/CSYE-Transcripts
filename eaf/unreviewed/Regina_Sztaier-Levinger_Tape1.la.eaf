		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a970" TIME_SLOT_REF1="ts1133" TIME_SLOT_REF2="ts1134">
				<ANNOTATION_VALUE>nisht b- ambasador, nor d- UNK di rusn hobn gearbet dort.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a971" TIME_SLOT_REF1="ts1135" TIME_SLOT_REF2="ts1136">
				<ANNOTATION_VALUE>hot er, hot eyner tsu undz UNK. "ikh bin oykhet a yid</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a972" TIME_SLOT_REF1="ts1137" TIME_SLOT_REF2="ts1138">
				<ANNOTATION_VALUE>ober eyns zog ikh enk. pasts oyf oyf zey, oyf di, di rusishe mentshn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a973" TIME_SLOT_REF1="ts1139" TIME_SLOT_REF2="ts1140">
				<ANNOTATION_VALUE>ikh UNK bin nisht farantvortlekh."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a974" TIME_SLOT_REF1="ts1141" TIME_SLOT_REF2="ts1142">
				<ANNOTATION_VALUE>un ikh far shrek</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a975" TIME_SLOT_REF1="ts1143" TIME_SLOT_REF2="ts1144">
				<ANNOTATION_VALUE>bin k- kra- krank gevorn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1160" TIME_SLOT_REF1="ts1145" TIME_SLOT_REF2="ts1146">
				<ANNOTATION_VALUE>hobn zey mir oyfgebrengt a rusishn dokter, hot er mikh ales zeyer gut bahandlt UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1161" TIME_SLOT_REF1="ts1147" TIME_SLOT_REF2="ts1148">
				<ANNOTATION_VALUE>un ikh gey arop, tref ikh a zelner, fregt er</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1162" TIME_SLOT_REF1="ts1149" TIME_SLOT_REF2="ts1150">
				<ANNOTATION_VALUE>"vi heyst ir?" zog ikh "REGINA." "oy," zogt er, "UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a977" TIME_SLOT_REF1="ts1151" TIME_SLOT_REF2="ts1152">
				<ANNOTATION_VALUE>UNK</ANNOTATION_VALUE>
