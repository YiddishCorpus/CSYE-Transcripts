		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a999" TIME_SLOT_REF1="ts1199" TIME_SLOT_REF2="ts1200">
				<ANNOTATION_VALUE>kumt tsurik UNK ot o dem UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1000" TIME_SLOT_REF1="ts1201" TIME_SLOT_REF2="ts1202">
				<ANNOTATION_VALUE>"undz broykhn mir dos ferd." UNK hob ikh dem sheygets gefregt "velekhe iz a gute ferd?" hot er getsaygt UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1001" TIME_SLOT_REF1="ts1203" TIME_SLOT_REF2="ts1204">
				<ANNOTATION_VALUE>"dos iz undzer ferd, ken men dos ferd UNK forn tsu di grenets."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1002" TIME_SLOT_REF1="ts1205" TIME_SLOT_REF2="ts1206">
				<ANNOTATION_VALUE>m'iz tsugets- -kumen tsi du grenets, iz nisht geven vu tsu UNK shlofn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1003" TIME_SLOT_REF1="ts1207" TIME_SLOT_REF2="ts1208">
				<ANNOTATION_VALUE>nor m'hot geshlofn oyf di poglige mit di UNK mit tsaytungen tsugedekt</ANNOTATION_VALUE>
