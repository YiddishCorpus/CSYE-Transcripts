		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a979" TIME_SLOT_REF1="ts1155" TIME_SLOT_REF2="ts1156">
				<ANNOTATION_VALUE>hob ikh gegegbn a kuk. er geyt mit dray hiner mit di feder. er leygt ales arayn in top arayn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a980" TIME_SLOT_REF1="ts1157" TIME_SLOT_REF2="ts1158">
				<ANNOTATION_VALUE>kh'hob shoyn nisht gevolt &lt;esn&gt; UNK ophaltn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
