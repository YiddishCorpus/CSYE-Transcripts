		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a695" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>farshteyst? azoy hot men UNK, un ikh bin geblibn dort in dem lager, un dort iz gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
