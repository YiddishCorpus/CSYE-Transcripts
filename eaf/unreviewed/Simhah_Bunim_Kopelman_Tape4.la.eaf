				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a725" TIME_SLOT_REF1="ts925" TIME_SLOT_REF2="ts926">
				<ANNOTATION_VALUE>hot er zikh gegebn, un iz avekgeforn mit &lt;di&gt; dos, un er iz antlofn.</ANNOTATION_VALUE>
