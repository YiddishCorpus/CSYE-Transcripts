		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1149" TIME_SLOT_REF1="ts931" TIME_SLOT_REF2="ts932">
				<ANNOTATION_VALUE>azoy iz gevezn &lt;yede&gt; tog.</ANNOTATION_VALUE>
