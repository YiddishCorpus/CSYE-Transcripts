				<ANNOTATION_VALUE>zogt er "tsvey un tsvontsik."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a766" TIME_SLOT_REF1="ts1095" TIME_SLOT_REF2="ts1096">
				<ANNOTATION_VALUE>tsvey un tsvontsik. vos hob ikh getun?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a767" TIME_SLOT_REF1="ts1097" TIME_SLOT_REF2="ts1098">
				<ANNOTATION_VALUE>m'hot tsugemakht dem lager, un m'hot UNK dos yingele antlofn, bin ikh nokhgelofn dem yingele. ikh bin arayngekumen, hob ikh getrofn mayn bruder</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a768" TIME_SLOT_REF1="ts1099" TIME_SLOT_REF2="ts1100">
