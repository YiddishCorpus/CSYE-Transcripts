		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1238" TIME_SLOT_REF1="ts1191" TIME_SLOT_REF2="ts1192">
				<ANNOTATION_VALUE>un dort &lt;hob ikh&gt; vayter gemakht</ANNOTATION_VALUE>
