			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1248" TIME_SLOT_REF1="ts1211" TIME_SLOT_REF2="ts1212">
				<ANNOTATION_VALUE>heybt zikh &lt;on&gt; a frishe mayse az &lt;me muz&gt; geyn oyf toytn marsh</ANNOTATION_VALUE>
