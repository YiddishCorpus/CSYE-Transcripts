		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1200" TIME_SLOT_REF1="ts1107" TIME_SLOT_REF2="ts1108">
				<ANNOTATION_VALUE>zog ikh "veystu vos? ikh volt zi gevolt zen."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
