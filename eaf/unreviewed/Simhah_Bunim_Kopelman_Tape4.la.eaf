			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1145" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts918">
				<ANNOTATION_VALUE>iz UNK gekumen tsu UNK "&lt;lomikh&gt; dos do"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
