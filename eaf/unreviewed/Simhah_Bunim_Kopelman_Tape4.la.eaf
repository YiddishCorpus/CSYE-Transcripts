		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts886" TIME_SLOT_REF2="ts889">
				<ANNOTATION_VALUE>host nisht gehert &lt;vegn&gt; keyn pipl?</ANNOTATION_VALUE>
