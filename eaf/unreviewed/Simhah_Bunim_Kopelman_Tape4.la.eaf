		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a765" TIME_SLOT_REF1="ts1091" TIME_SLOT_REF2="ts1092">
				<ANNOTATION_VALUE>"UNK dir nokh a broyt," zogt er "ikh hob gornisht getun." hot er nokhgelo- "vu iz d- vu, vu iz der tate? in velekhn blok?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
