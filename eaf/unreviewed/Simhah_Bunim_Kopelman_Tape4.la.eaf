		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a718" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>un der hot gegat a khaver vos er hot gevust ales f- fun dem kapo, un m'hot &lt;geshoybn&gt;.</ANNOTATION_VALUE>
