				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a769" TIME_SLOT_REF1="ts1101" TIME_SLOT_REF2="ts1102">
				<ANNOTATION_VALUE>dos yingele, vos hobn zey getun? &lt;yede&gt; tog zenen zey aroysgeganen fun</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1198" TIME_SLOT_REF1="ts1103" TIME_SLOT_REF2="ts1104">
				<ANNOTATION_VALUE>lager un, un ganen arayn in froyen lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
