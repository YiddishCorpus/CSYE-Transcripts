		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts907" TIME_SLOT_REF2="ts908">
				<ANNOTATION_VALUE>i- ts- hob ikh gegat, ikh hob geboyt dem tramvay</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1141" TIME_SLOT_REF1="ts909" TIME_SLOT_REF2="ts910">
				<ANNOTATION_VALUE>iz er tsugekumen ts- d- dortn, es iz nisht di tramvay, di shines, arayn in vald arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1142" TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts912">
				<ANNOTATION_VALUE>&lt;hot er&gt; gehat a drezne. veyst vos a drezne iz?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
