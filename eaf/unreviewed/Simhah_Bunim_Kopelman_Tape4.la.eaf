			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a764" TIME_SLOT_REF1="ts1089" TIME_SLOT_REF2="ts1090">
				<ANNOTATION_VALUE>ikh hob dos gehert un hot im gegebn a shtikl broyt</ANNOTATION_VALUE>
