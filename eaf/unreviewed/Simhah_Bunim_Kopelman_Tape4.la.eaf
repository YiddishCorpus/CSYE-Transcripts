		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>hot oysgenitst dos yingl. &lt;iz er&gt; geven a pipl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
