		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts895">
				<ANNOTATION_VALUE>hot er oysgenitst dos yingele.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
