			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1151" TIME_SLOT_REF1="ts935" TIME_SLOT_REF2="ts936">
				<ANNOTATION_VALUE>kurts tsu di zakh, ikh hob gearbet bay di shines, farshteystu.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
