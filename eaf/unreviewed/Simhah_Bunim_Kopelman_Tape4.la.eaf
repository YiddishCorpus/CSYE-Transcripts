				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1206" TIME_SLOT_REF1="ts1119" TIME_SLOT_REF2="ts1120">
				<ANNOTATION_VALUE>hob ikh mikh aroysge- aroysge&lt;UNK&gt; &lt;azoy a&gt; rizike</ANNOTATION_VALUE>
