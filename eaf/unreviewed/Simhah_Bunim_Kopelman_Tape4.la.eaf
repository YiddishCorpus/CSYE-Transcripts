		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1199" TIME_SLOT_REF1="ts1105" TIME_SLOT_REF2="ts1106">
				<ANNOTATION_VALUE>dertseylt mir mayn bruder, er hot getrofn mayn froy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
