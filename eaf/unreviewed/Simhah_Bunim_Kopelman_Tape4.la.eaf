			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1253" TIME_SLOT_REF1="ts1221" TIME_SLOT_REF2="ts1222">
				<ANNOTATION_VALUE>fun di zayt di umedum lagern</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
