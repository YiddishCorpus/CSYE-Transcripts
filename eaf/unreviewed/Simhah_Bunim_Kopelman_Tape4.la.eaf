			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1144" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>un dos fort zikh a- dos loyft UNK, azoy shnel geyt er</ANNOTATION_VALUE>
