		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1203" TIME_SLOT_REF1="ts1113" TIME_SLOT_REF2="ts1114">
				<ANNOTATION_VALUE>vestu mitgeyn mit di" UNK, hobn gefirt UNK di tsvey yingelekh hobn gefirt dem dishl</ANNOTATION_VALUE>
