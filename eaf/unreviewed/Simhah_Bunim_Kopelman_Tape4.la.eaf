			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1251" TIME_SLOT_REF1="ts1217" TIME_SLOT_REF2="ts1218">
				<ANNOTATION_VALUE>hot men ongehoybn, m'hot undz tsuzamengerufn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
