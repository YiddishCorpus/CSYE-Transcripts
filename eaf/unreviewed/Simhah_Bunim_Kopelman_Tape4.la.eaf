		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a723" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>ikh hob dokh moyre gehat</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
