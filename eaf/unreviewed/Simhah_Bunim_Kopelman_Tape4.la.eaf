		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1152" TIME_SLOT_REF1="ts937" TIME_SLOT_REF2="ts938">
				<ANNOTATION_VALUE>mit eyn molt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1153" TIME_SLOT_REF1="ts939" TIME_SLOT_REF2="ts940">
				<ANNOTATION_VALUE>mit eyn molt, farshteystu</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1154" TIME_SLOT_REF1="ts941" TIME_SLOT_REF2="ts942">
				<ANNOTATION_VALUE>zogt mir, farshteystu</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1155" TIME_SLOT_REF1="ts943" TIME_SLOT_REF2="ts944">
				<ANNOTATION_VALUE>"gey arayn in lager arayn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1156" TIME_SLOT_REF1="ts945" TIME_SLOT_REF2="ts946">
				<ANNOTATION_VALUE>UNK m'hot gekumen tsu geyn tsurik fun di arbet. ikh bin UNK gekumen tsu geyn shtendik a bisele shpeter, farshteyst?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1157" TIME_SLOT_REF1="ts947" TIME_SLOT_REF2="ts948">
				<ANNOTATION_VALUE>ikh bin UNK nokh dem &lt;hot men mikh&gt; tsugeteylt tsu di FLAK komando</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1158" TIME_SLOT_REF1="ts949" TIME_SLOT_REF2="ts950">
				<ANNOTATION_VALUE>veyst vos FLAK komando iz?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a730" TIME_SLOT_REF1="ts951" TIME_SLOT_REF2="ts953">
				<ANNOTATION_VALUE>az me bombet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a731" TIME_SLOT_REF1="ts954" TIME_SLOT_REF2="ts956">
				<ANNOTATION_VALUE>iz a bombe vos falt arunter, hob ikh gemuzt geyn, &lt;an elektrik&gt; oys&lt;UNK&gt;. rizikirt dos lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a732" TIME_SLOT_REF1="ts957" TIME_SLOT_REF2="ts958">
				<ANNOTATION_VALUE>hob ikh UNK tsugeteylt, bin ikh geblibn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1159" TIME_SLOT_REF1="ts959" TIME_SLOT_REF2="ts960">
				<ANNOTATION_VALUE>bay di FLAK komande</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1160" TIME_SLOT_REF1="ts961" TIME_SLOT_REF2="ts962">
				<ANNOTATION_VALUE>bay hundert</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1161" TIME_SLOT_REF1="ts963" TIME_SLOT_REF2="ts964">
				<ANNOTATION_VALUE>hundert geve- in di lagern gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1162" TIME_SLOT_REF1="ts965" TIME_SLOT_REF2="ts966">
				<ANNOTATION_VALUE>in tsvey shtubn akhtsn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1163" TIME_SLOT_REF1="ts967" TIME_SLOT_REF2="ts968">
				<ANNOTATION_VALUE>un tsvontsik iz gevezn di</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1164" TIME_SLOT_REF1="ts969" TIME_SLOT_REF2="ts970">
				<ANNOTATION_VALUE>di khevre, nor di kapos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1165" TIME_SLOT_REF1="ts971" TIME_SLOT_REF2="ts972">
				<ANNOTATION_VALUE>tsugeteylt hot men gemakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1166" TIME_SLOT_REF1="ts973" TIME_SLOT_REF2="ts974">
				<ANNOTATION_VALUE>a FLAK komando</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1167" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts976">
				<ANNOTATION_VALUE>bin ikh tsugeteylt gevorn tsu di FLAK komando</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1168" TIME_SLOT_REF1="ts977" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>ot dort iz UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1169" TIME_SLOT_REF1="ts979" TIME_SLOT_REF2="ts980">
				<ANNOTATION_VALUE>kurts tsu di zakh, vos hot, vos hot pasirt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1170" TIME_SLOT_REF1="ts981" TIME_SLOT_REF2="ts982">
				<ANNOTATION_VALUE>pasirt hot, farshteystu, az di khevre</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1171" TIME_SLOT_REF1="ts983" TIME_SLOT_REF2="ts984">
				<ANNOTATION_VALUE>hobn geshoybn. veyst &lt;vos taytsh&gt; geshoybn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1172" TIME_SLOT_REF1="ts985" TIME_SLOT_REF2="ts986">
				<ANNOTATION_VALUE>host gekrign a gut hemd</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1173" TIME_SLOT_REF1="ts987" TIME_SLOT_REF2="ts988">
				<ANNOTATION_VALUE>hot er, der kapo, tsugenumen, hot er gegebn a brudik hemd</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a734" TIME_SLOT_REF1="ts989" TIME_SLOT_REF2="ts990">
				<ANNOTATION_VALUE>un zey hobn es farkoyft aroys tsu di poyerim un gebrengt esn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a735" TIME_SLOT_REF1="ts991" TIME_SLOT_REF2="ts992">
				<ANNOTATION_VALUE>un ikh bin geven aroys- d- oyser di geto, un ikh bin aroysgeganen mit, me zukht, di bom- di bom- me darf zukhn di bombes</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1174" TIME_SLOT_REF1="ts993" TIME_SLOT_REF2="ts994">
				<ANNOTATION_VALUE>hobn zey geshoybn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1175" TIME_SLOT_REF1="ts995" TIME_SLOT_REF2="ts996">
				<ANNOTATION_VALUE>un m'hot zey derkhapt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1176" TIME_SLOT_REF1="ts997" TIME_SLOT_REF2="ts998">
				<ANNOTATION_VALUE>tsk m'hot geganen in di lager avekshikn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1177" TIME_SLOT_REF1="ts999" TIME_SLOT_REF2="ts1000">
				<ANNOTATION_VALUE>a shtraf komando</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1178" TIME_SLOT_REF1="ts1001" TIME_SLOT_REF2="ts1002">
				<ANNOTATION_VALUE>iz geven ikh un a yid vos er hot geheysn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a737" TIME_SLOT_REF1="ts1003" TIME_SLOT_REF2="ts1004">
				<ANNOTATION_VALUE>eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a738" TIME_SLOT_REF1="ts1005" TIME_SLOT_REF2="ts1006">
				<ANNOTATION_VALUE>vi heyst er?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a739" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>hot beyde kinder do do in UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a740" TIME_SLOT_REF1="ts1009" TIME_SLOT_REF2="ts1010">
				<ANNOTATION_VALUE>eh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a741" TIME_SLOT_REF1="ts1011" TIME_SLOT_REF2="ts1012">
				<ANNOTATION_VALUE>kh'vel dir bald zogn vi er heyst.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a742" TIME_SLOT_REF1="ts1013" TIME_SLOT_REF2="ts1014">
				<ANNOTATION_VALUE>ALSO ikh mit nokh a yid, kh- kh'vel dos kumen bald oyf dem nomen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a743" TIME_SLOT_REF1="ts1015" TIME_SLOT_REF2="ts1016">
				<ANNOTATION_VALUE>un m'hot geganen mit, farshteystu, m'hot undz avekgeshikt in a lager arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a744" TIME_SLOT_REF1="ts1017" TIME_SLOT_REF2="ts1018">
				<ANNOTATION_VALUE>shtraf komande, hundert un tsvey perzonen zenen gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a745" TIME_SLOT_REF1="ts1019" TIME_SLOT_REF2="ts1020">
				<ANNOTATION_VALUE>nor kapos</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a746" TIME_SLOT_REF1="ts1021" TIME_SLOT_REF2="ts1022">
				<ANNOTATION_VALUE>un undz ze'mir geven di tsvey yidn, ikh un</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a747" TIME_SLOT_REF1="ts1023" TIME_SLOT_REF2="ts1024">
				<ANNOTATION_VALUE>Feder, Leybl Feder.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a748" TIME_SLOT_REF1="ts1025" TIME_SLOT_REF2="ts1026">
				<ANNOTATION_VALUE>ikh un Leybl Feder zenen mir gevezn di tsvey oyf&lt;UNK&gt; vos &lt;iz&gt; mitgeganen mit di grupe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1179" TIME_SLOT_REF1="ts1027" TIME_SLOT_REF2="ts1028">
				<ANNOTATION_VALUE>m'iz gekumen arayn. dem ALTENHAMMER, ALTEHAMMER iz geven a lager</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1180" TIME_SLOT_REF1="ts1029" TIME_SLOT_REF2="ts1030">
				<ANNOTATION_VALUE>vu s'iz gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1181" TIME_SLOT_REF1="ts1031" TIME_SLOT_REF2="ts1032">
				<ANNOTATION_VALUE>italyener</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1182" TIME_SLOT_REF1="ts1033" TIME_SLOT_REF2="ts1034">
				<ANNOTATION_VALUE>un d- di UNK hobn zey demolst shoyn aroysgelozt, m'iz fray, s'iz shoyn gevorn a bisl beser</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1183" TIME_SLOT_REF1="ts1035" TIME_SLOT_REF2="ts1036">
				<ANNOTATION_VALUE>un mir zenen arayn, dort hot men ge- dos iz geven d- oyf poylish hot dos geheysn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1184" TIME_SLOT_REF1="ts1037" TIME_SLOT_REF2="ts1038">
				<ANNOTATION_VALUE>eh STARA KUZNIA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1185" TIME_SLOT_REF1="ts1039" TIME_SLOT_REF2="ts1040">
				<ANNOTATION_VALUE>dort iz geven a g- a grub, a d- koyln grub. spn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1186" TIME_SLOT_REF1="ts1041" TIME_SLOT_REF2="ts1042">
				<ANNOTATION_VALUE>hot men geboyt dort &lt;in&gt; oyvn, a KOMIN</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a749" TIME_SLOT_REF1="ts1043" TIME_SLOT_REF2="ts1044">
				<ANNOTATION_VALUE>spetsyal, hot men undz dort gebrengt. m'iz gekumen dort ahin</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a750" TIME_SLOT_REF1="ts1045" TIME_SLOT_REF2="ts1046">
				<ANNOTATION_VALUE>iz gevezn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a751" TIME_SLOT_REF1="ts1047" TIME_SLOT_REF2="ts1048">
				<ANNOTATION_VALUE>zekhtsik protsent</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a752" TIME_SLOT_REF1="ts1049" TIME_SLOT_REF2="ts1050">
				<ANNOTATION_VALUE>vos zenen gevezn UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1187" TIME_SLOT_REF1="ts1051" TIME_SLOT_REF2="ts1052">
				<ANNOTATION_VALUE>f- fun Lodzh</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1188" TIME_SLOT_REF1="ts1053" TIME_SLOT_REF2="ts1054">
				<ANNOTATION_VALUE>nor eyder ikh UNK dertseyln, oyf di kurts dertseyln, hob ikh fargesn in gantsn, dos iz dos vikhtikste</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1189" TIME_SLOT_REF1="ts1055" TIME_SLOT_REF2="ts1056">
				<ANNOTATION_VALUE>ALSO bin ikh gevezn dort in lager, ikh bin, eyder ikh bin geganen dort arayn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1190" TIME_SLOT_REF1="ts1057" TIME_SLOT_REF2="ts1058">
				<ANNOTATION_VALUE>bin aheymgekumen fun dem a- fun dem tramvay</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1192" TIME_SLOT_REF1="ts1059" TIME_SLOT_REF2="ts1060">
				<ANNOTATION_VALUE>&lt;vos&gt; ikh hob geleygt di shines</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1191" TIME_SLOT_REF1="ts1061" TIME_SLOT_REF2="ts1062">
				<ANNOTATION_VALUE>vos hot pasirt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a753" TIME_SLOT_REF1="ts1063" TIME_SLOT_REF2="ts1064">
				<ANNOTATION_VALUE>loyft adurkh a kleyn yingele</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a754" TIME_SLOT_REF1="ts1065" TIME_SLOT_REF2="ts1066">
				<ANNOTATION_VALUE>khapt im der kapo DIMANT</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a755" TIME_SLOT_REF1="ts1067" TIME_SLOT_REF2="ts1068">
				<ANNOTATION_VALUE>khapt dos kindl, un dos yingl heybt on tsu shrayen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a756" TIME_SLOT_REF1="ts1069" TIME_SLOT_REF2="ts1070">
				<ANNOTATION_VALUE>zogt er "ikh vel dir gornisht tun.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1193" TIME_SLOT_REF1="ts1071" TIME_SLOT_REF2="ts1072">
				<ANNOTATION_VALUE>ikh hob" zogt er "mayns a yingele in froyen lager mit."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1194" TIME_SLOT_REF1="ts1073" TIME_SLOT_REF2="ts1074">
				<ANNOTATION_VALUE>s'iz do tsvey yingelekh in gantsn in dem lager.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1195" TIME_SLOT_REF1="ts1075" TIME_SLOT_REF2="ts1076">
				<ANNOTATION_VALUE>hot er im gekhapt, &lt;UNK&gt; mir undz in blok</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1196" TIME_SLOT_REF1="ts1077" TIME_SLOT_REF2="ts1078">
				<ANNOTATION_VALUE>zogt er "ikh vel dir gornisht tun. na" zogt er "a shtikl broyt." zogt er "vos tustu?" zogt er "na, ikh vel zikh UNK teyln" zogt er "mit mayn tatn."</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a759" TIME_SLOT_REF1="ts1079" TIME_SLOT_REF2="ts1080">
				<ANNOTATION_VALUE>"ver bist? vi heyst der tate?"</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a760" TIME_SLOT_REF1="ts1081" TIME_SLOT_REF2="ts1082">
				<ANNOTATION_VALUE>"mayn tate heyst &lt;PYKORZ&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
