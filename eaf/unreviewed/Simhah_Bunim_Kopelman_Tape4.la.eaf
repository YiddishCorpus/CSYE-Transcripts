			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a693" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>vos hostu gemakht?" un er hot im gegebn nokh a ZBEK tsu</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a694" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
