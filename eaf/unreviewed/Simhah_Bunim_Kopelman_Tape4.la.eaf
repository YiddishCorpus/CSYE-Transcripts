		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1113" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>un tsurikgekumen IST nor, hot er gehat hundert man, iz tsurikgekumen nayntsik man.</ANNOTATION_VALUE>
