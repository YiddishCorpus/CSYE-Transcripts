		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1254" TIME_SLOT_REF1="ts1223" TIME_SLOT_REF2="ts1224">
				<ANNOTATION_VALUE>un &lt;m'iz&gt; adurkhgeganen ts- tsu ALTHAMMER zenen gekumen. mir zenen aroysgeganen dort. m-</ANNOTATION_VALUE>
