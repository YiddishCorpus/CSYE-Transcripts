		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1230" TIME_SLOT_REF1="ts1173" TIME_SLOT_REF2="ts1174">
				<ANNOTATION_VALUE>un m'hot aruntergelozt , un di mentshn zenen geshtanen oyf di shines</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
