			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1150" TIME_SLOT_REF1="ts933" TIME_SLOT_REF2="ts934">
				<ANNOTATION_VALUE>&lt;yede&gt; tog UNK pasirt vos andersh.</ANNOTATION_VALUE>
