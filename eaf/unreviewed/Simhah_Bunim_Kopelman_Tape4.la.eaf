		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1143" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>vos fort oyf a, azoy vi a rover, oyf di shines</ANNOTATION_VALUE>
