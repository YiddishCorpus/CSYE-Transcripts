			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1112" TIME_SLOT_REF1="ts1041" TIME_SLOT_REF2="ts1042">
				<ANNOTATION_VALUE>nokh dem hob ikh d- shoyn genumen derkonen, in mashine forndik, hob ikh genumen derkonen zeyere, ver zey zaynen. ikh hob zey nit gekont keynem.</ANNOTATION_VALUE>
