			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a323" TIME_SLOT_REF1="ts975" TIME_SLOT_REF2="ts978">
				<ANNOTATION_VALUE>flegt men lozn mitnemen zakhn dortn, pasude, me ken oysbaytn oyf tsum esn. ye.</ANNOTATION_VALUE>
