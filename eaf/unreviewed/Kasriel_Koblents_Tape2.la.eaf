			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a364" TIME_SLOT_REF1="ts1071" TIME_SLOT_REF2="ts1072">
				<ANNOTATION_VALUE>UNK &lt;nu, mir zaynen&gt; dortn geshtanen umgefer a tsvantsik minut un efsher DAZHE nokh merer, biz m'iz avek, biz m'hot UNK &lt;tsu trogn dem zak&gt;, altseding.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
