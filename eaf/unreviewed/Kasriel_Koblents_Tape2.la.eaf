		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a363" TIME_SLOT_REF1="ts1069" TIME_SLOT_REF2="ts1070">
				<ANNOTATION_VALUE>ikh bin gezesn oyfn breg mashine, hob ikh gekukt in GESTAPO vi es geyen arum di &lt;GE-&gt; GESTAPO UNK fentster, gebrent di elektrye umetum.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
