	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Roza Bieliauskienė">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a2" TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
				<ANNOTATION_VALUE>-S, VLINUS LITVA.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a5" TIME_SLOT_REF1="ts76" TIME_SLOT_REF2="ts77">
				<ANNOTATION_VALUE>bite sheyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a8" TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts132">
				<ANNOTATION_VALUE>du voltst gekent eh zogn vos vilt ir zogn tsu di kumendike doyrim?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a9" TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
				<ANNOTATION_VALUE>a groysn dank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
	<TIER LANG_REF="yid" LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Meishe Geguzhinskis">
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a10" TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
				<ANNOTATION_VALUE>in shpitol hot men mir zeyer gikh oysgeheylt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a11" TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
				<ANNOTATION_VALUE>ikh bin gelegn dort emes bay a tsvey a halb monat, biz dray monat tsayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a12" TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
				<ANNOTATION_VALUE>un m'iz gekumen tsu geyn in shtub, di froy hot mir gebrakht</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a13" TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
				<ANNOTATION_VALUE>tsu geyn in sh- tsu f- tsu firn in shtub shoyn oyf mayne fis.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a14" TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
				<ANNOTATION_VALUE>un ikh hob nor dokh hob ikh zikh geshpirt moralish zeyer gesh- zeyer</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a15" TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
				<ANNOTATION_VALUE>zeyer shtark dershlogn der- farshlogn. tsu arbet hob ikh shoyn nit gekent geyn vayter, un ikh hob shoyn nit gevelt geyn tsu der arbet, vayl ikh hob farshtanen az di batsiung</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a17" TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
				<ANNOTATION_VALUE>tsu di arbeter velkhe arbetn in dem ministorn-kabinet zaynen di zeyer nit nit m'bahandlt ver- vern bahandlt nit vi keyn mentshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a18" TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
				<ANNOTATION_VALUE>un ikh hob ongehoybn zikh farnemen mit literatur. in di fraye tsayt fleg ikh shraybn in yidishe tsaytungen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a21" TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
				<ANNOTATION_VALUE>in a sakh eyropeishe tsaytungen fleg ikh shraybn. in Parizher Tsaytung fleg ikh shraybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a22" TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
				<ANNOTATION_VALUE>in Erets-Yisroeldike Tsaytung, di nayes, hob ikh geshribn farshidene reportazhn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a23" TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts25">
				<ANNOTATION_VALUE>ikh hob geshribn mayne farsheydene, ikh hob ongehoybn shraybn dikhtung, farsheydene lider,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a25" TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts26">
				<ANNOTATION_VALUE>velkhe ikh hob eh frier gekent s'mir oysgekumen in in oyfn oyfn geza- oyfn gedank.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a194" TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
				<ANNOTATION_VALUE>un eh ikh mit dem hob ikh a bisl zikh fargesn ale mayne vaytokn un ikh hob eh bashlosn az ikh vel,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a195" TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>ikh bin dan dan ersht geven zibn un fuftsik yor. keyn gantse keyn zekhtsik hob ikh hob ikh nokh nit der- der- der- dertsoygn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a26" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>keyn pensye hob ikh, keyn pe- keyn pensyoner bin ikh nit geven.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a27" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>nor az ikh bin shoyn gevorn zekhtsik yor, trakht ikh, nu ikh vel shoyn mer mit arbet mistome mer nit kenen geyn. ikh vel zikh farnemen mit bay mit mayn eh neygung tsu literatur.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a28" TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
				<ANNOTATION_VALUE>nu mayne a- mayne artiklen hobn mir hobn gehat a gants groysn derfolg. m'hot di di redaktorn fun Varshever Tsaytung, Katarko, hot mir nit eyn mol geshribn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a29" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>er hot gebetn ikh zol shraybn, er hot iz do gekumen bay mir tsu gast tsu forn fun Varshe</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a30" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
				<ANNOTATION_VALUE>tsu mir shtub, un er hot mir zikh interesirt vegn mir. er flegt drukn ale mayne lider, s'nit geven keyn eyn eyn eyn gedikht vos er zol nit drukn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a31" TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
				<ANNOTATION_VALUE>un dos iz farshteyt zikh, oder haynt tsum tog, ot di letste tsayt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a196" TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
				<ANNOTATION_VALUE>bin ikh vider krank gevorn do, ikh bin gelegn oyfn bet a lange tsayt, onderhalbn yor tsayt bin ikh gelegn tsu,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a197" TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
				<ANNOTATION_VALUE>ikh hob gerufn bay mir kentik di ale iberlebenishn fun di lagern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a198" TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
				<ANNOTATION_VALUE>di ale veytokn vos ikh hob gehat. ikh fleg zen yedn ikh fleg</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a199" TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts51">
				<ANNOTATION_VALUE>shpirn yedn tog di veytokn fun di fun di fun di hent</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a200" TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
				<ANNOTATION_VALUE>un fun ti- fun dem brust-kastn b- beys ikh bin gelegn, gehongen oyf di shtrik.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a201" TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
				<ANNOTATION_VALUE>ikh fleg zen bay nakht, ikh fleg s'flegt mikh shteyn alts far di oygn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a33" TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
				<ANNOTATION_VALUE>un ikh hob zikh zeyer shtark tsebrokhn, ikh bin gelegn a lange tsayt biz hayntike yor,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a35" TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
				<ANNOTATION_VALUE>fun fir un nayntsikstn bizn zeks un nayntsikstn, dort bin ikh kimat nit aroys fun shtub.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a36" TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
				<ANNOTATION_VALUE>nor ikh fleg shraybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a37" TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
				<ANNOTATION_VALUE>di letste fleg ikh zikh farnemen mi- mit in fleg ikh arbetn mitarbetn tsvishn di doktoyrim fun fun meditsinishn tsenter tsu di bay di yidishe gemeynde,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a38" TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
				<ANNOTATION_VALUE>ikh hob dortn gehat oykh a interes tsum arbetn, mir flegn helfn dortn yidn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a39" TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
				<ANNOTATION_VALUE>oreme yidn, kranke yidn, mit meditsin, mit medikamen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a40" TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
				<ANNOTATION_VALUE>ikh hob dortn farnumen oykh als sekretar fun dem meditsi- fun dem fun dem komitet fun fun dem eh eh rat fun dem</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a41" TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
				<ANNOTATION_VALUE>meditsinishn tsenter bay dokter Zak UNK.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a42" TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
				<ANNOTATION_VALUE>nokh eh hayntike yor, fun onfang yor shoyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a45" TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
				<ANNOTATION_VALUE>hob ikh dershpirt az ikh ken nokh epes vos iz ton.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a47" TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts78">
				<ANNOTATION_VALUE>nu ikh ken do oysleyenen mayne a a dikht UNK, oyber, yo.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a48" TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts81">
				<ANNOTATION_VALUE>ikh hob ongeshribn far der tsayt eh fil dikhtn, farsheydene mit farsheydene temes.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a50" TIME_SLOT_REF1="ts80" TIME_SLOT_REF2="ts82">
				<ANNOTATION_VALUE>nor ikh volt voln eh oder tsum tog peysekh oder tsum tog purim.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a53" TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
				<ANNOTATION_VALUE>mayn baym bruder-keyver iz do aza min. eh di eh di lid hot ge- di dikht hot men gedrukt in a yidisher tsaytung in Ostralyen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a54" TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
				<ANNOTATION_VALUE>der redaktor hot geshribn tsu mir ikh zol vayter shraybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a55" TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
				<ANNOTATION_VALUE>ot ken ikh ir iberleyenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a56" TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
				<ANNOTATION_VALUE>ikh hob dir oyf krumike vegn getrofn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a58" TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
				<ANNOTATION_VALUE>un hob in dayn lebn a vogler derzen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a59" TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
				<ANNOTATION_VALUE>es zaynen di teg dayne blinde farlofn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a60" TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
				<ANNOTATION_VALUE>in nakhtikn blondzhen bagleyt dir dayn pen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a61" TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
				<ANNOTATION_VALUE>ver binstu, farlozener, eynzamer vogler?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a63" TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
				<ANNOTATION_VALUE>mit zorgfule kneytshn in shtern gefarbt,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a64" TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
				<ANNOTATION_VALUE>tsk tsi brent in dayn hartsn der vint fun a odler,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a65" TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
				<ANNOTATION_VALUE>tsi zingt in dayn sk- in tsi zingt shoyn in skeynes dayn shotn geshtalt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a66" TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
				<ANNOTATION_VALUE>vos zukhstu oyf vegn oyf blotike roye,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a67" TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
				<ANNOTATION_VALUE>vos shlingstu UNK dorshtik a yetvider roysh?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a68" TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
				<ANNOTATION_VALUE>dertseyln di himlen farveytikte, groye, az eybik vet ful zayn mit trern dayn kos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a69" TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
				<ANNOTATION_VALUE>tsi glet dir der vint dayne hor azoy tsartik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a70" TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
				<ANNOTATION_VALUE>tsi hot dir farkisheft der foygl-gezang?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a72" TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
				<ANNOTATION_VALUE>tsi vunken dir frukhtn shoyn tsaytike fartik,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a73" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
				<ANNOTATION_VALUE>vos nem zey nit raysn, es tut zey nor bang.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a74" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
				<ANNOTATION_VALUE>iz ver binstu dokh, du farneplter vogler?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a77" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
				<ANNOTATION_VALUE>tsi kon ikh dergreykhn dayn umklorn &lt;gnor&gt;,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a78" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
				<ANNOTATION_VALUE>du fregst un du blondzhest.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a79" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
				<ANNOTATION_VALUE>farvoglerster vogler, far zikh un far yenem an entfer shoyn do.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a81" TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
				<ANNOTATION_VALUE>dos alts.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a82" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts131">
				<ANNOTATION_VALUE>ikh hob do farsheydene lider, ober s'do s'do viln ikh hob keyn tsayt un der viln tsu dertseyln tsu tsu leyenen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a83" TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
				<ANNOTATION_VALUE>nu, mayn eyntsike farlang iz,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a84" TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
				<ANNOTATION_VALUE>ikh ze in di kum- in di kumendike doyres ze ikh mayne kinder, mayn zun un mayn tokhter. ikh hob a zun,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a85" TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts139">
				<ANNOTATION_VALUE>im iz shoyn bald fertsik yor. di tokhter mayne iz</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a87" TIME_SLOT_REF1="ts138" TIME_SLOT_REF2="ts140">
				<ANNOTATION_VALUE>zibn un tsvontsik shoyn, vert oykh in gikhn zibn un tsvontsik yor. zey hobn nit gevust zey hobn zey veysn nit zey hobn zey veysn nit vegn di g- vegn di laydn fun zayne fun zeyere fun zeyer eltern, zey veysn nit di laydn fun zeyer folk.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a88" TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts143">
				<ANNOTATION_VALUE>ikh vel zey veltn vintshn, nit nor mayne kinder nor ale kinder, fun undzer folk un fun ale felker,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a91" TIME_SLOT_REF1="ts142" TIME_SLOT_REF2="ts144">
				<ANNOTATION_VALUE>zey zoln oysmaydn di ale di ale laydn, di ale tsores vos mir hobn gehat in undzer tsayt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		</TIER>
