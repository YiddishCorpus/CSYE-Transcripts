		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1009" TIME_SLOT_REF1="ts911" TIME_SLOT_REF2="ts913">
				<ANNOTATION_VALUE>mentsh, hot er gelebt nit vayt fun undz, mir hobn zikh geshpilt, un er hot zikh &lt;mit mir&gt; UNK un ikh hob im gegebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
