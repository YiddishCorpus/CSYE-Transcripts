		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a165" TIME_SLOT_REF1="ts489" TIME_SLOT_REF2="ts490">
				<ANNOTATION_VALUE>bay eynem a inzhenyer vos hot gearbet oyf di ayznban,</ANNOTATION_VALUE>
