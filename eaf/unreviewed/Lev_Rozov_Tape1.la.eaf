			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a152" TIME_SLOT_REF1="ts455" TIME_SLOT_REF2="ts456">
				<ANNOTATION_VALUE>nor s'iz ge- nit geven... ikh'l aykh zogn, ikh hob gelitn ammerstn, mer fun ale. ikh bin geven der elterer.</ANNOTATION_VALUE>
