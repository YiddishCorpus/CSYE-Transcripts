				<ANNOTATION_VALUE>er iz avek aheym veynendik, un gekumen de&lt;m&gt; foter. ikh hob zikh bahaltn, iz gekumen de&lt;m&gt; foter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a297" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>&lt;zogt er, uh, nu&gt;... oto dos treft azetike zakhn. ikh'l aykh zogn, mir konen nit reydn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
