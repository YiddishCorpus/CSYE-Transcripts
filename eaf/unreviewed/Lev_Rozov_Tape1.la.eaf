		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a146" TIME_SLOT_REF1="ts438" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>&lt;a-&gt; draysik. in Poyln hob ikh gedint, &lt;ikh hob gedo-&gt; in Poyln hob ikh gedint azoy:</ANNOTATION_VALUE>
