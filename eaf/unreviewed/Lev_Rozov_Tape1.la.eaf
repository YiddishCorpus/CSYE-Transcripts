			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts1010" TIME_SLOT_REF2="ts1014">
				<ANNOTATION_VALUE>mir hobn gevust az, &lt;eh, di p-&gt; az Daytshland hot farnumen a teyl Poyln,</ANNOTATION_VALUE>
