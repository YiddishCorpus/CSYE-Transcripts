			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a288" TIME_SLOT_REF1="ts878" TIME_SLOT_REF2="ts880">
				<ANNOTATION_VALUE>vayl ikh, ikh bin geven gehodevet, ikh bin geven gehodevet,</ANNOTATION_VALUE>
