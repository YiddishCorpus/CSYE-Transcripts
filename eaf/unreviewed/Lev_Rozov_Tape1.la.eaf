		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a137" TIME_SLOT_REF1="ts411" TIME_SLOT_REF2="ts412">
				<ANNOTATION_VALUE>un ikh bin avekgegangen arbetn. UNK eyner iz geven bay undz a KHUDOZHNIK;</ANNOTATION_VALUE>
