		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1002" TIME_SLOT_REF1="ts881" TIME_SLOT_REF2="ts882">
				<ANNOTATION_VALUE>ale hobn mir gerufn, "LEYB&lt;A&gt;, IDI SYUDA!" &lt;der, a-&gt; az ikh bin geven a khaver tsevishn,</ANNOTATION_VALUE>
