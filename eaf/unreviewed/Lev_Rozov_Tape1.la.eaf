			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a133" TIME_SLOT_REF1="ts405" TIME_SLOT_REF2="ts406">
				<ANNOTATION_VALUE>iz hob ikh gelernt zikh dortn. gelernt hob ikh dortn tsvey yor, nit geendikt.</ANNOTATION_VALUE>
