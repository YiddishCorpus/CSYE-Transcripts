				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a243" TIME_SLOT_REF1="ts721" TIME_SLOT_REF2="ts722">
				<ANNOTATION_VALUE>mir hot men nit durkhgelozt; zey hobn gehaltn az ikh bin a linker mentsh, &lt;iz, uh&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a970" TIME_SLOT_REF1="ts723" TIME_SLOT_REF2="ts724">
				<ANNOTATION_VALUE>ikh hob nit gepast far zey,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a971" TIME_SLOT_REF1="ts725" TIME_SLOT_REF2="ts726">
				<ANNOTATION_VALUE>vayle ikh hob shtendik geven,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a972" TIME_SLOT_REF1="ts727" TIME_SLOT_REF2="ts728">
				<ANNOTATION_VALUE>mayn lebn un di khaveyrim un alts, ikh'l aykh zogn, tsvishn arbeter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a244" TIME_SLOT_REF1="ts729" TIME_SLOT_REF2="ts730">
				<ANNOTATION_VALUE>ikh bin gegangen mit a veg in gantsn an andere;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a973" TIME_SLOT_REF1="ts731" TIME_SLOT_REF2="ts732">
				<ANNOTATION_VALUE>ikh hob nit gekrokhn ergets, ikh hob gegangen tsevishn di arbeter.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a974" TIME_SLOT_REF1="ts733" TIME_SLOT_REF2="ts734">
				<ANNOTATION_VALUE>&lt;zikh ts&gt;&lt;UNK&gt;, a mol voltn mir leyenen rusishe bikher, geven Gorki,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a975" TIME_SLOT_REF1="ts735" TIME_SLOT_REF2="ts736">
				<ANNOTATION_VALUE>di linke bikher vayzn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a976" TIME_SLOT_REF1="ts737" TIME_SLOT_REF2="ts739">
				<ANNOTATION_VALUE>volt zikh undz oysdukhtn az Rusland</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a245" TIME_SLOT_REF1="ts738" TIME_SLOT_REF2="ts741">
				<ANNOTATION_VALUE>iz beser. ir farshteyt?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a246" TIME_SLOT_REF1="ts742" TIME_SLOT_REF2="ts744">
				<ANNOTATION_VALUE>uh, ikh hob a mol oykh getrakht az Rusland iz, iz, az s'iz do vos tsu arbetn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a977" TIME_SLOT_REF1="ts745" TIME_SLOT_REF2="ts747">
				<ANNOTATION_VALUE>mentshn on arbet,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a247" TIME_SLOT_REF1="ts746" TIME_SLOT_REF2="ts748">
				<ANNOTATION_VALUE>yugntlekhe umgeyn fray un frank,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a248" TIME_SLOT_REF1="ts749" TIME_SLOT_REF2="ts750">
				<ANNOTATION_VALUE>kukn... a mol hob ikh gearbet dortn in a shul, hob ikh gehat tsu makhn ongenumen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a978" TIME_SLOT_REF1="ts751" TIME_SLOT_REF2="ts753">
				<ANNOTATION_VALUE>ikh fleg geyn oyf di TARGes fun di melukhishe.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a249" TIME_SLOT_REF1="ts752" TIME_SLOT_REF2="ts754">
				<ANNOTATION_VALUE>iz oyf TARGes volt geyn der vos volt gelt aynleygn. ikh hob gehat a &lt;b-&gt;</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a979" TIME_SLOT_REF1="ts755" TIME_SLOT_REF2="ts756">
				<ANNOTATION_VALUE>kh'hob &lt;al-&gt; zayendik a y- nokh a, a yunger mentsh,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a980" TIME_SLOT_REF1="ts757" TIME_SLOT_REF2="ts758">
				<ANNOTATION_VALUE>hob ikh gehat a P.K.O. bikhl, volt ikh im aynleygn dem P.K.O. bikhl un ikh volt geyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a981" TIME_SLOT_REF1="ts759" TIME_SLOT_REF2="ts760">
				<ANNOTATION_VALUE>un TARGes volt ikh nemen. far vos?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a982" TIME_SLOT_REF1="ts761" TIME_SLOT_REF2="ts762">
				<ANNOTATION_VALUE>kh'volt zikh bakonen mitn sekretar, gebn im etlekhe zlot, &lt;eh&gt;...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a983" TIME_SLOT_REF1="ts763" TIME_SLOT_REF2="ts764">
				<ANNOTATION_VALUE>es iz dokh, uh, do azetike zakhn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a984" TIME_SLOT_REF1="ts765" TIME_SLOT_REF2="ts767">
				<ANNOTATION_VALUE>volt er mir makhn, "shrayb azoy fil." dos iz dos.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a250" TIME_SLOT_REF1="ts766" TIME_SLOT_REF2="ts768">
				<ANNOTATION_VALUE>&lt;volt ikh&gt; UNK. hob ikh gearbet, voltn ale khevre kumen zitsn, kukn vi ikh arbet.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a985" TIME_SLOT_REF1="ts769" TIME_SLOT_REF2="ts771">
				<ANNOTATION_VALUE>ir farshteyt? s'iz nit geven keyn groyser lebn in Dokshits</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a251" TIME_SLOT_REF1="ts770" TIME_SLOT_REF2="ts772">
				<ANNOTATION_VALUE>kegn, far di yugntlekhe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a986" TIME_SLOT_REF1="ts773" TIME_SLOT_REF2="ts774">
				<ANNOTATION_VALUE>afile &lt;Shomer Hatsair&gt;. yederer iz gezesn oyf di tate-mame's pleytse.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a252" TIME_SLOT_REF1="ts775" TIME_SLOT_REF2="ts776">
				<ANNOTATION_VALUE>zaynendik afile iber tsvantsik yor,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a253" TIME_SLOT_REF1="ts777" TIME_SLOT_REF2="ts778">
				<ANNOTATION_VALUE>iz men gezesn oyf di tate-mame's pleytse.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a254" TIME_SLOT_REF1="ts779" TIME_SLOT_REF2="ts782">
				<ANNOTATION_VALUE>m'hot gelebt tsuzamen...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a255" TIME_SLOT_REF1="ts783" TIME_SLOT_REF2="ts784">
				<ANNOTATION_VALUE>s'iz nit geven azoy... haynt</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a257" TIME_SLOT_REF1="ts785" TIME_SLOT_REF2="ts786">
				<ANNOTATION_VALUE>shtelt zikh mir, ot ikh in mayn elter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a987" TIME_SLOT_REF1="ts787" TIME_SLOT_REF2="ts788">
				<ANNOTATION_VALUE>shtelt zikh mir for a lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a258" TIME_SLOT_REF1="ts789" TIME_SLOT_REF2="ts790">
				<ANNOTATION_VALUE>vi azoy hot men gekont a mol lebn?</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a259" TIME_SLOT_REF1="ts791" TIME_SLOT_REF2="ts792">
				<ANNOTATION_VALUE>az m'hot gehat zeks kinder,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a989" TIME_SLOT_REF1="ts793" TIME_SLOT_REF2="ts794">
				<ANNOTATION_VALUE>mit eyn shtub, vos iz geshtanen fun dray tsimern,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a260" TIME_SLOT_REF1="ts795" TIME_SLOT_REF2="ts796">
				<ANNOTATION_VALUE>di kikh, bakn broyt aleyn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a261" TIME_SLOT_REF1="ts797" TIME_SLOT_REF2="ts798">
				<ANNOTATION_VALUE>vashn di vesh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a262" TIME_SLOT_REF1="ts799" TIME_SLOT_REF2="ts800">
				<ANNOTATION_VALUE>ir veyst vi? ot ot azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a263" TIME_SLOT_REF1="ts801" TIME_SLOT_REF2="ts802">
				<ANNOTATION_VALUE>hodeven zeks kinder, gebn alemen a hemd onton. me darf dokh, m'darf dokh lebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a990" TIME_SLOT_REF1="ts803" TIME_SLOT_REF2="ts804">
				<ANNOTATION_VALUE>un a froy aleyn! di froy hot gearb-...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a264" TIME_SLOT_REF1="ts805" TIME_SLOT_REF2="ts806">
				<ANNOTATION_VALUE>vi di froy hot gearbet iz a mol,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a991" TIME_SLOT_REF1="ts807" TIME_SLOT_REF2="ts808">
				<ANNOTATION_VALUE>iz haynt iz dos, kon men dos nit bashraybn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a265" TIME_SLOT_REF1="ts809" TIME_SLOT_REF2="ts810">
				<ANNOTATION_VALUE>me kon dos nit bashraybn!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a266" TIME_SLOT_REF1="ts811" TIME_SLOT_REF2="ts812">
				<ANNOTATION_VALUE>dos, oto dos iz geven in ale kleynshtetlekh...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a267" TIME_SLOT_REF1="ts813" TIME_SLOT_REF2="ts814">
				<ANNOTATION_VALUE>in di bikher leyent men dokh... ale kleynshtetlekh di zelbe zakh!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a268" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>ver es hot gekont, dem tsholnt volt araynshteln</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a269" TIME_SLOT_REF1="ts817" TIME_SLOT_REF2="ts818">
				<ANNOTATION_VALUE>oyf bay nakht, farmakhn dem oyvn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a992" TIME_SLOT_REF1="ts819" TIME_SLOT_REF2="ts821">
				<ANNOTATION_VALUE>UNK aroysnemen oyf morgn dem esn. ir farshteyt? dos iz nit geven...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a270" TIME_SLOT_REF1="ts820" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>KHASHMAL iz bay undz ersht gevorn in finf un draysiktn yor.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a271" TIME_SLOT_REF1="ts823" TIME_SLOT_REF2="ts824">
				<ANNOTATION_VALUE>mir hobn geve&lt;UNK&gt;t oyf a lomp mit, uh, ne- mit neft,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a272" TIME_SLOT_REF1="ts825" TIME_SLOT_REF2="ts826">
				<ANNOTATION_VALUE>aroyfdreyen a lomp mit neft.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a273" TIME_SLOT_REF1="ts827" TIME_SLOT_REF2="ts828">
				<ANNOTATION_VALUE>heytsn mit holts, tseklapn oyf shtiklekh, darfn unterheytsn di oyvn...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a993" TIME_SLOT_REF1="ts829" TIME_SLOT_REF2="ts830">
				<ANNOTATION_VALUE>s'iz nit geven alts vi &lt;its-&gt; vi azoy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a994" TIME_SLOT_REF1="ts831" TIME_SLOT_REF2="ts833">
				<ANNOTATION_VALUE>m'hot gedarft hobn an ort oyf haltn holts,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a274" TIME_SLOT_REF1="ts832" TIME_SLOT_REF2="ts834">
				<ANNOTATION_VALUE>an ort oyf haltn hey.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a275" TIME_SLOT_REF1="ts835" TIME_SLOT_REF2="ts836">
				<ANNOTATION_VALUE>kormen di beheymes, darf men kokhn tep un &lt;zey&gt; gebn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a995" TIME_SLOT_REF1="ts837" TIME_SLOT_REF2="ts838">
				<ANNOTATION_VALUE>un dem top, ir, oybe ir veyst, s'iz geven aza vilke vos me volt araynrukn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a996" TIME_SLOT_REF1="ts839" TIME_SLOT_REF2="ts840">
				<ANNOTATION_VALUE>aroysshlepn dem top, &lt;hot men&gt; gedarft hobn &lt;koyekh&gt;.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a276" TIME_SLOT_REF1="ts841" TIME_SLOT_REF2="ts842">
				<ANNOTATION_VALUE>dos iz di, dos iz geven di froy.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a277" TIME_SLOT_REF1="ts845" TIME_SLOT_REF2="ts847">
				<ANNOTATION_VALUE>vegn dem veln mir nokh oykh kumen, az mir veln kumen... UNK...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a279" TIME_SLOT_REF1="ts848" TIME_SLOT_REF2="ts852">
				<ANNOTATION_VALUE>a- ales kind? ikh'l aykh zogn: al- ikh hob zikh gehodevet tsevishn kristn, ikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a281" TIME_SLOT_REF1="ts853" TIME_SLOT_REF2="ts854">
				<ANNOTATION_VALUE>far vos? vayle mir hobn gelebt, iz geven antkegn undz a dokter,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a282" TIME_SLOT_REF1="ts855" TIME_SLOT_REF2="ts856">
				<ANNOTATION_VALUE>un dortn iz geven eyner an ag- eyner iz geven a, an agronom,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a999" TIME_SLOT_REF1="ts857" TIME_SLOT_REF2="ts858">
				<ANNOTATION_VALUE>der tsveyter iz geven a polyak, a rus.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1000" TIME_SLOT_REF1="ts859" TIME_SLOT_REF2="ts861">
				<ANNOTATION_VALUE>mir zaynen geven a gemisht, dortn iz dokh geven Vay- dos iz geven Vaysrusland,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a283" TIME_SLOT_REF1="ts860" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>nor polyakn hobn oykh gelebt dortn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a284" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts865">
				<ANNOTATION_VALUE>&lt;zey hobn tsvishn zikh...&gt; keyn gr- ikh hob &lt;in&gt; kind zayendik keyn antisemitizm nit gefilt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a285" TIME_SLOT_REF1="ts866" TIME_SLOT_REF2="ts868">
				<ANNOTATION_VALUE>ven hob ikh gefilt dem antisemitizm? az m'iz greser gevorn, m'iz gekumen in Vilne,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a286" TIME_SLOT_REF1="ts869" TIME_SLOT_REF2="ts871">
				<ANNOTATION_VALUE>un dortn hobn mir shoyn gefilt dem antisemitizm.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a287" TIME_SLOT_REF1="ts872" TIME_SLOT_REF2="ts873">
				<ANNOTATION_VALUE>in di shtetlekh, in Dokshits,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1001" TIME_SLOT_REF1="ts874" TIME_SLOT_REF2="ts876">
				<ANNOTATION_VALUE>in Dokshits iz nit geven keyn, uh, keyn... ikh'l aykh zogn, ikh hob dos nit gefilt,</ANNOTATION_VALUE>
