			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1022" TIME_SLOT_REF1="ts1007" TIME_SLOT_REF2="ts1008">
				<ANNOTATION_VALUE>un mir hobn nit gezen keyn poylishe armey.</ANNOTATION_VALUE>
