			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1063" TIME_SLOT_REF1="ts1151" TIME_SLOT_REF2="ts1152">
				<ANNOTATION_VALUE>s'iz geven UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
