			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1056" TIME_SLOT_REF1="ts1135" TIME_SLOT_REF2="ts1136">
				<ANNOTATION_VALUE>es iz geven a goy vos hot gearbet &lt;oyf&gt; di UNDERGROUND</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1057" TIME_SLOT_REF1="ts1137" TIME_SLOT_REF2="ts1138">
				<ANNOTATION_VALUE>UNK geven a bakonter goy. mayn shvester iz shoyn geven in dem lager, in SKARZYSKO</ANNOTATION_VALUE>
