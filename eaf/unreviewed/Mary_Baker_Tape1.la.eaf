		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1055" TIME_SLOT_REF1="ts1133" TIME_SLOT_REF2="ts1134">
				<ANNOTATION_VALUE>un dort di ershte por tog zenen zey geshlofn, hot men gedungen epes in a STORE, a nare hot men zikh gemakht, UNK gelign oyf di nare.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
