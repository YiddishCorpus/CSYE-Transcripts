			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1053" TIME_SLOT_REF1="ts1129" TIME_SLOT_REF2="ts1130">
				<ANNOTATION_VALUE>mayn foter hot gehat dort epes a feter tsi a zeyde tsi a bobe, veys nisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1054" TIME_SLOT_REF1="ts1131" TIME_SLOT_REF2="ts1132">
				<ANNOTATION_VALUE>dort zogt er iz shtil, efsher vet men nor blaybn lebn</ANNOTATION_VALUE>
