				<ANNOTATION_VALUE>hot er undz aroysgenumen fun geto</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1051" TIME_SLOT_REF1="ts1125" TIME_SLOT_REF2="ts1126">
