			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1039" TIME_SLOT_REF1="ts1093" TIME_SLOT_REF2="ts1094">
				<ANNOTATION_VALUE>UNK m'hot dokh aroysgetribn fun Gritse ale, ale yidn.</ANNOTATION_VALUE>
