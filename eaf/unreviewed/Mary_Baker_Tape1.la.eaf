		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1060" TIME_SLOT_REF1="ts1143" TIME_SLOT_REF2="ts1144">
				<ANNOTATION_VALUE>un zi hot aroysgeshikt a shtikl broyt, UNK avekgenumen fun moyl, ikh zol hobn a shtikl broyt</ANNOTATION_VALUE>
