		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1058" TIME_SLOT_REF1="ts1139" TIME_SLOT_REF2="ts1140">
				<ANNOTATION_VALUE>hot er gebrengt ale mol fun di mamen</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a1059" TIME_SLOT_REF1="ts1141" TIME_SLOT_REF2="ts1142">
				<ANNOTATION_VALUE>a fatsheyle, ikh zol tsudekn, nokh UNK. &lt;dos iz mayn muter&gt;.</ANNOTATION_VALUE>
