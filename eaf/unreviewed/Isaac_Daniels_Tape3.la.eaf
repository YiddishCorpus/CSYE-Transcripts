		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a330" TIME_SLOT_REF1="ts393" TIME_SLOT_REF2="ts394">
				<ANNOTATION_VALUE>un ikh un der yingerer bruder, tsk azoy vi s'geven shtil, zenen ongekumen fun Dantsik</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a334" TIME_SLOT_REF1="ts395" TIME_SLOT_REF2="ts397">
				<ANNOTATION_VALUE>barshtn, du veyst vos barshtn zenen? nisht keyn shif, s'iz azoy vi a shif, OH NO,</ANNOTATION_VALUE>
