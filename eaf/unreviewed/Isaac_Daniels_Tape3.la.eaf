			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a385" TIME_SLOT_REF1="ts459" TIME_SLOT_REF2="ts460">
				<ANNOTATION_VALUE>un tsu fus, m'iz gegangen. iz men opgegangen tsvey un fuftsik kilometer, mayl, a vayt veg,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a389" TIME_SLOT_REF1="ts461" TIME_SLOT_REF2="ts462">
				<ANNOTATION_VALUE>m'iz ongekumen far nakht dortn ahin,</ANNOTATION_VALUE>
