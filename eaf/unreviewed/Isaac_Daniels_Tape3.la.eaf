		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a369" TIME_SLOT_REF1="ts438" TIME_SLOT_REF2="ts440">
				<ANNOTATION_VALUE>un di daytshn yogn zey, m'hakt azoy bay di kep iber ale, az s'groylekh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a371" TIME_SLOT_REF1="ts441" TIME_SLOT_REF2="ts442">
				<ANNOTATION_VALUE>zog ikh tsu mayn bruder, spn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
