		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a372" TIME_SLOT_REF1="ts443" TIME_SLOT_REF2="ts444">
				<ANNOTATION_VALUE>ikh ken dos nisht zen, ikh ken dos nisht tsukukn, ikh muz avek fun danen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a374" TIME_SLOT_REF1="ts445" TIME_SLOT_REF2="ts446">
				<ANNOTATION_VALUE>di &lt;yingern&gt; bruder mayn muter vil im nisht lozn im kumen. im vil zi hobn mit zikh.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a376" TIME_SLOT_REF1="ts447" TIME_SLOT_REF2="ts448">
				<ANNOTATION_VALUE>der tsveyter bruder zi zogt az zey forn s'vet forn</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a377" TIME_SLOT_REF1="ts449" TIME_SLOT_REF2="ts450">
				<ANNOTATION_VALUE>tsum tatn, tsu di eltern dortn bay der ban vu zey voynen.</ANNOTATION_VALUE>
