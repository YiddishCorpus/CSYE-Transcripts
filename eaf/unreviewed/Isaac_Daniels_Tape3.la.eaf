		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a390" TIME_SLOT_REF1="ts463" TIME_SLOT_REF2="ts464">
				<ANNOTATION_VALUE>iz men arayn tsu a yidisher familye, undz hobn moyre gehat vos an emes,</ANNOTATION_VALUE>
