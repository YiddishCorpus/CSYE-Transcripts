		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a578" TIME_SLOT_REF1="ts691" TIME_SLOT_REF2="ts692">
				<ANNOTATION_VALUE>ikh bin ongekumen dortn ahin, iz gevezn di END OF september.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
