		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a329" TIME_SLOT_REF1="ts391" TIME_SLOT_REF2="ts392">
				<ANNOTATION_VALUE>dos kind iz gezunt gevorn.</ANNOTATION_VALUE>
