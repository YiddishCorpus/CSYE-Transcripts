			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a378" TIME_SLOT_REF1="ts451" TIME_SLOT_REF2="ts452">
				<ANNOTATION_VALUE>ikh mit nokh dray khaveyrim bashlisn mir dos iz frayt- s'shabes far tog,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
