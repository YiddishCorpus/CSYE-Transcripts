			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a336" TIME_SLOT_REF1="ts396" TIME_SLOT_REF2="ts398">
				<ANNOTATION_VALUE>nor di groyse groyse eh groyse BOATS, mit rayz.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a338" TIME_SLOT_REF1="ts399" TIME_SLOT_REF2="ts400">
				<ANNOTATION_VALUE>nu s'hot nisht gekent tsugeyn tsum breg, shteyt es a bisl avek fun breg.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a340" TIME_SLOT_REF1="ts401" TIME_SLOT_REF2="ts402">
				<ANNOTATION_VALUE>hot men geleygt breter, do a bret biz arayn INSIDE.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
