			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a357" TIME_SLOT_REF1="ts424" TIME_SLOT_REF2="ts426">
				<ANNOTATION_VALUE>m'iz ahey- mit a NO, poylisher zelner.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a358" TIME_SLOT_REF1="ts427" TIME_SLOT_REF2="ts428">
				<ANNOTATION_VALUE>un m'aheymgekumen mit gornisht.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a360" TIME_SLOT_REF1="ts429" TIME_SLOT_REF2="ts430">
				<ANNOTATION_VALUE>s'geven a fraytik un di yidn zenen gekumen davenen dortn in shtibl arayn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a362" TIME_SLOT_REF1="ts431" TIME_SLOT_REF2="ts432">
				<ANNOTATION_VALUE>un s'hot shoyn ongehoybn ontsukumen daytshn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
