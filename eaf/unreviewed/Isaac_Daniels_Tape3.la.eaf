		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a581" TIME_SLOT_REF1="ts693" TIME_SLOT_REF2="ts694">
				<ANNOTATION_VALUE>oder nayn un tsvontsikstn akht un tsvontsik zenen bin ikh ongekumen dortn ahin,</ANNOTATION_VALUE>
