		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a325" TIME_SLOT_REF1="ts381" TIME_SLOT_REF2="ts382">
				<ANNOTATION_VALUE>s'hot ir ongehoybn zi hot gekrign a disen- disenterye.</ANNOTATION_VALUE>
