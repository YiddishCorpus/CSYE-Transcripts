		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a342" TIME_SLOT_REF1="ts403" TIME_SLOT_REF2="ts404">
				<ANNOTATION_VALUE>keyn yidn hobn di goyim nisht arayngelozt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
