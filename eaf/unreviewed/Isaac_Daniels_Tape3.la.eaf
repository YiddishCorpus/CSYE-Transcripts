			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a326" TIME_SLOT_REF1="ts383" TIME_SLOT_REF2="ts385">
				<ANNOTATION_VALUE>ANYWAY koym vos zi hot zikh dershlept dortn ahin mitn kind.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
