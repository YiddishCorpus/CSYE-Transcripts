		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a367" TIME_SLOT_REF1="ts437" TIME_SLOT_REF2="ts439">
				<ANNOTATION_VALUE>un m'shlogt un m'harget, un di yidn loyfn aroys fun dortn, di hent in der heykh, reboyne-shel-oylem!</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
