		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a328" TIME_SLOT_REF1="ts389" TIME_SLOT_REF2="ts390">
				<ANNOTATION_VALUE>koym zey hobn zikh dershlept zikh ahin, vayl m'hot der dokter mit &lt;mayses&gt;.</ANNOTATION_VALUE>
