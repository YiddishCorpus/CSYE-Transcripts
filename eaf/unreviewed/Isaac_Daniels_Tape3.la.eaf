			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a383" TIME_SLOT_REF1="ts457" TIME_SLOT_REF2="ts458">
				<ANNOTATION_VALUE>un s'shabes far tog bin ikh aroys fun Varshe,</ANNOTATION_VALUE>
