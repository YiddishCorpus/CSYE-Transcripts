		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a327" TIME_SLOT_REF1="ts386" TIME_SLOT_REF2="ts388">
				<ANNOTATION_VALUE>oyf a fur.</ANNOTATION_VALUE>
