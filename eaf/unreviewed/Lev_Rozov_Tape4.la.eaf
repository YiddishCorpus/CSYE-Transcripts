		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a816" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>DANA, velkhe iz geborn gevorn in Vilne,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
