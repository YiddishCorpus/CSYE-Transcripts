		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a814" TIME_SLOT_REF1="ts913" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>dos iz mayn eltere tokhter D- DANA,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
