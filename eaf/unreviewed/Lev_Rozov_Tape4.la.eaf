		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a713" TIME_SLOT_REF1="ts631" TIME_SLOT_REF2="ts632">
				<ANNOTATION_VALUE>kh'hob gezen. i-</ANNOTATION_VALUE>
