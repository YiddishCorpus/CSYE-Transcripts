		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a714" TIME_SLOT_REF1="ts633" TIME_SLOT_REF2="ts634">
				<ANNOTATION_VALUE>ikh bin a mentsh aza vos ikh kon nit geyn vos ikh ze nit.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a715" TIME_SLOT_REF1="ts635" TIME_SLOT_REF2="ts636">
				<ANNOTATION_VALUE>kh'hob gezen.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a716" TIME_SLOT_REF1="ts637" TIME_SLOT_REF2="ts638">
				<ANNOTATION_VALUE>ikh gleyb in got</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a717" TIME_SLOT_REF1="ts639" TIME_SLOT_REF2="ts640">
				<ANNOTATION_VALUE>un ikh bet got un er helft mir.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a719" TIME_SLOT_REF1="ts641" TIME_SLOT_REF2="ts642">
				<ANNOTATION_VALUE>un ikh darf keynem's</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a720" TIME_SLOT_REF1="ts643" TIME_SLOT_REF2="ts644">
				<ANNOTATION_VALUE>protektsye tsu im, tsu got nit hobn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a721" TIME_SLOT_REF1="ts645" TIME_SLOT_REF2="ts646">
				<ANNOTATION_VALUE>vayle got iz undzer alemen's.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a722" TIME_SLOT_REF1="ts647" TIME_SLOT_REF2="ts648">
				<ANNOTATION_VALUE>ir farshteyt? got iz undzer alemen's.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a953" TIME_SLOT_REF1="ts649" TIME_SLOT_REF2="ts651">
				<ANNOTATION_VALUE>yeder kon betn got, s'shteyt in der toyre,</ANNOTATION_VALUE>
