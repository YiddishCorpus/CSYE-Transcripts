			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a994" TIME_SLOT_REF1="ts917" TIME_SLOT_REF2="ts918">
				<ANNOTATION_VALUE>gebrakht aher tsu elf yor.</ANNOTATION_VALUE>
