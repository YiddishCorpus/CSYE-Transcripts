		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a817" TIME_SLOT_REF1="ts919" TIME_SLOT_REF2="ts920">
				<ANNOTATION_VALUE>un dos iz mayn klenere tokhter ORIT, vos iz geborn gevorn do in tsvey vokhn arum vi mir zaynen gekumen in land.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a818" TIME_SLOT_REF1="ts921" TIME_SLOT_REF2="ts922">
				<ANNOTATION_VALUE>nu, un ikh hob zey a bisl</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a995" TIME_SLOT_REF1="ts923" TIME_SLOT_REF2="ts924">
				<ANNOTATION_VALUE>ayngeordnt, vifl m- ikh hob gehat meglekhkeyt,</ANNOTATION_VALUE>
