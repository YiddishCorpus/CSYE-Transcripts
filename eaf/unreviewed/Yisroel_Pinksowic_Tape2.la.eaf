		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a186" TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
				<ANNOTATION_VALUE>ober er hot zikh nisht geshtelt oyfn MASAIT, iz er tsurikgekumen, iz er gekumen er hot mir tsurik gezogt az er iz nisht avekgeforn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
