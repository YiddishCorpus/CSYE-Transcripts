			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a183" TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
				<ANNOTATION_VALUE>der numer iz geven oyfn hemd un m'hot opgefotografirt dos ponem, eyn mol in hitl un eyn onem hitl,</ANNOTATION_VALUE>
