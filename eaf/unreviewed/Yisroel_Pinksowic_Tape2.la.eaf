		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a184" TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
				<ANNOTATION_VALUE>az hot er zikh fun mir opgezegnt az m- im firt men avek.</ANNOTATION_VALUE>
