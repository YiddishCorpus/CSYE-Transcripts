			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a188" TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
				<ANNOTATION_VALUE>hob ikh im gezogt az mikh hot men shoyn fotografirt, dem andern tog hot men undz gefirt avek, iz er gekumen er hot mikh baleyt azoy fun der vaytns,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a189" TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
