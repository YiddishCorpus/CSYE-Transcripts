		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a536" TIME_SLOT_REF1="ts912" TIME_SLOT_REF2="ts914">
				<ANNOTATION_VALUE>vos zey hobn dertseylt? zey hobn dertseylt az s'iz shlekht un zey vern, un zey, un di, me shlogt un me harget. s'iz dokh bald in akht un draysiker yor geven a gev- gantsn,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
