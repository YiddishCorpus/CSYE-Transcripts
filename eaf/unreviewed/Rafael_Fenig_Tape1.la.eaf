		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a527" TIME_SLOT_REF1="ts897" TIME_SLOT_REF2="ts898">
				<ANNOTATION_VALUE>UNK zenen dos, un yetst hobn zey dokh gemuzt tsurikgeyn.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
