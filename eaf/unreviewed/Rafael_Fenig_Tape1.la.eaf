		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a454" TIME_SLOT_REF1="ts736" TIME_SLOT_REF2="ts738">
				<ANNOTATION_VALUE>biz kh'bin &lt;a&gt;, oyfgeva-... oyfgevaksn bin ikh keyn mol nisht; ir zet vi UNK ir kent mikh zen,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
