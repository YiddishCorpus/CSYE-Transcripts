		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a456" TIME_SLOT_REF1="ts739" TIME_SLOT_REF2="ts740">
				<ANNOTATION_VALUE>eh, nor ikh bin hekher &lt;gev- g-&gt; greber gevorn, hekher gevorn, un azoy bin ikh &lt;gev- ge-&gt; shoyn gelernt in besmedre- uhm, in di kloyz.</ANNOTATION_VALUE>
