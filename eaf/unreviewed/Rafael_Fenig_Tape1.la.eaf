		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a489" TIME_SLOT_REF1="ts815" TIME_SLOT_REF2="ts816">
				<ANNOTATION_VALUE>tomer hot er get- epes ge- dos, iz er geven bahaltn.</ANNOTATION_VALUE>
