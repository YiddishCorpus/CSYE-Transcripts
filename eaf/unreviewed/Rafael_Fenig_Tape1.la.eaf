		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a491" TIME_SLOT_REF1="ts821" TIME_SLOT_REF2="ts822">
				<ANNOTATION_VALUE>s'iz keyn mol nisht geven keyn fraye tsayt. m'hot eybik, oder UNK az m'iz in &lt;d-&gt; a moshl, UNK</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
