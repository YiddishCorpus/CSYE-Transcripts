		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a523" TIME_SLOT_REF1="ts893" TIME_SLOT_REF2="ts894">
				<ANNOTATION_VALUE>ni- iz m- eh, a bisl, s'iz nisht geven keyn groyse, dos... iz geven afile az di vos zenen a mol gevezn in D- in,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
