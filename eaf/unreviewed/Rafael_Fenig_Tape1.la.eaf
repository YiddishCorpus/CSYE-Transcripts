		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a512" TIME_SLOT_REF1="ts860" TIME_SLOT_REF2="ts862">
				<ANNOTATION_VALUE>UNK, s'iz geven a, eh, a sakh vos zey hobn ge- geshrign, "Ż-</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a513" TIME_SLOT_REF1="ts863" TIME_SLOT_REF2="ts864">
