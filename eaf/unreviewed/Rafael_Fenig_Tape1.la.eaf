		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a537" TIME_SLOT_REF1="ts915" TIME_SLOT_REF2="ts916">
				<ANNOTATION_VALUE>gantse UNK &lt;u&gt;n l- &lt;u&gt;n lagers mit, uh, alem, aroysgeyogt.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
