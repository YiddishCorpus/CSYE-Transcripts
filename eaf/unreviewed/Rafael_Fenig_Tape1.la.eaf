		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a528" TIME_SLOT_REF1="ts899" TIME_SLOT_REF2="ts900">
				<ANNOTATION_VALUE>zey hobn dokh nisht gegat k- z-... a, &lt;vos er iz&gt; geven a daytsher,</ANNOTATION_VALUE>
