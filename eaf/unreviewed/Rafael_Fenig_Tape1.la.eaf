			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a530" TIME_SLOT_REF1="ts903" TIME_SLOT_REF2="ts904">
				<ANNOTATION_VALUE>UNK heysn UNK er hot dokh oykhet, er hot dokh aroysgeyogt, az yidn, m'hot dokh aroysgeyogt yidn fun Daytshnland.</ANNOTATION_VALUE>
