		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a534" TIME_SLOT_REF1="ts908" TIME_SLOT_REF2="ts911">
				<ANNOTATION_VALUE>SURE. zikher.</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
