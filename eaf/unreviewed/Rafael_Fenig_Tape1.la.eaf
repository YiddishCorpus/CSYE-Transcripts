		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a521" TIME_SLOT_REF1="ts886" TIME_SLOT_REF2="ts889">
				<ANNOTATION_VALUE>s'zenen dokh gekumen fun Daytshnland, uh, a sakh tsurik tsu, tsu P- Rayshe un tsu, un tsu andere shtet, tsu Kroke, tsu...</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
			</ANNOTATION>
		<ANNOTATION>
			<ALIGNABLE_ANNOTATION ANNOTATION_ID="a522" TIME_SLOT_REF1="ts890" TIME_SLOT_REF2="ts892">
				<ANNOTATION_VALUE>di doytshe yidn vos zenen gekumen keyn Rayshe,</ANNOTATION_VALUE>
				</ALIGNABLE_ANNOTATION>
