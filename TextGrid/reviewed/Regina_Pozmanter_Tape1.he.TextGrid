        intervals [100]:
            xmin = 361.268 
            xmax = 366.843 
            text = "פֿון די צװײטע זײַט װאָס בײַ אונדז איז געװען אַ אַ פֿרױען־שול פֿאַר <-זונדער> און אַ מענער־שול" 
        intervals [101]:
            xmin = 366.843 
            xmax = 370.58 
            text = "און דורכן פֿענצטער האָט מען געװאָרפֿן דאָס װאָס מע האָט געהאַט." 
