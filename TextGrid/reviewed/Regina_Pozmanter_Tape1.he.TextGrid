            xmax = 89.108 
            text = "מײַן נאָמען איז YESHAYAHU PERY." 
        intervals [22]:
            xmin = 89.108 
            xmax = 95.737 
            text = "איך האָב דעם HONOR OF מאַכן הײַנט אַ אינטערװיו אין דער נאָמען פֿון THE FOUNDATION VISUAL HISTORY FOR SURVIVORS." 
        intervals [23]:
            xmin = 95.737 
            xmax = 96.216 
            text = "" 
        intervals [24]:
            xmin = 96.216 
            xmax = 103.213 
            text = "הײַנט, מערץ דעם צענטן, נײַנצן הונדערט נײַן eh זעקס און נײַנציק דאָ אין BNEY-BARAK," 
        intervals [25]:
            xmin = 103.213 
