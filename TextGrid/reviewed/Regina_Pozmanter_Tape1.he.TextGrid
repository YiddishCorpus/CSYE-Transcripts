            text = "" 
        intervals [10]:
            xmin = 125.95 
            xmax = 130.376 
            text = "אָבער ס'איז געװעזן אַ שטעטל מיט אַ רבֿ, מיט אַ שמשׂ, מיט אַ" 
        intervals [11]:
            xmin = 130.376 
            xmax = 136.338 
            text = "שוחט, מיט אַ חזן און דאָס אַלץ איז געװאָרן אױסגעהאַלטן פֿון דעם שטעטל." 
        intervals [12]:
            xmin = 136.338 
            xmax = 137.087 
            text = "" 
        intervals [13]:
            xmin = 137.087 
            xmax = 143.409 
            text = "נאַטירלעך, ס'איז נישט געװען קײן זײער רײַך אָבער ס'איז גע-, מע האָט עס אױסגעהאַלטן, די קהילה האָט דאָס אַלץ אױסגעהאַלטן." 
        intervals [14]:
            xmin = 143.409 
            xmax = 144.023 
            text = "" 
        intervals [15]:
            xmin = 144.023 
            xmax = 144.728 
            text = "spn" 
        intervals [16]:
            xmin = 144.728 
            xmax = 147.155 
            text = "ס'איז געװען אַ בעל־הבתּיש לעבן," 
        intervals [17]:
            xmin = 147.155 
            xmax = 147.33 
            text = "" 
        intervals [18]:
            xmin = 147.33 
            xmax = 150.193 
            text = "אַ פֿײַן לעבן, נישט געװען קײן גרױסע" 
        intervals [19]:
            xmin = 150.193 
            xmax = 150.57 
            text = "" 
        intervals [20]:
            xmin = 150.57 
            xmax = 154.006 
            text = "צו פֿיל נגידים, ס'איז נישט געװען קײן סך אָרעמע־לײַט," 
        intervals [21]:
            xmin = 154.006 
            xmax = 154.047 
            text = "" 
        intervals [22]:
            xmin = 154.047 
            xmax = 159.221 
            text = "אַזױ. איבער הױפּט, דער, די ייִדיש, ייִדן זענען געװעזן סוחרים." 
        intervals [23]:
            xmin = 159.221 
            xmax = 159.312 
            text = "" 
        intervals [24]:
            xmin = 159.312 
            xmax = 163.929 
            text = "יעדער האָט געהאַט אַ, אַ קלײט, זײַ- זײַן געשעפֿט," 
        intervals [25]:
            xmin = 163.929 
            xmax = 164.02 
            text = "" 
        intervals [26]:
            xmin = 164.02 
            xmax = 168.013 
            text = "אַ געװעלב, אין מיטן מאַרק זענען געװען די ייִדישע געשעפֿטן" 
        intervals [27]:
            xmin = 168.013 
            xmax = 168.07 
            text = "" 
        intervals [28]:
            xmin = 168.07 
            xmax = 171.18 
            text = "און דאָס איז געװען די פּרנסה." 
        intervals [29]:
            xmin = 171.18 
            xmax = 175.069 
            text = "יעדער האָט געהאַט, אײנער <אַזאַ> קלײט, אײנער אַזאַ ס- UNK, eh" 
        intervals [30]:
            xmin = 175.069 
            xmax = 177.277 
            text = "דאָס איז געװען די ייִדישע פּרנסה." 
        intervals [31]:
            xmin = 177.277 
            xmax = 177.351 
            text = "" 
        intervals [32]:
            xmin = 177.351 
            xmax = 180.99 
            text = "און גאָט אַ דאַנק, ס'איז געװען ביז דער מלחמה איז געװעזן" 
        intervals [33]:
            xmin = 180.99 
            xmax = 181.182 
            text = "" 
        intervals [34]:
            xmin = 181.182 
            xmax = 185.864 
            text = "זײער גוט, די גאַ-, די אַלע ייִדן האָבן געלעבט אַזױ װי אײן משפּחה." 
        intervals [35]:
            xmin = 185.864 
            xmax = 191.884 
            text = "ס'איז געװען אַ שׂימחה, זענען אַלע זיך צוזאַמענגעקומען: דער רבֿ, און דער חזן, און דער שוחט" 
        intervals [36]:
            xmin = 191.884 
            xmax = 191.886 
            text = "" 
        intervals [37]:
            xmin = 191.886 
            xmax = 194.366 
            text = "און אַ- און די ייִדן, די קהילה." 
        intervals [38]:
            xmin = 194.366 
            xmax = 201.378 
            text = "און ס'איז געװען די זעלבע זאַך, אַ שׂימחה, אַ ברית, אָבער אַלץ, און חלילה־וחלילה עס זאָל נישט געשען אַז ס'איז געװען" 
        intervals [39]:
            xmin = 201.378 
            xmax = 203.757 
            text = "אַ צרה האָבן אַלע מיטגעװײנט." 
        intervals [40]:
            xmin = 203.757 
            xmax = 208.024 
            text = "דאָס איז געװען דאָס ייִדישע לעבן, דאָס שטילע לעבן." 
        intervals [41]:
            xmin = 208.024 
            xmax = 208.148 
            text = "" 
        intervals [42]:
            xmin = 208.148 
            xmax = 214.388 
            text = "און <עס זאָל גײן> מיט די קריסטן האָבן מיר אױך נישט שלעכט געלעבט. מיר ז- האָבן גוט געלעבט מיט זײ, זענען געװעזן" 
        intervals [43]:
            xmin = 214.388 
            xmax = 217.304 
            text = "שכנים. מע קען נישט זאָגן." 
        intervals [44]:
            xmin = 217.304 
            xmax = 217.834 
            text = "" 
        intervals [45]:
            xmin = 217.834 
            xmax = 220.41 
            text = "ביז די מלחמה. מע האָט זײ נישט געהעצט." 
        intervals [46]:
            xmin = 220.41 
            xmax = 220.602 
            text = "" 
        intervals [47]:
            xmin = 220.602 
            xmax = 225.593 
            text = "ס'איז געװען, דאָס איז געװען די צרה, אַז מע האָט זײ נישט געהעצט, זענען נישט געװען ק'אַזאַ מין" 
        intervals [48]:
            xmin = 225.593 
            xmax = 228.341 
