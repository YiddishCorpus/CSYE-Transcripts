            text = "" 
        intervals [26]:
            xmin = 103.438 
            xmax = 107.949 
            text = "און מיט אײַער ערלױבעניש װעלן מיר אָנפֿאַנגען דעם אינטערװיו." 
        intervals [27]:
            xmin = 107.949 
            xmax = 112.478 
            text = "ביטע, דערצײלט מיר װאָס איר געדענקט פֿון דער הײם," 
