            text = "" 
        intervals [33]:
            xmin = 262.418 
            xmax = 268.75 
            text = "יעצט האָב איך אײַך געװאָלט פֿרײַ- פֿרעגן אַ קורצע פֿראַגע, לעבן ד- װי האָט געהײסן אײַער שטעטל?" 
