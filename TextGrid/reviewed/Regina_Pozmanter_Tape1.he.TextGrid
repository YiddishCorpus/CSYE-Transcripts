            xmin = 112.478 
            xmax = 113.04 
            text = "" 
        intervals [29]:
            xmin = 113.04 
            xmax = 116.696 
            text = "פֿון דער פֿאַמיליע, װי ס'האָט זיך געלעבט פֿאַר דער מלחמה. ביטע." 
