            text = "" 
        intervals [28]:
            xmin = 168.07 
            xmax = 171.18 
            text = "un dos iz geven di parnose." 
        intervals [29]:
            xmin = 171.18 
            xmax = 175.069 
            text = "yeder hot gehat, eyner <aza> kleyt, eyner aza s- UNK, eh" 
        intervals [30]:
            xmin = 175.069 
            xmax = 177.277 
            text = "dos iz geven di yidishe parnose." 
        intervals [31]:
            xmin = 177.277 
