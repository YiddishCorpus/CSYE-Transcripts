            text = "" 
        intervals [13]:
            xmin = 137.087 
            xmax = 143.409 
            text = "natirlekh, s'iz nisht geven keyn zeyer raykh ober s'iz ge-, me hot es oysgehaltn, di kehile hot dos alts oysgehaltn." 
