            text = "" 
        intervals [32]:
            xmin = 177.351 
            xmax = 180.99 
            text = "un got a dank, s'iz geven biz der milkhome iz gevezn" 
        intervals [33]:
            xmin = 180.99 
            xmax = 181.182 
            text = "" 
        intervals [34]:
            xmin = 181.182 
            xmax = 185.864 
            text = "zeyer gut, di ga-, di ale yidn hobn gelebt azoy vi eyn mishpokhe." 
        intervals [35]:
            xmin = 185.864 
            xmax = 191.884 
            text = "s'iz geven a simkhe, zenen ale zikh tsuzamengekumen: der rov, un der khazn, un der shoykhet" 
        intervals [36]:
            xmin = 191.884 
            xmax = 191.886 
            text = "" 
        intervals [37]:
            xmin = 191.886 
            xmax = 194.366 
            text = "un a- un di yidn, di kehile." 
        intervals [38]:
            xmin = 194.366 
            xmax = 201.378 
            text = "un s'iz geven di zelbe zakh, a simkhe, a bris, ober alts, un kholile-vekholile es zol nisht geshen az s'iz geven" 
        intervals [39]:
            xmin = 201.378 
            xmax = 203.757 
            text = "a tsore hobn ale mitgeveynt." 
        intervals [40]:
            xmin = 203.757 
            xmax = 208.024 
            text = "dos iz geven dos yidishe lebn, dos shtile lebn." 
        intervals [41]:
            xmin = 208.024 
            xmax = 208.148 
            text = "" 
        intervals [42]:
            xmin = 208.148 
            xmax = 214.388 
            text = "un <es zol geyn> mit di kristn hobn mir oykh nisht shlekht gelebt. mir z- hobn gut gelebt mit zey, zenen gevezn" 
        intervals [43]:
            xmin = 214.388 
            xmax = 217.304 
            text = "shkheynim. me ken nisht zogn." 
        intervals [44]:
            xmin = 217.304 
            xmax = 217.834 
            text = "" 
        intervals [45]:
            xmin = 217.834 
            xmax = 220.41 
            text = "biz di milkhome. me hot zey nisht gehetst." 
        intervals [46]:
            xmin = 220.41 
            xmax = 220.602 
            text = "" 
        intervals [47]:
            xmin = 220.602 
            xmax = 225.593 
            text = "s'iz geven, dos iz geven di tsore, az me hot zey nisht gehetst, zenen nisht geven k'aza min" 
        intervals [48]:
            xmin = 225.593 
            xmax = 228.341 
            text = "inteligent folk vos zey hobn," 
        intervals [49]:
            xmin = 228.341 
            xmax = 228.567 
            text = "" 
        intervals [50]:
            xmin = 228.567 
            xmax = 231.871 
            text = "zey hobn eh aleynt farshtanen. az me hot zey," 
        intervals [51]:
            xmin = 231.871 
            xmax = 234.756 
            text = "geganen mit zey in gutn iz undz oykh geven gut." 
        intervals [52]:
            xmin = 234.756 
            xmax = 237.161 
            text = "az me hot zey gehetst zenen zey geven nisht gut." 
        intervals [53]:
            xmin = 237.161 
            xmax = 239.017 
            text = "letstns ven s'iz geven shoyn" 
        intervals [54]:
            xmin = 239.017 
            xmax = 244.983 
            text = "far der milkhome az me hot shoyn geredt azoy vegn der milkhome hobn zey shoyn gehat mer khutspe." 
        intervals [55]:
            xmin = 244.983 
            xmax = 250.965 
            text = "hobn zey shoyn mer ongehoybn tsu boykotirn, nisht tsu kumen in di yidishe gesheftn," 
        intervals [56]:
            xmin = 250.965 
            xmax = 253.023 
            text = "un s'iz shoyn geven nisht azoy gut." 
        intervals [57]:
            xmin = 253.023 
            xmax = 259.031 
            text = "vayl eh der Hitler, me hot zey gehetst, az Hiter vet kumen vet er, vet er makhn a khurbn." 
