        intervals [73]:
            xmin = 295.13 
            xmax = 300.906 
            text = "ya, spetsyel, keyn organizatsye, s'iz nisht geven <vayl> s'iz nisht geven a groyser yugnt," 
        intervals [74]:
            xmin = 300.906 
            xmax = 304.02 
            text = "nor der yugnt iz geven tsienistish." 
        intervals [75]:
            xmin = 304.02 
            xmax = 309.859 
            text = "mir hobn geshtrebt ale <nokh> demolt Palestine, demolt iz dokh nokh nisht geven Yisroel." 
        intervals [76]:
