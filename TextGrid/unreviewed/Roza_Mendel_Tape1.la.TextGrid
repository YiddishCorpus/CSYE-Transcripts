            xmin = 1547.476 
            xmax = 1548.681 
            text = "" 
        intervals [586]:
            xmin = 1548.681 
            xmax = 1552.387 
            text = "vos, voser...? LO. vosere esn?" 
        intervals [587]:
            xmin = 1552.387 
            xmax = 1552.9 
            text = "" 
        intervals [588]:
            xmin = 1552.9 
            xmax = 1555.722 
            text = "nisht geven mer esn bikhlal." 
