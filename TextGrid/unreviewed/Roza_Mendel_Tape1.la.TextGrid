        intervals [542]:
            xmin = 1429.341 
            xmax = 1432.474 
            text = "un iz gekumen fun Budapest a," 
        intervals [543]:
            xmin = 1432.474 
            xmax = 1432.682 
            text = "" 
        intervals [544]:
            xmin = 1432.682 
            xmax = 1443.425 
            text = "iz gekumen demls a naye transport bay undz in, in lager, un er hot bakant a BAKHURA, a sheyne, a hoykhe YEHUDIYA. ERZSI hot zi geheysn. dos gedenk ikh, afile ir nomen." 
        intervals [545]:
            xmin = 1443.425 
            xmax = 1443.533 
            text = "" 
        intervals [546]:
            xmin = 1443.533 
            xmax = 1447.222 
            text = "zi iz gegan- gegangen sheyn ongetun, mit a tikhele," 
        intervals [547]:
            xmin = 1447.222 
            xmax = 1447.296 
            text = "" 
        intervals [548]:
            xmin = 1447.296 
            xmax = 1449.585 
            text = "mit a fartekh a sheyne." 
        intervals [549]:
            xmin = 1449.585 
            xmax = 1449.625 
            text = "" 
        intervals [550]:
            xmin = 1449.625 
            xmax = 1452.457 
            text = "<a> gantse tog hot zi geputst di negelekh." 
        intervals [551]:
            xmin = 1452.457 
            xmax = 1454.025 
            text = "yo, yo." 
        intervals [552]:
            xmin = 1454.025 
            xmax = 1458.97 
            text = "nu, er iz geven MENAHEL, der gelibter." 
        intervals [553]:
            xmin = 1458.97 
            xmax = 1465.835 
            text = "er hot zikh farlibt fun di ERZSI, un zi, er hot zi gemakht oykh a MENAHELET. <zi hot> gornisht gearbet, nor a gantse tog <hot zi>" 
        intervals [554]:
            xmin = 1465.835 
            xmax = 1466.027 
            text = "" 
        intervals [555]:
            xmin = 1466.027 
            xmax = 1470.678 
            text = "gemakht di nogl, gegangen sheyn ongetun, mit a tikhele, mit a fa-..." 
        intervals [556]:
            xmin = 1470.678 
            xmax = 1471.191 
            text = "" 
        intervals [557]:
            xmin = 1471.191 
            xmax = 1474.304 
            text = "uh, EKH OMRIM? a shirtsl, fartekh." 
        intervals [558]:
            xmin = 1474.304 
            xmax = 1474.937 
            text = "" 
        intervals [559]:
            xmin = 1474.937 
            xmax = 1482.727 
            text = "UNK er hot khasene gehat. ven s'<iz> geendikt di MILKHAMA, ven s'iz gevorn SHIKHRUR, er hot khasene gehat mit ir." 
        intervals [560]:
            xmin = 1482.727 
            xmax = 1484.083 
            text = "" 
        intervals [561]:
            xmin = 1484.083 
            xmax = 1489.308 
            text = "er iz geven a HOMOSEKSUAL. er hot gehat koydem a yingl, a BAKHUR fun POLANYA." 
        intervals [562]:
            xmin = 1489.308 
            xmax = 1489.618 
            text = "" 
        intervals [563]:
            xmin = 1489.618 
            xmax = 1492.143 
            text = "er hot gehat a TSRIF lebn di kikh," 
        intervals [564]:
            xmin = 1492.143 
            xmax = 1492.251 
            text = "" 
        intervals [565]:
            xmin = 1492.251 
            xmax = 1499.728 
            text = "un er hot geh- er iz geven HOMOSEKSUAL, un dernokh dem, PITOM, er <hot> khasene gehat mit di ERZSI." 
        intervals [566]:
            xmin = 1499.728 
            xmax = 1504.375 
            text = "<mir ale>, kh'gedenk, ""vos iz dos?"" nu, er hot gevolt heyratn mit ir." 
        intervals [567]:
            xmin = 1504.375 
            xmax = 1504.84 
            text = "" 
        intervals [568]:
            xmin = 1504.84 
            xmax = 1510.334 
            text = "er iz geven a goy; vegn POLITIKA m'hot im genemen. er iz nisht geven keyn YEHUD, a yid." 
        intervals [569]:
            xmin = 1510.334 
            xmax = 1511.455 
            text = "" 
        intervals [570]:
            xmin = 1511.455 
            xmax = 1515.668 
            text = "un, spn, nor dos. ikh hob gearbet in kikh zeyer shver." 
        intervals [571]:
            xmin = 1515.668 
            xmax = 1515.792 
            text = "" 
        intervals [572]:
            xmin = 1515.792 
            xmax = 1517.045 
            text = "<in kikh> UNK..." 
        intervals [573]:
            xmin = 1517.045 
            xmax = 1518.559 
            text = "" 
        intervals [574]:
            xmin = 1518.559 
            xmax = 1524.757 
            text = "m'hot gedarft helfn far di GERMANIM, <uh, g-> far di GERMANIM, hobn gehat a ungarishe kukher." 
        intervals [575]:
            xmin = 1524.757 
            xmax = 1528.813 
            text = "di ungarishe kenen zeyer gut kokhn, zogt men." 
        intervals [576]:
            xmin = 1528.813 
            xmax = 1529.494 
            text = "" 
        intervals [577]:
            xmin = 1529.494 
            xmax = 1534.517 
            text = "zey hobn gevolt a HUNGARI, iz er hot gekokht. ho'mir gedarft sheyln kartofl" 
        intervals [578]:
            xmin = 1534.517 
            xmax = 1534.722 
            text = "" 
        intervals [579]:
            xmin = 1534.722 
            xmax = 1538.61 
            text = "mit, ikh vey- kh'gedenk shoyn nisht vos BEEMET m'hot gedarft dortn..." 
        intervals [580]:
            xmin = 1538.61 
            xmax = 1542.245 
            text = "un far groyse <KAZANA> vos m'hot gekokht far di yidn," 
        intervals [581]:
            xmin = 1542.245 
            xmax = 1542.403 
            text = "" 
        intervals [582]:
            xmin = 1542.403 
            xmax = 1545.282 
            text = "hot men gedarft vashn groyse <KAZANIM>." 
        intervals [583]:
            xmin = 1545.282 
            xmax = 1545.964 
            text = "" 
        intervals [584]:
            xmin = 1545.964 
            xmax = 1547.476 
            text = "s'iz geven a<rb->..." 
