            xmin = 1558.086 
            xmax = 1561.557 
            text = "" 
        intervals [592]:
            xmin = 1561.557 
            xmax = 1566.09 
            text = "<dernokh dem>, m'hot gearbet, uh, als SABALIT, SABAL." 
        intervals [593]:
            xmin = 1566.09 
            xmax = 1566.805 
            text = "" 
        intervals [594]:
            xmin = 1566.805 
            xmax = 1578.662 
            text = "yo, eyn mol dos un eyn mol, uh, SABAL, getrogn milekh far di... gegangen in dorf, dray kilometer, in TÜRKHEIM. iz geven a kleyne TNUVA dortn." 
        intervals [595]:
            xmin = 1578.662 
            xmax = 1578.668 
            text = "" 
        intervals [596]:
            xmin = 1578.668 
            xmax = 1582.779 
            text = "<mir hobn> gebrengt mit di AGALA. m'hot nisht ge- undz ze'mir geven di SUSIM." 
        intervals [597]:
            xmin = 1582.779 
            xmax = 1583.275 
            text = "" 
        intervals [598]:
            xmin = 1583.275 
            xmax = 1589.898 
            text = "etlekhe froyen ze'mir gef- geshtupt, uh, eyne hot geshtupt fornt, eyne hintn, ho'mir gebrengt KHALAV." 
        intervals [599]:
            xmin = 1589.898 
            xmax = 1592.235 
            text = "" 
        intervals [600]:
            xmin = 1592.235 
            xmax = 1603.501 
            text = "yo, S.S. nor dos vil ikh zogn: di S.S. iz a bisl aroysgegangen, un der iz gev- dort iz geven a alte mentsh, hot gearbet bay di TNUVA. ikh hob gevoynt, nokh di SHIKHRUR hob ikh gevoynt bay im." 
        intervals [601]:
            xmin = 1603.501 
            xmax = 1603.963 
            text = "" 
        intervals [602]:
            xmin = 1603.963 
            xmax = 1610.254 
            text = "zey hobn gegebn, uh, dires tsu voynen. zey hobn gemeynt, az di AMERIKAIM zenen arayngekumen, m'vet makhn" 
        intervals [603]:
            xmin = 1610.254 
            xmax = 1611.855 
            text = "TSAROT far zey," 
        intervals [604]:
            xmin = 1611.855 
            xmax = 1612.03 
            text = "" 
        intervals [605]:
            xmin = 1612.03 
            xmax = 1617.103 
            text = "hobn zey gezukht YEHUDIM, zey zoln voynen bay zey, az KEILU az zey hobn geholfn far undz." 
        intervals [606]:
            xmin = 1617.103 
            xmax = 1617.632 
            text = "" 
        intervals [607]:
            xmin = 1617.632 
            xmax = 1620.714 
            text = "iz ven di GERMANI iz aroysgegangen," 
        intervals [608]:
            xmin = 1620.714 
            xmax = 1620.923 
            text = "" 
        intervals [609]:
            xmin = 1620.923 
            xmax = 1627.025 
            text = "fleg er undz ale mol gebn far ale BAKHUROT dortn a bisele milekh tsu trinken. dos iz geven gut BEEMET." 
        intervals [610]:
            xmin = 1627.025 
            xmax = 1627.538 
            text = "" 
        intervals [611]:
            xmin = 1627.538 
            xmax = 1628.376 
            text = "KEN." 
        intervals [612]:
            xmin = 1628.376 
            xmax = 1629.31 
            text = "" 
        intervals [613]:
            xmin = 1629.31 
            xmax = 1636.695 
            text = "LO, dos nisht. ikh hob gevoynt bay zey, ober... er hot gehat a froy, oykhet a alte froy, er a alter mentsh." 
        intervals [614]:
            xmin = 1636.695 
            xmax = 1637.157 
            text = "" 
        intervals [615]:
            xmin = 1637.157 
            xmax = 1642.264 
            text = "di nomen nisht, ober s'iz geven zeyer sheyn az er hot geholfn a bisl..." 
        intervals [616]:
            xmin = 1642.264 
            xmax = 1642.54 
            text = "" 
        intervals [617]:
            xmin = 1642.54 
            xmax = 1649.527 
            text = "un <BE- do-> un BEEMTSA HADEREKH iz geven gute daytshn oykhet. zey hobn a vorf gegebn a kleyne broyt," 
        intervals [618]:
            xmin = 1649.527 
            xmax = 1653.145 
            text = "ho'mir in der heym gemakht KHALUKA fun dos," 
        intervals [619]:
            xmin = 1653.145 
            xmax = 1655.139 
            text = "gegebn yedn a shtikele." 
        intervals [620]:
            xmin = 1655.139 
            xmax = 1655.702 
            text = "" 
        intervals [621]:
            xmin = 1655.702 
            xmax = 1660.471 
            text = "KEN, s'iz geven gute GERMANIM oykhet. zey hobn gehat RAKHMANUT oyf undz. <ober GE->" 
        intervals [622]:
            xmin = 1660.471 
            xmax = 1660.478 
            text = "" 
        intervals [623]:
            xmin = 1660.478 
            xmax = 1665.782 
            text = "veyst ver iz geven di GERMANIM? ukraynIM zenen geven ongetun alts, uh, S.S.n," 
        intervals [624]:
            xmin = 1665.782 
            xmax = 1668.892 
            text = "S.S. kleyder, ukraynishe BAKHURIM," 
        intervals [625]:
            xmin = 1668.892 
            xmax = 1669.185 
            text = "" 
        intervals [626]:
            xmin = 1669.185 
            xmax = 1672.928 
            text = "nor zey hobn dokh geharget oykhet, di ukraynishe hobn geharget mayn bruder." 
        intervals [627]:
            xmin = 1672.928 
            xmax = 1677.545 
            text = "UNK ge- mitgearbet mit di GERMANIM, <PASHUT MEOD>... ha?" 
        intervals [628]:
            xmin = 1677.545 
            xmax = 1678.056 
            text = "" 
        intervals [629]:
            xmin = 1678.056 
