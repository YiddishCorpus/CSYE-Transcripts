            text = "" 
        intervals [210]:
            xmin = 713.537 
            xmax = 720.437 
            text = "gevalgert zikh ahin, gevalgert zikh aher. nisht keyn mol nisht gekont shlofn a mol in a bet azoy vi s-darf, gelegn oyfn <erd> fun alde kholeres, fun ale tsores," 
        intervals [211]:
