            text = "spn gib a kuk op. eh yeder eyner vos tut zikh in Kanade, un s'nisht keyn nayes," 
        intervals [298]:
            xmin = 962.972 
            xmax = 967.179 
            text = "un git a kuk op, eh s'do in ale meg- in yede land iz do antisemitizm," 
        intervals [299]:
            xmin = 967.179 
            xmax = 967.303 
            text = "" 
        intervals [300]:
            xmin = 967.303 
            xmax = 970.788 
            text = "in bestn land. in Amerike iz nishto keyn antisemitizm? un do iz antisemitizm." 
        intervals [301]:
            xmin = 970.788 
            xmax = 975.763 
            text = "mir darf mir vayter geyn. az Parizo iz an antisemit hob ikh nisht vos tsu redn, er redt dokh oykh di zelbe zakhn," 
        intervals [302]:
            xmin = 975.763 
            xmax = 978.363 
            text = "az nor er hot farloyrn der hot farloyrn nor, di farshteyst mikh," 
        intervals [303]:
            xmin = 978.363 
            xmax = 982.963 
            text = "eh zayne zayne valn hot er farloyrn durkh di yidn, durkh di grekn, durkh di italyener," 
        intervals [304]:
            xmin = 982.963 
            xmax = 984.904 
            text = "" 
        intervals [305]:
            xmin = 984.904 
            xmax = 989.69 
            text = "un vos ikh, er iz shoyn a PRIME minister un er redt dos. un far vos zol nisht redn keyn grober yung, andere andere khevre?" 
        intervals [306]:
            xmin = 989.69 
            xmax = 994.033 
            text = "" 
        intervals [307]:
            xmin = 994.033 
            xmax = 1001.666 
            text = "in Kanade hob ikh nisht vos tsu zogn vos tsu z- kum vos tsu zogn, vayl ikh hob nisht vos tsu redn oyf Kanade. un Kanade hot mikh nisht shlekht bahandlt, ikh vel nisht zogn gornisht, keyn eh" 
        intervals [308]:
            xmin = 1001.666 
            xmax = 1009.764 
            text = "farkert, eh keyn Poyln volt ikh NEVER tsurikgeforn voynen, vayl dos iz geven dos argste folk fun der velt iz geven dos argste folk. ober in ikh hob nisht keyn shum taynes tsu Kanade," 
        intervals [309]:
            xmin = 1009.764 
            xmax = 1013.614 
            text = "un m'lebt do sheyn, m'lebt op krant bakvem UNK un fayn." 
        intervals [310]:
            xmin = 1013.614 
            xmax = 1021.118 
            text = "" 
        intervals [311]:
            xmin = 1021.118 
            xmax = 1026.515 
            text = "ya, o ya, ikh bin gefo- ikh for dokh, yedes yor for ikh dokh keyn Yisroel, ze ikh mikh mit im." 
        intervals [312]:
            xmin = 1026.515 
            xmax = 1032.67 
            text = "dos yor vos ikh for nor nisht, azoy, dos dos mol hot ir a mazl ir hot mir getrofn, ven nisht volt ikh shoyn geven in Yisroel." 
        intervals [313]:
            xmin = 1032.67 
            xmax = 1032.762 
            text = "" 
        intervals [314]:
            xmin = 1032.762 
            xmax = 1035.77 
            text = "dos yor vos ikh for nisht, vayl ikh hob PROBLEM mit mayn vayb's BACK," 
        intervals [315]:
            xmin = 1035.77 
            xmax = 1040.487 
            text = "zi darf geyn tsum dokter do dortn, zi letshket zikh yetst, zi m'hot optsutun mit ir BACK." 
        intervals [316]:
            xmin = 1040.487 
            xmax = 1045.462 
            text = "hob ikh dem dokter, do dokter, do darf ikh makhn a CHECKUP, dortn a CHECKUP. derfar for'mir nisht dos yor." 
        intervals [317]:
            xmin = 1045.462 
            xmax = 1051.054 
            text = "" 
        intervals [318]:
            xmin = 1051.054 
            xmax = 1054.524 
            text = "a sakh mol. nisht vos ikh UNK, un kholem a sakh." 
        intervals [319]:
            xmin = 1054.524 
            xmax = 1054.8 
            text = "" 
        intervals [320]:
            xmin = 1054.8 
            xmax = 1061.088 
            text = "mayn vayb vekt mikh oyf yedes mol fun der fun der nakht vekt zi mikh oyf, Oyshvits Oyshvits! Oyshvits Oyshvits! ikh shray gevald, vek mikh oyf," 
        intervals [321]:
            xmin = 1061.088 
            xmax = 1061.77 
            text = "" 
        intervals [322]:
            xmin = 1061.77 
            xmax = 1065.476 
            text = "m'shlogt mikh, m'harget mikh, biz yetst hob ikh nokh azelkhe zakhn," 
        intervals [323]:
            xmin = 1065.476 
            xmax = 1065.769 
            text = "" 
        intervals [324]:
            xmin = 1065.769 
            xmax = 1071.112 
            text = "ikh hob hersht hersht eyn eyn nakht hob ikh gekholemt, hot zi mikh oyfgevekt. ikh hob geshrign." 
        intervals [325]:
            xmin = 1071.112 
            xmax = 1074.038 
            text = "" 
        intervals [326]:
            xmin = 1074.038 
            xmax = 1076.664 
            text = "fun di fun di yom-t- yomim-toyvim kumen on mer." 
        intervals [327]:
            xmin = 1076.664 
            xmax = 1076.755 
            text = "" 
        intervals [328]:
            xmin = 1076.755 
            xmax = 1084.781 
            text = "fun der tsayt fun di yomim-toyvim kumt mir di eltern tsum kop, di mishpokhe, un tsu yeder eyner kumt men oyf di gedanken, ikh zits in di shul veyn ikh, kukn m'makh mentshn op," 
        intervals [329]:
            xmin = 1084.781 
            xmax = 1085.158 
            text = "" 
        intervals [330]:
            xmin = 1085.158 
            xmax = 1089.585 
            text = "nu, un natirlekh, az m'hot m'hot farshteystu mikh Yisker bin ikh shoyn in gantsn fertik." 
        intervals [331]:
            xmin = 1089.585 
            xmax = 1095.311 
            text = "zog ikh far yedn eynem Yisker. far di brider un far di shvester un far tate mame, far di far far yedn eynem zog ikh Yisker." 
        intervals [332]:
            xmin = 1095.311 
            xmax = 1101.443 
            text = "" 
        intervals [333]:
            xmin = 1101.443 
            xmax = 1108.76 
            text = "ya, dos dos di religye hot gevirkt. vayl ikh hob keyn mol nisht gevolt gleybn az s'vet tsugeyn an S.S. man tsu mayn tatn un shisn az zayn hant vet nisht aropfaln." 
        intervals [334]:
            xmin = 1108.76 
