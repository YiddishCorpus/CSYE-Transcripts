            text = "" 
        intervals [337]:
            xmin = 1112.361 
            xmax = 1116.775 
            text = "fun dem hob ikh hob ikh zikh opgezogt, s'hot gornisht geholfn." 
        intervals [338]:
            xmin = 1116.775 
            xmax = 1125.45 
            text = "vi ken zayn a got, az m'nemt kleyne kinder un m'varft zey arop fun shtokn, m'varft un m'hakt un m'brent un m'shekht un m'tut azelkhe zakhn vos di velt hot nokh dos nisht ibergelebt?" 
        intervals [339]:
            xmin = 1125.45 
            xmax = 1133.775 
            text = "azelkhe zakhn. un az s'nishto gornisht, m'varft nisht keyn shum vunder. m'zol vayzn epes a shtikl vunder volt ikh farshtanen. gornisht! gornisht! un m'lot tun." 
