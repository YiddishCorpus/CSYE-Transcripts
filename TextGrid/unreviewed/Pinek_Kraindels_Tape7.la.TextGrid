        intervals [218]:
            xmin = 739.305 
            xmax = 741.09 
            text = "bin ikh gegangen, ikh hob mir genumen CHOFESH." 
        intervals [219]:
            xmin = 741.09 
            xmax = 745.445 
            text = "un ikh bin aroysgeforn. ir meynt az ikh hob gezen di militer az ikh for aroys? ikh vil CHOFESH." 
        intervals [220]:
            xmin = 745.445 
            xmax = 749.512 
            text = "ikh hob gezogt farn farn general, gib mir CHOFESH. ikh ikh vil a yor CHOFESH." 
        intervals [221]:
            xmin = 749.512 
            xmax = 757.696 
            text = "a yor CHOFESH? zogt er neyn. vi ken ikh dir farlirn far a yor? ikh vel dir gebn a halb yor. zog ikh, veyst dokh, a halb yor ken ikh gornisht oyftun, ikh darf forn keyn Brazil, ikh hob mishpokhe in Brazil," 
        intervals [222]:
            xmin = 757.696 
