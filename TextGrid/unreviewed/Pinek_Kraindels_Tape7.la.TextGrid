            text = "" 
        intervals [224]:
            xmin = 760.129 
            xmax = 764.201 
            text = "un shoyn ikh bin aroysgeforn. aroysgeforn hot men do ahergekumen ikh hob gezen an ander lebn, m'ken lebn," 
        intervals [225]:
            xmin = 764.201 
            xmax = 769.93 
            text = "ikh leb ikh a bisl dekhen, ken ikh nisht dekhen in Yisroel. yeder montik un donershtik ven di araber gebn zikh a bapish bin ikh shoyn in militer." 
        intervals [226]:
