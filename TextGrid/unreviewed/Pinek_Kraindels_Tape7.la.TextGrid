            xmin = 730.508 
            xmax = 730.513 
            text = "" 
        intervals [215]:
            xmin = 730.513 
            xmax = 736.013 
            text = "hot er mir ongehoybn tsu shraybn LETTERS, Pinek, zogt er, vos ikh vel esn vestu esn, vos ikh tu vestu tun, kum aher." 
        intervals [216]:
            xmin = 736.013 
            xmax = 739.163 
            text = "s'vet dir nisht gefeln vestu tsurikforn. kum nem dir CHOFESH un for aroys." 
