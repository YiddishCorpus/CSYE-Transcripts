            xmax = 1160.856 
            text = "ikh hob zey ibergetsoygn un un nokh bizn hayntikn tog, vi ikh gleyb nisht, az s'kumen fraytik tsu nakhts, yedn fraytik tsu nakhts, kumen tsu mir di kinder, di eyniklekh," 
