            text = "" 
        intervals [370]:
            xmin = 1247.479 
            xmax = 1254.979 
            text = "derfar zog ikh, ikh dertseyl yedes mol, un red mit di eyniklekh un red mit di kinder, ikh dertseyl zey dos iberlebenish vos ikh hob ibergelebt," 
        intervals [371]:
