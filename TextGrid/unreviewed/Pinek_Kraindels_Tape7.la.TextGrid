            text = "" 
        intervals [212]:
            xmin = 720.557 
            xmax = 726.207 
            text = "hob ikh getrakht zikh eyn zakh, ikh hob do gehat a feter, hot er mir gesh- hot er mir ongehoybn tsu shra- un ikh hob gehat khaveyrim do oykhet," 
        intervals [213]:
            xmin = 726.207 
            xmax = 730.508 
            text = "ikh hob kh- yo, ikh hob gehat do khaveyrim vos zey hobn geven in Oyshvits, vos ikh hob zey geholfn." 
