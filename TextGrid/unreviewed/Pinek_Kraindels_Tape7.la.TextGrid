        intervals [4]:
            xmin = 10.525 
            xmax = 12.257 
            text = "Yis- Yisroel, yo, in Rekhovot." 
        intervals [5]:
            xmin = 12.257 
            xmax = 12.533 
            text = "" 
        intervals [6]:
            xmin = 12.533 
            xmax = 13.236 
            text = "yo." 
        intervals [7]:
            xmin = 13.236 
            xmax = 18.169 
            text = "" 
        intervals [8]:
            xmin = 18.169 
            xmax = 28.153 
            text = "eh vos hob ikh tsu redn tsu dertseyln. eh m'hot zikh bakent, ir veyst dokh vi yunge khevre, un m'iz gegangen aroys a tsayt biz mir hobn geheyrat. mir hobn nisht geheyrat bald tsu morgns, s'hot genumen a yor anderthalbn." 
        intervals [9]:
            xmin = 28.153 
            xmax = 28.513 
            text = "" 
        intervals [10]:
            xmin = 28.513 
            xmax = 35.358 
            text = "m'iz gegangen aroys yedes mol ven ikh hob gehat CHOFESH bin ikh gekumen arayn keyn Rekhovot un m'hot farbrengt m'iz gegangen un un m'hot geheyrat nakher." 
        intervals [11]:
            xmin = 35.358 
            xmax = 37.39 
            text = "" 
        intervals [12]:
            xmin = 37.39 
            xmax = 41.889 
            text = "in eh eyn u- eyn un fuftsik." 
        intervals [13]:
            xmin = 41.889 
            xmax = 43.127 
            text = "" 
        intervals [14]:
            xmin = 43.127 
            xmax = 43.964 
            text = "ya." 
        intervals [15]:
            xmin = 43.964 
            xmax = 48.426 
            text = "" 
        intervals [16]:
            xmin = 48.426 
            xmax = 54.613 
            text = "o ya o ya, zi veyst ales. un ikh hob zi gefirt oykh keyn Oyshvits, eh iz zi geven mit mir in Poyln mit mit zeks yor tsurik." 
        intervals [17]:
            xmin = 54.613 
            xmax = 54.822 
            text = "" 
        intervals [18]:
            xmin = 54.822 
            xmax = 63.203 
            text = "hob ikh zi gefirt keyn Poyln un ikh hob ze gevezn eh ikh bin geven mit ir in Treblinke un ikh bin geven mit ir in Oyshvits, ikh bin geven iberal, un ikh hob ir gevizn mayn plats vu ikh bin geshlofn, vu ikh hob gegesn." 
        intervals [19]:
            xmin = 63.203 
            xmax = 64.44 
            text = "" 
        intervals [20]:
            xmin = 64.44 
            xmax = 65.885 
            text = "mit zeks yor tsurik." 
        intervals [21]:
            xmin = 65.885 
            xmax = 66.972 
            text = "" 
        intervals [22]:
            xmin = 66.972 
            xmax = 70.746 
            text = "yo, ya, ikh hob ni- ven di rusn zenen aroys. ikh hob zey shoyn mer nisht," 
        intervals [23]:
            xmin = 70.746 
            xmax = 73.198 
            text = "" 
        intervals [24]:
            xmin = 73.198 
            xmax = 74.086 
            text = "ya?" 
        intervals [25]:
            xmin = 74.086 
            xmax = 77.704 
            text = "" 
        intervals [26]:
            xmin = 77.704 
            xmax = 79.554 
            text = "in NINETY eyn un NINETY." 
        intervals [27]:
            xmin = 79.554 
            xmax = 79.982 
            text = "" 
        intervals [28]:
            xmin = 79.982 
            xmax = 86.459 
            text = "bin ikh gevezn dortn in Poyln, un ikh bin arayngeforn, ikh hob nisht mer gekent oyshaltn, ikh hob geshrign tsu mayn vayb, gib a kuk op, ikh bin geblibn lebn," 
        intervals [29]:
            xmin = 86.459 
            xmax = 93.662 
            text = "far vos zol ikh nisht forn oyf keyver oves, zen dortn di gantse mishpokhe iz gevorn dortn oysgeharget in Treblinke?" 
        intervals [30]:
            xmin = 93.662 
            xmax = 94.647 
            text = "" 
        intervals [31]:
            xmin = 94.647 
            xmax = 101.901 
            text = "nu, un dos hot mikh gepaynikt, vayl sof kol sof yeder eyner do geyt oyf der UNK CEMETARY un m'geyt m'geyt un geyt aroyf" 
        intervals [32]:
            xmin = 101.901 
            xmax = 101.935 
            text = "" 
        intervals [33]:
            xmin = 101.935 
            xmax = 108.914 
            text = "tsum keyver un m- un m'zogt kadesh, m'hot a mol a yortsayt, un zog ikh, far vos az ikh bin geblibn lebn far vos zol ikh nisht geyn zen dortn ale?" 
        intervals [34]:
            xmin = 108.914 
            xmax = 109.041 
            text = "" 
        intervals [35]:
            xmin = 109.041 
            xmax = 120.225 
            text = "nu bin ikh arayngeforn, ze'mir geforn arayn keyn Treblinke, m'hot undz gevizn dem keyver oyf Treblinke. dos iz dos ershte mol vos in mayn lebn vos ikh hob gezogt kadesh barn keyver, ikh hob zikh gehat tsvey mol farkhalesht," 
        intervals [36]:
            xmin = 120.225 
            xmax = 123.407 
            text = "m'hot mikh geratevet, ikh hob alts nisht gekent zogn," 
        intervals [37]:
            xmin = 123.407 
            xmax = 130.067 
            text = "ikh hob nisht gegleybt zikh az s'vet oyskumen a tsayt ikh vel darfn zogn kadesh, eh s'kumt a tsayt m'darf zogn, ober nokh aza fal nokh di gantse FAMILY," 
        intervals [38]:
            xmin = 130.067 
            xmax = 133.577 
            text = "di shvester un brider, di shvesters zenen geven mit kinder, brider mit kinder," 
        intervals [39]:
            xmin = 133.577 
            xmax = 141.772 
            text = "un un un FAMILIES, un UNCLES, un ales, eh s'a veytik, m'farlirt azoy fil mentshn vos vos s'gevezn gebundn un geknipt." 
        intervals [40]:
            xmin = 141.772 
            xmax = 143.685 
            text = "" 
        intervals [41]:
            xmin = 143.685 
            xmax = 147.594 
            text = "nu. ya, un ikh bin geven," 
        intervals [42]:
            xmin = 147.594 
            xmax = 150.013 
            text = "" 
        intervals [43]:
            xmin = 150.013 
            xmax = 152.622 
            text = "di gantse undzer shtot iz gegangen keyn Treblinke." 
        intervals [44]:
            xmin = 152.622 
            xmax = 152.697 
            text = "" 
        intervals [45]:
            xmin = 152.697 
            xmax = 155.815 
            text = "un dan nakher vayter iz geven nokh a zakh." 
        intervals [46]:
            xmin = 155.815 
            xmax = 159.862 
            text = "ikh nakher ikh bin geven in Poyln, ikh bin geven in Treblinke," 
        intervals [47]:
            xmin = 159.862 
            xmax = 160.003 
            text = "" 
        intervals [48]:
            xmin = 160.003 
            xmax = 166.488 
            text = "ikh bin tsurikgekumen fun Treblinke, in a shabes far nakht kum ikh arayn in hotel arayn, tref ikh a KVUTZA, a GROUP, fun Montreal," 
        intervals [49]:
            xmin = 166.488 
            xmax = 175.595 
            text = "fun fun fun Dole Dezamur, di RABBI fun Dole Dezamur, vu di gantse khevre a khevre fun yidn fun Dola Dezamur hobn gemakht a GROUP, oykhet a" 
        intervals [50]:
            xmin = 175.595 
            xmax = 175.68 
            text = "" 
        intervals [51]:
            xmin = 175.68 
            xmax = 177.659 
            text = "tsu zen Oyshvits, Treblinke," 
        intervals [52]:
            xmin = 177.659 
            xmax = 186.85 
            text = "zogn zey, zey hobn shoyn gezen Treblinke. un eyner iz dortn geven tsvishn di yidn, eyner a LAWYER, vos er ken mikh, zogt er, Pinek, zog ter, vo- vo- vos tust du do? zog ikh, ikh bin do mit mayn vayb, er ken di vayb oykhet." 
        intervals [53]:
            xmin = 186.85 
            xmax = 186.916 
            text = "" 
        intervals [54]:
            xmin = 186.916 
            xmax = 191.891 
            text = "hob ikh mikh zeyer shtark tsefreyt, hobn zey gezogt az zey forn morgn keyn Oyshvits." 
        intervals [55]:
            xmin = 191.891 
            xmax = 192.808 
            text = "" 
        intervals [56]:
            xmin = 192.808 
            xmax = 198.354 
            text = "keyn Oyshvits VISITn. dos iz geven yidn vos zenen geboyrn gevorn do in Kanade, un zey forn mit dem RABBI." 
        intervals [57]:
            xmin = 198.354 
            xmax = 198.917 
            text = "" 
        intervals [58]:
            xmin = 198.917 
            xmax = 207.213 
            text = "zogt er tsu mir, efsher vilstu geyn oyf shaleshudes? zog ikh, veystu vos? ikh ken arayngeyn oyf shaleshudes. vos iz do tsu redn? arayngeyn oyf shaleshudes, trefn zikh, mir veln redn a bisl." 
        intervals [59]:
            xmin = 207.213 
            xmax = 207.473 
            text = "" 
        intervals [60]:
            xmin = 207.473 
            xmax = 212.04 
            text = "er iz avek, er hot gevust az ikh bin geven in Oyshvits. der zelber LAWYER." 
        intervals [61]:
            xmin = 212.04 
            xmax = 212.181 
            text = "" 
        intervals [62]:
            xmin = 212.181 
            xmax = 220.764 
            text = "un geyt avek tsum RABBI, un dertseylt im, geb a kuk, ikh hob do, zogt er, a Montrealer yid, er iz geven in Oyshvits. un zey hobn tsu dorfn morgn forn di gantse GROUP keyn Oyshvits VISITn." 
        intervals [63]:
            xmin = 220.764 
            xmax = 221.901 
            text = "" 
        intervals [64]:
            xmin = 221.901 
            xmax = 225.439 
            text = "iz tsugegangen der RABBI, zogt er tsu mir azoy, zogt er, Pinek," 
        intervals [65]:
            xmin = 225.439 
            xmax = 225.833 
            text = "" 
        intervals [66]:
            xmin = 225.833 
            xmax = 234.771 
            text = "ikh volt gevolt, eh bay bay dem, azoy vi ikh bin arayngegangen ersht zey hobn dokh zayn shul, in hotel iz geven aza shul far yidn tsu davenen, un dort hot men gemakht shaleshudes. di resht iz geven shabes far nakht." 
        intervals [67]:
            xmin = 234.771 
            xmax = 235.013 
            text = "" 
        intervals [68]:
            xmin = 235.013 
            xmax = 239.51 
            text = "kumt tsu der RABBI un zogt tsu mir, Pinek, ikh hob gehert, zogt er, dayn nomen, zogt er, er hot mir dertseylt mir," 
        intervals [69]:
            xmin = 239.51 
            xmax = 239.566 
            text = "" 
        intervals [70]:
            xmin = 239.566 
            xmax = 244.162 
            text = "du bist gevezn a yid in Oyshvits, zogt er, ikh volt gevolt, zogt er, nokhn shaleshudes," 
        intervals [71]:
            xmin = 244.162 
            xmax = 248.844 
            text = "oyb du kenst gebn a bisl a SPEECH. hob ikh gezogt, OK." 
        intervals [72]:
            xmin = 248.844 
            xmax = 249.643 
            text = "" 
        intervals [73]:
            xmin = 249.643 
            xmax = 252.236 
            text = "er hot zikh derfreyt, nokh shaleshudes" 
        intervals [74]:
            xmin = 252.236 
            xmax = 252.242 
            text = "" 
        intervals [75]:
            xmin = 252.242 
            xmax = 257.715 
            text = "hot er mikh aroyf gerufn oyf zayn tish un er hot gemoldn der gantse khevre, mir hobn do, zogt er, a gast," 
        intervals [76]:
            xmin = 257.715 
            xmax = 263.036 
            text = "zayn nomen iz Pinek Kreyndels, dos iz a yid vos hot ibergemakht, er iz a SURVIVOR fun Oyshvits," 
        intervals [77]:
            xmin = 263.036 
            xmax = 263.194 
            text = "" 
        intervals [78]:
            xmin = 263.194 
            xmax = 270.832 
            text = "un er vet aykh ibergebn a barikht. hob ikh ongehoybn tsu dertseyln fun Oyshvits un ale lign, un zey hobn geklogt un geveynt un gekhalesht." 
        intervals [79]:
            xmin = 270.832 
            xmax = 271.092 
            text = "" 
        intervals [80]:
            xmin = 271.092 
            xmax = 279.101 
            text = "ikh hob dertseylt fun alem, dos esn badingen, fun shlofn badingen, fun yeder zakh, vos iz tsugekumen, fun alding, un vi azoy ikh hob zikh bafrayt." 
        intervals [81]:
            xmin = 279.101 
            xmax = 279.597 
            text = "" 
        intervals [82]:
            xmin = 279.597 
            xmax = 287.387 
            text = "nokh dem iz tsugegangen der RABBI, zogt er tsu mir, geb a kuk, reb Pinkhes, ikh vel dir gebn, zogt er, nokh a nomen, Pinkhes Khaim. zolst lebn eybik." 
        intervals [83]:
            xmin = 287.387 
            xmax = 287.95 
            text = "" 
        intervals [84]:
            xmin = 287.95 
            xmax = 295.386 
            text = "du host mitgemakht azelkhes, der oylem iz shtark tsufridn. zogt er, yetst vet men khotsh visn vos s'hot dortn ongegangen, vos du host dertseylt," 
        intervals [85]:
            xmin = 295.386 
            xmax = 295.493 
            text = "" 
        intervals [86]:
            xmin = 295.493 
            xmax = 302.692 
            text = "un hot zikh gebetn efsher ken men vayter mitforn, ikh zol vider zen, er vil mikh zen, er fort shpeter keyn Yisroel, zog ikh, mir forn oykh keyn Yisroel." 
        intervals [87]:
            xmin = 302.692 
            xmax = 303.07 
            text = "" 
        intervals [88]:
            xmin = 303.07 
            xmax = 307.012 
            text = "zogt er az er vet forn arayn, donershtik fort er arayn keyn Yisroel." 
        intervals [89]:
            xmin = 307.012 
            xmax = 307.457 
            text = "" 
        intervals [90]:
            xmin = 307.457 
            xmax = 309.841 
            text = "zog ikh, ikh for oykh avek keyn Yisroel." 
        intervals [91]:
            xmin = 309.841 
            xmax = 313.382 
            text = "vil er er zol, vil er mikh aynladenen, er vet zayn in Yerusholaim," 
        intervals [92]:
            xmin = 313.382 
            xmax = 313.437 
            text = "" 
        intervals [93]:
            xmin = 313.437 
            xmax = 317.33 
            text = "vil er ikh zol kumen tsu im in Yerusholaim. zog ikh gib a kuk on, mayn vayb hot di greste FAMILY in Yisroel." 
        intervals [94]:
            xmin = 317.33 
            xmax = 320.394 
            text = "zeyer a groyse FAMILY, s'a por hundert mentshn." 
        intervals [95]:
            xmin = 320.394 
            xmax = 320.434 
            text = "" 
        intervals [96]:
            xmin = 320.434 
            xmax = 325.455 
            text = "zog ikh, k- un zey hobn undz derzen. ikh ken avekforn fun zey tsu dir? du farsh- zogt er, derbarem dikh," 
        intervals [97]:
            xmin = 325.455 
            xmax = 331.391 
            text = "kum arayn, zogt er, oyf shabes, s'vet zayn far mir aza fargenign, du vest haltn nor fraytik vestu zayn kum arayn, for avek shabes." 
        intervals [98]:
            xmin = 331.391 
            xmax = 335.701 
            text = "ikh hob nisht gekent, ober er iz geven, er hot mir geshikt a PICTURE fun Oyshvits," 
        intervals [99]:
            xmin = 335.701 
            xmax = 337.765 
            text = "hob ikh di PICTURE do fun Oyshvits," 
        intervals [100]:
            xmin = 337.765 
            xmax = 340.233 
            text = "m'hot geshtelt lekhtlekh un er hot mir gedankt mir," 
        intervals [101]:
            xmin = 340.233 
            xmax = 344.467 
            text = "un di khevre ven zey trefn zikh fun der gantser GROUP, nokh biz hayntikn tog, ven zey trefn mikh," 
        intervals [102]:
            xmin = 344.467 
            xmax = 348.966 
            text = "Pinek, m'ken dikh nisht fargesn fun dayn SPEECH vos du host gegebn. dos iz eyns." 
        intervals [103]:
            xmin = 348.966 
            xmax = 356.889 
            text = "tsu morgns vayter, iz iz got helft, hoyb ikh on tsu redn vayter, yo." 
        intervals [104]:
            xmin = 356.889 
            xmax = 363.662 
            text = "in in in hotel. makht zikh vayter a rederay, fun dem fun yenem, dem fun yenem, vi azoy Poyln hot gehandlt," 
        intervals [105]:
            xmin = 363.662 
            xmax = 363.904 
            text = "" 
        intervals [106]:
            xmin = 363.904 
            xmax = 369.883 
            text = "gib ikh mikh a shtel avek, un un demolts hob ikh shoyn gekent redn, s'nisht geven di rusn, m'hot shoyn geven fray, m'hot gekent redn." 
        intervals [107]:
            xmin = 369.883 
            xmax = 375.845 
            text = "shtel ikh mikh avek un zog eyn zakh. iz geven a bisl polyakn. un yidn." 
        intervals [108]:
            xmin = 375.845 
            xmax = 376.071 
            text = "" 
        intervals [109]:
            xmin = 376.071 
            xmax = 383.349 
            text = "zog ikh, ir veyst vu ir tret? yeder trit vos ir tret in Poyln iz oyf blut." 
        intervals [110]:
            xmin = 383.349 
            xmax = 389.297 
            text = "der hotel vos mir zitsn yetst shteyt in geto, iz geven foyer der geto." 
        intervals [111]:
            xmin = 389.297 
            xmax = 389.3 
            text = "" 
        intervals [112]:
            xmin = 389.3 
            xmax = 395.087 
            text = "do iz shteyn mir oyf blut. mir tretn yeder trit iz geven oysgegosn yidish blut." 
        intervals [113]:
            xmin = 395.087 
            xmax = 400.405 
            text = "" 
        intervals [114]:
            xmin = 400.405 
            xmax = 408.431 
            text = "Forum. Forum. ikh bin gevezn in Forum, in Kroke bin ikh gevezn in in dos, in in HOLIDAY INN. der Forum." 
        intervals [115]:
            xmin = 408.431 
            xmax = 408.792 
            text = "" 
        intervals [116]:
            xmin = 408.792 
            xmax = 415.152 
            text = "do ikh dos iz der Forum shteyt dort, ikh hob fotografirt di matseyve fun eh ir veyst dokh der denkmol fun der geto in Varshe." 
        intervals [117]:
            xmin = 415.152 
            xmax = 417.918 
            text = "zog ikh, der hotel shteyt vu der geto iz gevezn." 
        intervals [118]:
            xmin = 417.918 
            xmax = 425.053 
            text = "do hot gebrent fayer, do hobn zikh farbrent yidn, do iz gevorn fargosn liters shvere liters mit blutn." 
        intervals [119]:
            xmin = 425.053 
            xmax = 425.143 
            text = "" 
        intervals [120]:
            xmin = 425.143 
            xmax = 426.431 
            text = "dos hot men getretn." 
        intervals [121]:
            xmin = 426.431 
            xmax = 427.835 
            text = "un dos iz nokh nisht genug." 
        intervals [122]:
            xmin = 427.835 
            xmax = 433.516 
            text = "un dos, ikh hob zey ongehoybn tsu dertseyln, vos ir hot getun do enkere milkhome, vos ir hot gearbet mit di daytshn," 
        intervals [123]:
            xmin = 433.516 
            xmax = 436.303 
            text = "un dos vos ir hot getun nokh der milkhome," 
        intervals [124]:
            xmin = 436.303 
            xmax = 436.703 
            text = "" 
        intervals [125]:
            xmin = 436.703 
            xmax = 440.966 
            text = "az ikh bin arayngekumen keyn Apt, ikh bin gekumen zen mayn bruder," 
        intervals [126]:
            xmin = 440.966 
            xmax = 441.9 
            text = "" 
        intervals [127]:
            xmin = 441.9 
            xmax = 446.011 
            text = "iz hot gevezn dortn zelbn hoyz iz geven a hoyz fun dray shtok." 
        intervals [128]:
            xmin = 446.011 
            xmax = 446.592 
            text = "" 
        intervals [129]:
            xmin = 446.592 
            xmax = 454.393 
            text = "oyfn tsveytn shtok hobn di yidn gevoynt, un oykhet in der zayt un der zayt gevoynt a froy a goye vos hot mikh gekent. oy! panye Pinko! panye Pinko!" 
        intervals [130]:
            xmin = 454.393 
            xmax = 455.714 
            text = "zi hot zikh derfreyt." 
        intervals [131]:
            xmin = 455.714 
            xmax = 456.497 
            text = "" 
        intervals [132]:
            xmin = 456.497 
            xmax = 465.029 
            text = "hot zi mir gezogt mir, az ikh zol nisht shlofn di nakhtn dortn bay di yidn. zog ikh far vos? far vos zol ikh nisht hobn di yidn bay fal? zogt zi, Pinek," 
        intervals [133]:
            xmin = 465.029 
            xmax = 465.373 
            text = "" 
        intervals [134]:
            xmin = 465.373 
            xmax = 472.049 
            text = "kum arayn tsu mir, ikh meyn nisht keyn shlekhts, nor kum arayn, shlof bay mir in hoyz, vestu zayn geratevet." 
        intervals [135]:
            xmin = 472.049 
            xmax = 474.03 
            text = "" 
        intervals [136]:
            xmin = 474.03 
            xmax = 480.386 
            text = "bay nakht zenen gekumen di A.K. bafaln dos hoyz. un m'hot ongehoybn tsu klapn." 
        intervals [137]:
            xmin = 480.386 
            xmax = 480.932 
            text = "" 
        intervals [138]:
            xmin = 480.932 
            xmax = 484.063 
            text = "un zi heyst mikh ontun, di froy heyst mikh ontun." 
        intervals [139]:
            xmin = 484.063 
            xmax = 484.114 
            text = "" 
        intervals [140]:
            xmin = 484.114 
            xmax = 489.39 
            text = "oyb du kenst kum shnel aroys, vel ikh dikh aroysfirn oyf der hintn. zey zenen gekumen in fornt, iz do a balkon fun hintn." 
        intervals [141]:
            xmin = 489.39 
            xmax = 492.199 
            text = "ir veyst aroptsushpringen oyfn hoyf un aroysgeyn oyf a tsveyter gas." 
        intervals [142]:
            xmin = 492.199 
            xmax = 492.252 
            text = "" 
        intervals [143]:
            xmin = 492.252 
            xmax = 497.919 
            text = "hot zi mikh aroysgeyogt oyf der balkon, un ikh hob aropgeshprungen fun di balkon, fun tsveytn shtok," 
        intervals [144]:
            xmin = 497.919 
            xmax = 497.976 
            text = "" 
        intervals [145]:
            xmin = 497.976 
            xmax = 505.803 
            text = "un ikh loyf aroys fun der anderer zayt iz geven a shmole gas s'ahingekumen fun der breyter gas. un ikh loyf oyf Ostrovtser veg un ikh khap a taksi UNK." 
        intervals [146]:
            xmin = 505.803 
            xmax = 507.403 
            text = "UNK." 
        intervals [147]:
            xmin = 507.403 
            xmax = 508.303 
            text = "" 
        intervals [148]:
            xmin = 508.303 
            xmax = 516.43 
            text = "un er fort, zogt er, UNK. zog ikh, UNK. vifl du vest mir zogn, for! ikh hob alts gemeynt m'vet mir nokhloyfn." 
        intervals [149]:
            xmin = 516.43 
            xmax = 516.471 
            text = "" 
        intervals [150]:
            xmin = 516.471 
            xmax = 522.382 
            text = "un er fort avek mit mir keyn Ostrovtse. un zogt mir der prayz, ikh nem aroys un gib im nokh a gutn TIP, un firt mikh tsu, vu?" 
        intervals [151]:
            xmin = 522.382 
            xmax = 524.787 
            text = "fir mikh tsu, zog ikh, tsu der tsu der tsu der ban." 
        intervals [152]:
            xmin = 524.787 
            xmax = 533.678 
            text = "er hot mikh tsugefirt tsu der ban, hob ikh dortn genekhtikt. genakhtikt, a por sho iz nokh gevezn oyf der ban, biz ikh hob bakumen der ban vos fort arayn keyn Tsozomir, zen dem bruder." 
        intervals [153]:
            xmin = 533.678 
            xmax = 534.257 
            text = "" 
        intervals [154]:
            xmin = 534.257 
            xmax = 535.921 
            text = "dos iz geven demolts di nakht." 
        intervals [155]:
            xmin = 535.921 
            xmax = 537.058 
            text = "" 
        intervals [156]:
            xmin = 537.058 
            xmax = 539.617 
            text = "un ikh hob gehaltn a SPEECH demolts in Varshe," 
        intervals [157]:
            xmin = 539.617 
            xmax = 540.079 
            text = "" 
        intervals [158]:
            xmin = 540.079 
            xmax = 542.725 
            text = "hob ikh ze gegebn vos di A.K. hobn gemakht." 
        intervals [159]:
            xmin = 542.725 
            xmax = 545.35 
            text = "hob ikh zey dermant zey, ver zent ir gevezn." 
        intervals [160]:
            xmin = 545.35 
            xmax = 552.3 
            text = "ikh bin geforn in Tshekhn nokh der milkhome, oyf yeder stantsye hot men ayngehaltn di Royte Kreyts un meydelekh mit vayse fertekher" 
        intervals [161]:
            xmin = 552.3 
            xmax = 554.4 
            text = "mit milkh mit zeml mit puter," 
        intervals [162]:
            xmin = 554.4 
            xmax = 560.55 
            text = "m'hot gezogt far di ehm ALL far di imigrantn, far di farshlepte mentshn, vos m'hot zey geshlept, eh s'do mentshn" 
        intervals [163]:
            xmin = 560.55 
            xmax = 564.6 
            text = "vos zenen geven in lagern, zol men aroysgeyn nemen milkh mit zemelekh mit puter." 
        intervals [164]:
            xmin = 564.6 
            xmax = 564.953 
            text = "" 
        intervals [165]:
            xmin = 564.953 
            xmax = 569.351 
            text = "ir hot oykh geheysn makhn puter, ir hot gegebn KADURIM, ir hot geshokhtn." 
        intervals [166]:
            xmin = 569.351 
            xmax = 569.408 
            text = "" 
        intervals [167]:
            xmin = 569.408 
            xmax = 570.532 
            text = "poylish." 
        intervals [168]:
            xmin = 570.532 
            xmax = 571.433 
            text = "" 
        intervals [169]:
            xmin = 571.433 
            xmax = 576.694 
            text = "in poylish. geredt a poylish, ikh hob zey gegebn, zenen geblibn shteyn, hobn zey dos nisht gehert keyn mol." 
        intervals [170]:
            xmin = 576.694 
            xmax = 580.744 
            text = "zog ikh, ver iz geven der A.K.? vos hot ir getun? ir hot gekemft gegn yidn gegn daytshn," 
        intervals [171]:
            xmin = 580.744 
            xmax = 585.494 
            text = "nokh di milkhome hot ir geshosn shvangerdike froyen, yidishe. avekgeharget yedn eynem." 
        intervals [172]:
            xmin = 585.494 
            xmax = 589.819 
            text = "mikh hot ir gevolt avekhargenen, ikh bin antlofn bay nakht, zog ikh, aropgeshprungen fun tsvey shtok a FLOOR," 
        intervals [173]:
            xmin = 589.819 
            xmax = 592.719 
            text = "un antlofn keyn Ostrovtse vi azoy m'hot geharget demolts fir yidn," 
        intervals [174]:
            xmin = 592.719 
            xmax = 592.847 
            text = "" 
        intervals [175]:
            xmin = 592.847 
            xmax = 596.722 
            text = "in dem hoyz. akht iz geven, hot men fir geharget. fir hobn zikh oykh bahaltn." 
        intervals [176]:
            xmin = 596.722 
            xmax = 601.082 
            text = "" 
        intervals [177]:
            xmin = 601.082 
            xmax = 604.198 
            text = "demolts bin ikh nisht geven lang, ikh bin nokh geven demolts, m'hot genumen dem bruder," 
        intervals [178]:
            xmin = 604.198 
            xmax = 604.238 
            text = "" 
        intervals [179]:
            xmin = 604.238 
            xmax = 607.657 
            text = "yetst, yo, bin ikh gevezn dortn bin ikh gevezn akht tog." 
        intervals [180]:
            xmin = 607.657 
            xmax = 608.068 
            text = "" 
        intervals [181]:
            xmin = 608.068 
            xmax = 612.9 
            text = "hob ikh genumen mayn vayb, un dortn ikh hob gedungen bald a taksi in Varshe," 
        intervals [182]:
            xmin = 612.9 
            xmax = 613.026 
            text = "" 
        intervals [183]:
            xmin = 613.026 
            xmax = 617.126 
            text = "un ikh bin geforn di gantse akht tog bizkale ikh bin tsurikgekumen keyn Varshe," 
        intervals [184]:
            xmin = 617.126 
            xmax = 621.851 
            text = "arayngegangen in hotel arayn, genumen dort di peklekh un aropgeforn nakher tsum PLANE un geforn keyn Yisroel." 
        intervals [185]:
            xmin = 621.851 
            xmax = 628.375 
            text = "ikh bin in Yisroel vayter, ir veyst dokh vi s'iz in Yisroel, hob ikh gearbet, gedos un di ales getun," 
        intervals [186]:
            xmin = 628.375 
            xmax = 634.725 
            text = "un m'hot gelebt, m'hot nokh oyfgeboyt zikh a sheyne hoyz in Yisroel, ikh hob gevoynt in a zeyer a sheyn hoyz oyfgeboyt zikh a BEAUTIFUL in Rekhovot," 
        intervals [187]:
            xmin = 634.725 
            xmax = 639.079 
            text = "un m'hot gefirt a sheyn lebn, un un un un zet dokh azoy dos iz es." 
        intervals [188]:
            xmin = 639.079 
            xmax = 641.785 
            text = "" 
        intervals [189]:
            xmin = 641.785 
            xmax = 648.152 
            text = "ikh hob gehat farshidene gesheftn, ikh hob gehat a gesheft un ikh hob gehat ikh hob gearbet, farshidene gesheftn hob ikh gemakht, ober," 
        intervals [190]:
            xmin = 648.152 
            xmax = 650.841 
            text = "ikh hob gelebt. ikh hob gelebt sheyn. ikh hob gelebt sheyn." 
        intervals [191]:
            xmin = 650.841 
            xmax = 652.703 
            text = "" 
        intervals [192]:
            xmin = 652.703 
            xmax = 657 
            text = "o a gut gezelshaft. o hob ikh gehat a zeyer gut gezelshaft. ikh hob gehat eynem a khaver," 
        intervals [193]:
            xmin = 657 
            xmax = 657.853 
            text = "" 
        intervals [194]:
            xmin = 657.853 
            xmax = 662.453 
            text = "alts nay gekumene. alts nay gekumene. ikh hob a gezelshaft eyner vos hot gehat a KOLNOA," 
        intervals [195]:
            xmin = 662.453 
            xmax = 662.592 
            text = "" 
        intervals [196]:
            xmin = 662.592 
            xmax = 670.483 
            text = "yo, hot men zikh getrofn tsuzamen, eyner vos hot gehat a fabrik fun tekstil, m- ikh hob gehat a gute CHEVRA, m'hot zikh getrofn yedn fraytik un shabes, un un afile in mitn der vokh." 
        intervals [197]:
            xmin = 670.483 
            xmax = 674.573 
            text = "" 
        intervals [198]:
            xmin = 674.573 
            xmax = 680.81 
            text = "ikh hob gehat bakante geboyrene, ober di MOST iz geven alts ayngevanderte. alts ayngevanderte frishe. fun Poyln." 
        intervals [199]:
            xmin = 680.81 
            xmax = 681.205 
            text = "" 
        intervals [200]:
            xmin = 681.205 
            xmax = 685.687 
            text = "fun Poyln, Rumenyen, mir hobn zikh gehaltn tsuzamen. m'iz geven gute FRIEND." 
        intervals [201]:
            xmin = 685.687 
            xmax = 688.461 
            text = "" 
        intervals [202]:
            xmin = 688.461 
            xmax = 690.227 
            text = "ikh bin geven in Yisroel tsvontsik yor." 
        intervals [203]:
            xmin = 690.227 
            xmax = 691.583 
            text = "" 
        intervals [204]:
            xmin = 691.583 
            xmax = 696.049 
            text = "ikh bin aroysgeforn zibn un zekhtsik, ven ikh hob geendikt di z- di di milkhome, di zeks-tege milkhome," 
        intervals [205]:
            xmin = 696.049 
            xmax = 696.122 
            text = "" 
        intervals [206]:
            xmin = 696.122 
            xmax = 700.503 
            text = "ikh hob geendikt di zeks-tege milkhome un dos iz geven mayn letste milkhome. dray milkhomes hob ikh mitgemakht in Yisroel." 
        intervals [207]:
            xmin = 700.503 
            xmax = 704.155 
            text = "" 
        intervals [208]:
            xmin = 704.155 
            xmax = 713.5 
            text = "di sibe iz gevezn eh iz azoy. eh eh ir veyst dokh, tsvontsik yor bin ikh gevezn in dort in Yisroel kimat in der ARMY, un do hob ikh mit gemakht Oyshvits dos gantse lebn," 
        intervals [209]:
            xmin = 713.5 
