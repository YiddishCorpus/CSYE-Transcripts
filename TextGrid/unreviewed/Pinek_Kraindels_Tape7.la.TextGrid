            xmax = 1242.41 
            text = "dos iz dokh nisht tsu bagrayfn. m'ken shraybn tog un nakht, m'ken shraybn bikher, m'ken dos nisht ibergebn vos zey hobn opgetun. dos iz gornisht gloyblekh." 
        intervals [369]:
