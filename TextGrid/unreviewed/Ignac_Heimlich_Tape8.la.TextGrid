            text = "" 
        intervals [69]:
            xmin = 187.442 
            xmax = 192.217 
            text = "blaybstu in Sidni, blayb ikh in Sidni beerekh. beerekh tsvey un zekhtsik," 
        intervals [70]:
            xmin = 192.217 
            xmax = 195.095 
            text = "in Sidni bin ikh geven azoy. koydem hob ikh gearbet oyf a JOB," 
        intervals [71]:
            xmin = 195.095 
            xmax = 198.849 
            text = "vayl ikh hob nisht gevolt, ikh hob nisht tsu ton mit keyn rabones, gornisht, ikh hob nisht gevolt," 
        intervals [72]:
            xmin = 198.849 
            xmax = 202.13 
            text = "gearbet oyf a JOB. dervayl ven di rabonim hobn gevoyer gevorn" 
        intervals [73]:
            xmin = 202.13 
            xmax = 202.154 
            text = "" 
        intervals [74]:
            xmin = 202.154 
            xmax = 205.714 
            text = "az ikh bin yo a rov, zenen zey gekumen tsu mir az s'past nisht" 
        intervals [75]:
            xmin = 205.714 
            xmax = 211.342 
            text = "IT'S NOT NICE, UNK WORK, un undz hobn genumen, bin ikh geven, hob ikh hob ikh organizirt" 
        intervals [76]:
            xmin = 211.342 
            xmax = 217.103 
            text = "in Sidni di ale kashres zakhn hob ikh organizirt, mit Reb Ebnzon un mit eh RABBI Svift," 
        intervals [77]:
            xmin = 217.103 
            xmax = 217.159 
            text = "" 
        intervals [78]:
            xmin = 217.159 
            xmax = 221.203 
            text = "zey hobn ales organizirt, azoy bin ikh geven dortn tsvelef yor bin ikh geven dortn kimat." 
