            xmin = 1614.912 
            xmax = 1621.609 
            text = "un keyn matseyve hob ikh nisht gekent shteln, vayl ikh hob nisht gevust, vayl m'hot vu ikh hob moyre gehat vu ikh shtel es vet es zayn kvorim vet zayn dortn." 
