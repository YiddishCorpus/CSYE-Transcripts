            text = "COUNTER'S CAKE SHOP, mayn bruder hot es opgekoyft, un ze'mir gegangen oyf COOLING ROAD, dort ho'mir es gemakht, dortn greser gemakht," 
        intervals [95]:
            xmin = 269.873 
