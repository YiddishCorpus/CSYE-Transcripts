        intervals [481]:
            xmin = 1541.121 
            xmax = 1543.269 
            text = "hob ikh geshribn far der Royte Kreyts" 
        intervals [482]:
            xmin = 1543.269 
            xmax = 1550.112 
            text = "un ikh hob gevolt pinktlekh mer DETAILS tsu visn oyb oyb zey hobn shoyn UNK, vos vos vo- vos nokh visn zey fun tatn, vos iz gevezn." 
        intervals [483]:
            xmin = 1550.112 
            xmax = 1554.128 
            text = "iz dos di dokumentn vos shikn arayn. vos zey hobn mir arayngeshikt." 
        intervals [484]:
            xmin = 1554.128 
            xmax = 1558.364 
            text = "un kedey durkh tsu kukn. leyder visn zey nisht mer azoy fil, er iz geven a yid," 
        intervals [485]:
            xmin = 1558.364 
            xmax = 1566.591 
            text = "far vos er iz geshtorbn veysn zey nisht, ver er iz geshtorbn veysn zey nisht, vu er iz geshtorbn veysn zey nisht. dos iz gornisht, s'gornisht s'iz s'gornisht UNK," 
        intervals [486]:
            xmin = 1566.591 
            xmax = 1572.387 
            text = "un vayzt dikh vos di daytshn dos hobn zey, khuts dem vos zey hobn mir gezogt di dem nomen, dertsu veysn zey gornisht." 
        intervals [487]:
            xmin = 1572.387 
            xmax = 1574.155 
