            text = "" 
        intervals [86]:
            xmin = 241.645 
            xmax = 246.94 
            text = "far vos ikh bin gekumen keyn Melburn, vayl in Melburn do di kinder, dort iz nisht geven keyn yidishkeyt azoy gut far di kinder." 
        intervals [87]:
            xmin = 246.94 
            xmax = 251.848 
            text = "un dortn di kinder hobn nisht gehat keyn khaveyrim. oder shkotsim, oder keyner nisht." 
        intervals [88]:
            xmin = 251.848 
