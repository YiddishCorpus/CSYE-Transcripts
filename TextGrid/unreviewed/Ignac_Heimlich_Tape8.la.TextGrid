            text = "ikh for oyf Pari- oyf eh Oystralye, iz eh" 
        intervals [311]:
            xmin = 1003.376 
            xmax = 1003.703 
            text = "" 
        intervals [312]:
            xmin = 1003.703 
            xmax = 1006.973 
            text = "hot men mir gezogt fun Dzhoynt, hot men mir gezogt, zolst visn" 
        intervals [313]:
            xmin = 1006.973 
            xmax = 1011.951 
            text = "az tomer, un m'zukht in Oystralye zukht men eh hoyzn-shnayders," 
        intervals [314]:
            xmin = 1011.951 
            xmax = 1016.068 
            text = "farshidene arbayters, ober nisht keyn RABBIS. keyn RABBIS zukhn zey nisht beshum oyfn nisht." 
        intervals [315]:
            xmin = 1016.068 
            xmax = 1018.25 
            text = "un oyb ikh vel forn ikh vel geyn mit bord," 
        intervals [316]:
            xmin = 1018.25 
            xmax = 1022.204 
            text = "vestu keyn vestu nisht kenen forn. m'vet dikh nisht lozn, der konsulat vet dikh nisht lozn forn." 
        intervals [317]:
            xmin = 1022.204 
            xmax = 1025.568 
            text = "iz farn ikh gey tsum konsulat, zol ikh mikh opshern di bord." 
        intervals [318]:
            xmin = 1025.568 
            xmax = 1028.226 
            text = "a klal, ikh hob gefregt farshidene eytses," 
        intervals [319]:
            xmin = 1028.226 
            xmax = 1031.112 
            text = "ale hobn gezogt, yo, vos heyst, s'geven di milkhome in Koree," 
        intervals [320]:
            xmin = 1031.112 
            xmax = 1034.998 
            text = "m'zol loyfn, loyfn zol ikh, shoyn zolst kenen forn, ikh zol kenen forn oyf Oystralye." 
        intervals [321]:
            xmin = 1034.998 
            xmax = 1035.057 
            text = "" 
        intervals [322]:
            xmin = 1035.057 
            xmax = 1038.088 
            text = "a klal, bin ikh geforn, gegangen, ikh hob mir opgeshoyrn di bord," 
        intervals [323]:
            xmin = 1038.088 
            xmax = 1038.262 
            text = "" 
        intervals [324]:
            xmin = 1038.262 
            xmax = 1042.588 
            text = "un un ikh hob opgeshoyrn di bord, bin ikh geven in besmedresh iz geven a groyser" 
        intervals [325]:
            xmin = 1042.588 
            xmax = 1045.347 
            text = "tuml, hayitokhn? UNK hob ikh zey gezogt, herts mikh oys," 
        intervals [326]:
            xmin = 1045.347 
            xmax = 1047.642 
            text = "ikh hob nisht gevolt dertseyln di gantse mayse far vos," 
        intervals [327]:
            xmin = 1047.642 
            xmax = 1051.84 
            text = "hob ikh zey gezogt az eh s'geve- ikh hob gez- farloyrn gelt in shtub," 
        intervals [328]:
            xmin = 1051.84 
            xmax = 1051.864 
            text = "" 
        intervals [329]:
            xmin = 1051.864 
            xmax = 1055.641 
            text = "un s'hot zikh gemakht, ikh hob genumen a likht, ikh hob es gezukht, ikh hob gemakht a sreyfe," 
        intervals [330]:
            xmin = 1055.641 
            xmax = 1059.823 
            text = "un s'hot zikh gemakht a sreyfe hob ikh shoyn eh m'hot gemuzt aropnemen di gantse bord." 
        intervals [331]:
            xmin = 1059.823 
            xmax = 1059.964 
            text = "" 
        intervals [332]:
            xmin = 1059.964 
            xmax = 1062.675 
            text = "ober interesant iz geven, ven ikh bin gekumen tsum konsul," 
        intervals [333]:
            xmin = 1062.675 
            xmax = 1063.373 
            text = "" 
        intervals [334]:
            xmin = 1063.373 
            xmax = 1065.977 
            text = "hob i- hob ikh gemeynt, ikh kum shoyn tsum konsulat" 
        intervals [335]:
            xmin = 1065.977 
            xmax = 1066.004 
            text = "" 
        intervals [336]:
            xmin = 1066.004 
            xmax = 1068.55 
            text = "vet er shoyn zikher nisht hobn keyn shum trakhtenisher." 
        intervals [337]:
            xmin = 1068.55 
            xmax = 1074.521 
            text = "di ershte shayle vos der konsul hot gefregt, ""AREN'T YOU A RABBI?"" hot er mikh gefregt." 
        intervals [338]:
            xmin = 1074.521 
            xmax = 1074.645 
            text = "" 
        intervals [339]:
            xmin = 1074.645 
            xmax = 1076.591 
            text = "zog ikh farn konsulat," 
        intervals [340]:
            xmin = 1076.591 
            xmax = 1080.067 
            text = "WHY DO YOU THINK, far vos trakhtstu az ikh bin a a RABBI?" 
        intervals [341]:
            xmin = 1080.067 
            xmax = 1085.98 
            text = "zogt er, der WAY vos ikh kum, vayl dort er iz gezesn inevendik, un s'gevezn a groyse koridor." 
        intervals [342]:
            xmin = 1085.98 
            xmax = 1089.571 
            text = "zogt er, di WAY azoy vi ikh gey, gey ikh punkt vi a RABBI." 
        intervals [343]:
            xmin = 1089.571 
            xmax = 1089.715 
            text = "" 
        intervals [344]:
            xmin = 1089.715 
            xmax = 1093.01 
            text = "shoyn, hob ikh ikh makh, hob ikh gezogt, ikh vel zogn dem emes." 
        intervals [345]:
            xmin = 1093.01 
            xmax = 1098.343 
            text = "az mayn tate iz gevezn a RABBI, er hot undz gelozt lernen tsu zayn a RABBI," 
        intervals [346]:
            xmin = 1098.343 
            xmax = 1103.034 
            text = "nor azoy vi s'gevorn di milkhome, hob ikh gezen az fun keyn RABBI vel ikh keyn lebn nisht makhn." 
        intervals [347]:
            xmin = 1103.034 
            xmax = 1105.268 
            text = "bin ikh gegangen ikh hob mikh oysgelernt fakhn," 
        intervals [348]:
            xmin = 1105.268 
            xmax = 1108.95 
            text = "vegn dem ikh hob ikh mir oysgelernt hitstert tsu makhn leder WORKER," 
        intervals [349]:
            xmin = 1108.95 
            xmax = 1113.2 
            text = "un er zest dokh az ikh hob dortn iz oyfgeshribn az ikh bin a kapl makher," 
        intervals [350]:
            xmin = 1113.2 
            xmax = 1115.791 
            text = "un az UNK az ikh ken di ale fakhn ken ikh," 
        intervals [351]:
            xmin = 1115.791 
            xmax = 1120.518 
            text = "az ikh kum oyf Oystralye, zol ikh kenen makhn fun dos a a lebn un nisht fun RABBI." 
        intervals [352]:
            xmin = 1120.518 
            xmax = 1123.225 
            text = "nu, s'im gefeln gevorn, hot er dos ongenumen." 
        intervals [353]:
            xmin = 1123.225 
            xmax = 1127.542 
            text = "un mimeyle vegn dem ikh hob ikh nokh a bild on a bord azoy vi ikh hob oysgezen." 
        intervals [354]:
            xmin = 1127.542 
            xmax = 1130.721 
            text = "" 
        intervals [355]:
            xmin = 1130.721 
            xmax = 1132.827 
            text = "un azoy ikh hob shoyn gemuzt hobn a fakh," 
        intervals [356]:
            xmin = 1132.827 
            xmax = 1136.671 
            text = "andersh ken men nisht forn. un ikh hob nisht keyn shum ts- keyn eh tsetl nisht derfun," 
        intervals [357]:
            xmin = 1136.671 
            xmax = 1136.745 
            text = "" 
        intervals [358]:
            xmin = 1136.745 
            xmax = 1142.311 
            text = "bin ikh gegangen in Ort, in Ort hob ikh genumen, ikh hob mikh oysgelernt, ikh hob gemakht der dem briv-tash," 
        intervals [359]:
            xmin = 1142.311 
            xmax = 1147.93 
            text = "nor vos den, azoy vi s'gevezn eyn vos iz a shvere, vayl s'shoyn nisht geven keyn tsayt, vayl s'shoyn gevezn mamesh farn endikn," 
        intervals [360]:
            xmin = 1147.93 
            xmax = 1151.634 
            text = "un makhn mit zeyere mashinen er hot nisht gevust, hob ikh gevust ikh vel nisht kenen." 
        intervals [361]:
            xmin = 1151.634 
            xmax = 1153.929 
            text = "bin ikh gegangen, ikh hob genumen mayn moyel meserl," 
        intervals [362]:
            xmin = 1153.929 
            xmax = 1157.38 
            text = "un ikh hob genumen, mit dem hob ikh es opgesharft dem leder baym ek," 
        intervals [363]:
            xmin = 1157.38 
            xmax = 1161.523 
            text = "un ikh hob es ts- gemakht, tsu ales tsugeshnitn, ales geven zeyer sheyn aroysgekumen" 
        intervals [364]:
            xmin = 1161.523 
            xmax = 1163.742 
            text = "un tsum sof hob ikh bakumen a tsertifikat." 
        intervals [365]:
            xmin = 1163.742 
            xmax = 1167.024 
            text = "nor vos den, ikh hob nisht bakumen keyn hundert protsentike tsertifikat," 
        intervals [366]:
            xmin = 1167.024 
            xmax = 1172.804 
            text = "far vos, vayl ikh hob geton a groyse feler. vos iz geven der feler? ikh hob es geneyt farkert oyf der mashin." 
        intervals [367]:
            xmin = 1172.804 
            xmax = 1175.765 
            text = "ikh hob es take aleyn geneyt, un ikh hob gevust es shoyn tsu neyen," 
        intervals [368]:
            xmin = 1175.765 
            xmax = 1180.364 
            text = "ober az m'zol es neyen farkert, hob ikh nisht az s'a khilek az m'leygt arayn farkert azoy tsu azoy," 
        intervals [369]:
            xmin = 1180.364 
            xmax = 1183.636 
            text = "mimeyle ober al kol ponem, a k- a tsertifikat hob ikh bakumen," 
        intervals [370]:
            xmin = 1183.636 
            xmax = 1188.318 
            text = "un mit dem bin ikh gekumen oyf Oystralye als a leder WORKER, mit dem briv-tash." 
        intervals [371]:
            xmin = 1188.318 
            xmax = 1188.484 
            text = "" 
        intervals [372]:
            xmin = 1188.484 
            xmax = 1191.481 
            text = "un dos hob ikh nokh azoy, leyg ikh es avek lezeykher." 
        intervals [373]:
            xmin = 1191.481 
            xmax = 1195.032 
            text = "" 
        intervals [374]:
            xmin = 1195.032 
            xmax = 1199.615 
            text = "dos iz der zeyde mayner, dem tatn's tate, reb Nokhem." 
        intervals [375]:
            xmin = 1199.615 
            xmax = 1199.655 
            text = "" 
        intervals [376]:
            xmin = 1199.655 
            xmax = 1201.994 
            text = "er hot gevoynt in Kemetsh hot er gevoynt," 
        intervals [377]:
            xmin = 1201.994 
            xmax = 1202.052 
            text = "" 
        intervals [378]:
            xmin = 1202.052 
            xmax = 1206.073 
            text = "un er iz geven a yid a groyser erlekher yid, er iz geven zeyer a kluger yid." 
        intervals [379]:
            xmin = 1206.073 
            xmax = 1209.892 
            text = "ikh hob getrofn a a eyner vos er voynt in Kemetsh," 
        intervals [380]:
            xmin = 1209.892 
            xmax = 1209.932 
            text = "" 
        intervals [381]:
            xmin = 1209.932 
            xmax = 1213.954 
            text = "hot er mir a mol gezogt az eh, oysgekumen a shmues," 
        intervals [382]:
            xmin = 1213.954 
            xmax = 1216.299 
            text = "zogt zi, ir zent reb Nokhem's an eynikl?" 
        intervals [383]:
            xmin = 1216.299 
            xmax = 1219.277 
            text = "zogt er, aza klugn yid vi reb Nokhem iz gevezn" 
        intervals [384]:
            xmin = 1219.277 
            xmax = 1222.632 
            text = "hot zi nokh nisht getrofn. er hot gehat a shem fun a klugn yid." 
        intervals [385]:
            xmin = 1222.632 
            xmax = 1222.875 
            text = "" 
        intervals [386]:
            xmin = 1222.875 
            xmax = 1228.348 
            text = "un eh nebekh ikh ho- ikh hob im nokh ikh hob im nokh gekent, nor ikh hob gevust iber im veynik. er ligt in Pest." 
        intervals [387]:
            xmin = 1228.348 
            xmax = 1230.972 
            text = "ven ikh bin gevezn in Pest, bin ikh gevezn oyfn beys-akvores," 
        intervals [388]:
            xmin = 1230.972 
            xmax = 1233.858 
            text = "freg ikh dortn dem shoymer fun fun dem," 
        intervals [389]:
            xmin = 1233.858 
            xmax = 1237.908 
            text = "efsher veyst ir vu ligt do mayn zeyde reb Nokhem Heymlekh? o!" 
        intervals [390]:
            xmin = 1237.908 
            xmax = 1237.91 
            text = "" 
        intervals [391]:
            xmin = 1237.91 
            xmax = 1243.39 
            text = "dortn pinktlekh hot er es gevust oyfn plats, der ershter blik hot er bald gevust vu UNK, vu er ligt." 
        intervals [392]:
            xmin = 1243.39 
            xmax = 1248.222 
            text = "" 
        intervals [393]:
            xmin = 1248.222 
            xmax = 1257.261 
            text = "dos iz der zeyde fun Korat. di di mame's eltern. tate un der mame's, tate un mame's mame." 
        intervals [394]:
            xmin = 1257.261 
            xmax = 1257.351 
            text = "" 
        intervals [395]:
            xmin = 1257.351 
            xmax = 1259.977 
            text = "zey zenen geshtorbn eygntlekh in eyn tog." 
        intervals [396]:
            xmin = 1259.977 
            xmax = 1260.102 
            text = "" 
        intervals [397]:
            xmin = 1260.102 
            xmax = 1263.296 
            text = "dos heyst zey zenen gevorn fargazt. vayl er iz geven a groyser oysher," 
        intervals [398]:
            xmin = 1263.296 
            xmax = 1268.803 
            text = "kuk nisht oyfn hut, vosere hut er hot, nor er iz geven a yid a groyser oysher iz er gevezn," 
        intervals [399]:
            xmin = 1268.803 
            xmax = 1268.944 
            text = "" 
        intervals [400]:
            xmin = 1268.944 
            xmax = 1272.594 
            text = "un er iz geforn oyf eh zumer, vinter iz er geforn" 
        intervals [401]:
            xmin = 1272.594 
            xmax = 1275.681 
            text = "oyf eh Karlsbad, Maryenbad, dort yener gegnt," 
        intervals [402]:
            xmin = 1275.681 
            xmax = 1275.717 
            text = "" 
        intervals [403]:
            xmin = 1275.717 
            xmax = 1279.49 
            text = "un er hot gevoynt in a dort in Korat, iz er nisht geven gevoynt tsu keyn gaz." 
        intervals [404]:
            xmin = 1279.49 
            xmax = 1282.672 
            text = "dort iz shoyn gevezn gaz-oyvns iz shoyn geven dortn," 
        intervals [405]:
            xmin = 1282.672 
            xmax = 1288.074 
            text = "un zet m'hot nisht farmakht dem gaz vi es darf tsu zayn, zenen zey nebekh beyde gevorn fargazt dortn." 
        intervals [406]:
            xmin = 1288.074 
            xmax = 1288.992 
            text = "" 
        intervals [407]:
            xmin = 1288.992 
            xmax = 1293.828 
            text = "zayn nomen iz Mortkhe Itsik Samet, un di babe iz gevezn Pesl Samet." 
        intervals [408]:
            xmin = 1293.828 
            xmax = 1294.02 
            text = "" 
        intervals [409]:
            xmin = 1294.02 
            xmax = 1298.008 
            text = "un er hot gehat eydemer, er iz geven a groyser oysher, hot er gehat eydemer" 
        intervals [410]:
            xmin = 1298.008 
            xmax = 1303.036 
            text = "loyter talmide-khakhomim, hot er nokh gelozt a sakh gelt, un er hot gehat a gvaldik groyse" 
        intervals [411]:
            xmin = 1303.036 
            xmax = 1305.269 
            text = "a groyse vertshaft hot er gehat bay zikh." 
        intervals [412]:
            xmin = 1305.269 
            xmax = 1305.58 
            text = "" 
        intervals [413]:
            xmin = 1305.58 
            xmax = 1311.412 
            text = "un er iz geven a groyser Kerestirer khosid. Kerestirer hot er gegebn a sakh gelt oyf Kerestir." 
        intervals [414]:
            xmin = 1311.412 
            xmax = 1312.988 
            text = "" 
        intervals [415]:
            xmin = 1312.988 
            xmax = 1317.018 
            text = "un zayn matseyve, o zayn matseyve shteyt nokh haynt" 
        intervals [416]:
            xmin = 1317.018 
            xmax = 1322.595 
            text = "in Korat. iz gevezn a, er hot gehat a goy vos der goy hot geheysn Ontol Batshi." 
        intervals [417]:
            xmin = 1322.595 
            xmax = 1327.995 
            text = "er hot gearbet bay im yorn yorn lang. nokh der milkhome, in der milkhome heyst es," 
        intervals [418]:
            xmin = 1327.995 
            xmax = 1330.717 
            text = "iz er hot, un nokh hitstert nokh der milkhome, nokh bay di rusn," 
        intervals [419]:
            xmin = 1330.717 
            xmax = 1330.74 
            text = "" 
        intervals [420]:
            xmin = 1330.74 
            xmax = 1334.188 
            text = "hot er hot men gevolt tsunemen dem gantsn beys-akvores," 
        intervals [421]:
            xmin = 1334.188 
            xmax = 1339.526 
            text = "hot er gezogt az der Samet di mishpokhe Samet lot er nisht beshum oyfn nisht." 
        intervals [422]:
            xmin = 1339.526 
            xmax = 1339.6 
            text = "" 
        intervals [423]:
            xmin = 1339.6 
            xmax = 1348.355 
            text = "oyb m'vil es t- BULLDOZEn iz nor durkh zayn kerper. iz geblibn der zeyde, di babe, un a mume, iz geblibn der gantser keyver." 
        intervals [424]:
            xmin = 1348.355 
            xmax = 1352.362 
            text = "interesant iz az eyn mayner a geshvesterkind vos hot gevoynt in Korat" 
        intervals [425]:
            xmin = 1352.362 
            xmax = 1354.893 
            text = "iz geforn oyf Korat, dort hot der goy gelebt," 
        intervals [426]:
            xmin = 1354.893 
            xmax = 1358.125 
            text = "un er hot im dertseylt di gantse mayse un er hot es gelozt farrekhtn" 
        intervals [427]:
            xmin = 1358.125 
            xmax = 1362.006 
            text = "mit CONCRETE s'zol zayn zeyer gut. dem andern tog iz der goy geshtorbn." 
        intervals [428]:
            xmin = 1362.006 
            xmax = 1364.433 
            text = "er iz shoyn alt geven kimat hundert yor, geven der goy." 
        intervals [429]:
            xmin = 1364.433 
            xmax = 1367.747 
            text = "" 
        intervals [430]:
            xmin = 1367.747 
            xmax = 1371.808 
            text = "azoy hob ikh oysgezen in Poking. hob ikh azoy oysgezen." 
        intervals [431]:
            xmin = 1371.808 
            xmax = 1373.265 
            text = "" 
        intervals [432]:
            xmin = 1373.265 
            xmax = 1375.284 
            text = "bin ikh alt geven dray un tsvontsik yor." 
        intervals [433]:
            xmin = 1375.284 
            xmax = 1375.611 
            text = "" 
        intervals [434]:
            xmin = 1375.611 
            xmax = 1378.76 
            text = "mayn yidene hot gehaltn az ikh ze oys vi eyner vos iz alt finef un fertsik." 
        intervals [435]:
            xmin = 1378.76 
            xmax = 1383.357 
            text = "" 
        intervals [436]:
            xmin = 1383.357 
            xmax = 1389.876 
            text = "dos iz a sh- a vi nokh geheysn, a TEUDA" 
        intervals [437]:
            xmin = 1389.876 
            xmax = 1397.154 
            text = "a COPY fun dem vos ven der tate, fun der vos m'get ven der tate iz, fun vos der tate iz geshtorbn in Daytshland." 
        intervals [438]:
            xmin = 1397.154 
            xmax = 1397.211 
            text = "" 
        intervals [439]:
            xmin = 1397.211 
            xmax = 1401.204 
            text = "dos hot keyner nisht bakumen, dos iz kimat nishto aza zakh." 
        intervals [440]:
            xmin = 1401.204 
            xmax = 1401.227 
            text = "" 
        intervals [441]:
            xmin = 1401.227 
            xmax = 1405.628 
            text = "ven ikh bin geven eh in Daytshland hob ikh gefregt vi kumt dos az s'zol zayn?" 
        intervals [442]:
            xmin = 1405.628 
            xmax = 1412.142 
            text = "hobn zey nokhgekukt in bikhl, iz geven dort ayngeshribn, ober keyn anderer mentsh iz keyner nisht ayngeshribn nor er." 
        intervals [443]:
            xmin = 1412.142 
            xmax = 1414.547 
            text = "vos dos iz farshtey ikh nisht un ikh veys nisht." 
        intervals [444]:
            xmin = 1414.547 
            xmax = 1422.113 
            text = "ober al kol ponem, s'gevezn a zakh min-ashomaim, vos durkh dem bin ikh gevoyer gevorn pinktlekh vu der tate ligt." 
        intervals [445]:
            xmin = 1422.113 
            xmax = 1422.118 
            text = "" 
        intervals [446]:
            xmin = 1422.118 
            xmax = 1425.574 
            text = "bin ikh gevoyer gevorn er iz geven az er ligt in Daytshland, bin ikh geven dortn," 
        intervals [447]:
            xmin = 1425.574 
            xmax = 1434.603 
            text = "hob ikh bakumen az er ligt dortn nisht vayt fun fun Kovbayern, iz a shtikl veg fun dortn. in in a feld." 
        intervals [448]:
            xmin = 1434.603 
            xmax = 1438.636 
            text = "vos dort iz geven der lager iz geven dort. UNK zet men shoyn gornisht, ikh bin geven dortn," 
        intervals [449]:
            xmin = 1438.636 
            xmax = 1438.687 
            text = "" 
        intervals [450]:
            xmin = 1438.687 
            xmax = 1442.392 
            text = "m'zet dortn gornisht keyn shum lager nisht, alts bavaksn dortn," 
        intervals [451]:
            xmin = 1442.392 
            xmax = 1448.574 
            text = "nor vos m'zet iz do a eh az do a s'do leydiker plats, s'hot a geder," 
        intervals [452]:
            xmin = 1448.574 
            xmax = 1455.028 
            text = "un der geder, dort iz do dray matseyves, hob ikh shoyn nisht gevolt shteln dort keyn matseyve, ikh hob nor geshtelt a" 
        intervals [453]:
            xmin = 1455.028 
            xmax = 1457.921 
            text = "a shteyn, oyf der vant hob ikh es geshtelt." 
        intervals [454]:
            xmin = 1457.921 
            xmax = 1458.703 
            text = "" 
        intervals [455]:
            xmin = 1458.703 
            xmax = 1462.067 
            text = "vifl mol m'iz gekumen zukhn dem vu dem vu dos iz," 
        intervals [456]:
            xmin = 1462.067 
            xmax = 1462.092 
            text = "" 
        intervals [457]:
            xmin = 1462.092 
            xmax = 1466.501 
            text = "iz alts geshen interesante zakh. m'iz gekumen, vu iz <doses> plats hot keyner nisht gevust." 
        intervals [458]:
            xmin = 1466.501 
            xmax = 1471.774 
            text = "iz eyn mol gekumen stam a goy iz gekumen, zogt er mir azoy, o, ikh veys vu s'iz. punkt damolts" 
        intervals [459]:
            xmin = 1471.774 
            xmax = 1473.797 
            text = "iz er arayngekumen dort in di IRIYA," 
        intervals [460]:
            xmin = 1473.797 
            xmax = 1479.297 
            text = "in der shtot-hoyz iz er arayngekumen, er hot mir gezogt vu dos iz. un di tsveyte mol vi gekumen iz gekumen a goye" 
        intervals [461]:
            xmin = 1479.297 
            xmax = 1483.206 
            text = "un zi hot punkt gehat a ACCIDENT, a vokh frier hot zi gehat an ACCIDENT derlebn," 
        intervals [462]:
            xmin = 1483.206 
            xmax = 1487.616 
            text = "undz ze'mir gekumen, hot zi gevust pinktlekh vu es iz, azoy iz zi gekumen mir vayzn vu s'iz." 
        intervals [463]:
            xmin = 1487.616 
            xmax = 1493.581 
            text = "un dos dort hot zi mir, dos iz dos plats. un bin ikh gevoyer gevorn nokh dem, der plats iz gekumen iz fun Riderlikh," 
        intervals [464]:
            xmin = 1493.581 
            xmax = 1497.476 
            text = "ober der Riderlikh ekzistirt shoyn haynt nisht. zey visn nisht vu dos iz." 
        intervals [465]:
            xmin = 1497.476 
            xmax = 1497.752 
            text = "" 
        intervals [466]:
            xmin = 1497.752 
            xmax = 1502.145 
            text = "un al kol ponem iz eh di yidn in Daytshland, in Minkhn," 
        intervals [467]:
            xmin = 1502.145 
            xmax = 1504.931 
            text = "hob ikh zey, zey geyen a mol on tsum tsien," 
