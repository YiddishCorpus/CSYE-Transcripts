            text = "az s'lign dortn fir hundert kdoyshim, muz es muz es helfn." 
        intervals [475]:
            xmin = 1527.295 
            xmax = 1528.498 
            text = "" 
        intervals [476]:
            xmin = 1528.498 
            xmax = 1531.512 
            text = "un s'zol take helfn vayter. zkhusom yogn oleynu." 
