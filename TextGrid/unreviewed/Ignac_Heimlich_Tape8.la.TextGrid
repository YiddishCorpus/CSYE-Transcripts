            xmin = 1504.931 
            xmax = 1504.945 
            text = "" 
        intervals [469]:
            xmin = 1504.945 
            xmax = 1507.672 
            text = "vayl ikh hob zey gezogt, koydem kol gehaltn dortn, lign dortn" 
        intervals [470]:
            xmin = 1507.672 
            xmax = 1511.445 
            text = "eh nokh a fir hundert andere yidn lign oykh dortn." 
        intervals [471]:
            xmin = 1511.445 
            xmax = 1515.721 
            text = "un eh hob ikh zey gezogt az der eyner hot er broykh tsu hobn a yeshue" 
        intervals [472]:
            xmin = 1515.721 
            xmax = 1519.813 
            text = "zol er geyn ahin, vet er geholfn vern. un zey hobn take gezen az s'iz take azoy." 
        intervals [473]:
            xmin = 1519.813 
            xmax = 1522.791 
            text = "un ay vi vi hob ikh mikh getroyt aza zakh tsu zogn?" 
        intervals [474]:
            xmin = 1522.791 
