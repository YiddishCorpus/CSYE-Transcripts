            text = "hob ikh gezogt ikh muz kumen oyf Melburn." 
        intervals [90]:
            xmin = 253.859 
            xmax = 257.485 
            text = "ikh bin gekumen oyf Melburn, in Melburn ho'mir geefnt a gesheft," 
        intervals [91]:
            xmin = 257.485 
