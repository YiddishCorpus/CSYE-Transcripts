            text = "ikh hob gearbet in eh Penfold" 
        intervals [82]:
            xmin = 227.685 
            xmax = 234.264 
            text = "vayn vayn FACTORY. ober zey hobn mikh opgezogt vayl ikh bin nisht gekumen yontev un aher un s'geven." 
        intervals [83]:
            xmin = 234.264 
