            text = "" 
        intervals [6]:
            xmin = 22.489 
            xmax = 28.51 
            text = "ober, FIRST I WANT TO TELL YOU HERE I COME, I DI- I DIDN'T COME TO SYDNEY YET. I WAS STILL IN PARIS." 
        intervals [7]:
            xmin = 28.51 
            xmax = 31.899 
            text = "SO ikh bin geven in PARIS iz gevezn hob ikh bahat," 
        intervals [8]:
            xmin = 31.899 
            xmax = 31.921 
            text = "" 
        intervals [9]:
            xmin = 31.921 
            xmax = 33.987 
            text = "WITH APPEARANCE OF AFTER THAT" 
        intervals [10]:
            xmin = 33.987 
            xmax = 34.064 
            text = "" 
        intervals [11]:
            xmin = 34.064 
            xmax = 37.441 
            text = "WE WILL GO EH THEY HAD A LOT OF QUESTIONS, gehat a sakh shayles do-hi," 
        intervals [12]:
            xmin = 37.441 
            xmax = 41.675 
            text = "WELFARE, farshidene shayles, tsi I ikh ze oys elter, ikh ze oys yinger," 
        intervals [13]:
            xmin = 41.675 
            xmax = 48.144 
            text = "ober zi hot mir gornisht gefregt, zi hot ales geFIXed, aleyn. vayl zi ken dokh mikh. zi iz dokh UNK shoyn." 
        intervals [14]:
            xmin = 48.144 
            xmax = 49.466 
            text = "a mol baku-" 
        intervals [15]:
            xmin = 49.466 
            xmax = 49.692 
            text = "" 
        intervals [16]:
            xmin = 49.692 
            xmax = 56.092 
            text = "a froy, yo, di Koyen, Koyen Eyvo, vos iz gevezn, Koyen. un shoyn zi hot mir dos ales erleydikt," 
        intervals [17]:
            xmin = 56.092 
            xmax = 61.171 
            text = "un ikh bakum di papirn, far der vayb, ikh bakum di papirn, forn." 
        intervals [18]:
            xmin = 61.171 
            xmax = 62.01 
            text = "" 
        intervals [19]:
            xmin = 62.01 
            xmax = 64.518 
            text = "a klal, s'shoyn gekumen tsu forn," 
        intervals [20]:
            xmin = 64.518 
            xmax = 64.575 
            text = "" 
        intervals [21]:
            xmin = 64.575 
            xmax = 69.007 
            text = "a klal, zogt mir der Dzhoynt, az du vest forn mit der bord kenstu nisht forn." 
        intervals [22]:
            xmin = 69.007 
            xmax = 69.823 
            text = "" 
        intervals [23]:
            xmin = 69.823 
            xmax = 72.571 
            text = "vayl m'vet zen bald az du, broykhst tsu geyn tsum konsulat," 
        intervals [24]:
            xmin = 72.571 
            xmax = 72.732 
            text = "" 
        intervals [25]:
            xmin = 72.732 
            xmax = 77.693 
            text = "vest kumen tsum konsulat, un konsulat vet nisht gleybn az du bist a leder WORKER mit ale mayses," 
        intervals [26]:
            xmin = 77.693 
            xmax = 81.083 
            text = "er vet zogn bald du bist a RABBI, un fartik, vest gornisht hobn." 
        intervals [27]:
            xmin = 81.083 
            xmax = 81.248 
            text = "" 
        intervals [28]:
            xmin = 81.248 
            xmax = 85.241 
            text = "DON'T WORRY. bin ikh gegangen a sheynem opgeshoyrn di bord." 
        intervals [29]:
            xmin = 85.241 
            xmax = 85.855 
            text = "" 
        intervals [30]:
            xmin = 85.855 
            xmax = 91.771 
            text = "m'hot opgeshoyrn di bord in gantsn, un ikh kum in besmedresh arayn," 
        intervals [31]:
            xmin = 91.771 
            xmax = 91.947 
            text = "" 
        intervals [32]:
            xmin = 91.947 
            xmax = 94.34 
            text = "zogt mir yeder eyner vos vos iz geshen?" 
        intervals [33]:
            xmin = 94.34 
            xmax = 96.853 
            text = "zog ikh, fregt nisht. WHAT HAPPENED?" 
        intervals [34]:
            xmin = 96.853 
            xmax = 99.5 
            text = "s'gevezn, ikh hob farloyrn gelt untern bet," 
        intervals [35]:
            xmin = 99.5 
            xmax = 99.726 
            text = "" 
        intervals [36]:
            xmin = 99.726 
            xmax = 103.461 
            text = "un ikh hob genumen a likhtl tsu zukhn es, hot mir ongetsundn di bord." 
        intervals [37]:
            xmin = 103.461 
            xmax = 108.287 
            text = "nu az s'hot zikh ongetsundn di bord hob ikh gemuzt hob ikh gemuzt shoyn makhn in gantsn di bord sheyn gemakht, ikh hob es opgeshoyrn." 
        intervals [38]:
            xmin = 108.287 
            xmax = 109.541 
            text = "keyner nisht dertseylt." 
        intervals [39]:
            xmin = 109.541 
            xmax = 110.357 
            text = "" 
        intervals [40]:
            xmin = 110.357 
            xmax = 115.45 
            text = "un nokh dem, un ikh zog geforn, un ikh hob shoyn gehat di papirn ober m'hot nokh alts nisht gevolt forn vayl tsk" 
        intervals [41]:
            xmin = 115.45 
            xmax = 119.818 
            text = "vu'z Oystralye? ver Oystralye? Oystralye? s'gevorn di milkhome in Koree." 
        intervals [42]:
            xmin = 119.818 
            xmax = 119.824 
            text = "" 
        intervals [43]:
            xmin = 119.824 
            xmax = 122.766 
            text = "hot yeder geshrign, oy meshugener, for for!" 
        intervals [44]:
            xmin = 122.766 
            xmax = 122.837 
            text = "" 
        intervals [45]:
            xmin = 122.837 
            xmax = 126.422 
            text = "Oystralye iz azoy vayt, dort vet zikher nisht zayn keyn milkhome." 
        intervals [46]:
            xmin = 126.422 
            xmax = 129.876 
            text = "dort iz zikher, yeder hot yeder hot azoy gemeynt demolts. dort vet zikher nisht zayn keyn milkhome." 
        intervals [47]:
            xmin = 129.876 
            xmax = 130.089 
            text = "" 
        intervals [48]:
            xmin = 130.089 
            xmax = 133.301 
            text = "azoy ze'mir demolts gekumen keyn keyn Oystralye." 
        intervals [49]:
            xmin = 133.301 
            xmax = 133.425 
            text = "" 
        intervals [50]:
            xmin = 133.425 
            xmax = 136.659 
            text = "ze'mir gekumen keyn Oystralye ze'mir gekumen, ho'mir gemuzt kumen koydem oyf Sidni," 
        intervals [51]:
            xmin = 136.659 
            xmax = 138.353 
            text = "" 
        intervals [52]:
            xmin = 138.353 
            xmax = 141.387 
            text = "mit a shif, Pro- Prot- yo, Protea." 
        intervals [53]:
            xmin = 141.387 
            xmax = 147.673 
            text = "Pro- Protea. zeyer a shlekhte shif, ober mir ho'mir nisht gekent vartn, vayl demolts di froy iz geven shvanger," 
        intervals [54]:
            xmin = 147.673 
            xmax = 150.178 
            text = "un un s'kimat in zibetn khoydesh." 
        intervals [55]:
            xmin = 150.178 
            xmax = 153.754 
            text = "di froy hot geshvangert. kimat, dos iz dem dritn, yo." 
        intervals [56]:
            xmin = 153.754 
            xmax = 158.298 
            text = "un kimat in zibetn khoydesh, az oyb m'hot oyb m'iz veyst az dos dortn, volt men shoyn nisht forn." 
        intervals [57]:
            xmin = 158.298 
            xmax = 160.719 
            text = "ho'mir gezogt zogn lignt az s'iz zekstn khoydesh," 
        intervals [58]:
            xmin = 160.719 
            xmax = 164.368 
            text = "un m'hot gemuzt khapn dem ershtn shif vos m'khapt fort men shoyn." 
        intervals [59]:
            xmin = 164.368 
            xmax = 167.912 
            text = "azoy borekh-hashem ze'mir gekumen mit dem shif. ze'mir ongekumen far peysekh," 
        intervals [60]:
            xmin = 167.912 
            xmax = 167.914 
            text = "" 
        intervals [61]:
            xmin = 167.914 
            xmax = 170.46 
            text = "un s'borekh-hashem geven gants fayn ze'mir ongekumen." 
        intervals [62]:
            xmin = 170.46 
            xmax = 173.672 
            text = "" 
        intervals [63]:
            xmin = 173.672 
            xmax = 176.889 
            text = "iz gevorn geboyrn in in eh Sidni. yo." 
        intervals [64]:
            xmin = 176.889 
            xmax = 179.919 
            text = "" 
        intervals [65]:
            xmin = 179.919 
            xmax = 183.112 
            text = "geven eyn un fuftsik meyn ikh, eyn un fuftsik." 
        intervals [66]:
            xmin = 183.112 
            xmax = 183.238 
            text = "" 
        intervals [67]:
            xmin = 183.238 
