            xmax = 73.33 
            text = "bin geborn in toyznt nayn hundert tsvey un tsvantsiktn yor," 
        intervals [5]:
            xmin = 73.33 
            xmax = 75.13 
            text = "dem fuftsetn mart," 
        intervals [6]:
            xmin = 75.13 
