            xmax = 169.509 
            text = "kumendik fun klas flegn mir vider geyn in feld, geholfn di eltern." 
        intervals [45]:
            xmin = 169.509 
            xmax = 171.13 
            text = "azoy hobn mir gelebt" 
        intervals [46]:
            xmin = 171.13 
            xmax = 173.87 
            text = "di gantse, hm, gantse yorn tsayt." 
        intervals [47]:
