            xmax = 155.987 
            text = "" 
        intervals [39]:
            xmin = 155.987 
            xmax = 158.377 
            text = "oyf di land, geholfn arbetn." 
        intervals [40]:
            xmin = 158.377 
            xmax = 158.67 
            text = "" 
        intervals [41]:
            xmin = 158.67 
            xmax = 163.417 
            text = "mir flegn akht a zeyger kumen fun feld in shtub nemen di por bikher" 
        intervals [42]:
            xmin = 163.417 
            xmax = 164.908 
            text = "un geyn in klas." 
        intervals [43]:
            xmin = 164.908 
            xmax = 165.37 
            text = "" 
        intervals [44]:
