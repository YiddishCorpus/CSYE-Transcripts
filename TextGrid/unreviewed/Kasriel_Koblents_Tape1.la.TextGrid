            xmin = 77.394 
            xmax = 82.142 
            text = "" 
        intervals [9]:
            xmin = 82.142 
            xmax = 85.42 
            text = "uh, tsvey, dray un zibetsik yor." 
        intervals [10]:
            xmin = 85.42 
            xmax = 98.207 
            text = "" 
        intervals [11]:
            xmin = 98.207 
            xmax = 102.836 
            text = "fun ayer lebn, fun mayn lebn gedenk ikh ot vos. nu, ikh'l onfangen fun mayne eltern:" 
        intervals [12]:
            xmin = 102.836 
            xmax = 104.464 
            text = "zey hobn zikh evakuirt" 
        intervals [13]:
            xmin = 104.464 
            xmax = 106.709 
            text = "fun, uh, shtot Zarasay in" 
        intervals [14]:
            xmin = 106.709 
            xmax = 109.035 
            text = "Rusland, di ershte velt-milkhome." 
        intervals [15]:
            xmin = 109.035 
            xmax = 109.125 
            text = "" 
        intervals [16]:
            xmin = 109.125 
            xmax = 111.886 
            text = "zey hobn zikh bazesn in shtot VOLOGDA," 
        intervals [17]:
            xmin = 111.886 
            xmax = 111.893 
            text = "" 
        intervals [18]:
            xmin = 111.893 
            xmax = 113.929 
            text = "un dortn bin ikh geborn gevorn." 
        intervals [19]:
            xmin = 113.929 
            xmax = 115.099 
            text = "" 
        intervals [20]:
            xmin = 115.099 
            xmax = 119.365 
            text = "<ts-> nokh di krig zaynen mir gekumen tsu forn tsurik in Lite" 
        intervals [21]:
            xmin = 119.365 
            xmax = 123.378 
            text = "un zikh bazesn in shtot Zarasay, dortn vu zey hobn gelebt biz di krig." 
        intervals [22]:
            xmin = 123.378 
            xmax = 124.026 
            text = "" 
        intervals [23]:
            xmin = 124.026 
            xmax = 127.204 
            text = "mayn foter hot zikh farnumen mit land-virtshaft." 
        intervals [24]:
            xmin = 127.204 
            xmax = 129.993 
            text = "er hot gehat eygene e- gehat land." 
        intervals [25]:
            xmin = 129.993 
            xmax = 130.101 
            text = "" 
        intervals [26]:
            xmin = 130.101 
            xmax = 134.398 
            text = "nu, undzer familye iz geven zeyer a groyse: UNK zibn kinder" 
        intervals [27]:
            xmin = 134.398 
            xmax = 134.455 
            text = "" 
        intervals [28]:
            xmin = 134.455 
            xmax = 136.845 
            text = "<u- un> tate un mame, nayn mentshn." 
        intervals [29]:
            xmin = 136.845 
            xmax = 137.34 
            text = "" 
        intervals [30]:
            xmin = 137.34 
            xmax = 139.494 
            text = "<m- d-> fun derayn hobn mir gelebt;" 
        intervals [31]:
            xmin = 139.494 
            xmax = 140.007 
            text = "" 
        intervals [32]:
            xmin = 140.007 
            xmax = 142.127 
            text = "mir hobn ale gearbet oyf di land." 
        intervals [33]:
            xmin = 142.127 
            xmax = 142.656 
            text = "" 
        intervals [34]:
            xmin = 142.656 
            xmax = 148.6 
            text = "nu, mir hobn ongefangen zikh lernen, iz, uh, geven der lebn zeyer a shverer geven." 
        intervals [35]:
            xmin = 148.6 
            xmax = 150.395 
            text = "mir flegn fun in der fri" 
        intervals [36]:
            xmin = 150.395 
            xmax = 150.655 
            text = "" 
        intervals [37]:
            xmin = 150.655 
            xmax = 155.796 
            text = "oyfshteyn, flegt men undz avekfirn fir a, zumer, fir a zeyger in der fri avekfirn in feld," 
