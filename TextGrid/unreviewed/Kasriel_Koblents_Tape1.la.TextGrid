            text = "" 
        intervals [54]:
            xmin = 185.468 
            xmax = 191.486 
            text = "gezeyet, gegrobn bulbes, ale arbet vos me, <er tut oyf> di felder, dos hobn mir geton." 
        intervals [55]:
