            text = "" 
        intervals [97]:
            xmin = 241.645 
            xmax = 244.896 
            text = "dernokhn hob ikh ir, ikh hob shoyn gezen ikh hob a por funt," 
        intervals [98]:
            xmin = 244.896 
            xmax = 245.02 
            text = "" 
        intervals [99]:
            xmin = 245.02 
            xmax = 250.197 
            text = "z- eh eh hob ikh zey gezogt, forts ergets tsu, vu iz amnentstn? hobn zey gezogt keyn Bolonye." 
        intervals [100]:
            xmin = 250.197 
            xmax = 254.542 
            text = "hob ikh gekoyft far zey tsvey kleyne yetst-geboyrene khazeyrimlekh," 
        intervals [101]:
