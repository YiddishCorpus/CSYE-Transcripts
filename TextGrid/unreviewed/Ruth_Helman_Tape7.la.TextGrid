            text = "ikh hob zey geneyt fun kotsn ontsutun, a hitl fun, a kots veystu vos s'heyst?" 
        intervals [92]:
            xmin = 230.934 
            xmax = 235.246 
            text = "aza min, nisht vi azoy, a sheyne, an elegante, azoy vi farn militer." 
        intervals [93]:
            xmin = 235.246 
