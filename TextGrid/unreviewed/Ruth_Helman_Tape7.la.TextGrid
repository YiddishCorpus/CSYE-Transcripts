            xmin = 988.577 
            xmax = 990.557 
            text = "" 
        intervals [382]:
            xmin = 990.557 
            xmax = 995.314 
            text = "di daytshn zenen opgetretn fun Prage, hobn zey mitgenumen aroys ale mener in lager arayn." 
        intervals [383]:
            xmin = 995.314 
            xmax = 998.388 
            text = "azoy az zi iz gevezn a lange tsayt on im," 
        intervals [384]:
            xmin = 998.388 
            xmax = 1000.999 
            text = "un er iz geven a farantvortlekher mentsh," 
        intervals [385]:
            xmin = 1000.999 
