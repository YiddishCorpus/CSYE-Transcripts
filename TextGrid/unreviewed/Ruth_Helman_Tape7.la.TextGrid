            text = "" 
        intervals [136]:
            xmin = 349.054 
            xmax = 354.396 
            text = "eh ikh hob im ayngepakt, ikh hob eh ikh hob zikh azoy vi zey zenen geshtanen zikh gebetn er zol zey rateven," 
        intervals [137]:
            xmin = 354.396 
