            text = "a MERKAZ fun oysarbetn barshtn." 
        intervals [562]:
            xmin = 1524.344 
            xmax = 1527.584 
            text = "oyf poylish hot es geheysn MIEDZYRZ- MIEDZYRZEC," 
        intervals [563]:
            xmin = 1527.584 
            xmax = 1531.479 
            text = "un oyf yidish hot men gezogt Mezritsh. dos iz geven a yidishe branzhe." 
