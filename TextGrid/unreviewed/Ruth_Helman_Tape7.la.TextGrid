        intervals [377]:
            xmin = 975.825 
            xmax = 980.78 
            text = "zi vil nisht zayn keyn yidishe. zi hot in ir azoy arayngegoret, un gevoygn hot zi tsvelef kilo." 
        intervals [378]:
            xmin = 980.78 
            xmax = 981.04 
            text = "" 
        intervals [379]:
            xmin = 981.04 
            xmax = 982.868 
            text = "un vos dertseyln zey mir?" 
        intervals [380]:
            xmin = 982.868 
            xmax = 988.577 
            text = "az zint m'hot tsugenumen dem ale mener hot hobn zey mitgenumen azoy vi zey zenen opgetretn." 
