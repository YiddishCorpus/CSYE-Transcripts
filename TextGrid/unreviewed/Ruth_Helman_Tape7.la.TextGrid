            text = "" 
        intervals [130]:
            xmin = 330.593 
            xmax = 334.633 
            text = "un dershosn gevorn iz er als yid. m'hot im derkent epes ver" 
        intervals [131]:
            xmin = 334.633 
            xmax = 337.393 
            text = "in Bloyne take un dort iz er dershosn gevorn." 
        intervals [132]:
            xmin = 337.393 
