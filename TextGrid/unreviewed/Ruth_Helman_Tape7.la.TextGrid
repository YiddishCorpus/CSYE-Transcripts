            xmin = 1364.147 
            xmax = 1364.288 
            text = "" 
        intervals [504]:
            xmin = 1364.288 
            xmax = 1369.327 
            text = "ikh bin dokh geven z- oysergeveyntlekh eh mid, ikh hob dokh nisht gehat vu tsu zayn, un er iz avekgeganen," 
        intervals [505]:
            xmin = 1369.327 
            xmax = 1371.105 
            text = "" 
        intervals [506]:
            xmin = 1371.105 
            xmax = 1376.667 
            text = "zogt zog ikh, eh vu vu velk ikh shlofn? zogt er, do oyf der SAPA. s'geven a breyte SAPA." 
        intervals [507]:
            xmin = 1376.667 
            xmax = 1376.978 
            text = "" 
        intervals [508]:
            xmin = 1376.978 
            xmax = 1381.393 
            text = "un ikh ikh leyg mikh shlofn, ikh vil khapn a dos, er krikht arayn." 
        intervals [509]:
            xmin = 1381.393 
            xmax = 1382.698 
            text = "" 
        intervals [510]:
            xmin = 1382.698 
            xmax = 1386.961 
            text = "zog ikh, ""Noyekh! ikh hob nokh Godlen nisht farratn un du vest nisht zayn der ershter!""" 
        intervals [511]:
            xmin = 1386.961 
            xmax = 1388.824 
            text = "" 
        intervals [512]:
            xmin = 1388.824 
            xmax = 1393.408 
            text = "un geb mikh a shpring arop un geb mikh a tu on un zits azoy op biz in der fri." 
        intervals [513]:
            xmin = 1393.408 
            xmax = 1396.013 
            text = "" 
        intervals [514]:
            xmin = 1396.013 
            xmax = 1397.829 
            text = "kumen biz in der fri," 
