        intervals [465]:
            xmin = 1234.465 
            xmax = 1236.878 
            text = "z- zogt zi, vos iz mit gelt?" 
        intervals [466]:
            xmin = 1236.878 
            xmax = 1243.147 
            text = "zog ikh, ikh hob gelt, nor dos gelt iz do nishto eh do far vos tsu koyfn. s'geyt nisht do dos gelt fun yener zayt." 
