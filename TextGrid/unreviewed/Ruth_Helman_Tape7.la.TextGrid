            text = "zogt er, ruft zikh on nokh eyner, ikh voyn oykh, zogt er, bay di Sheymels." 
        intervals [589]:
            xmin = 1603.808 
            xmax = 1609.351 
            text = "iz er shoyn gekumen mit britshesn ongetun, mit shtivelekh, elegant, er hot shoyn gehandlt mit valute." 
