        intervals [347]:
            xmin = 910.435 
            xmax = 915.454 
            text = "nor m'hot gemuzt vartn biz dos ayz vet avek, vet men kenen zikh adurkh shvimen," 
        intervals [348]:
            xmin = 915.454 
            xmax = 921.501 
            text = "o- un ven m'vet farrekhtn di fabr- di di brikn oykhet oyf oyf di oyf Prage." 
