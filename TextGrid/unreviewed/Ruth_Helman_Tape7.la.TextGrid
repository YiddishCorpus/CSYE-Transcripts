            xmin = 1397.829 
            xmax = 1397.92 
            text = "" 
        intervals [516]:
            xmin = 1397.92 
            xmax = 1401.255 
            text = "un ikh veys shoyn az dos kind lebt, az m'darf es opnemen," 
        intervals [517]:
            xmin = 1401.255 
            xmax = 1401.447 
            text = "" 
        intervals [518]:
            xmin = 1401.447 
            xmax = 1405.215 
            text = "gey ikh in komitet arayn, alts tsu fus, s'nisht geven mit vos tsu forn." 
        intervals [519]:
            xmin = 1405.215 
            xmax = 1408.122 
            text = "eh in Prage iz oykh geven alts hefker." 
        intervals [520]:
            xmin = 1408.122 
            xmax = 1409.007 
            text = "" 
        intervals [521]:
            xmin = 1409.007 
            xmax = 1412.375 
            text = "kum in komitet arayn, un ikh shtey azoy." 
        intervals [522]:
            xmin = 1412.375 
            xmax = 1412.466 
            text = "" 
        intervals [523]:
            xmin = 1412.466 
            xmax = 1415.818 
            text = "get a kum on der vos ikh bin gelegn mit im unter der erd," 
        intervals [524]:
            xmin = 1415.818 
            xmax = 1415.908 
            text = "" 
        intervals [525]:
            xmin = 1415.908 
            xmax = 1420.002 
            text = "Ruznberg hot er geheysn, neyn, epes azoy endlekh, ikh gedenk nisht." 
        intervals [526]:
            xmin = 1420.002 
            xmax = 1420.819 
            text = "" 
        intervals [527]:
            xmin = 1420.819 
            xmax = 1422.838 
            text = "ikh ken mikh di nisht nisht dermanen." 
        intervals [528]:
            xmin = 1422.838 
            xmax = 1423.08 
            text = "" 
        intervals [529]:
            xmin = 1423.08 
            xmax = 1427.714 
            text = "un s'shteyt a redl mit eh ze- zelner vos geyen oyfn Berliner front," 
        intervals [530]:
            xmin = 1427.714 
            xmax = 1427.805 
            text = "" 
        intervals [531]:
            xmin = 1427.805 
            xmax = 1432.254 
            text = "rusishe un poylishe, farshidene, a gants krentsl in komitet." 
        intervals [532]:
            xmin = 1432.254 
            xmax = 1432.395 
            text = "" 
        intervals [533]:
            xmin = 1432.395 
            xmax = 1437.536 
            text = "un zey geyen zikh nemen tsu im shlogn, tsu dem vos ikh bin geven unter der erd mit der froy." 
        intervals [534]:
            xmin = 1437.536 
            xmax = 1437.829 
            text = "" 
        intervals [535]:
            xmin = 1437.829 
            xmax = 1443.931 
            text = "vos iz? er hot oysgegebn mentshn, yinglekh bay der vakh. un m'hot zey dershosn." 
        intervals [536]:
            xmin = 1443.931 
            xmax = 1444.427 
            text = "" 
        intervals [537]:
            xmin = 1444.427 
            xmax = 1448.499 
            text = "ikh hob nor badorfn zogn, ikh hob oykh gehat an avle, un mikh onrufn." 
        intervals [538]:
            xmin = 1448.499 
            xmax = 1450.372 
            text = "zey voltn im gemakht toyt." 
        intervals [539]:
            xmin = 1450.372 
            xmax = 1452.347 
            text = "ikh hob mikh gemakht nisht hern," 
        intervals [540]:
            xmin = 1452.347 
            xmax = 1456.162 
            text = "nor er hot mir gegebn a zog dernokh, azoy vi zey hobn im ibergelozt" 
        intervals [541]:
            xmin = 1456.162 
            xmax = 1461.088 
            text = "lebn, im gornisht getun, zey hobn a bisl opgeharget un im do geshtupt, dortn gegebn a por boksn." 
        intervals [542]:
            xmin = 1461.088 
            xmax = 1461.206 
            text = "" 
        intervals [543]:
            xmin = 1461.206 
            xmax = 1464.536 
            text = "nor ikh hob mikh in gantsn nisht ongerufn, ikh hob oykh gehat an avle." 
        intervals [544]:
            xmin = 1464.536 
            xmax = 1464.829 
            text = "" 
        intervals [545]:
            xmin = 1464.829 
            xmax = 1469.88 
            text = "geyt er arop mit mir, zogt er, du veyst, zi iz oykh geblibn. dos heyst, di froy iz oykh geblibn lebn." 
        intervals [546]:
            xmin = 1469.88 
            xmax = 1473.361 
            text = "zi iz, zogt er, avek keyn Prushkov, un zi zi hot epes gehat vemenen." 
        intervals [547]:
            xmin = 1473.361 
            xmax = 1475.084 
            text = "nor s'kind, zogt er, lebt nisht." 
        intervals [548]:
            xmin = 1475.084 
            xmax = 1478.139 
            text = "ale kinder fu- fun di Tshonkalezes hobn nisht gelebt." 
        intervals [549]:
            xmin = 1478.139 
            xmax = 1482.457 
            text = "zenen oysgeshtorbn far hunger. poylishe kinder oykhet, kranke." 
        intervals [550]:
            xmin = 1482.457 
            xmax = 1484.505 
            text = "" 
        intervals [551]:
            xmin = 1484.505 
            xmax = 1493.341 
            text = "a klal, un ikh zog ir, un ikh z- iz geb ikh get eyner a kum tsu mir tsu, an ofitsir vos geyt oykh oyfn front fun Berlin," 
        intervals [552]:
            xmin = 1493.341 
            xmax = 1493.415 
            text = "" 
        intervals [553]:
            xmin = 1493.415 
            xmax = 1495.569 
            text = "un zogt, du bist Rutke?" 
        intervals [554]:
            xmin = 1495.569 
            xmax = 1496.267 
            text = "" 
        intervals [555]:
            xmin = 1496.267 
            xmax = 1505.233 
            text = "zog ikh, yo, ikh, un s'kind, zog ikh, iz geblibn lebn, nor s'iz, zog ikh, a a a skeletl, s'vegt tsvelef kilo in gantsn. s'halt shoyn bay shtarbn, zi hot es gevolt" 
        intervals [556]:
            xmin = 1505.233 
            xmax = 1512.118 
            text = "eh op- op- eh eh eh sh- opshmadn a- az er zol kenen s'zol kenen opshtarbn." 
        intervals [557]:
            xmin = 1512.118 
            xmax = 1515.447 
            text = "un zi hot zikh nisht gevizn, zog ikh, in komitet arayn a gantse tsayt." 
        intervals [558]:
            xmin = 1515.447 
            xmax = 1515.96 
            text = "" 
        intervals [559]:
            xmin = 1515.96 
            xmax = 1518.513 
            text = "zogt er azoy, ikh gey oyfn front," 
        intervals [560]:
            xmin = 1518.513 
            xmax = 1522.015 
            text = "nor ikh kum yetst fun Mezritsh, dortn iz gevezn" 
        intervals [561]:
            xmin = 1522.015 
