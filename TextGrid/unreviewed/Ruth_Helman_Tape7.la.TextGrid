            text = "" 
        intervals [126]:
            xmin = 319.9 
            xmax = 324.48 
            text = "hobn zey gezogt er iz umgeku- un er shraybt oykhet do, der Bernard, der firer fun Bund," 
        intervals [127]:
            xmin = 324.48 
            xmax = 326.78 
            text = "az er iz um- umgekumen in oyfshtand. neyn." 
        intervals [128]:
            xmin = 326.78 
            xmax = 330 
            text = "er iz geven keseyder oyf der arisher zayt un tsugeshtelt gever." 
