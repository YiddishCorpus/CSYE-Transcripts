        intervals [2]:
            xmin = 2.121 
            xmax = 4.072 
            text = "Helman, ZE KEN, BESEDER." 
        intervals [3]:
            xmin = 4.072 
            xmax = 6.913 
            text = "" 
        intervals [4]:
            xmin = 6.913 
            xmax = 10.302 
            text = "host zi mikh genumen tsu zikh aroyf. zi iz di," 
        intervals [5]:
            xmin = 10.302 
            xmax = 13.795 
            text = "zi zi hot nisht gehat keyn man, zi iz geven an almone," 
        intervals [6]:
            xmin = 13.795 
            xmax = 16.712 
            text = "un zi hot gehat a p- di k- eh kinder." 
        intervals [7]:
            xmin = 16.712 
            xmax = 16.853 
            text = "" 
        intervals [8]:
            xmin = 16.853 
            xmax = 19.192 
            text = "sheyn vi di lyalkes!" 
        intervals [9]:
            xmin = 19.192 
            xmax = 19.738 
            text = "" 
        intervals [10]:
            xmin = 19.738 
            xmax = 21.402 
            text = "MALKAT HAYOFI!" 
        intervals [11]:
            xmin = 21.402 
            xmax = 21.493 
            text = "" 
        intervals [12]:
            xmin = 21.493 
            xmax = 23.861 
            text = "un zey hobn gehat benkartn fun di" 
        intervals [13]:
            xmin = 23.861 
            xmax = 25.827 
            text = "eygntimer fun dem git," 
        intervals [14]:
            xmin = 25.827 
            xmax = 31.387 
            text = "a git heyst a farmegn, a groysn, un zey hobn parobkes azelkhes vos arbetn." 
        intervals [15]:
            xmin = 31.387 
            xmax = 35.645 
            text = "ikh hob nisht gezen dortn keyn balbatim. ikh hob gezen nor di parobkes." 
        intervals [16]:
            xmin = 35.645 
            xmax = 35.82 
            text = "" 
        intervals [17]:
            xmin = 35.82 
            xmax = 40.876 
            text = "ikh kum aroyf azoy tsunoyf geklapt fun di breter azelkhe mine, ale shlofn tsuzamen." 
        intervals [18]:
            xmin = 40.876 
            xmax = 41.001 
            text = "" 
        intervals [19]:
            xmin = 41.001 
            xmax = 43.492 
            text = "ikh hob mikh oykh geleygt. zi hot mikh aroyfgenumen un," 
        intervals [20]:
            xmin = 43.492 
            xmax = 43.617 
            text = "" 
        intervals [21]:
            xmin = 43.617 
            xmax = 46.226 
            text = "un ikh bin geblibn dortn. hot men ongehoybn redn," 
        intervals [22]:
            xmin = 46.226 
            xmax = 46.603 
            text = "" 
        intervals [23]:
            xmin = 46.603 
            xmax = 48.414 
            text = "hobn zey mikh ongenumen, ikh" 
        intervals [24]:
            xmin = 48.414 
            xmax = 53.33 
            text = "az a poylishe nisht, eh ikh hob nisht oysgezen UNK. dernokh hot zi mir gezogt az m'hot azoy geredt," 
        intervals [25]:
            xmin = 53.33 
            xmax = 53.505 
            text = "" 
        intervals [26]:
            xmin = 53.505 
            xmax = 56.75 
            text = "z- eh zo- ikh hob gemeynt bist a frantsuske." 
        intervals [27]:
            xmin = 56.75 
            xmax = 58.497 
            text = "hob ikh ir dertseylt azoy." 
        intervals [28]:
            xmin = 58.497 
            xmax = 60.958 
            text = "her, mayn man iz geven an ofitsir," 
        intervals [29]:
            xmin = 60.958 
            xmax = 61.403 
            text = "" 
        intervals [30]:
            xmin = 61.403 
            xmax = 63.169 
            text = "un im genumen di armey," 
        intervals [31]:
            xmin = 63.169 
            xmax = 63.546 
            text = "" 
        intervals [32]:
            xmin = 63.546 
            xmax = 67.809 
            text = "un dakht zikh mir az er lebt nisht, vayl m'hot ale ofitsirn heyst araynge-" 
        intervals [33]:
            xmin = 67.809 
            xmax = 68.878 
            text = "" 
        intervals [34]:
            xmin = 68.878 
            xmax = 70.998 
            text = "eh v- barn militer." 
        intervals [35]:
            xmin = 70.998 
            xmax = 71.562 
            text = "" 
        intervals [36]:
            xmin = 71.562 
            xmax = 73.328 
            text = "un ikh hob, zog ikh, a kind," 
        intervals [37]:
            xmin = 73.328 
            xmax = 73.384 
            text = "" 
        intervals [38]:
            xmin = 73.384 
            xmax = 80.01 
            text = "hob ikh zi iberge- hob ikh in Prage. ikh hob ir gezogt di vorheyt, in Prage, in dos iz nokh unter Prage geven vu zi iz geven." 
        intervals [39]:
            xmin = 80.01 
            xmax = 80.387 
            text = "" 
        intervals [40]:
            xmin = 80.387 
            xmax = 87.477 
            text = "un ikh darf, un ven s'hot zikh ongehoybn e- endikn dos eh di milkhome, zey ho- zey hobn ongehoybn shoyn antloyfn di daytshn," 
        intervals [41]:
            xmin = 87.477 
            xmax = 87.522 
            text = "" 
        intervals [42]:
            xmin = 87.522 
            xmax = 91.363 
            text = "zenen aroysgegangen fun di stodoles vu zey UNK, a stodole heyst eh" 
        intervals [43]:
            xmin = 91.363 
            xmax = 91.429 
            text = "" 
        intervals [44]:
            xmin = 91.429 
            xmax = 96.809 
            text = "a a sha- a a a a a plats vu m- zey haltn alding eh" 
        intervals [45]:
            xmin = 96.809 
            xmax = 101.945 
            text = "shtroy, di eh eh hober, alding, heyst eh a stodole." 
        intervals [46]:
            xmin = 101.945 
            xmax = 104.931 
            text = "hobn UNK gelegn bahaltn shoyn daytshn," 
        intervals [47]:
            xmin = 104.931 
            xmax = 108.14 
            text = "vayl di s'zenen ongekumen di bolshevikes shoyn nokh der Vaysl," 
        intervals [48]:
            xmin = 108.14 
            xmax = 108.771 
            text = "" 
        intervals [49]:
            xmin = 108.771 
            xmax = 111.6 
            text = "un azoy vi ikh hob doser gezen," 
        intervals [50]:
            xmin = 111.6 
            xmax = 111.775 
            text = "" 
        intervals [51]:
            xmin = 111.775 
            xmax = 114.733 
            text = "hob ikh ir, hob ikh mikh gegebn a pak ayn," 
        intervals [52]:
            xmin = 114.733 
            xmax = 119.88 
            text = "ikh hob epes gehat fun lang ongegreyt a por shikhelekh, m'hot dokh gevust s'vet zikh endikn. un m'hot gevust" 
        intervals [53]:
            xmin = 119.88 
            xmax = 129.785 
            text = "az eh iz di di di bolshevikes shteyen in yener zayt Vaysl, zey viln ekstere az di polyakn zoln zikh aleyn oysblut- oys blutikn," 
        intervals [54]:
            xmin = 129.785 
            xmax = 135.09 
            text = "un dernokhn veln zey k- vet zey onkumen laykhter dos geyn forverts. un oyf Berlin." 
        intervals [55]:
            xmin = 135.09 
            xmax = 135.197 
            text = "" 
        intervals [56]:
            xmin = 135.197 
            xmax = 141.721 
            text = "un azoy iz gevezn, in yanuar, mer oder veyniker," 
        intervals [57]:
            xmin = 141.721 
            xmax = 141.897 
            text = "" 
        intervals [58]:
            xmin = 141.897 
            xmax = 146.925 
            text = "dem akhtstn oder in fift- zibetstn oder akhtstn, ikh gedenk nisht genoy. alnfals," 
        intervals [59]:
            xmin = 146.925 
            xmax = 147 
            text = "" 
        intervals [60]:
            xmin = 147 
            xmax = 149.375 
            text = "azoy vi zey zenen ongekumen tsu undz," 
        intervals [61]:
            xmin = 149.375 
            xmax = 152.5 
            text = "un di daytshn ongehoybn aroysgeyn fun di stodoles," 
        intervals [62]:
            xmin = 152.5 
            xmax = 155.55 
            text = "un zey hobn eh aroysgenumen vayse tikhlekh, un eyner hot gekhapt" 
        intervals [63]:
            xmin = 155.55 
            xmax = 161.025 
            text = "eh fotografyes gevizn un er hot, un zey hobn geveynt vi di kleyne kinder, di o- di di," 
        intervals [64]:
            xmin = 161.025 
            xmax = 161.197 
            text = "" 
        intervals [65]:
            xmin = 161.197 
            xmax = 163.122 
            text = "fun di mishpokhes zeyere." 
        intervals [66]:
            xmin = 163.122 
            xmax = 163.53 
            text = "" 
        intervals [67]:
            xmin = 163.53 
            xmax = 167.155 
            text = "m'zol hobn rakhmones, mit di vay- mit vayse doser." 
        intervals [68]:
            xmin = 167.155 
            xmax = 169.751 
            text = "hob ikh shoyn gepakt a plet-zak," 
        intervals [69]:
            xmin = 169.751 
            xmax = 169.808 
            text = "" 
        intervals [70]:
            xmin = 169.808 
            xmax = 176.721 
            text = "mit alts vos ikh hob gehat, ikh hob epes gehat eh epes gekoyft in Byale oykhet, in KOSCIOL bin ikh dort oykh geganen." 
        intervals [71]:
            xmin = 176.721 
            xmax = 176.811 
            text = "" 
        intervals [72]:
            xmin = 176.811 
            xmax = 178.138 
            text = "un eh," 
        intervals [73]:
            xmin = 178.138 
            xmax = 180.22 
            text = "" 
        intervals [74]:
            xmin = 180.22 
            xmax = 183.081 
            text = "yo, hob ikh dokh gemuzt fa-" 
        intervals [75]:
            xmin = 183.081 
            xmax = 183.113 
            text = "" 
        intervals [76]:
            xmin = 183.113 
            xmax = 187.458 
            text = "als als kristin. zey iz nisht ayngefaln. zey hobn zikh gekent zikh be-" 
        intervals [77]:
            xmin = 187.458 
            xmax = 190.638 
            text = "eh azelkhe vos hobn gearbet yetst in dem git," 
        intervals [78]:
            xmin = 190.638 
            xmax = 192.523 
            text = "zey hobn dokh nisht gehat gornisht keyn eygntum." 
        intervals [79]:
            xmin = 192.523 
            xmax = 192.594 
            text = "" 
        intervals [80]:
            xmin = 192.594 
            xmax = 197.746 
            text = "nor zey hobn gekrign eh esn tsugeteylt dortn un efsher a a por zlotes." 
        intervals [81]:
            xmin = 197.746 
            xmax = 198.04 
            text = "" 
        intervals [82]:
            xmin = 198.04 
            xmax = 201.729 
            text = "ober zi iz geven an almone, zi hot nisht gehat keyn man, nor a zun hot zi gehat." 
        intervals [83]:
            xmin = 201.729 
            xmax = 202.798 
            text = "" 
        intervals [84]:
            xmin = 202.798 
            xmax = 206.119 
            text = "hot z- eh iz far vos hob ikh ir dertseylt az ikh hob a man?" 
        intervals [85]:
            xmin = 206.119 
            xmax = 209.711 
            text = "vayl zi hot mir gegebn ontsugehern, zi vil ikh zol khasene hobn mit dem zun." 
        intervals [86]:
            xmin = 209.711 
            xmax = 210.375 
            text = "" 
        intervals [87]:
            xmin = 210.375 
            xmax = 213.052 
            text = "un ikh volt geven khasene gehat, ven ikh ken mikh" 
        intervals [88]:
            xmin = 213.052 
            xmax = 213.058 
            text = "" 
        intervals [89]:
            xmin = 213.058 
            xmax = 222.564 
            text = "z- oyszogn farn farn eh shto- farn eh heylikn, farn galekh, vayl s- eh un sh- un dos bin ikh gegangen, vayl ale zenen geganen." 
        intervals [90]:
            xmin = 222.564 
            xmax = 225.838 
            text = "di Varshever vos zenen geven, di polyakn, hobn oysgezen," 
        intervals [91]:
            xmin = 225.838 
