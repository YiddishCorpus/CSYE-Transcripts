            text = "m'est op, yo, un er hot gekoyft di ke- di batus, mit di kabase mitn broyt," 
        intervals [500]:
            xmin = 1356.152 
            xmax = 1360.744 
            text = "hot er bay mir genumen gelt fun di tsvey toyznt zlotes vos ikh hob gekrign fun komitet." 
