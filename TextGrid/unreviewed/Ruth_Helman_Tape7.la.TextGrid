            xmax = 256.719 
            text = "zey hobn zikh dos unter gepashet." 
        intervals [102]:
            xmin = 256.719 
            xmax = 262.833 
            text = "iz shoyn geven a bisl milkh, hot zi shoyn gekokht oyf milkh a bisl ZUREK hot es geheysn." 
        intervals [103]:
