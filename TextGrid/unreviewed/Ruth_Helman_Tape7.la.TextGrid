            text = "ze'mir shoyn geven fray." 
        intervals [118]:
            xmin = 298.215 
            xmax = 300.991 
            text = "demolts hob ikh shoyn genumen ayngepakt a pekl," 
        intervals [119]:
            xmin = 300.991 
            xmax = 307.327 
            text = "un a por shikhelekh hob ikh gehat fun lang ongegreyt, gekoyft oyf eh tsvelef k- kilometer fun eh zey," 
