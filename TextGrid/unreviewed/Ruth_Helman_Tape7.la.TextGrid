        intervals [569]:
            xmin = 1545.171 
            xmax = 1548.483 
            text = "un zey hobn gevoynt oyf der hoypt gas, oyf der Varshever gas." 
        intervals [570]:
            xmin = 1548.483 
            xmax = 1553.384 
            text = "du vest dikh bay, hot er alding opgemoshlt, m'vet dikh, zogt er, tsukhapn, m'vet nisht visn vos tsu tun." 
        intervals [571]:
            xmin = 1553.384 
            xmax = 1555.31 
            text = "un meyle vegn kind iz opgeredt," 
        intervals [572]:
            xmin = 1555.31 
            xmax = 1560.495 
            text = "ikh ken, ikh volt mit dikh geforn, nor ikh muz mikh shoyn, zogt er, tsushteln, vayl undz gey'mir oyf Berlin." 
