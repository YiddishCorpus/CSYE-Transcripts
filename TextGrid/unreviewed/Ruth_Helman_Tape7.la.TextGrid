            text = "m'vet dikh, zogt er, dort iz do a a mishpokhe Sheymel," 
        intervals [567]:
            xmin = 1537.81 
            xmax = 1544.979 
            text = "hobn zey farloyrn tsvey zin in poylishn oyfshtand, zey zenen geblibn lebn, un zey hobn fabrikn fun a <gra> mashine." 
