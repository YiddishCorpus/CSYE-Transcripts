            xmin = 786.042 
            xmax = 786.133 
            text = "" 
        intervals [280]:
            xmin = 786.133 
            xmax = 789.52 
            text = "afile ikh hob gehat dortn a meydl, ikh hob gevolt..." 
        intervals [281]:
            xmin = 789.52 
            xmax = 795.504 
            text = "nor s'iz ge- nit geven... ikh'l aykh zogn, ikh hob gelitn ammerstn, mer fun ale. ikh bin geven der elterer." 
        intervals [282]:
            xmin = 795.504 
            xmax = 797.96 
            text = "kh'hob gemuzt haltn di shtub." 
        intervals [283]:
            xmin = 797.96 
