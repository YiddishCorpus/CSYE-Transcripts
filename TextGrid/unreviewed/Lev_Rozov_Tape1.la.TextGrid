            text = "di eltere, di eltere, der yingerer bruder iz gegangen nokh in Tarbut shul." 
        intervals [284]:
            xmin = 802.921 
            xmax = 807.407 
            text = "di elt- di tokhter, eyne hot zikh gelernt in Vilne" 
