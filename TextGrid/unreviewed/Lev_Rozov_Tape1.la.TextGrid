            text = "tsu Rusland." 
        intervals [190]:
            xmin = 527.653 
            xmax = 527.98 
            text = "" 
        intervals [191]:
            xmin = 527.98 
            xmax = 531.875 
            text = "un... o! shpe- a, dos <hob ikh nit...> shpeter, shpeter," 
        intervals [192]:
            xmin = 531.875 
            xmax = 538.31 
            text = "in n- der, in der tsveyter velt-milkhome, ven s'iz gevorn di revolutsye in dem zibetsntn," 
        intervals [193]:
            xmin = 538.31 
            xmax = 539.96 
            text = "in zibetsntn yor," 
        intervals [194]:
            xmin = 539.96 
            xmax = 541.14 
            text = "iz gevorn di velt-..." 
        intervals [195]:
            xmin = 541.14 
            xmax = 542.6 
            text = "nayntsn zibetsn." 
        intervals [196]:
            xmin = 542.6 
            xmax = 547.15 
            text = "iz gevorn di revolutsye, hot Poyln zikh gemakht zelbshtendikeyt" 
        intervals [197]:
            xmin = 547.15 
            xmax = 550.56 
            text = "un zi hot mit di Sovyetn milkhome gehaltn," 
        intervals [198]:
            xmin = 550.56 
            xmax = 555.525 
            text = "iz hot zi farnumen Dokshits in tsvey un tsvantsiktn yor." 
        intervals [199]:
            xmin = 555.525 
            xmax = 557.89 
            text = "iz nokh geven milkhome a bisl," 
        intervals [200]:
            xmin = 557.89 
            xmax = 562.196 
            text = "nor nokhn, dortn, nokh dem MIR vos me hot gemakht dan," 
        intervals [201]:
            xmin = 562.196 
            xmax = 562.27 
            text = "" 
        intervals [202]:
            xmin = 562.27 
            xmax = 565.549 
            text = "in di, fun di Sovyetn, dos vos, ikh veys nit," 
        intervals [203]:
            xmin = 565.549 
            xmax = 568.05 
            text = "oder dos iz gevorn Poyln." 
        intervals [204]:
            xmin = 568.05 
            xmax = 572.59 
            text = "Poyln iz gevo-... nayntsn tsvey un tsvantsik iz gevorn Poyln." 
        intervals [205]:
            xmin = 572.59 
            xmax = 577.361 
            text = "iz di gantsene, alts iz ibergegangen oyf di poylishe kultur..." 
        intervals [206]:
            xmin = 577.361 
            xmax = 581.29 
            text = "<dos darf ikh oykh zogn...> di poylishe kultur. iz shoyn gevorn" 
        intervals [207]:
            xmin = 581.29 
            xmax = 583.93 
            text = "poylishe shuln, a Tarbut shul" 
        intervals [208]:
            xmin = 583.93 
            xmax = 587.376 
            text = "iz geven bay undz, a yidishe shul iz geven bay undz," 
        intervals [209]:
            xmin = 587.376 
            xmax = 593.654 
            text = "un s'iz geven UNK <un,> un hekher lernen zikh, hekher lernen zikh hobn mir gedarft" 
        intervals [210]:
            xmin = 593.654 
            xmax = 601.69 
            text = "onkumen i- oder in Vilne... in Vilne ammerstns. s'iz geven Glubok, volt zayn dortn a gimnazye nokh gevezn," 
        intervals [211]:
            xmin = 601.69 
            xmax = 605.59 
            text = "nor, nor forn lernen zikh hot men gedarft ale fakhn" 
        intervals [212]:
            xmin = 605.59 
            xmax = 605.79 
            text = "" 
        intervals [213]:
            xmin = 605.79 
            xmax = 610.697 
            text = "in Vilne. Vilne iz geven a shtot mit a, a tekhnikum," 
        intervals [214]:
            xmin = 610.697 
            xmax = 614.58 
            text = "s'iz geven a te- a Hilf Durkh Arbet, Ort," 
        intervals [215]:
            xmin = 614.58 
            xmax = 617.47 
            text = "ot azetike ale shuln. geven, uh," 
        intervals [216]:
            xmin = 617.47 
            xmax = 621.61 
            text = "di pedagogishe shuln iz gevezn in Vilne, a, a ivrit" 
        intervals [217]:
            xmin = 621.61 
            xmax = 624.12 
            text = "l- far lerer, un oyf yidish far lerer." 
        intervals [218]:
            xmin = 624.12 
            xmax = 626.91 
            text = "dos iz alts in Vilne. <me volt forn in Vilne>." 
        intervals [219]:
            xmin = 626.91 
            xmax = 629.224 
            text = "ikh bin, ikh bin gev-..." 
        intervals [220]:
            xmin = 629.224 
            xmax = 629.77 
            text = "" 
        intervals [221]:
            xmin = 629.77 
            xmax = 635.968 
            text = "ikh bin geven a kind biz<n> dem kumendik fun P- fun di <p>oyln tsu undz," 
        intervals [222]:
            xmin = 635.968 
            xmax = 638.56 
            text = "bin ikh gelernt in shtot," 
        intervals [223]:
            xmin = 638.56 
            xmax = 642.63 
            text = "do in di sh- do in<em>, in talmed-toyre, do," 
        intervals [224]:
            xmin = 642.63 
            xmax = 645.052 
            text = "bay di rusn bin ikh gegangen in shule." 
        intervals [225]:
            xmin = 645.052 
            xmax = 645.109 
            text = "" 
        intervals [226]:
            xmin = 645.109 
            xmax = 650.92 
            text = "UNK biz<n> ikh hob bavizn bay di rusn tsu endikn di shule, zaynen shoyn geven di milkhome," 
        intervals [227]:
            xmin = 650.92 
            xmax = 653.101 
            text = "mit di koyln. ikh bin nokh geven a kind." 
        intervals [228]:
            xmin = 653.101 
            xmax = 653.277 
            text = "" 
        intervals [229]:
            xmin = 653.277 
            xmax = 658.097 
            text = "iz keyn, iz keyn, keyn hekher shul <aleyn> hob ikh shoyn nit durkhgemakht." 
        intervals [230]:
            xmin = 658.097 
            xmax = 658.423 
            text = "" 
        intervals [231]:
            xmin = 658.423 
            xmax = 662.602 
            text = "bin ikh zikh avekgeforn lernen az mir iz shoyn alt geven zibetsn yor." 
        intervals [232]:
            xmin = 662.602 
            xmax = 663.047 
            text = "" 
        intervals [233]:
            xmin = 663.047 
            xmax = 665.11 
            text = "keyn Vilne. in Vilne" 
        intervals [234]:
            xmin = 665.11 
            xmax = 667.83 
            text = "hob ikh zikh ongel- ongehoybn lernen," 
        intervals [235]:
            xmin = 667.83 
            xmax = 670.86 
            text = "ongehoybn lernen in Hilf Durkh Arbet." 
        intervals [236]:
            xmin = 670.86 
            xmax = 673.29 
            text = "dos iz geven...  darf ikh oyfklern vos..." 
        intervals [237]:
            xmin = 673.29 
            xmax = 677.435 
            text = "dos iz geven a shul <D-> oysgehaltn fun Dzhoynt." 
        intervals [238]:
            xmin = 677.435 
            xmax = 677.796 
            text = "" 
        intervals [239]:
            xmin = 677.796 
            xmax = 680.26 
            text = "di Amerikaner gezelshaft" 
        intervals [240]:
            xmin = 680.26 
            xmax = 682.69 
            text = "hot undz gemakht yidishe shuln." 
        intervals [241]:
            xmin = 682.69 
            xmax = 685.36 
            text = "dortn iz geven KHUDOZHESTVENNe shuln," 
        intervals [242]:
            xmin = 685.36 
            xmax = 688.93 
            text = "s'iz geven far froyen shuln, a stoleray iz dortn gevezn," 
        intervals [243]:
            xmin = 688.93 
            xmax = 690.34 
            text = "alts in der shul." 
        intervals [244]:
            xmin = 690.34 
            xmax = 693.242 
            text = "ikh hob zikh gelernt dekorativ maleray." 
        intervals [245]:
            xmin = 693.242 
            xmax = 694.79 
            text = "getrakht hob ikh a mol" 
        intervals [246]:
            xmin = 694.79 
            xmax = 698.87 
            text = "arbetn in teater... ir veyst dokh, in di yung- in di yunge yorn" 
        intervals [247]:
            xmin = 698.87 
            xmax = 701.887 
            text = "iz dokh andere, an ander g- andere gedanken." 
        intervals [248]:
            xmin = 701.887 
            xmax = 702.062 
            text = "" 
        intervals [249]:
            xmin = 702.062 
            xmax = 707.99 
            text = "iz hob ikh gelernt zikh dortn. gelernt hob ikh dortn tsvey yor, nit geendikt." 
        intervals [250]:
            xmin = 707.99 
            xmax = 708.255 
            text = "" 
        intervals [251]:
            xmin = 708.255 
            xmax = 713.46 
            text = "far vos? s'iz geven a tsayt, m'hot mir gedarft hobn in shtub." 
