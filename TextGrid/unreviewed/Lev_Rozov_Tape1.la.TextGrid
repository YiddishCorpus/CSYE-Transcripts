            xmax = 727.223 
            text = "" 
        intervals [258]:
            xmin = 727.223 
            xmax = 730.15 
            text = "hob ikh shoyn fardint gelt." 
        intervals [259]:
            xmin = 730.15 
            xmax = 734.253 
            text = "kh'hob opgearbet di etlekhe yor, un nakher hot men mir tsugenumen in militer," 
