        intervals [2]:
            xmin = 28.581 
            xmax = 37.471 
            text = "HAYOM YOM REVII, HAESRIM VESHEVA BENOVEMBER, ELEF TSHA MEOT TISHIM VESHESH, TET ZAYIN KISLEV, TAV SHIN NUN ZAYIN." 
        intervals [3]:
            xmin = 37.471 
            xmax = 42.39 
            text = "SHMI TOBY REISS-RUBIN VEANI OREKHET REAYON IM Lev Rozov" 
        intervals [4]:
            xmin = 42.39 
            xmax = 44.673 
            text = "BEIR NATANYA, YISRAEL." 
        intervals [5]:
            xmin = 44.673 
            xmax = 48.561 
            text = "" 
        intervals [6]:
            xmin = 48.561 
            xmax = 53.865 
            text = "HAYOM YOM REVII, HAESRIM VESHEVA BENOVEMBER, ELEF TSHA MEOT TISHIM VESHESH," 
