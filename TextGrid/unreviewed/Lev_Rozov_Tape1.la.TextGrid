            text = "az me vet konen gut davnen oder lernen, dos iz geendikt oyf dem," 
        intervals [294]:
            xmin = 832.65 
            xmax = 837 
            text = "nor ikh hob shoyn geven mer in shtot un in militer," 
        intervals [295]:
            xmin = 837 
            xmax = 839.87 
            text = "in Varshe geven, un ikh hob alts shoyn gezen." 
        intervals [296]:
            xmin = 839.87 
