        intervals [304]:
            xmin = 857.262 
            xmax = 862.79 
            text = "oyf moln dortn mit di kolirn. hob ikh zey gedarft tsuzamenshteln kolirn. ikh hob, bin shoyn geven" 
        intervals [305]:
