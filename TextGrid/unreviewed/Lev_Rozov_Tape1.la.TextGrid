            xmin = 718.34 
            xmax = 718.347 
            text = "" 
        intervals [255]:
            xmin = 718.347 
            xmax = 722.992 
            text = "un ikh bin avekgegangen arbetn. UNK eyner iz geven bay undz a KHUDOZHNIK;" 
        intervals [256]:
            xmin = 722.992 
            xmax = 727.115 
            text = "gemakht shutfes, un mir hobn gearbet shtub-maleray." 
