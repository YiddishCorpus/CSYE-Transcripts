            xmin = 59.928 
            xmax = 60.019 
            text = "" 
        intervals [23]:
            xmin = 60.019 
            xmax = 64.35 
            text = "ikh hob genumen un mir zaynen geforn, mir zaynen geforn, mir zaynen geforn oyf Moskeve." 
