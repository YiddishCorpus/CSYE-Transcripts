            text = "" 
        intervals [723]:
            xmin = 1715.895 
            xmax = 1719.08 
            text = "neyn, zey zaynen geblibn in der heym, zaynen zey geblibn," 
        intervals [724]:
            xmin = 1719.08 
            xmax = 1721.154 
            text = "un zey zaynen shoyn fun geto gelofn." 
        intervals [725]:
            xmin = 1721.154 
