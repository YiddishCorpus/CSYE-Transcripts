            xmax = 1622.368 
            text = "a kuk ton, <bin ikh> gekumen ahin, <hob ikh gezen, eh,> gekumen ahin UNK glaykh gefaln." 
        intervals [692]:
            xmin = 1622.368 
            xmax = 1622.391 
            text = "" 
        intervals [693]:
            xmin = 1622.391 
            xmax = 1624.64 
            text = "a kuk geton vos s'tut zikh..." 
        intervals [694]:
            xmin = 1624.64 
            xmax = 1628.93 
            text = "ikh hob gezen di griber vu m'iz geven farshotn. der foter" 
        intervals [695]:
            xmin = 1628.93 
            xmax = 1634.2 
            text = "hot geven, <zey hobn>, epes a komisye iz gekumen <un hobn> gekukt, UNK gegrobn. der foter iz dortn geven." 
        intervals [696]:
            xmin = 1634.2 
            xmax = 1635.997 
            text = "ikh bin nit geven, nor der foter." 
        intervals [697]:
            xmin = 1635.997 
            xmax = 1640.308 
            text = "un m'hot gezen az di mentshn vos m'hot geharget un bashotn," 
        intervals [698]:
            xmin = 1640.308 
            xmax = 1642.77 
            text = "geven farshotn mit kalkh." 
        intervals [699]:
            xmin = 1642.77 
            xmax = 1643.569 
            text = "" 
        intervals [700]:
            xmin = 1643.569 
            xmax = 1649.31 
            text = "az m'hot bakumen fun dortn beyner, iz geven ot vi porekh, oyfgegesene." 
        intervals [701]:
            xmin = 1649.31 
            xmax = 1652.16 
            text = "volt men nor nemen in hant, volt dos tseshitn zikh." 
        intervals [702]:
            xmin = 1652.16 
            xmax = 1655.23 
            text = "" 
        intervals [703]:
            xmin = 1655.23 
            xmax = 1663.29 
            text = "zey hobn dortn, in Dokshits iz geven griber lebn dem besalmen. dos iz geven take nit vayt vu mir hobn gelebt <a, in,> azoy on a zayt. UNK..." 
        intervals [704]:
            xmin = 1663.29 
            xmax = 1664.865 
            text = "" 
        intervals [705]:
            xmin = 1664.865 
            xmax = 1667.132 
            text = "ikh hob gelebt noent," 
        intervals [706]:
            xmin = 1667.132 
            xmax = 1671.66 
            text = "noent nit tsum tsenter, oder noent tsum, tsum breg." 
        intervals [707]:
            xmin = 1671.66 
            xmax = 1675.93 
            text = "dortn iz geven azetike griber bay undz; zamd volt men nemen dortn, alts." 
        intervals [708]:
            xmin = 1675.93 
            xmax = 1679.05 
            text = "un dortn hot men gefirt di yidn un m'hot dortn ale geshosn," 
        intervals [709]:
            xmin = 1679.05 
            xmax = 1681.69 
            text = "afile di vos zaynen geven in JUDENRAT!" 
        intervals [710]:
            xmin = 1681.69 
            xmax = 1681.909 
            text = "" 
        intervals [711]:
            xmin = 1681.909 
            xmax = 1685.078 
            text = "s'zaynen geven dokh yidn in JUDENRAT un yidishe mil-" 
        intervals [712]:
            xmin = 1685.078 
            xmax = 1687.829 
            text = "di politseyske yidishe UNK <hobn> zey gemakht." 
        intervals [713]:
            xmin = 1687.829 
            xmax = 1692.42 
            text = "m'hot ale oysgeshosn. s'iz, zey hot men di letste, nor zey hobn gedarft nokh" 
        intervals [714]:
            xmin = 1692.42 
            xmax = 1695.35 
            text = "kukn vi men shist di, un nakher hot UNK..." 
        intervals [715]:
            xmin = 1695.35 
            xmax = 1698.545 
            text = "mir hob- ikh bin gekumen, hob ikh gefunen partizaner." 
        intervals [716]:
            xmin = 1698.545 
            xmax = 1700.789 
            text = "eyner mayner a khaver iz geven," 
        intervals [717]:
            xmin = 1700.789 
            xmax = 1705.055 
            text = "di vos zaynen nokh nit antlofn. er iz geven in vald di gantse tsayt," 
