            text = "" 
        intervals [18]:
            xmin = 45.085 
            xmax = 50.76 
            text = "zayn- un ale zaynen gelofn. un mir hobn shoyn geforn oyf a ferd, vayl ikh hob gekhapt a ferd bay eynem" 
        intervals [19]:
            xmin = 50.76 
            xmax = 54.53 
            text = "<fun bakante>. er hot gevolt opgebn in militer. zog ikh, ""ikh bin militer." 
        intervals [20]:
            xmin = 54.53 
            xmax = 57.662 
            text = "gib mir dem ferd, vel ikh forn. zoln zey mir araynzetsn!""" 
        intervals [21]:
            xmin = 57.662 
            xmax = 59.928 
            text = "<ah,> s'iz dokh nit geven keyn ordenung." 
