        intervals [728]:
            xmin = 1725.852 
            xmax = 1730.3 
            text = "ven m'hot gemakht a geto zaynen zey gelofn in vald. der vald iz shoyn geven organizirt." 
        intervals [729]:
            xmin = 1730.3 
            xmax = 1731.752 
            text = "ikh bin nit geven <dor-...>" 
