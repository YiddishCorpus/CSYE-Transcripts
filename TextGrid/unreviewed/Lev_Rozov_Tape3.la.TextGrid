            xmin = 1705.055 
            xmax = 1705.062 
            text = "" 
        intervals [719]:
            xmin = 1705.062 
            xmax = 1709.612 
            text = "Yos- Yos<ik>. mir hobn, mir, ikh hob mit im dortn zikh getrofn. <hot er...>" 
