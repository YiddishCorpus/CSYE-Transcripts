item []: 
    item [1]:
        class = "IntervalTier" 
        name = "Ruth Helman" 
        xmin = 0 
        xmax = 1812.046 
        intervals: size = 489 
        intervals [1]:
            xmin = 0 
            xmax = 4.18 
            text = "" 
        intervals [2]:
            xmin = 4.18 
            xmax = 8.848 
            text = "yo. ikh kum keyn Mezritsh, alzo m'veyst nisht vos tsu tun," 
        intervals [3]:
            xmin = 8.848 
            xmax = 8.888 
            text = "" 
        intervals [4]:
            xmin = 8.888 
            xmax = 20.323 
            text = "un ikh eh eh eh iz iz a yidish kind un s'do zeyer fil iz gevezn dezertirn un azelkhe vos zenen bafrayt gevorn fun der rusisher armey." 
        intervals [5]:
            xmin = 20.323 
            xmax = 20.447 
            text = "" 
        intervals [6]:
            xmin = 20.447 
            xmax = 24.325 
            text = "eh s'shoyn do hundert tsvontsik yidn, un s'do a beker a beker oykhet." 
        intervals [7]:
            xmin = 24.325 
            xmax = 33.212 
            text = "un ale ge- ikh hob gehat eh opgenu- un ikh hob ge- ikh bin geven nisht, gut sheyn ongetun un yung oykhet. un ikh hob zikh shoyn ge- mit dem ZUREK, mit di zup fun di" 
        intervals [8]:
            xmin = 33.212 
            xmax = 36.509 
            text = "fun der poyer, bin ikh sh- hob ikh shoyn gut oysgezen." 
        intervals [9]:
            xmin = 36.509 
            xmax = 42.463 
            text = "vi nor a man, azoy fil mener. di varsheverin, di varsheverin, di varshever, di varshever." 
        intervals [10]:
            xmin = 42.463 
            xmax = 42.79 
            text = "" 
        intervals [11]:
            xmin = 42.79 
            xmax = 50.152 
            text = "a klal, ikh bin gevezn epes a por teg, mitn kind, dos kind hot zikh ongehoybn eh popraven oykhet." 
        intervals [12]:
            xmin = 50.152 
            xmax = 54.776 
            text = "s'dokh geven a koysh mit beyner, mamesh oyf tsu shtarbn, tsvelef kilo hot zi gevoygn" 
        intervals [13]:
            xmin = 54.776 
            xmax = 58.21 
            text = "ven ikh hob ir opgenumen nokh a por yor zayn dortn bay im." 
        intervals [14]:
            xmin = 58.21 
            xmax = 64.451 
            text = "vayl zi hot nisht gekent lebn im. im hot zi lib gehat. er iz dokh geven a kultureler mentsh, er hot dokh ir gelernt." 
        intervals [15]:
            xmin = 64.451 
            xmax = 64.608 
            text = "" 
        intervals [16]:
            xmin = 64.608 
            xmax = 72.838 
            text = "un er un er hot eh eh un er hot gezen az a fakt az zi hot ongehoybn geyn in shule bald az er iz gekumen, in der driter klas." 
        intervals [17]:
            xmin = 72.838 
            xmax = 74.582 
            text = "" 
        intervals [18]:
            xmin = 74.582 
            xmax = 79.234 
            text = "ikh bin do a por tog, un ikh trakht mikh, ikh darf dokh makhn epes a lebn." 
        intervals [19]:
            xmin = 79.234 
            xmax = 80.826 
            text = "" 
        intervals [20]:
            xmin = 80.826 
            xmax = 85.832 
            text = "un ikh gey ikh for tsurik keyn Paplovits nemen a por zakhn vos ikh hob shoyn gehat." 
        intervals [21]:
            xmin = 85.832 
            xmax = 86.344 
            text = "" 
        intervals [22]:
            xmin = 86.344 
            xmax = 92.998 
            text = "ikh zol epes hobn zikh vi tsu eh dos. in komitet hot men mir gezogt bald, in ershtn tog ven ikh bin gekumen," 
        intervals [23]:
            xmin = 92.998 
            xmax = 99.264 
            text = "az m'zukht a shnayderin in MINISTERSTWO vu s'geven a mol fun fun der ban," 
        intervals [24]:
            xmin = 99.264 
            xmax = 99.321 
            text = "" 
        intervals [25]:
            xmin = 99.321 
            xmax = 102.397 
            text = "iz haynt do kh- eh a kikh," 
        intervals [26]:
            xmin = 102.397 
            xmax = 108.832 
            text = "un m'firt a shnayderay vayl ale alerley zenen opgerisn opgeshlisn, di vos zenen geven in Rusland, un di vos zenen in Poyln," 
        intervals [27]:
            xmin = 108.832 
            xmax = 112.981 
            text = "m'darf zey epes oyfneyen, afilek der prezident, di PREZYDENTOWA." 
        intervals [28]:
            xmin = 112.981 
            xmax = 113.028 
            text = "" 
        intervals [29]:
            xmin = 113.028 
            xmax = 115.869 
            text = "nor s'arbetn tsvelef shikses," 
        intervals [30]:
            xmin = 115.869 
            xmax = 116.314 
            text = "" 
        intervals [31]:
            xmin = 116.314 
            xmax = 121.86 
            text = "un zey kumen der porutshnik, mit a range heyst es, a militer man, vos firt dos on dos," 
        intervals [32]:
            xmin = 121.86 
            xmax = 122.22 
            text = "" 
        intervals [33]:
            xmin = 122.22 
            xmax = 128.542 
            text = "er er vil a yidishe zol hobn an oyg oyf di shikses. zey hobn nisht gehat keyn tsutroy. farshteyt?" 
        intervals [34]:
            xmin = 128.542 
            xmax = 129.088 
            text = "" 
        intervals [35]:
            xmin = 129.088 
            xmax = 132.592 
            text = "alzo, ikh hob shoyn gevust az ikh hob shoyn vu tsu geyn arbetn oykhet." 
        intervals [36]:
            xmin = 132.592 
            xmax = 132.885 
            text = "" 
        intervals [37]:
            xmin = 132.885 
            xmax = 140.827 
            text = "bin ikh hob ikh genumen un bin avekgeforn tsurik nemen ale zakhn dortn fun Pabovits vos ikh hob nokh dem gantsn vinter opgearbet." 
        intervals [38]:
            xmin = 140.827 
            xmax = 142.099 
            text = "" 
        intervals [39]:
            xmin = 142.099 
            xmax = 150.795 
            text = "un un zog ikh un ts- eh oyf tsurik vegs, vel ikh mikh heysn, hob ikh shoyn gehat a a oyfn veg gekhapt azan a taksi, an oyto," 
        intervals [40]:
            xmin = 150.795 
            xmax = 155.34 
            text = "aza mine s'iz an oyto geven, a vegele, alnfals a shtikl mashin." 
        intervals [41]:
            xmin = 155.34 
            xmax = 155.346 
            text = "" 
        intervals [42]:
            xmin = 155.346 
            xmax = 158.228 
            text = "un heyst mikh opshteln vu s'heybt zikh on Vlokhi." 
        intervals [43]:
            xmin = 158.228 
            xmax = 163.119 
            text = "zog ikh yetst vel ikh tsugeyn zen vos mit di shtub iz. s'dokh an eygntum." 
        intervals [44]:
            xmin = 163.119 
            xmax = 163.193 
            text = "" 
        intervals [45]:
            xmin = 163.193 
            xmax = 166.48 
            text = "tsi s'vet epes zayn derfun. ikh ho- ikh hob dokh shoyn gornisht gehat," 
        intervals [46]:
            xmin = 166.48 
            xmax = 170.476 
            text = "gornisht farmogt. epes a a kishele hob ikh shoyn gehat, ikh hob es alts genumen." 
        intervals [47]:
            xmin = 170.476 
            xmax = 171.023 
            text = "" 
        intervals [48]:
            xmin = 171.023 
            xmax = 179.061 
            text = "un ikh gey oyf mayn rikhtikn veg. forn ale shofern, shiker, ale rusn," 
        intervals [49]:
            xmin = 179.061 
            xmax = 184.028 
            text = "nisht zey hobn nisht keyn spirtn, nor zey trinken alkohol, un eh bren-spirt," 
        intervals [50]:
            xmin = 184.028 
            xmax = 184.371 
            text = "" 
        intervals [51]:
            xmin = 184.371 
            xmax = 190.755 
            text = "un ikh gey oyf mayn veg, un ikh krig a eh un un ikh fil az er fort oyf mir on," 
        intervals [52]:
            xmin = 190.755 
            xmax = 196.116 
            text = "un ikh krig epes do a klap, ikh farlir nisht UNK vos in kop arayn nisht, un ikh tsu mikh azoy tsunoyf," 
        intervals [53]:
            xmin = 196.116 
            xmax = 202.073 
            text = "un s'get mikh a fir ariber der tsenter vogn, a Shrudebek iz dos geven, an amerikaner last-oyto." 
        intervals [54]:
            xmin = 202.073 
            xmax = 202.292 
            text = "" 
        intervals [55]:
            xmin = 202.292 
            xmax = 205.728 
            text = "vos zey hobn di r- di amerikaner hobn gegebn far di rusn oykhet." 
        intervals [56]:
            xmin = 205.728 
            xmax = 206.325 
            text = "" 
        intervals [57]:
            xmin = 206.325 
            xmax = 212.481 
            text = "un azoy iz geven ze- a shpitol dortn in Vlokhi, bloyz fun di SAMOCHODn." 
        intervals [58]:
            xmin = 212.481 
            xmax = 215.882 
            text = "azoy vi haynt bay undz, a aza min oys shekhteray." 
        intervals [59]:
            xmin = 215.882 
            xmax = 216.329 
            text = "" 
        intervals [60]:
            xmin = 216.329 
            xmax = 220.207 
            text = "alzo, s'kumt on a por goyim, m'firt mikh un m'nemt mikh in shpitol arayn." 
        intervals [61]:
            xmin = 220.207 
            xmax = 220.298 
            text = "" 
        intervals [62]:
            xmin = 220.298 
            xmax = 225.809 
            text = "un ikh lig op tsvey vokhn un di Sheymels vu dos kind iz veyst nisht vu ikh bin ahingekumen." 
        intervals [63]:
            xmin = 225.809 
            xmax = 227.537 
            text = "" 
        intervals [64]:
            xmin = 227.537 
            xmax = 235.108 
            text = "nisht ikh, ikh bin gelegn mit dem fus, nisht tsebrokhn gevorn. nor der fus iz geven shvarts, s'geven oysgegosn dos blut." 
        intervals [65]:
            xmin = 235.108 
            xmax = 235.3 
            text = "" 
        intervals [66]:
            xmin = 235.3 
            xmax = 243.557 
            text = "iz bin ikh gelegn tsvey vokhn azoy nokh eh nokh ale tsores, mitn fus azoy tsum sufit, mit aza ekstere eksperiment," 
        intervals [67]:
            xmin = 243.557 
            xmax = 249.252 
            text = "un di hant, un do bloyz der oyf der f- nogl, der di der nogl iz aropgefaln." 
        intervals [68]:
            xmin = 249.252 
            xmax = 258.193 
            text = "do hob ikh gekrign mit dem letstn rod, vayl ikh hob mikh azoy tsunoyf gekortshet, ikh hob nisht farloyrn. der vogn iz adurkhgeforn, dos letste, der letster rod iz aroyf oyf mir." 
        intervals [69]:
            xmin = 258.193 
            xmax = 259.414 
            text = "" 
        intervals [70]:
            xmin = 259.414 
            xmax = 268.672 
            text = "dernokhn, ikh bin aroys, bin ikh shoyn gegangen glaykh oyf mayn veg, yo, in komitet arayn, u- u- u- ts- nokhn kind," 
        intervals [71]:
            xmin = 268.672 
            xmax = 268.797 
            text = "" 
        intervals [72]:
            xmin = 268.797 
            xmax = 276.266 
            text = "un ikh hob gezogt in komitet az ikh ken nokh dervayl nisht, ikh muz opnemen dos kind, dos kind tsum ersht aynordenen. zogn zey, dos kind e'mir undz tsunemen." 
        intervals [73]:
            xmin = 276.266 
            xmax = 276.559 
            text = "" 
        intervals [74]:
            xmin = 276.559 
            xmax = 282.723 
            text = "s'iz do a kinder-hoyz in Otvotsk. dort iz gevezn a a linye vos m'iz geforn" 
        intervals [75]:
            xmin = 282.723 
            xmax = 284.352 
            text = "UNK," 
        intervals [76]:
            xmin = 284.352 
            xmax = 288.52 
            text = "nor in yener tsayt hobn zey geshafn kinder-hayzer far di vos zey hobn opgenumen fun di" 
        intervals [77]:
            xmin = 288.52 
            xmax = 293.542 
            text = "vos zey hobn gefunen in di gasn oder opgenumen bay goyim. der komitet, der yidisher komitet." 
        intervals [78]:
            xmin = 293.542 
            xmax = 293.566 
            text = "" 
        intervals [79]:
            xmin = 293.566 
            xmax = 297.444 
            text = "shoyn. un eh ikh ikh gey ir opnemen," 
        intervals [80]:
            xmin = 297.444 
            xmax = 297.653 
            text = "" 
        intervals [81]:
            xmin = 297.653 
            xmax = 306.779 
            text = "iz dem tog vos s'geshen dos hot zi zikh oyfgekhapt, zi hot mir dernokh dertseylt, zi hot gevoynt zi eh eh do gekumen. zey hobn gevoynt in Belgye dernokhn." 
        intervals [82]:
            xmin = 306.779 
            xmax = 310.236 
            text = "zeyer raykhe mentshn, un eh zenen zey geven." 
        intervals [83]:
            xmin = 310.236 
            xmax = 310.309 
            text = "" 
        intervals [84]:
            xmin = 310.309 
            xmax = 314.972 
            text = "eh zey lebn zi lebt shoyn nisht, zi lebt shoyn oykh zikher nisht. er iz geshtorbn shoyn do oykhet." 
        intervals [85]:
            xmin = 314.972 
            xmax = 319.494 
            text = "nor demolts hot zi mir dertseylt, az dem tog vos mir iz dos geshen, di nakht," 
        intervals [86]:
            xmin = 319.494 
            xmax = 322.942 
            text = "hot zi zikh oyfgekhapt, UNK." 
        intervals [87]:
            xmin = 322.942 
            xmax = 322.982 
            text = "" 
        intervals [88]:
            xmin = 322.982 
            xmax = 325.355 
            text = "dos heyst, ikh hob shoyn nisht keyn mamen oykhet." 
        intervals [89]:
            xmin = 325.355 
            xmax = 325.362 
            text = "" 
        intervals [90]:
            xmin = 325.362 
            xmax = 327.713 
            text = "dem tatn hot zi gevust er iz umgekumen." 
        intervals [91]:
            xmin = 327.713 
            xmax = 328.883 
            text = "fun dem goy." 
        intervals [92]:
            xmin = 328.883 
            xmax = 330.39 
            text = "" 
        intervals [93]:
            xmin = 330.39 
            xmax = 336.948 
            text = "fun di goy, oder zi hot gehert politik, oder m'hot geleyent a tsaytung, ikh veys nisht vos, zi hot dokh gehat farshtand oysergeveyntlekh." 
        intervals [94]:
            xmin = 336.948 
            xmax = 338.052 
            text = "" 
        intervals [95]:
            xmin = 338.052 
            xmax = 341.86 
            text = "a klal ikh lo- ikh kum tsu geyn un vil nemen dos kind," 
        intervals [96]:
            xmin = 341.86 
            xmax = 343.283 
            text = "" 
        intervals [97]:
            xmin = 343.283 
            xmax = 350.923 
            text = "zogt er, zogt mir dos meydl, dos yidishe vos m'hot shoyn opgenumen fun di goyim, eh vos zi hot getun alts in shtub, gekokht un gevashn un alding," 
        intervals [98]:
            xmin = 350.923 
            xmax = 357.2 
            text = "in di shtub iz geven an araynfor hoyz. ver s'iz gekumen, fun eh velkher zayt, iz gegangen tsu di Sheymels." 
        intervals [99]:
            xmin = 357.2 
            xmax = 357.947 
            text = "" 
        intervals [100]:
            xmin = 357.947 
            xmax = 366.277 
            text = "vayl zey hobn keynem nisht gehat, zey hobn gehat tsvey zin, zenen zey umgekumen in poylishn oyfshtand in Varshe. un zey hobn oykhet ibergelebt in Varshe ergets in a bunker." 
        intervals [101]:
            xmin = 366.277 
            xmax = 366.672 
            text = "" 
        intervals [102]:
            xmin = 366.672 
            xmax = 372.943 
            text = "AI- I- HAIKAR, ikh vil nemen dos kind un geb aza rir on," 
        intervals [103]:
            xmin = 372.943 
            xmax = 373.185 
            text = "" 
        intervals [104]:
            xmin = 373.185 
            xmax = 380.249 
            text = "ikh fil az s'hot fil nis, zog ikh vi azoy fir ikh ir avek in dem hoyz arayn? m'vet dokh ir opshern di hor!" 
        intervals [105]:
            xmin = 380.249 
            xmax = 380.796 
            text = "" 
        intervals [106]:
            xmin = 380.796 
            xmax = 382.984 
            text = "yo, in komitet hot men mir gezogt," 
        intervals [107]:
            xmin = 382.984 
            xmax = 383.108 
            text = "" 
        intervals [108]:
            xmin = 383.108 
            xmax = 392.467 
            text = "az ale kinder zenen opgeshoyrn vayl m'hot genumen kinder fun gas, farloyzte, farbrudikte, un un s'nokh s'epes do a krankeyt oykhet dortn." 
        intervals [109]:
            xmin = 392.467 
            xmax = 392.878 
            text = "" 
        intervals [110]:
            xmin = 392.878 
            xmax = 395.116 
            text = "un ikh hob n- do hob ikh nisht vu tsu geyn." 
        intervals [111]:
            xmin = 395.116 
            xmax = 395.14 
            text = "" 
        intervals [112]:
            xmin = 395.14 
            xmax = 402.823 
            text = "ikh hob nisht vu ikh hob ni- ikh hob nisht keyn shtub, ikh hob nisht vu tsu geyn. tsu dem Noyekhn vos hot gevolt mikh arayn farbetn oyf der SAPA, vel ikh dokh nisht geyn," 
        intervals [113]:
            xmin = 402.823 
            xmax = 409.849 
            text = "trots dem vos s'volt geven der rikhtikster plats, a khaver, eh vos ken, un veyst az dos kind iz do bay Brovlevski." 
        intervals [114]:
            xmin = 409.849 
            xmax = 409.939 
            text = "" 
        intervals [115]:
            xmin = 409.939 
            xmax = 413.994 
            text = "nor er iz a biterer mentsh gevezn. zog ikh, tsu im gey ikh nisht." 
        intervals [116]:
            xmin = 413.994 
            xmax = 423.298 
            text = "un nem dos kind, un gey aroyf tsu di tsu der tsu dem Droshn on dem fus vos ikh bin gevezn," 
        intervals [117]:
            xmin = 423.298 
            xmax = 423.304 
            text = "" 
        intervals [118]:
            xmin = 423.304 
            xmax = 430.402 
            text = "er zi iz geven rikhtik oyf Stolanski nisht vayt, Stolanski tsen hot er gevoynt. azoy vi yetst gedenk ikh es." 
        intervals [119]:
            xmin = 430.402 
            xmax = 431.016 
            text = "" 
        intervals [120]:
            xmin = 431.016 
            xmax = 436.426 
            text = "un ikh ikh geb ir finef hundert zlotes fun di tsvey toyznt vos ikh hob gekrign fun komitet," 
        intervals [121]:
            xmin = 436.426 
            xmax = 436.888 
            text = "" 
        intervals [122]:
            xmin = 436.888 
            xmax = 441.32 
            text = "un ikh koyf tsukerlekh, ikh koyf vos es lozt zikh, un leyg avek dos kind," 
        intervals [123]:
            xmin = 441.32 
            xmax = 441.462 
            text = "" 
        intervals [124]:
            xmin = 441.462 
            xmax = 447.176 
            text = "un do krig azelkhe blozn. un tsip aroys di nis. fun lange hor." 
        intervals [125]:
            xmin = 447.176 
            xmax = 448.313 
            text = "" 
        intervals [126]:
            xmin = 448.313 
            xmax = 452.205 
            text = "tsvey vokhn hot zikh nisht gelozt vashn, bay di Sheymels." 
        intervals [127]:
            xmin = 452.205 
            xmax = 452.329 
            text = "" 
        intervals [128]:
            xmin = 452.329 
            xmax = 458.021 
            text = "UNK zi hot shoyn nisht keyn mamen oykhet. a shvere tip dos kind. fun kind vos <oyf? shver." 
        intervals [129]:
            xmin = 458.021 
            xmax = 462.11 
            text = "zi iz f- iber iber dem farshtand shtendik geven antviklt." 
        intervals [130]:
            xmin = 462.11 
            xmax = 462.252 
            text = "" 
        intervals [131]:
            xmin = 462.252 
            xmax = 466.583 
            text = "zi hot zikh nisht gelozt vashn, zi hot shoyn nisht nokh vos tsu lebn, zi hot shoyn nisht keyn mame." 
        intervals [132]:
            xmin = 466.583 
            xmax = 467.584 
            text = "" 
        intervals [133]:
            xmin = 467.584 
            xmax = 475.065 
            text = "hobn zey ir nisht gevashn, zey hobn zikh nisht gevolt mit dem arum krign oder shlogn es oder vos. zi hot zikh nisht gelozt vashn. hobn zey farlozt dem kop," 
        intervals [134]:
            xmin = 475.065 
            xmax = 479.537 
            text = "hot zi gehat a kop mit layz un mit nis. yakh hob dos alts" 
        intervals [135]:
            xmin = 479.537 
            xmax = 486.784 
            text = "az ir geshtupt tsukerlekh in moyl arayn bay di kristin, un ir gegebn finef hundert funt zi zol mikh lozn zitsn in kekh," 
        intervals [136]:
            xmin = 486.784 
            xmax = 494.308 
            text = "un ikh hob oysgetsupt. zi iz geven eyn kind fun ale mit hor, mit tsep. ale zenen geven opgegolt in Otvotsk." 
        intervals [137]:
            xmin = 494.308 
            xmax = 494.938 
            text = "" 
        intervals [138]:
            xmin = 494.938 
            xmax = 499.964 
            text = "un ikh bin dervayl, azoy vi ikh hob ir gehat bashtat bay keyn Otvotsk," 
        intervals [139]:
            xmin = 499.964 
            xmax = 505.716 
            text = "bin ge- ongehoybn arbetn un yedn zuntik bin ikh geforn nor zen vayl m'hot nisht gearbet." 
        intervals [140]:
            xmin = 505.716 
            xmax = 508.017 
            text = "" 
        intervals [141]:
            xmin = 508.017 
            xmax = 512.28 
            text = "in tsvishn tsayt, ven ikh hob gearbet in MINISTERSTWO," 
        intervals [142]:
            xmin = 512.28 
            xmax = 512.556 
            text = "" 
        intervals [143]:
            xmin = 512.556 
            xmax = 519.463 
            text = "hot zikh geyavet eyner vos hot ibergelebt oykh oyfn eh oyfn poylishn oyfshtand un gevorn raykh." 
        intervals [144]:
            xmin = 519.463 
            xmax = 522.945 
            text = "un er hot gekrign a voynung vu s'geven a shule." 
        intervals [145]:
            xmin = 522.945 
            xmax = 523.356 
            text = "" 
        intervals [146]:
            xmin = 523.356 
            xmax = 533.334 
            text = "a a a a a shule tsu lernen. nor s'gevezn, eh s- ikh vil araynrukn poylishe verter keseyder, derfar kumt mir on shver." 
        intervals [147]:
            xmin = 533.334 
            xmax = 541.726 
            text = "iz zog ikh eh eh iz iz geven a a a a hoyz vos iz gevezn ruinirt fun bombardirn. iz geven a shule." 
        intervals [148]:
            xmin = 541.726 
            xmax = 541.783 
            text = "" 
        intervals [149]:
            xmin = 541.783 
            xmax = 550.079 
            text = "in di shule hot er gekrign a groyse klas, ikh veys eh er hot gemuzt lernen efsher fertsik fuftsik kinder, ikh veys vifl." 
        intervals [150]:
            xmin = 550.079 
            xmax = 550.272 
            text = "" 
        intervals [151]:
            xmin = 550.272 
            xmax = 556.813 
            text = "un er er hot ibergelebt un a bruder un a bruder's a tokhter, un di froy hot nisht ibergelebt." 
        intervals [152]:
            xmin = 556.813 
            xmax = 557.038 
            text = "" 
        intervals [153]:
            xmin = 557.038 
            xmax = 562.562 
            text = "un dos iz gevezn undzerer a guter fra- a khaver. fun undzer, in undzer GIL." 
        intervals [154]:
            xmin = 562.562 
            xmax = 565.942 
            text = "nor eh m'nisht geven azoy spetsyel noent." 
        intervals [155]:
            xmin = 565.942 
            xmax = 565.948 
            text = "" 
        intervals [156]:
            xmin = 565.948 
            xmax = 571.629 
            text = "un zayn fr- iz er hot gevoynt vayt fun undz oykhet. m'hot eyn mol bazukht vu er hot gevoynt dort in Varshe." 
        intervals [157]:
            xmin = 571.629 
            xmax = 572.142 
            text = "" 
        intervals [158]:
            xmin = 572.142 
            xmax = 576.298 
            text = "un er er hot zikh zeyer tsu undz geklebt, nokhn geto dertsu." 
        intervals [159]:
            xmin = 576.298 
            xmax = 582.682 
            text = "un flegt er aroyfkumen. hot er eyn mol genumen fun undz genumen di fotografye. a kleyne." 
        intervals [160]:
            xmin = 582.682 
            xmax = 583.735 
            text = "" 
        intervals [161]:
            xmin = 583.735 
            xmax = 592.453 
            text = "hot er bay, er ho- eh vi azoy er hot dos oysbahaltn veys ikh nisht, tsuzamen mit di gelter un in oyfshtand dem poylishn, vos zey hobn ibergelebt, shreklekh ibergelebt." 
        intervals [162]:
            xmin = 592.453 
            xmax = 592.847 
            text = "" 
        intervals [163]:
            xmin = 592.847 
            xmax = 594.292 
            text = "geblibn lebn." 
        intervals [164]:
            xmin = 594.292 
            xmax = 594.383 
            text = "" 
        intervals [165]:
            xmin = 594.383 
            xmax = 601.695 
            text = "un get mir di fotografye. un dernokhn hot mayn shvogerl eyner vos iz gekumen mit Ander's Armey, du veyst dokh do iz geven," 
        intervals [166]:
            xmin = 601.695 
            xmax = 606.285 
            text = "a yingerer bruder fun mayn man gemakht a gresere, nor a ikh vil es zi nisht vayzn" 
        intervals [167]:
            xmin = 606.285 
            xmax = 608.923 
            text = "vayl zi h- vil nisht hern fun keyn SHOAH." 
        intervals [168]:
            xmin = 608.923 
            xmax = 609.182 
            text = "" 
        intervals [169]:
            xmin = 609.182 
            xmax = 616.331 
            text = "un ikh vil nisht vayzn vi zi hot oysgezen in geto. fun geto vu zi iz alt gevezn fir yor shoyn." 
        intervals [170]:
            xmin = 616.331 
            xmax = 616.54 
            text = "" 
        intervals [171]:
            xmin = 616.54 
            xmax = 623.689 
            text = "iz do a kl-  hob ikh a herlekhe ZDJECIE, nor ikh vil nisht mit ir onheybn. s'iz geven shver iz es haynt nokh shver." 
        intervals [172]:
            xmin = 623.689 
            xmax = 623.695 
            text = "" 
        intervals [173]:
            xmin = 623.695 
            xmax = 634.019 
            text = "ikh hob nisht keyn shum hilf mit ir. nor vos zi mit mir gemuzt geyn in der bank arayn vayl ikh ze nisht untertsushraybn, un ikh ze nisht optsutseyln. un do darf ikh dokh gelt far eh farn shpitol geyn." 
        intervals [174]:
            xmin = 634.019 
            xmax = 638.592 
            text = "farshteyst? derfar hob ikh a harts zikh mit ir bashteln, a toyve." 
        intervals [175]:
            xmin = 638.592 
            xmax = 646.774 
            text = "nemt zi sh- shteyn un ir mashin lozt zi shteyn un nemt SPECIAL, kumt in bank arayn mir tsu helfn opnemen di por funt." 
        intervals [176]:
            xmin = 646.774 
            xmax = 656.753 
            text = "" 
        intervals [177]:
            xmin = 656.753 
            xmax = 658.656 
            text = "a mayn tsveytn man?" 
        intervals [178]:
            xmin = 658.656 
            xmax = 666.782 
            text = "hob ikh getrofn, dos dertseyl ikh dokh, bay dem vos hot ibergelebt, bay dem khaver, un er hot gekrign aza a groys eh tsimer." 
        intervals [179]:
            xmin = 666.782 
            xmax = 669.234 
            text = "un zayn bruder iz epes gezesn." 
        intervals [180]:
            xmin = 669.234 
            xmax = 669.628 
            text = "" 
        intervals [181]:
            xmin = 669.628 
            xmax = 678.532 
            text = "der an elterer bruder, a raykher mentsh, er hot gehat eh ontuekhtser oyf a eksterer gas oyf Zhelne fun eh me- eh mener zakhn." 
        intervals [182]:
            xmin = 678.532 
            xmax = 678.724 
            text = "" 
        intervals [183]:
            xmin = 678.724 
            xmax = 683.623 
            text = "ikh veys nisht far vos er hot eh er iz gezesn, un un m'hot im bafrayt," 
        intervals [184]:
            xmin = 683.623 
            xmax = 690.094 
            text = "hot er bashlosn er makht aza mine bibke, dos iz geven a zuntik, ven ikh gevezn eh barn kind." 
        intervals [185]:
            xmin = 690.094 
            xmax = 691.947 
            text = "un ikh bin gekumen shoyn shpet." 
        intervals [186]:
            xmin = 691.947 
            xmax = 692.275 
            text = "" 
        intervals [187]:
            xmin = 692.275 
            xmax = 699.491 
            text = "un er hot farbe- yidn hobn zikh dokh gehaltn eyner dem andern, vifl m'hot gekent eh m- zi- m'hot dokh koym getrofn zikh tsunoyf getrofn." 
        intervals [188]:
            xmin = 699.491 
            xmax = 699.632 
            text = "" 
        intervals [189]:
            xmin = 699.632 
            xmax = 706.376 
            text = "ikh kum shoyn shpet tsurik fun kind, fun Otvotsk, eh kumt er tsu, der Yakub," 
        intervals [190]:
            xmin = 706.376 
            xmax = 706.652 
            text = "" 
        intervals [191]:
            xmin = 706.652 
            xmax = 711.812 
            text = "a neyn, ikh eh s'iz eh geven shoyn vayl ikh hob im sh- eh Yakubn shoyn gekent a por teg." 
        intervals [192]:
            xmin = 711.812 
            xmax = 717.328 
            text = "un s'hot zikh in mir gelibt vider an ofitsir, er hot mikh nisht opgelozt, a bokher, BEDIYUK in mayn GIL." 
        intervals [193]:
            xmin = 717.328 
            xmax = 717.587 
            text = "" 
        intervals [194]:
            xmin = 717.587 
            xmax = 722.323 
            text = "eh tsvey yor elter. un ikh hob a kind shoyn fun fun fun eh fun akht yor." 
        intervals [195]:
            xmin = 722.323 
            xmax = 722.65 
            text = "" 
        intervals [196]:
            xmin = 722.65 
            xmax = 726.93 
            text = "fun eh zibn yor, akht yor. mit a a kavalir." 
        intervals [197]:
            xmin = 726.93 
            xmax = 726.936 
            text = "" 
        intervals [198]:
            xmin = 726.936 
            xmax = 733.072 
            text = "a klal, bin ikh fun im a- un un ikh hob gehat a gekrign a shtub fun MINISTERSTWO oykhet, fun eh fun der regirung." 
        intervals [199]:
            xmin = 733.072 
            xmax = 733.078 
            text = "" 
        intervals [200]:
            xmin = 733.078 
            xmax = 742.1 
            text = "bay a pr- eh bay a koleye, bay eyner f- oyf der ban vos er hot gearbet, un er hot nisht gelebt nor zi hot gehat dray tsimern, hob ikh gekrign a tsimer noent fun der arbet." 
        intervals [201]:
            xmin = 742.1 
            xmax = 742.343 
            text = "" 
        intervals [202]:
            xmin = 742.343 
            xmax = 744.246 
            text = "fun vanet aroptsugeyn arbetn." 
        intervals [203]:
            xmin = 744.246 
            xmax = 753.153 
            text = "di arbet iz geven oyf der Gove, oyf der Gove iz geven oykh der komitet, nor in hekhere numern, un oyf Inzhenyerski tsen. spn zakhn vos ikh darf nisht gedenk ikh." 
        intervals [204]:
            xmin = 753.153 
            xmax = 754.577 
            text = "" 
        intervals [205]:
            xmin = 754.577 
            xmax = 763.34 
            text = "alzo, ikh eh eh ikh eh ikh ho- ikh hob mikh far- un nisht gevolt trefn mit dem BACHUR," 
        intervals [206]:
            xmin = 763.34 
            xmax = 774.923 
            text = "er hot tsugeshtelt ale gute zakhn az s'zol kumen oyslender, hot er gehat a JOB eh f- in in der in in in fun der regirung. der BA- BACHUR." 
        intervals [207]:
            xmin = 774.923 
            xmax = 775.148 
            text = "" 
        intervals [208]:
            xmin = 775.148 
            xmax = 780.44 
            text = "iz geshtanen oyfn tash, a kaylekhike tish hob ikh gehat bay di goye vu ikh hob gevoynt," 
        intervals [209]:
            xmin = 780.44 
            xmax = 780.514 
            text = "" 
        intervals [210]:
            xmin = 780.514 
            xmax = 788.068 
            text = "ful ongeshtelt, fun konzervn, fun kavyar, fun alding, un di flign hobn gegesn un ikh bin nisht gekumen shlofn dort ahin." 
        intervals [211]:
            xmin = 788.068 
            xmax = 788.091 
            text = "" 
        intervals [212]:
            xmin = 788.091 
            xmax = 792.813 
            text = "un bin geganen, un dortn tsu dem vos hot ibergelebt un er hot gekrign di shtub," 
        intervals [213]:
            xmin = 792.813 
            xmax = 796.919 
            text = "hot ver s'ge- ver s'gekumene fun lager, ver s'nor gekumen fun vanet iz," 
        intervals [214]:
            xmin = 796.919 
            xmax = 801.578 
            text = "hot oyfgehongen a laylekh, un er hot gesh- eh shtelt er, eh er hot yo gehat a bet, az nisht a bet," 
        intervals [215]:
            xmin = 801.578 
            xmax = 807.289 
            text = "fun breter, un m'hot fortn geshlofn. s'geven aza a rizn zal. nor a ruinirter." 
        intervals [216]:
            xmin = 807.289 
            xmax = 807.531 
            text = "" 
        intervals [217]:
            xmin = 807.531 
            xmax = 812.641 
            text = "alzo, ikh kum tsu forn fun kind vos ikh hob ir bazukht, un dortn in Otvotsk" 
        intervals [218]:
            xmin = 812.641 
            xmax = 816.62 
            text = "iz azoy vi azoy vi ikh bin nor ongekumen dos ershte mol bazukhn," 
        intervals [219]:
            xmin = 816.62 
            xmax = 816.88 
            text = "" 
        intervals [220]:
            xmin = 816.88 
            xmax = 822.493 
            text = "get zikh in mir a heng on nokh a kind, nor opgeshoyrn, un zogt MAMUSIU, mame!" 
        intervals [221]:
            xmin = 822.493 
            xmax = 823.427 
            text = "" 
        intervals [222]:
            xmin = 823.427 
            xmax = 829.127 
            text = "iz vos ikh hob gebrengt dernokhn mayn kind, iz dos kind geven, az ikh hob gehat shoyn tsvey kinder." 
        intervals [223]:
            xmin = 829.127 
            xmax = 835.16 
            text = "un az yene iz geven shoyn opgeshoyrn, zi iz geven frier fun mayn kind, un ikh hob gebrengt a kind mit tsep." 
        intervals [224]:
            xmin = 835.16 
            xmax = 839.857 
            text = "on a on a nis, on a on on eh farshidene eh brudikeytn." 
        intervals [225]:
            xmin = 839.857 
            xmax = 840.285 
            text = "" 
        intervals [226]:
            xmin = 840.285 
            xmax = 845.901 
            text = "alzo, un ikh kum tsurik un ikh zets zikh avek oyf a bank, zitsn oyf oyf oyf benk," 
        intervals [227]:
            xmin = 845.901 
            xmax = 853.593 
            text = "mit sh- breter epes gemakht tishn oyf aza mine oyfn, nokh di aza shtikl bal nokh dem bafrayen fun dem bruder." 
        intervals [228]:
            xmin = 853.593 
            xmax = 853.887 
            text = "" 
        intervals [229]:
            xmin = 853.887 
            xmax = 858.018 
            text = "zitst do ikh veys keygn iber ikh veys f- fir finef mentshn." 
        intervals [230]:
            xmin = 858.018 
            xmax = 864.405 
            text = "un ikh zits nor eyne aleyn fun di zayt do, un er keygn iber mir. kumt tsu der Yakub," 
        intervals [231]:
            xmin = 864.405 
            xmax = 866.809 
            text = "un Yakub iz nisht andersh gevezn" 
        intervals [232]:
            xmin = 866.809 
            xmax = 873.351 
            text = "vi eh az ikh bin geblibn lebn, a fakt, er hot, UNK er hot afilek mayn fotografye fun mayn kind gehat, un er" 
        intervals [233]:
            xmin = 873.351 
            xmax = 878.01 
            text = "er aleyn hot nisht gehat keyn kind. un zayn vayb iz geven a miese, Rutke iz geven a sheynkeyt." 
        intervals [234]:
            xmin = 878.01 
            xmax = 882.006 
            text = "alzo, nisht andersh nor Rutke iz geblibn lebn far zaynet vegn." 
        intervals [235]:
            xmin = 882.006 
            xmax = 885.96 
            text = "a guter mentsh iz er gevezn. a guter fakhman, a shnayder." 
        intervals [236]:
            xmin = 885.96 
            xmax = 887.383 
            text = "" 
        intervals [237]:
            xmin = 887.383 
            xmax = 891.984 
            text = "HAIKAR, u- un zey hobn zey hobn ongezamlt a farmegn," 
        intervals [238]:
            xmin = 891.984 
            xmax = 892.277 
            text = "" 
        intervals [239]:
            xmin = 892.277 
            xmax = 896.18 
            text = "dos hot geheysn sha- eh sh- eh shaber, dos heyst ganvenen." 
        intervals [240]:
            xmin = 896.18 
            xmax = 901.907 
            text = "vos fun farshidene baheltenishn fun dos, vos zenen gekumen raykh, zey hobn ober gelebt raykh." 
        intervals [241]:
            xmin = 901.907 
            xmax = 902.082 
            text = "" 
        intervals [242]:
            xmin = 902.082 
            xmax = 908.727 
            text = "nor keyner fun der familye iz nisht geblibn nor eyn tokhter fun dem bruder, a inteligente eh BACHURAH," 
        intervals [243]:
            xmin = 908.727 
            xmax = 913.213 
            text = "un zi hot mikh lib gehat shoyn fun der ershter on, zi hot nisht gehat vos tsu tun mit mir." 
