            xmin = 1557.34 
            xmax = 1557.387 
            text = "" 
        intervals [413]:
            xmin = 1557.387 
            xmax = 1562.663 
            text = "iz men un zi hot gevust eh vegn Bergn-Belzn. ze'mir farforn keyn Bergn-Belzn" 
        intervals [414]:
            xmin = 1562.663 
            xmax = 1566.706 
            text = "m'iz ongekumen in tsvelftn LIPIEC keyn Bergn-Belzn," 
        intervals [415]:
            xmin = 1566.706 
