            xmin = 1482.12 
            xmax = 1482.936 
            text = "" 
        intervals [394]:
            xmin = 1482.936 
            xmax = 1490.096 
            text = "oyfn veg iz geven a gantse dos, in TOWAROWA, in in nisht in keyn normal eh eh banen." 
        intervals [395]:
            xmin = 1490.096 
            xmax = 1497.577 
            text = "nor vos m'firt eh eh eh ki, eh eh dos heyst handls, TOWAROWA vagonen." 
