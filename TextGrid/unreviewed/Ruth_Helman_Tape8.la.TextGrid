            xmin = 1353.23 
            xmax = 1356.528 
            text = "in a ekstere opteylung fun dray hundert un zibetsn mentshn" 
        intervals [362]:
            xmin = 1356.528 
            xmax = 1361.025 
            text = "vos m'hot badorfn hitn di konter-revolutsyonern. farhstey-" 
