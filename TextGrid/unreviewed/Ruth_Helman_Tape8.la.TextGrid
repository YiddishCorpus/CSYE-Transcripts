            text = "" 
        intervals [416]:
            xmin = 1566.889 
            xmax = 1572.092 
            text = "iz eyner hot glaykh tsugekumen un gezogt, ikh ken dikh fun Varshe, tsu mayn man." 
        intervals [417]:
            xmin = 1572.092 
            xmax = 1578.51 
            text = "un undz ho'mir gefirt a valizke mit gelt oykhet, vos iz dort nisht geganen, un in Daytshland iz es gut geven, markn." 
        intervals [418]:
            xmin = 1578.51 
            xmax = 1578.955 
            text = "" 
        intervals [419]:
            xmin = 1578.955 
            xmax = 1584.326 
            text = "un khuts dem gelt oykhet, un afilek tsirung vos m'hot gebakn ekstere ayn" 
        intervals [420]:
            xmin = 1584.326 
            xmax = 1590.317 
            text = "eh eh un m'hot get- in di khales un alding, azoy az m'iz gekumen nisht orem keyn Daytshland." 
        intervals [421]:
            xmin = 1590.317 
            xmax = 1594.527 
            text = "iz gege- un ikh bin gevezn krank, ikh hob gehaltn in eyn blutikn," 
        intervals [422]:
            xmin = 1594.527 
            xmax = 1600.526 
            text = "hot men mikh genumen koydemen hot men mikh aroyfgegebn oyf a blok tsu di po- vu di politsey hot gevoynt," 
        intervals [423]:
            xmin = 1600.526 
            xmax = 1605.391 
            text = "un lerers un s'geven a klinik un s'geven a studye alts in dem blok." 
        intervals [424]:
            xmin = 1605.391 
            xmax = 1606.377 
            text = "" 
        intervals [425]:
            xmin = 1606.377 
            xmax = 1609.491 
            text = "un vi zi kumt take zogt take zi veyst vegn demer," 
        intervals [426]:
            xmin = 1609.491 
            xmax = 1613.406 
            text = "vayl zi iz oykhet bafrayt gevorn in Bergn-Belzn, zi iz nokh geblibn nokh vayter." 
        intervals [427]:
            xmin = 1613.406 
            xmax = 1617.534 
            text = "zi hot gelernt nokh in gimnazye eh di vos zi kumt tsu mir, fun Amkha." 
