            xmin = 1361.025 
            xmax = 1361.301 
            text = "" 
        intervals [364]:
            xmin = 1361.301 
            xmax = 1369.406 
            text = "azoy az ikh hob oyfgegebn oykhet az mayn tateshi iz eh gevezn, ikh hob shoyn dakht zikh geredt vegn dem mit dir vegn, ikh gedenk nisht." 
        intervals [365]:
            xmin = 1369.406 
            xmax = 1372.517 
            text = "HAIKAR, ober yetst iz dokh vikhtik vos ikh zog." 
        intervals [366]:
            xmin = 1372.517 
            xmax = 1374.683 
            text = "" 
        intervals [367]:
            xmin = 1374.683 
            xmax = 1381.835 
            text = "eh eh hob ikh im gezogt eh eh oyb eh eh iz eh iz hot er ongehoybn handlen, ongehoybn fardinen ekstere," 
        intervals [368]:
            xmin = 1381.835 
            xmax = 1388.076 
            text = "un m'hot nisht gevoynt shoyn mer in Prage nor in Valbzhikh, in a farnumene gebitn vos hobn a mol gevezn daytshn," 
        intervals [369]:
            xmin = 1388.076 
            xmax = 1388.183 
            text = "" 
        intervals [370]:
            xmin = 1388.183 
            xmax = 1395.444 
            text = "un in eh eh eh in un in Breslau iz geven a gants lebn. eyns hobn zikh di daytshn dortn" 
        intervals [371]:
            xmin = 1395.444 
            xmax = 1401.114 
            text = "eh zeks vokhn nokh geshlogn ven Berlin iz shoyn geven genumen, iz di shtot gevezn hefker," 
        intervals [372]:
            xmin = 1401.114 
            xmax = 1406.075 
            text = "un di shto- un tse- un tsevorfn, un un un f- un ruinirt," 
        intervals [373]:
            xmin = 1406.075 
            xmax = 1409.756 
            text = "nor yidn vos zenen ongekumen fun Poyln un fun un fun Rusland" 
        intervals [374]:
            xmin = 1409.756 
            xmax = 1415.112 
            text = "zenen ge- hobn dortn gevoynt in Breslau. hot gevoynt dort a a a a rebetsn oykhet," 
        intervals [375]:
            xmin = 1415.112 
            xmax = 1420.041 
            text = "hot zi oysgearbet toyznt zibn hundert un fuftsik yidn aroystsufirn als" 
        intervals [376]:
            xmin = 1420.041 
            xmax = 1425.829 
            text = "eh daytshishe yidn, un hot genumen fun yedn eynem hundert un finef un tsvontsik dolar." 
        intervals [377]:
            xmin = 1425.829 
            xmax = 1430.021 
            text = "zogt er, un un un undz ho'mir gevoynt nokh a bisl vayter in Valbzhikh," 
