        intervals [438]:
            xmin = 1638.27 
            xmax = 1642.82 
            text = "hot men mir oysnamlekh oysgezukht aza tsimer azoy groys vi mayn kokh." 
        intervals [439]:
            xmin = 1642.82 
            xmax = 1643.232 
            text = "" 
        intervals [440]:
            xmin = 1643.232 
            xmax = 1647.998 
            text = "un zey hobn gornisht gekrign. s'geforn azoy, nokh a CHAVERA mayne, vos zi" 
        intervals [441]:
            xmin = 1647.998 
            xmax = 1653.26 
            text = "eh zi iz dernokh fun danet shoyn geforn avek keyn Oystarlye, hot zi geshvangert," 
        intervals [442]:
            xmin = 1653.26 
            xmax = 1662.243 
            text = "un ir vos m'hot zi hot getrofn az er volt gevorn ayngezetst fun di bol- fun di bolshevikes, vayl er iz geven der MENAHEL fun a garazh," 
        intervals [443]:
            xmin = 1662.243 
            xmax = 1662.84 
            text = "" 
        intervals [444]:
            xmin = 1662.84 
            xmax = 1670.692 
            text = "eh az er volt gegan avek tsu di vayse bern, zogt er, vos voltstu getun, bist gekumen, zogt er, tsurik? un zi iz shoyn, zi hot in dray tog arum geboyrn a kind." 
        intervals [445]:
            xmin = 1670.692 
            xmax = 1673.536 
            text = "nor di shtub hob ikh bakumen, eyn shtikl shtibl." 
        intervals [446]:
            xmin = 1673.536 
            xmax = 1677.662 
            text = "iz eh undz ze'mir geshlofn oyf der erd, un tsvey ayzerne betlekh iz gevezn," 
        intervals [447]:
            xmin = 1677.662 
            xmax = 1682.944 
            text = "alzo, ikh hob gek- zi hot geboyrn, eyne hot geboyrn bald, iz zi aroys, hot zi gekrign a" 
        intervals [448]:
            xmin = 1682.944 
            xmax = 1689.902 
            text = "a a a shtub a di ergets, ikh bin nisht keyn mol geven dortn, un er hot ongehoybn arbetn in der politsey." 
        intervals [449]:
            xmin = 1689.902 
            xmax = 1691.342 
            text = "" 
        intervals [450]:
            xmin = 1691.342 
            xmax = 1697.883 
            text = "un di tsveyte iz nokh geblibn mit mir un hot oykh geshvangert, un zi hot gevolt poter vern fun dem man, zi hot im nisht lib gehat." 
        intervals [451]:
            xmin = 1697.883 
            xmax = 1697.957 
            text = "" 
        intervals [452]:
            xmin = 1697.957 
            xmax = 1703.182 
            text = "zi hot gehat zeyer fil derfolg. zi iz geven azelkhe vos hot gehat a seks-apil, ekstere." 
        intervals [453]:
            xmin = 1703.182 
            xmax = 1703.205 
            text = "" 
        intervals [454]:
            xmin = 1703.205 
            xmax = 1707.721 
            text = "nisht keyn sheynkeyt, nor a seks-apil. mener hobn ir nor ongekukt, zenen zey geven fertik." 
        intervals [455]:
            xmin = 1707.721 
            xmax = 1707.829 
            text = "" 
        intervals [456]:
            xmin = 1707.829 
            xmax = 1713.015 
            text = "hot zi im gevolt patern, un zi iz shoyn geven oykh efsher in, iz oyb zi hot geboyrn in yanuar," 
        intervals [457]:
            xmin = 1713.015 
            xmax = 1716.648 
            text = "iz vifl geven in in LIPIEC? ikh, epes a por monatn." 
        intervals [458]:
            xmin = 1716.648 
            xmax = 1716.807 
            text = "" 
        intervals [459]:
            xmin = 1716.807 
            xmax = 1724.951 
            text = "flegt zi shpringen, az di b- di a POCIAG di di ban iz geblibn shteyn, flegn zi mit mayn tokhter shpringen fun di dekher az s'zol ir kalye vern." 
        intervals [460]:
            xmin = 1724.951 
            xmax = 1725.042 
            text = "" 
        intervals [461]:
            xmin = 1725.042 
            xmax = 1729.468 
            text = "un mikh hot men dervayl genumen in shpitol arayn, un s'hot zikh azoy fartsoygn a por vokhn." 
        intervals [462]:
            xmin = 1729.468 
            xmax = 1734.616 
            text = "a klal, vi ikh kum eyn mol tsu geyn, ikh bin ge- mikh gefilt a bisl beser, <m'hot gegebn zikh a ZASIEGes>," 
        intervals [463]:
            xmin = 1734.616 
            xmax = 1738.34 
            text = "hob ikh bin ikh epes oyf a tog aheymkumen. ikh kum ahey- aheym," 
        intervals [464]:
            xmin = 1738.34 
            xmax = 1738.403 
            text = "" 
        intervals [465]:
            xmin = 1738.403 
            xmax = 1741.893 
            text = "di shtub iz dokh geven a shtikl an ayzern betl mit gornisht," 
        intervals [466]:
            xmin = 1741.893 
            xmax = 1742.018 
            text = "" 
        intervals [467]:
            xmin = 1742.018 
            xmax = 1746.855 
            text = "nor ikh bin dokh gekumen fun shpitol un aheym tsum kind un un tsu mayn man," 
        intervals [468]:
            xmin = 1746.855 
            xmax = 1747.03 
            text = "" 
        intervals [469]:
            xmin = 1747.03 
            xmax = 1751.057 
            text = "zo- z- geyt zi aroys mitn, zi hot nokh oykhet gevoynt," 
        intervals [470]:
            xmin = 1751.057 
            xmax = 1751.097 
            text = "" 
        intervals [471]:
            xmin = 1751.097 
            xmax = 1754.384 
            text = "geyt zi aroys es mit a pekele. zog ikh eh Stefa," 
        intervals [472]:
            xmin = 1754.384 
            xmax = 1759.494 
            text = "UNK RAK poylish. Ste- Stefa, vu geystu?" 
        intervals [473]:
            xmin = 1759.494 
            xmax = 1760.074 
            text = "" 
        intervals [474]:
            xmin = 1760.074 
            xmax = 1765.468 
            text = "zogt zi, zest dokh vu ikh gey. veyst dokh in vosere shtand ikh bin, un far vos ikh bin geshprungen fun di dekher." 
        intervals [475]:
            xmin = 1765.468 
            xmax = 1765.677 
            text = "" 
        intervals [476]:
            xmin = 1765.677 
            xmax = 1768.337 
            text = "zog ikh, kuk oyf mir, zog ikh." 
        intervals [477]:
            xmin = 1768.337 
            xmax = 1768.461 
            text = "" 
        intervals [478]:
            xmin = 1768.461 
            xmax = 1772.741 
            text = "vi krank ikh bin vos ikh hob oykh nisht gevolt hobn keyn kind, un ikh hob oykh gevolt." 
        intervals [479]:
            xmin = 1772.741 
            xmax = 1773.068 
            text = "" 
        intervals [480]:
            xmin = 1773.068 
            xmax = 1778.884 
            text = "ikh hob ir koym opgeredt un ayngeredt zi zol geyn tsurik. zi iz geganen kalye makhn dos kind." 
        intervals [481]:
            xmin = 1778.884 
            xmax = 1778.974 
            text = "" 
        intervals [482]:
            xmin = 1778.974 
            xmax = 1783.679 
            text = "a sof iz zi hot zi gelebt in yanuar un zi iz nokh shpeter gekumen do in land arayn." 
        intervals [483]:
            xmin = 1783.679 
            xmax = 1789.717 
            text = "un hot geboyrn in fiftstn yanuar iz zibn un fertsik," 
        intervals [484]:
            xmin = 1789.717 
            xmax = 1789.723 
            text = "" 
        intervals [485]:
            xmin = 1789.723 
            xmax = 1796.166 
            text = "hot zi geboyrn a kind, a meydele, un hot gekrign a voynung. azoy ikh hob shoyn gehat di voynung biz tsum avekforn," 
        intervals [486]:
            xmin = 1796.166 
            xmax = 1805.58 
            text = "bin aroysgeforn punkt in zelbn tog vos ikh bin gekumen tsum yor, mit der tsveyter TURE fun di legale men- fun di le- fun di tsen toyznt sertifikatn," 
        intervals [487]:
            xmin = 1805.58 
            xmax = 1805.822 
            text = "" 
        intervals [488]:
            xmin = 1805.822 
            xmax = 1809.893 
            text = "un er hor ir ge- m'hot batsolt gut derfar, ze'mir gekumen in land arayn." 
        intervals [489]:
            xmin = 1809.893 
            xmax = 1812.046 
            text = "" 
