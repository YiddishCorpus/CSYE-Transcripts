            xmin = 1430.021 
            xmax = 1430.079 
            text = "" 
        intervals [379]:
            xmin = 1430.079 
            xmax = 1433.441 
            text = "zol men, un mayne a CHAVERA hot gevoynt in Breslau." 
        intervals [380]:
            xmin = 1433.441 
            xmax = 1439.105 
            text = "ze'mir geforn arayngeforn keyn Breslau, un m'hot eh alts gekoyft dires, nisht gekrign." 
