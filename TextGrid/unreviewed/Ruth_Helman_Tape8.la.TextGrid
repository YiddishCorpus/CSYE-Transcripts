            xmin = 1439.105 
            xmax = 1439.247 
            text = "" 
        intervals [382]:
            xmin = 1439.247 
            xmax = 1442.61 
            text = "herlekhe dires ibergelozt mit farshidene zakhn." 
        intervals [383]:
            xmin = 1442.61 
            xmax = 1451.812 
            text = "alzo ze'mir arayngeforn, un m'hot batsolt eh far eh far ale dray oyf falshe nemen oyf tsu forn keyn Daytshland." 
        intervals [384]:
            xmin = 1451.812 
            xmax = 1453.152 
            text = "" 
        intervals [385]:
            xmin = 1453.152 
            xmax = 1459.997 
            text = "dos iz gevezn alding nokh in finef un fertsikstn, in s'shoyn dos iz shoyn geven in zeks un fertsikstn yor." 
        intervals [386]:
            xmin = 1459.997 
            xmax = 1461.927 
            text = "" 
        intervals [387]:
            xmin = 1461.927 
            xmax = 1469.396 
            text = "m'hot eh m'iz aroysgeforn zibetsn hundert un fu- un fuftsik yidn, tsi vifl s'iz nokh geven, efsher a por un fuftsik," 
        intervals [388]:
            xmin = 1469.396 
            xmax = 1469.419 
            text = "" 
        intervals [389]:
            xmin = 1469.419 
            xmax = 1473.069 
            text = "iz gevezn punkt a tog ven m'hot badorfn shtimen" 
        intervals [390]:
            xmin = 1473.069 
            xmax = 1477.412 
            text = "yo far der regirung, nisht far der regirung. TAK, NIE, yo, neyn." 
        intervals [391]:
            xmin = 1477.412 
            xmax = 1477.435 
            text = "" 
        intervals [392]:
            xmin = 1477.435 
            xmax = 1482.12 
            text = "ho'mir gezdonzhet optsushtimen, un far nakhts ze'mir avekgeforn ale." 
