            text = "" 
        intervals [397]:
            xmin = 1498.377 
            xmax = 1507.584 
            text = "in transport-vagonen. ze'mir gezes- ze'mir azoy opgelegn, bin ikh azoy opgelegn oyf a bisl eh eh eh dos eh eh shtroy, ale," 
