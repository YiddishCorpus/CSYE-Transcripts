            xmin = 1507.584 
            xmax = 1507.675 
            text = "" 
        intervals [399]:
            xmin = 1507.675 
            xmax = 1513.234 
            text = "un dernokhn iz arayngekumen a kontrolir, shpeter shoyn, m'iz shoyn geven nisht nisht in Poyln, nor oyf der" 
        intervals [400]:
            xmin = 1513.234 
            xmax = 1513.235 
            text = "" 
        intervals [401]:
            xmin = 1513.235 
            xmax = 1515.576 
            text = "oyf anderer zayn fun Daytshland," 
        intervals [402]:
            xmin = 1515.576 
            xmax = 1521.363 
            text = "iz gekumen a kontrolir, un far- un yedn gefregt vi er heyst. yeder iz geforn oyfn an ander nomen." 
        intervals [403]:
            xmin = 1521.363 
            xmax = 1525.955 
            text = "eh hot mayn man hot gezogt eh, ikh hob gezogt eh eh Kurts," 
        intervals [404]:
            xmin = 1525.955 
            xmax = 1530.68 
            text = "un mayn man hot er oykh gezogt Kurts. zogt er der zogt der kontrolir eh oyf doytsh," 
        intervals [405]:
            xmin = 1530.68 
            xmax = 1530.72 
            text = "" 
        intervals [406]:
            xmin = 1530.72 
            xmax = 1534.592 
            text = "er hot dos gut gut gelernt. er hot gevust, er iz geven opgekoyft" 
        intervals [407]:
            xmin = 1534.592 
            xmax = 1539.401 
            text = "az dos forn falshe yi- ikh bin epes geforn epes far Klara Kurts." 
