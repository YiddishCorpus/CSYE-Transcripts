            xmin = 913.213 
            xmax = 913.388 
            text = "" 
        intervals [245]:
            xmin = 913.388 
            xmax = 916.824 
            text = "ober dos mol tsurik vi azoy s'iz geven ven ikh hob bakent mayn man." 
        intervals [246]:
            xmin = 916.824 
            xmax = 917.488 
            text = "" 
        intervals [247]:
            xmin = 917.488 
            xmax = 923.872 
            text = "a klal, er kumt tsu, Yakub, un er zogt azoy. s'iz shoyn gornisht geblibn far dir. vos zol ikh dir makhn? ikh gey dir makhn, zogt er," 
        intervals [248]:
            xmin = 923.872 
            xmax = 927.163 
            text = "a JAJECZNICA, a JAJECZNICEA heys a a gepreglt ey." 
        intervals [249]:
            xmin = 927.163 
            xmax = 936.115 
            text = "zog ikh, makh a gepreglt ey. brengt er tsu a gepreglt ey mit a gopl, er flegt mir vashn un presn afile." 
        intervals [250]:
            xmin = 936.115 
            xmax = 937.519 
            text = "" 
        intervals [251]:
            xmin = 937.519 
            xmax = 946.169 
            text = "HAIKAR, er get mir dem gopl. yakh nem a shtikl eh ey, un vil nemen broyt." 
        intervals [252]:
            xmin = 946.169 
            xmax = 946.311 
            text = "" 
        intervals [253]:
            xmin = 946.311 
            xmax = 950.169 
            text = "keygn iber mir shtekt eyner azoy oys dem moyl, dos moyl." 
        intervals [254]:
            xmin = 950.169 
            xmax = 950.209 
            text = "" 
        intervals [255]:
            xmin = 950.209 
            xmax = 959.045 
            text = "geb a kuk, ligt a por hent, herlekhe sheyne, a man, a blonder, enlekh tsu der Nikey nor a shenerer." 
        intervals [256]:
            xmin = 959.045 
            xmax = 959.085 
            text = "" 
        intervals [257]:
            xmin = 959.085 
            xmax = 962.15 
            text = "ir zet dokh oyf der foto az er iz a sheyner man gevezn." 
        intervals [258]:
            xmin = 962.15 
            xmax = 963.507 
            text = "" 
        intervals [259]:
            xmin = 963.507 
            xmax = 971.097 
            text = "un get mikh a khap oyf di hent azoy nakher azoy vi a vi vi <yurke>, azoy vi gornisht, un get mikh a trog aroys fun hoyz aroys un heyst mikh onkushn." 
        intervals [260]:
            xmin = 971.097 
            xmax = 971.127 
            text = "" 
        intervals [261]:
            xmin = 971.127 
            xmax = 974.999 
            text = "dos ershte az er iz eh hot mit mir geshen, mit gevald mamesh." 
        intervals [262]:
            xmin = 974.999 
            xmax = 980.829 
            text = "un di ale khevre, zayne bakante, zogn, s'dokh Yakub's eh v- eh eh kale!" 
        intervals [263]:
            xmin = 980.829 
            xmax = 984.553 
            text = "zi geyt dokh er ge- er nemt dokh ir keyn Bitol, s'vet dokh ir zayn gut!" 
        intervals [264]:
            xmin = 984.553 
            xmax = 989.347 
            text = "vos eh eh Shlamik! Shloyme hobn zey gerufn Shlame. Shlamik, loz ir op!" 
        intervals [265]:
            xmin = 989.347 
            xmax = 992.424 
            text = "di bakante vos zenen gezesn. azoy hob ikh im bakent." 
        intervals [266]:
            xmin = 992.424 
            xmax = 992.582 
            text = "" 
        intervals [267]:
            xmin = 992.582 
            xmax = 994.668 
            text = "er hot mikh shoyn mer nisht opgelozt," 
        intervals [268]:
            xmin = 994.668 
            xmax = 994.995 
            text = "" 
        intervals [269]:
            xmin = 994.995 
            xmax = 999.826 
            text = "do vu m'hot gearbet iz gevezn glaykh mit dem trotuar, vu m'geyt," 
        intervals [270]:
            xmin = 999.826 
            xmax = 1009.164 
            text = "oyf parter. dort iz a mol gevezn dos di m- di minis- di di regirungs anshtalt fun fun di banen, fun farker." 
        intervals [271]:
            xmin = 1009.164 
            xmax = 1009.373 
            text = "" 
        intervals [272]:
            xmin = 1009.373 
            xmax = 1015.191 
            text = "hot men dortn gearbet un s-m'hot gekokht azoy gut far far Byerutn, far dem prezident," 
        intervals [273]:
            xmin = 1015.191 
            xmax = 1020.599 
            text = "un far di eh ministorn. azoy hob ikh gehat dos zelbe esn, un ikh hob badorfn zen" 
        intervals [274]:
            xmin = 1020.599 
            xmax = 1026.625 
            text = "ts- un un m'hot badorfn dortn on tsudatn, un on zhurnaln, un on faserner." 
        intervals [275]:
            xmin = 1026.625 
            xmax = 1031.506 
            text = "un on a a dos m- tsu kenen mestn. vayl s'gornisht nokh gevezn." 
        intervals [276]:
            xmin = 1031.506 
            xmax = 1031.714 
            text = "" 
        intervals [277]:
            xmin = 1031.714 
            xmax = 1039.643 
            text = "nor kaponen iz geven, zey hobn gebrengt fun Lodzh, eh vos s'nokh geven fun Lodzh vos di daytshn hobn ibergelozt, hobn zey opgebrengt keseyder kaponen farshidene" 
        intervals [278]:
            xmin = 1039.643 
            xmax = 1044.635 
            text = "eh eh zakhn. m'hot yedn un mir oykh gegebn. yede vokh hot men mir gegebn a kapon." 
        intervals [279]:
            xmin = 1044.635 
            xmax = 1046.109 
            text = "" 
        intervals [280]:
            xmin = 1046.109 
            xmax = 1051.861 
            text = "un i- un ikh hob badorfn akhtung gebn oyf di sh- eh shikses oyf di ts- oyf di tsvelef vos hobn gearbet." 
        intervals [281]:
            xmin = 1051.861 
            xmax = 1057.957 
            text = "un ikh hob gedorfn aleyn on a zhurnaln oder alding, fleg ikh shnaydn oyf di figurn yedn eynem." 
        intervals [282]:
            xmin = 1057.957 
            xmax = 1057.988 
            text = "" 
        intervals [283]:
            xmin = 1057.988 
            xmax = 1062.626 
            text = "un s'nokh geven azelkhe komones, iz gut oysgekumen. nor azoy hob ikh geshnitn vifl s-" 
        intervals [284]:
            xmin = 1062.626 
            xmax = 1067.009 
            text = "az ikh hob nisht gehat in gantsn keyn zhurnaln, nisht gornisht, nisht keyn nisht keyn tsudatn," 
        intervals [285]:
            xmin = 1067.009 
            xmax = 1067.116 
            text = "" 
        intervals [286]:
            xmin = 1067.116 
            xmax = 1071.99 
            text = "m'hot kneplekh aleyn ibertsien un makhn. gornisht iz geven. a hefker." 
        intervals [287]:
            xmin = 1071.99 
            xmax = 1071.996 
            text = "" 
        intervals [288]:
