            text = "ver es geyt. s'geven azoy di fentster groyse, hekhere eh hekhere fentster vi dos iz geven, nor fun der erd, fun der gas." 
        intervals [291]:
            xmin = 1087.363 
            xmax = 1088.027 
            text = "" 
        intervals [292]:
            xmin = 1088.027 
            xmax = 1090.805 
            text = "al- zogt eh zogn di shikses azoy." 
        intervals [293]:
            xmin = 1090.805 
            xmax = 1091.166 
            text = "" 
        intervals [294]:
            xmin = 1091.166 
            xmax = 1095.997 
            text = "Rutetshka, UNK" 
        intervals [295]:
            xmin = 1095.997 
            xmax = 1101.318 
            text = "UNK." 
        intervals [296]:
            xmin = 1101.318 
            xmax = 1101.443 
            text = "" 
        intervals [297]:
            xmin = 1101.443 
            xmax = 1110.532 
            text = "do dreyt zikh arum a tseratene kap- kapete un epes a man, ze nor ver dos iz. ikh geb a kuk, s'iz er." 
        intervals [298]:
            xmin = 1110.532 
            xmax = 1110.623 
            text = "" 
        intervals [299]:
            xmin = 1110.623 
            xmax = 1114.56 
            text = "der Shlamik. iz er geshtanen, er hot mikh gehitn in MINISTERSTWO," 
        intervals [300]:
            xmin = 1114.56 
            xmax = 1119.088 
            text = "ikh hob im shoyn nisht gekent optretn,  azoy iz es gevorn derfun." 
        intervals [301]:
            xmin = 1119.088 
            xmax = 1120.195 
            text = "" 
        intervals [302]:
            xmin = 1120.195 
            xmax = 1121.855 
            text = "demolt bald." 
        intervals [303]:
            xmin = 1121.855 
            xmax = 1127.16 
            text = "" 
        intervals [304]:
            xmin = 1127.16 
            xmax = 1130.309 
            text = "m'iz gevorn bafrayt in finef un fertsikstn yor." 
        intervals [305]:
            xmin = 1130.309 
            xmax = 1131.042 
            text = "" 
        intervals [306]:
            xmin = 1131.042 
            xmax = 1138.68 
            text = "ongehoybn arbetn hob ikh, ikh farshtey az s'iz shoyn gevezn," 
        intervals [307]:
            xmin = 1138.68 
            xmax = 1140.627 
            text = "" 
        intervals [308]:
            xmin = 1140.627 
            xmax = 1145.261 
            text = "ikh ikh veys a tsvey monatn hot gedoyert, mitn lign in shpitol, mit alding." 
        intervals [309]:
            xmin = 1145.261 
            xmax = 1147.039 
            text = "" 
        intervals [310]:
            xmin = 1147.039 
            xmax = 1153.091 
            text = "un undz un un dernokh hot ongerukt a zumer, alts iz tsvey un fertsikster yor," 
        intervals [311]:
            xmin = 1153.091 
            xmax = 1153.958 
            text = "" 
        intervals [312]:
            xmin = 1153.958 
            xmax = 1162.805 
            text = "eh eh f- eh finef un fertsikstn yor, hot men khasene gehat. un er hot ongehoybn handlen." 
        intervals [313]:
            xmin = 1162.805 
            xmax = 1166.155 
            text = "yo, a klal, azoy vi ikh hob gezen er ken zikh nisht optshepen," 
        intervals [314]:
            xmin = 1166.155 
            xmax = 1174.235 
            text = "un eh vegn a- als men iz er geven tsum gefeln. un keyn soydes hob ikh nisht gevust, ikh hob nisht gezen er hot andere khesroynes," 
        intervals [315]:
            xmin = 1174.235 
            xmax = 1174.309 
            text = "" 
        intervals [316]:
            xmin = 1174.309 
            xmax = 1177.149 
            text = "alzo s'ge- eh hot er mikh gehitn." 
        intervals [317]:
            xmin = 1177.149 
            xmax = 1185.156 
            text = "un eh der Yakub iz gekumen er hot gehat tsugegreyt fir fir tsimern in Biton, mit a klavir mit alding farn kind iz geven greyt." 
        intervals [318]:
            xmin = 1185.156 
            xmax = 1187.398 
            text = "un er hot gevust az er hot nisht keyn gelt." 
        intervals [319]:
            xmin = 1187.398 
            xmax = 1187.404 
            text = "" 
        intervals [320]:
            xmin = 1187.404 
            xmax = 1192.143 
            text = "iz Yakubn im gezogt, Shlamik, ikh veys dokh az du host nisht keyn gelt un host lib" 
        intervals [321]:
            xmin = 1192.143 
            xmax = 1195.583 
            text = "a a a g- a a shnepsl, un host lib a portn," 
        intervals [322]:
            xmin = 1195.583 
            xmax = 1195.69 
            text = "" 
        intervals [323]:
            xmin = 1195.69 
            xmax = 1200.471 
            text = "na dir hundert toyznt zlotes, un loz ir op, Rutke, vos vilstu fun ir?" 
        intervals [324]:
            xmin = 1200.471 
            xmax = 1208.475 
            text = "vi vestu ir gebn tsu dos vos ir kind darf? er hot im opgeredt un er hot im gevolt iberkoyfn. zogt er, Rutke vet zayn mayn mayn froy." 
        intervals [325]:
            xmin = 1208.475 
            xmax = 1209.578 
            text = "" 
        intervals [326]:
            xmin = 1209.578 
            xmax = 1214.08 
            text = "azoy iz gevorn. nor PITOM, get a kum," 
        intervals [327]:
            xmin = 1214.08 
            xmax = 1219.986 
            text = "eh yo, ikh hob gearbet in MINISTERSTWO, s'nokh nisht geven keyn post, s'nokh nisht geganen keyn shum farbindung mit oysland." 
        intervals [328]:
            xmin = 1219.986 
            xmax = 1228.331 
            text = "iz geforn a eh eh a a a shishke a MINISTROWA, der minister, a <grar> minister mit der froy," 
        intervals [329]:
            xmin = 1228.331 
            xmax = 1230.55 
            text = "hob ikh ir gebetn, keyn Kanade." 
        intervals [330]:
            xmin = 1230.55 
            xmax = 1233.905 
            text = "hob ikh ir gebetn, ikh hob gehat dem adres fun mayn bruder," 
        intervals [331]:
            xmin = 1233.905 
            xmax = 1234.333 
            text = "" 
        intervals [332]:
            xmin = 1234.333 
            xmax = 1240.287 
            text = "az eh eh vu dos iz, afilek yetst gedenk ikh, eh volt ikh gekent zogn." 
        intervals [333]:
            xmin = 1240.287 
            xmax = 1246.505 
            text = "hob ikh ir gebetn zi zol araynvarfn a briv, er iz in Kuba, in Havana," 
        intervals [334]:
            xmin = 1246.505 
            xmax = 1252.969 
            text = "un s'iz der un der nomen, vayl ikh hob dokh s- vi ver veyst ven do vet zayn a komunikatsye?" 
        intervals [335]:
            xmin = 1252.969 
            xmax = 1257.744 
            text = "un eh eh un eh un z- un mit a briv un ikh hob im geshribn," 
        intervals [336]:
            xmin = 1257.744 
            xmax = 1260.55 
            text = "ikh bin aleyn, dos kind iz mir geblibn lebn." 
        intervals [337]:
            xmin = 1260.55 
            xmax = 1262.025 
            text = "" 
        intervals [338]:
            xmin = 1262.025 
            xmax = 1267.093 
            text = "azoy vi azoy vi zi iz gekumen keyn Kanade hot zi arayngevorfn dem briv," 
        intervals [339]:
            xmin = 1267.093 
            xmax = 1272.043 
            text = "ikh hob gekrign an entfer oyf di, eh ikh hob dokh gehat an adres, gevoynt bay di koleyarke," 
        intervals [340]:
            xmin = 1272.043 
            xmax = 1272.1 
            text = "" 
        intervals [341]:
            xmin = 1272.1 
            xmax = 1277.392 
            text = "iz gekumen an adres, shvester, ikh tu shoyn ikh zol dikh nemen ariber mitn kind." 
        intervals [342]:
            xmin = 1277.392 
            xmax = 1278.158 
            text = "" 
        intervals [343]:
            xmin = 1278.158 
            xmax = 1279.907 
            text = "key- yo, keyn Kuba." 
        intervals [344]:
            xmin = 1279.907 
            xmax = 1282.866 
            text = "" 
        intervals [345]:
            xmin = 1282.866 
            xmax = 1288.395 
            text = "k- fun der mishpokhe keyner nisht. ale zenen nokh farn kesl tsugenumen gevorn." 
        intervals [346]:
            xmin = 1288.395 
            xmax = 1288.485 
            text = "" 
        intervals [347]:
            xmin = 1288.485 
            xmax = 1293.558 
            text = "farn ke- vayl ale hobn gevoynt in yenem gegnt vu s'iz geven der umshlag-plats, ikh oykhet." 
        intervals [348]:
            xmin = 1293.558 
            xmax = 1293.835 
            text = "" 
        intervals [349]:
            xmin = 1293.835 
            xmax = 1299.803 
            text = "di letste gas far a poylishe gas iz geven mayn gas vu ikh hob gevoynt, oyf Shishlive." 
        intervals [350]:
            xmin = 1299.803 
            xmax = 1304.365 
            text = "" 
        intervals [351]:
            xmin = 1304.365 
            xmax = 1307.886 
            text = "y- yo, tsi ikh vil? ikh hob dokh geshribn az ikh bin geblibn." 
        intervals [352]:
            xmin = 1307.886 
            xmax = 1313.258 
            text = "" 
        intervals [353]:
            xmin = 1313.258 
            xmax = 1318.511 
            text = "neyn, nisht in ven s'vet zayn meglekh, er er er makht shoyn er zol epes tun." 
        intervals [354]:
            xmin = 1318.511 
            xmax = 1327.021 
            text = "er un ikh hob gekrign dem entfer, bin ikh gegangen eyn mol bloyz keyn dos, nor er hot mikh dervayl gehitn, mayn man, der der Shlamik." 
        intervals [355]:
            xmin = 1327.021 
            xmax = 1327.197 
            text = "" 
        intervals [356]:
            xmin = 1327.197 
            xmax = 1340.151 
            text = "a klal, ikh eh eh ikh eh ikh zog im az er shraybt er redt makhn az undz tsu forn. zogt er, vu bin ikh? zog ikh, du kumst nisht in batrakht. tsu mayn bruder for ikh aleyn, ikh hob nisht khasene mit Yakubn oykhet nisht." 
        intervals [357]:
            xmin = 1340.151 
            xmax = 1340.494 
            text = "" 
        intervals [358]:
            xmin = 1340.494 
            xmax = 1343.739 
            text = "un iz iz dos dos muz es zayn." 
        intervals [359]:
            xmin = 1343.739 
            xmax = 1349.911 
            text = "zogt er, oyb azoy, lomir bikhlal farlozn Poyln, farlozn di arbet." 
        intervals [360]:
            xmin = 1349.911 
            xmax = 1353.23 
            text = "ikh hob on a derloybenish zikh bafrayt, vayl ikh hob gehert in a gev-" 
