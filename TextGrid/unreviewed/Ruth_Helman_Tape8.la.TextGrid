        intervals [409]:
            xmin = 1539.788 
            xmax = 1544.282 
            text = "ikh veys nisht far, oyf a falshn nomen. ale zenen azoy geforn, ale hundert un fuftsi-" 
        intervals [410]:
            xmin = 1544.282 
            xmax = 1551.555 
            text = "HAIKAR, nokh dem, iz gekumen oykhet a, iz geforn mit undz eyner tsurik vos iz bafrayt gevorn in Bergn-Belzn," 
        intervals [411]:
            xmin = 1551.555 
            xmax = 1557.34 
            text = "a khaver hot er gebrengt tsurik keyn Poyln, hot men ir oykhet mitgenumen fun Breslau," 
