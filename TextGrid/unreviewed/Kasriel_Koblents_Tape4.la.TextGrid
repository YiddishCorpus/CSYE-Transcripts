        intervals [2]:
            xmin = 5.23 
            xmax = 13.776 
            text = "tsk, mir hobn ir getrogn, un dortn grade iz geven azoy oyf a barg-aroyf aroyftsugeyn mit ir. mir zeen fun vaytns forn mashines un me balaykht di veg." 
        intervals [3]:
            xmin = 13.776 
            xmax = 14.052 
            text = "" 
        intervals [4]:
            xmin = 14.052 
            xmax = 18.83 
            text = "<hobn mir> farshtanen az me fort, <m'hot shoyn> gehert a shiseray, hot men glaykh genumen shikn" 
        intervals [5]:
            xmin = 18.83 
            xmax = 20.779 
            text = "hilf fun andere garnizonen." 
        intervals [6]:
            xmin = 20.779 
            xmax = 21.122 
            text = "" 
        intervals [7]:
            xmin = 21.122 
            xmax = 24.71 
            text = "vos iz undz geblibn tsum ton? mir hobn fun ir tsugenumen dem AVTOMAT," 
        intervals [8]:
            xmin = 24.71 
            xmax = 24.953 
            text = "" 
        intervals [9]:
            xmin = 24.953 
            xmax = 29.925 
            text = "fun ir aruntergenumen di, d- di shtivl, vayle undz iz geven <z- g-> groyse zakh," 
        intervals [10]:
            xmin = 29.925 
            xmax = 29.998 
            text = "" 
        intervals [11]:
            xmin = 29.998 
            xmax = 33.57 
            text = "un mir hobn ir ar- avekgeleygt in zayt un mir zaynen antlofn" 
        intervals [12]:
            xmin = 33.57 
            xmax = 33.762 
            text = "" 
        intervals [13]:
            xmin = 33.762 
            xmax = 35.05 
            text = "tsum UNK." 
        intervals [14]:
            xmin = 35.05 
            xmax = 36.219 
            text = "nu, mir zaynen gekumen" 
        intervals [15]:
            xmin = 36.219 
            xmax = 36.276 
            text = "" 
        intervals [16]:
            xmin = 36.276 
            xmax = 39.378 
            text = "tsum komandir, tsu Tseykon. mir hobn im gezogt" 
        intervals [17]:
            xmin = 39.378 
            xmax = 43.18 
            text = "az me hot ir dershosn un zi ligt dortn un dortn." 
        intervals [18]:
