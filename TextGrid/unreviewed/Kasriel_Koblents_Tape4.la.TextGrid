            text = "" 
        intervals [25]:
            xmin = 61.183 
            xmax = 69.091 
            text = "neyn, dortn hobn mir shoyn zey nit gezen, di, di, uh, di, uh, rusishe teyln. dos iz geven nor dortn vu, nit vayt fun undzer baze. dortn hobn mir zikh mit zey getrofn." 
        intervals [26]:
