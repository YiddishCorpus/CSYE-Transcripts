        intervals [45]:
            xmin = 147.87 
            xmax = 155.508 
            text = "un di goye iz UNK gevezn azoy vi <dayn> mame. zi hot afilek bentshn, krishme leyenen, ales mit undz tsuzam, vayl di mame iz gevezn a gantsn tog in gesheft." 
