            text = "" 
        intervals [106]:
            xmin = 283.258 
            xmax = 285.159 
            text = "deys iz mayne eltern." 
        intervals [107]:
            xmin = 285.159 
            xmax = 285.975 
            text = "" 
        intervals [108]:
            xmin = 285.975 
            xmax = 289.529 
            text = "deys bild iz gemakht gevorn in finef un draysiker yor." 
        intervals [109]:
            xmin = 289.529 
            xmax = 290.194 
            text = "" 
        intervals [110]:
            xmin = 290.194 
            xmax = 296.477 
            text = "mayn tate heyst Goydl, Yitskhok Leyb oyf yidish hot er geheysn." 
        intervals [111]:
            xmin = 296.477 
            xmax = 301.731 
            text = "di mame heyst Khane. di familye zire, di meydlshe, Tabak." 
        intervals [112]:
            xmin = 301.731 
            xmax = 302.462 
            text = "" 
        intervals [113]:
            xmin = 302.462 
            xmax = 304.683 
            text = "undz ho'mir gevoynt in Rakhev." 
        intervals [114]:
            xmin = 304.683 
            xmax = 309.364 
            text = "" 
        intervals [115]:
            xmin = 309.364 
            xmax = 314.735 
            text = "deys iz mayn dokument vos ikh hob bakumen funem Roytn Kreyts fun Daytshland," 
        intervals [116]:
            xmin = 314.735 
            xmax = 317.019 
            text = "vu ikh bin geven in konts-lager." 
        intervals [117]:
            xmin = 317.019 
            xmax = 323.691 
            text = "" 
        intervals [118]:
            xmin = 323.691 
            xmax = 326.807 
            text = "TAK deys iz der dokument oyf der tsveyter zayt." 
        intervals [119]:
            xmin = 326.807 
            xmax = 327.353 
            text = "" 
        intervals [120]:
            xmin = 327.353 
            xmax = 332.797 
            text = "deys iz oykhet vu pinktlekh geshribn vu ikh bin geven in konts-lager, velkhe pletser." 
        intervals [121]:
            xmin = 332.797 
            xmax = 334.018 
            text = "" 
        intervals [122]:
            xmin = 334.018 
            xmax = 334.42 
            text = "shoy-" 
