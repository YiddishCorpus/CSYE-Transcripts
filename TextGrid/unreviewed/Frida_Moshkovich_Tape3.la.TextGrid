item []: 
    item [1]:
        class = "IntervalTier" 
        name = "Frida Moshkovich" 
        xmin = 0 
        xmax = 334.42 
        intervals: size = 122 
        intervals [1]:
            xmin = 0 
            xmax = 1.53 
            text = "" 
        intervals [2]:
            xmin = 1.53 
            xmax = 3.431 
            text = "er hot nisht gekent arbetn." 
        intervals [3]:
            xmin = 3.431 
            xmax = 3.555 
            text = "" 
        intervals [4]:
            xmin = 3.555 
            xmax = 6.485 
            text = "ven undz ze'mir gekumen fun Rusland hot men undz gezogt" 
        intervals [5]:
            xmin = 6.485 
            xmax = 6.525 
            text = "" 
        intervals [6]:
            xmin = 6.525 
            xmax = 10.788 
            text = "az eh efsher er iz shtark, a a groyse astme hot er gehat." 
        intervals [7]:
            xmin = 10.788 
            xmax = 11.672 
            text = "" 
        intervals [8]:
            xmin = 11.672 
            xmax = 16.419 
            text = "un eh dos harts iz im geven nisht eh sh- nisht gut." 
        intervals [9]:
            xmin = 16.419 
            xmax = 19.48 
            text = "ober nisht azoy vayt az in dort hot er gehat eyn fakt." 
        intervals [10]:
            xmin = 19.48 
            xmax = 20.532 
            text = "" 
        intervals [11]:
            xmin = 20.532 
            xmax = 27.495 
            text = "nor di astme hot im shtark gemutshet. er hot nu dort in Rusland hot er zitserdikerheyt geshlofn." 
        intervals [12]:
            xmin = 27.495 
            xmax = 27.838 
            text = "" 
        intervals [13]:
            xmin = 27.838 
            xmax = 31.899 
            text = "nisht geshlofn nor gehust di gantse nakht. oyf fir kishn." 
        intervals [14]:
            xmin = 31.899 
            xmax = 33.002 
            text = "" 
        intervals [15]:
            xmin = 33.002 
            xmax = 39.797 
            text = "un ven ze'mir gekumen aher oyf Izrael, in Lud hot men undz gezogt az undz darf'mir nemen nor Ber Sheva." 
        intervals [16]:
            xmin = 39.797 
            xmax = 40.663 
            text = "" 
        intervals [17]:
            xmin = 40.663 
            xmax = 42.564 
            text = "Ber Sheva ober Arad." 
        intervals [18]:
            xmin = 42.564 
            xmax = 43.093 
            text = "" 
        intervals [19]:
            xmin = 43.093 
            xmax = 48.757 
            text = "mayn man's UNK hot do a bruder gehat, ze'mir gekumen tsun im, er iz oykh befor aroysgekumen." 
        intervals [20]:
            xmin = 48.757 
            xmax = 50.772 
            text = "" 
        intervals [21]:
            xmin = 50.772 
            xmax = 57.262 
            text = "un eh ze'mir gekumen aher oyf Ber Sheva, in tsvey vokhn, in a khoydesh arum, iz im fariber dos husn." 
        intervals [22]:
            xmin = 57.262 
            xmax = 57.336 
            text = "" 
        intervals [23]:
            xmin = 57.336 
            xmax = 60.64 
            text = "DA? er iz gevorn in gantsn an anderer mentsh." 
        intervals [24]:
            xmin = 60.64 
            xmax = 62.572 
            text = "m'hot im arayngenumen in shpitol arayn," 
        intervals [25]:
            xmin = 62.572 
            xmax = 66.949 
            text = "m'hot ongehoybn tsu heyln, m'hot ibergebitn di gantse meditsinen," 
        intervals [26]:
            xmin = 66.949 
            xmax = 67.005 
            text = "" 
        intervals [27]:
            xmin = 67.005 
            xmax = 70.807 
            text = "un di gantse vaser iz fun im arop." 
        intervals [28]:
            xmin = 70.807 
            xmax = 77.495 
            text = "dort hobn zey gezogt mir az er vet nisht oyshaltn, vayl bayn im iz di gantse leber tsevashn." 
        intervals [29]:
            xmin = 77.495 
            xmax = 77.873 
            text = "" 
        intervals [30]:
            xmin = 77.873 
            xmax = 84.836 
            text = "vifl hobn geven do in Izrael hot keyn keyn eyn dokter nisht gezogt az im epes mit di leber. DA." 
        intervals [31]:
            xmin = 84.836 
            xmax = 85.382 
            text = "" 
        intervals [32]:
            xmin = 85.382 
            xmax = 87.603 
            text = "iz nayn yor hot er nokh do gelebt." 
        intervals [33]:
            xmin = 87.603 
            xmax = 91.845 
            text = "" 
        intervals [34]:
            xmin = 91.845 
            xmax = 93.239 
            text = "UNK" 
        intervals [35]:
            xmin = 93.239 
            xmax = 97.87 
            text = "" 
        intervals [36]:
            xmin = 97.87 
            xmax = 105.899 
            text = "nu eh undz ho'mir demolts gornisht gekent fir eh UNK. ober az epes andersht neyn." 
        intervals [37]:
            xmin = 105.899 
            xmax = 113.946 
            text = "nor undz hot men oykhet gemutshet nayn khadoshim. undz ze'mir nisht geven nisht keyn partiner, un nisht keyn shum min problemen, proste arbetorer." 
        intervals [38]:
            xmin = 113.946 
            xmax = 114.643 
            text = "" 
        intervals [39]:
            xmin = 114.643 
            xmax = 119.311 
            text = "hot men undz gemutshet nayn khadoshim, m'hot undz gegebn UNK." 
        intervals [40]:
            xmin = 119.311 
            xmax = 120.195 
            text = "" 
        intervals [41]:
            xmin = 120.195 
            xmax = 125.791 
            text = "iz ales geven tsen tog, in der tsen tog hot men zikh gedarft tsamnemen. nu m'hot zikh tsugegreyt foroys." 
        intervals [42]:
            xmin = 125.791 
            xmax = 126.945 
            text = "" 
        intervals [43]:
            xmin = 126.945 
            xmax = 129.116 
            text = "nor mit mayn man iz geven shver." 
        intervals [44]:
            xmin = 129.116 
            xmax = 133.628 
            text = "" 
        intervals [45]:
            xmin = 133.628 
            xmax = 134.415 
            text = "UNK" 
        intervals [46]:
            xmin = 134.415 
            xmax = 136.75 
            text = "" 
        intervals [47]:
            xmin = 136.75 
            xmax = 138.229 
            text = "UNK" 
        intervals [48]:
            xmin = 138.229 
            xmax = 138.336 
            text = "" 
        intervals [49]:
            xmin = 138.336 
            xmax = 143.341 
            text = "vi ken ikh forn mit a krankn mentsh? UNK Izrael efsher." 
        intervals [50]:
            xmin = 143.341 
            xmax = 143.533 
            text = "" 
        intervals [51]:
            xmin = 143.533 
            xmax = 148.271 
            text = "der UNK hot men undz gefregt etlekhe mol tsi undz vil'mir nisht forn ergets andersh." 
        intervals [52]:
            xmin = 148.271 
            xmax = 154.749 
            text = "nu vu hin? mayn man hot shvesterkinder in Amerike, nu yeder far zikh." 
        intervals [53]:
            xmin = 154.749 
            xmax = 156.797 
            text = "" 
        intervals [54]:
            xmin = 156.797 
            xmax = 159.418 
            text = "er hot nisht gevolt iber hoypt forn az er iz krank," 
        intervals [55]:
            xmin = 159.418 
            xmax = 162.7 
            text = "mir ho'mir gezogt undz e'mir beyde arbetn. ikh un mayn zun e'mir arbetn." 
        intervals [56]:
            xmin = 162.7 
            xmax = 168.89 
            text = "mayn zun hot opgedint, afile er iz gekumen a PEREROSTOK, er iz shoyn geven a tsvey un tsvontsik yor." 
        intervals [57]:
            xmin = 168.89 
            xmax = 169.318 
            text = "" 
        intervals [58]:
            xmin = 169.318 
            xmax = 171.961 
            text = "dort iz er nisht geven a soldat, der yingerer." 
        intervals [59]:
            xmin = 171.961 
            xmax = 173.807 
            text = "" 
        intervals [60]:
            xmin = 173.807 
            xmax = 178.526 
            text = "un eh undz hot di ARMIYA geholfn a bisl vayl m'hot nisht bakumen keyn pensye." 
        intervals [61]:
            xmin = 178.526 
            xmax = 178.752 
            text = "" 
        intervals [62]:
            xmin = 178.752 
            xmax = 181.176 
            text = "tsvey yor hot er nisht bakumen keyn pensye." 
        intervals [63]:
            xmin = 181.176 
            xmax = 181.89 
            text = "" 
        intervals [64]:
            xmin = 181.89 
            xmax = 187.824 
            text = "nokh di tsvey yor hot men undz gegebn. er hot gezogt az di krankeyt hot er fun Rusland gebrengt. nisht do." 
        intervals [65]:
            xmin = 187.824 
            xmax = 188.37 
            text = "" 
        intervals [66]:
            xmin = 188.37 
            xmax = 190.186 
            text = "undz iz geven zeyer shver." 
        intervals [67]:
            xmin = 190.186 
            xmax = 190.817 
            text = "" 
        intervals [68]:
            xmin = 190.817 
            xmax = 193.629 
            text = "hitst iz oykh nisht gring, nor demolts iz geven nokh shverer." 
        intervals [69]:
            xmin = 193.629 
            xmax = 196.335 
            text = "" 
        intervals [70]:
            xmin = 196.335 
            xmax = 197.696 
            text = "UNK" 
        intervals [71]:
            xmin = 197.696 
            xmax = 203.187 
            text = "" 
        intervals [72]:
            xmin = 203.187 
            xmax = 206.099 
            text = "nu dos shraybt zikh oykhet ales? DA." 
        intervals [73]:
            xmin = 206.099 
            xmax = 206.342 
            text = "" 
        intervals [74]:
            xmin = 206.342 
            xmax = 211.499 
            text = "yo, spn avade bin ikh tsufridn. vos het ikh geton in Rusland aleyn?" 
        intervals [75]:
            xmin = 211.499 
            xmax = 211.894 
            text = "" 
        intervals [76]:
            xmin = 211.894 
            xmax = 216.208 
            text = "het gelebt oyf der pensye, dort do ken ikh oyslebn oyf der pensye, ober dort ken ikh nisht." 
        intervals [77]:
            xmin = 216.208 
            xmax = 218.526 
            text = "" 
        intervals [78]:
            xmin = 218.526 
            xmax = 221.338 
            text = "s'hot hob ikh do nisht gearbet, ikh hob nor TAPELET," 
        intervals [79]:
            xmin = 221.338 
            xmax = 221.698 
            text = "" 
        intervals [80]:
            xmin = 221.698 
            xmax = 225.303 
            text = "vayl ikh hob nisht gekent arbetn, un ikh hob bakumen BITUACH LEUMI." 
        intervals [81]:
            xmin = 225.303 
            xmax = 229.022 
            text = "" 
        intervals [82]:
            xmin = 229.022 
            xmax = 229.691 
            text = "NIET." 
        intervals [83]:
            xmin = 229.691 
            xmax = 238.759 
            text = "" 
        intervals [84]:
            xmin = 238.759 
            xmax = 239.883 
            text = "PLASIBO." 
        intervals [85]:
            xmin = 239.883 
            xmax = 240.666 
            text = "" 
        intervals [86]:
            xmin = 240.666 
            xmax = 248.625 
            text = "nu yo UNK." 
        intervals [87]:
            xmin = 248.625 
            xmax = 249.66 
            text = "" 
        intervals [88]:
            xmin = 249.66 
            xmax = 252.624 
            text = "UNK" 
        intervals [89]:
