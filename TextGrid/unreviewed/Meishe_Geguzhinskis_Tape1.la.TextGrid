        intervals [90]:
            xmin = 336.212 
            xmax = 343.31 
            text = "m'iz ariber in a sht- in ariber in Kovne lebn in a in a sh- in hinter in a forshtot fun Kovne vos heyst Slabodke." 
        intervals [91]:
