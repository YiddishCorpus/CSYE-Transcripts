            text = "" 
        intervals [85]:
            xmin = 319.759 
            xmax = 324.861 
            text = "un mir zey hobn bashlosn, azoy vi Raseyn iz geven a kleyne shle- sh- a kleyne shtetele, mayn foter hot zikh" 
        intervals [86]:
