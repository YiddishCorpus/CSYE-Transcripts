            text = "un er hot gehat a min shvakhkeyt tsum shlogn di kinder. er hot gehat" 
        intervals [134]:
            xmin = 489.771 
            xmax = 499.888 
            text = "er flegt hobn bay zikh a <lineyke> un baym onfang arop flegt er muzn gebn yedn eynem a zets mitn <milyeyke> oyfn ponem. nit eyn mol hob ikh shoyn gehat fun im gekrogn azelkhene z- azelkhene klep." 
        intervals [135]:
            xmin = 499.888 
            xmax = 507.876 
            text = "un mir hobn zikh fun dest vegn baklogt far far Kharitn vegn dem az der s'iz nit keyn pedagogisher metod mit di kinder." 
        intervals [136]:
            xmin = 507.876 
            xmax = 508.084 
