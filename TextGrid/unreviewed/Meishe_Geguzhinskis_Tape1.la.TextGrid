            text = "" 
        intervals [109]:
            xmin = 393.52 
            xmax = 401.799 
            text = "dos iz geven a vunderbarer pedagog, a posheter mentsh, un er hot zeyer lib gehat zayne kinder, di shiler." 
        intervals [110]:
            xmin = 401.799 
            xmax = 406.041 
            text = "" 
        intervals [111]:
            xmin = 406.041 
            xmax = 417.796 
            text = "er hot mir gegebn di ershte visn fun natur-visnshaft, fun matematik, fun hebreishe shprakh." 
        intervals [112]:
