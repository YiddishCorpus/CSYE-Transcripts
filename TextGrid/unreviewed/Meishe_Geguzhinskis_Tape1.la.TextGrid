        intervals [95]:
            xmin = 352.822 
            xmax = 360.371 
            text = "tsvey yor hob ikh gelernt in Raseyn, un in dritn klas bin ikh arayngegangen in dem in a hebreishe shul, zi hot geheysn Bardon's shul." 
        intervals [96]:
