        intervals [2]:
            xmin = 50.89 
            xmax = 53.567 
            text = "mayn nomen iz Meyshe Geguzhinski." 
        intervals [3]:
            xmin = 53.567 
            xmax = 53.826 
            text = "" 
        intervals [4]:
            xmin = 53.826 
            xmax = 60.789 
            text = "ikh bin geboyrn gevorn in toyznt nayn hundert fir un tsvontsikstn yor, eyn un tsvontsikstn yanvar in Kovne." 
        intervals [5]:
            xmin = 60.789 
            xmax = 61.774 
            text = "" 
        intervals [6]:
            xmin = 61.774 
            xmax = 64.62 
            text = "itst bin ikh shoyn alt tsvey un zibetsik yor." 
        intervals [7]:
            xmin = 64.62 
            xmax = 65.352 
            text = "" 
        intervals [8]:
            xmin = 65.352 
            xmax = 69.514 
            text = "shoyn a tsayt shoyn do gemakht ale rishn, shvern lebn." 
        intervals [9]:
            xmin = 69.514 
            xmax = 70.127 
            text = "" 
        intervals [10]:
            xmin = 70.127 
            xmax = 74.694 
            text = "ikh volt gezogt, a tragishn un kemferishn lebn." 
        intervals [11]:
            xmin = 74.694 
            xmax = 77.063 
            text = "" 
        intervals [12]:
            xmin = 77.063 
            xmax = 80.111 
            text = "ikh bin geboyrn in UNK ikh bin geboyrn in Kovne," 
        intervals [13]:
            xmin = 80.111 
            xmax = 80.708 
            text = "" 
        intervals [14]:
            xmin = 80.708 
            xmax = 87.57 
            text = "bay di eltern, mayn foter hot geheysn Aron Geguzhinski, mayn muter Tema Geguzhinski." 
        intervals [15]:
            xmin = 87.57 
            xmax = 87.711 
            text = "" 
        intervals [16]:
            xmin = 87.711 
            xmax = 96.867 
            text = "ven ikh volt dort geven fir finf yor, gedenk ikh az der foter hot dort gehat an eygenem kleynem magazintshik." 
        intervals [17]:
            xmin = 96.867 
            xmax = 97.684 
            text = "" 
        intervals [18]:
            xmin = 97.684 
            xmax = 102.825 
            text = "er hot gehandlt mit farsheydene papirosn," 
        intervals [19]:
            xmin = 102.825 
            xmax = 103.371 
            text = "" 
        intervals [20]:
            xmin = 103.371 
            xmax = 106.605 
            text = "eh un nokh azelkhene skhoyres, velkhe" 
        intervals [21]:
            xmin = 106.605 
            xmax = 106.695 
            text = "" 
        intervals [22]:
            xmin = 106.695 
            xmax = 110.649 
            text = "eh es hot im nit gepast afile dem fakh. velkhe dem zayn fakh iz geven" 
        intervals [23]:
            xmin = 110.649 
            xmax = 118.653 
            text = "a meb- a <medmim> arbeter, a mebl arbeter fun veykhn mebl velkhe er hot bakumen zayendik in gefangenshaft" 
        intervals [24]:
            xmin = 118.653 
            xmax = 118.761 
            text = "" 
        intervals [25]:
            xmin = 118.761 
            xmax = 123.373 
            text = "in Daytshland, hot er zikh oysgelernt als zeyer a guter shpetsyalist fun meykh- veykhn mebl." 
        intervals [26]:
            xmin = 123.373 
            xmax = 130.039 
            text = "nor azoy vi er hot gekrogn azoy tsu zogn fun di mamen, fun di fun zayn froy, a nadn, a kleyne kremele," 
        intervals [27]:
            xmin = 130.039 
            xmax = 133.183 
            text = "hot er zikh mit dem farnumen. nor s'im nit gegangen." 
        intervals [28]:
            xmin = 133.183 
            xmax = 134.978 
            text = "" 
        intervals [29]:
            xmin = 134.978 
            xmax = 138.532 
            text = "er hot ge<UNK> dem gantsn lebn hot getroymt tsu forn in Amerike." 
        intervals [30]:
            xmin = 138.532 
            xmax = 139.146 
            text = "" 
        intervals [31]:
            xmin = 139.146 
            xmax = 146.177 
            text = "in yents a tsayt hobn a sakh yidn, un nit nor yidn, getrakht tsu farbesern dem zeyer lebn," 
        intervals [32]:
            xmin = 146.177 
            xmax = 146.368 
            text = "" 
        intervals [33]:
            xmin = 146.368 
            xmax = 152.471 
            text = "un avekforn in a groyser land, in a a groys frayer land, un dortn makhn a karyere." 
        intervals [34]:
            xmin = 152.471 
            xmax = 154.35 
            text = "" 
        intervals [35]:
            xmin = 154.35 
            xmax = 159.947 
            text = "in zayn gesheftl iz im gornit gegangen derfar vos er hot kentik in der yene tsayt nit gekent handlen." 
        intervals [36]:
            xmin = 159.947 
            xmax = 160.645 
            text = "" 
        intervals [37]:
            xmin = 160.645 
            xmax = 167.304 
            text = "er hot gehandlt mit azelkhene zakhn vi papirosn un in der tsayt, in yener, in Vil- in in eh Lite," 
        intervals [38]:
            xmin = 167.304 
            xmax = 167.344 
            text = "" 
        intervals [39]:
            xmin = 167.344 
            xmax = 171.134 
            text = "hot men oyf papirosn gedarft hobn a shpetsyeln erloybenish." 
        intervals [40]:
            xmin = 171.134 
            xmax = 171.529 
            text = "" 
        intervals [41]:
            xmin = 171.529 
            xmax = 175.1 
            text = "un er hot <got> mit dem gehandlt. in a gutn tog hobn zikh arayngekhapt" 
        intervals [42]:
            xmin = 175.1 
            xmax = 177.013 
            text = "" 
        intervals [43]:
            xmin = 177.013 
            xmax = 185.293 
            text = "fun fin- fun fin- eh fin-inspektorn. zey hobn untergekhapt zen di papirosn un hobn mit a groysn groyser shtrof bashtroft im, un farmakht dem gesheft." 
        intervals [44]:
            xmin = 185.293 
            xmax = 186.649 
            text = "" 
        intervals [45]:
            xmin = 186.649 
            xmax = 190.22 
            text = "oyf vifl ikh gedenk, ikh bin ot o alt geven bay finf zeks yor, finf yor," 
        intervals [46]:
            xmin = 190.22 
            xmax = 190.935 
            text = "" 
        intervals [47]:
            xmin = 190.935 
            xmax = 197.611 
            text = "hot er bashlosn nemen di gantse mishpokhe un ariberforn in a kleyninke shtetl Raseyn. in Lite." 
        intervals [48]:
            xmin = 197.611 
            xmax = 199.845 
            text = "" 
        intervals [49]:
            xmin = 199.845 
            xmax = 207.343 
            text = "dortn hot er getrakht vet efsher, er fun dortn vet men shoyn laykhter ven geven avektsuforn in Amerike." 
        intervals [50]:
            xmin = 207.343 
            xmax = 209.441 
            text = "vayl er hot gemeynt az di ortike" 
        intervals [51]:
            xmin = 209.441 
            xmax = 210.932 
            text = "" 
        intervals [52]:
            xmin = 210.932 
            xmax = 217.811 
            text = "finantsiner fin- finantsier opteylungen veln nit veln nit veln nit kenen veln nit gefinen zeyer shrtrof vos er darf batsoln." 
        intervals [53]:
            xmin = 217.811 
            xmax = 218.442 
            text = "" 
        intervals [54]:
            xmin = 218.442 
            xmax = 224.679 
            text = "nor eh leyder hot er hot men fun fun Raseyn oykh nit aroysgelozn un mir zaynen geblibn lebn in Raseyn." 
        intervals [55]:
            xmin = 224.679 
            xmax = 225.613 
            text = "" 
        intervals [56]:
            xmin = 225.613 
            xmax = 230.095 
            text = "dortn in Raseyn hobn mir gelebt etlekhe yor," 
        intervals [57]:
            xmin = 230.095 
            xmax = 230.541 
            text = "" 
        intervals [58]:
            xmin = 230.541 
            xmax = 234.883 
            text = "er hot eh er hot zikh ayngeor- er hot er hot zikh aynge<oret> als zayn als shoyn bay zayn fakh." 
        intervals [59]:
            xmin = 234.883 
            xmax = 242.752 
            text = "als eh mebl mebl arbeter, un ikh hob un ikh bin avek in yidishe in a hebreishe folkshul." 
        intervals [60]:
            xmin = 242.752 
            xmax = 243.737 
            text = "" 
        intervals [61]:
            xmin = 243.737 
            xmax = 247.426 
            text = "ikh hob ongehoybn fun ershtn klas farshteyt zikh, vifl ikh gedenk," 
        intervals [62]:
            xmin = 247.426 
            xmax = 251.398 
            text = "" 
        intervals [63]:
            xmin = 251.398 
            xmax = 255.611 
            text = "ven ikh bin ven ikh ven ikh bin arayn in ershtn klas hob ikh shoyn gekent gut yidish." 
        intervals [64]:
            xmin = 255.611 
            xmax = 256.039 
            text = "" 
        intervals [65]:
            xmin = 256.039 
            xmax = 263.306 
            text = "ikh hob shoyn geleyent farsheydene bikhelekh oyf yidish. ikh mit mayn bruderl flegn zitsn un durkhleyenen, gedenk ikh, dem bikhele" 
        intervals [66]:
            xmin = 263.306 
            xmax = 263.869 
            text = "" 
        intervals [67]:
            xmin = 263.869 
            xmax = 268.874 
            text = "Andersen's bikhele vegn di tragedye fun Nelo in Portrash," 
        intervals [68]:
            xmin = 268.874 
            xmax = 269.168 
            text = "" 
        intervals [69]:
            xmin = 269.168 
            xmax = 273.178 
            text = "velkhe hot mir zeyer UNK zeyer shtark zeyer shtark baumruikt di tragedye." 
        intervals [70]:
            xmin = 273.178 
            xmax = 273.285 
            text = "" 
        intervals [71]:
            xmin = 273.285 
            xmax = 278.189 
            text = "ikh hob geleyent nokh farsheydene, fun di Grininke Beymelekh iz geven a yidishn a yidisher bikhl," 
        intervals [72]:
            xmin = 278.189 
            xmax = 278.247 
            text = "" 
        intervals [73]:
            xmin = 278.247 
            xmax = 280.401 
            text = "velkhe hot aroysgelozn Helene Khatskeles." 
        intervals [74]:
            xmin = 280.401 
            xmax = 285.148 
            text = "" 
        intervals [75]:
            xmin = 285.148 
            xmax = 290.998 
            text = "un ven ikh bin shoyn geg- arayngegangen in ershtn klas, bin ikh shoyn geven a guter shiler." 
        intervals [76]:
            xmin = 290.998 
            xmax = 291.072 
            text = "" 
        intervals [77]:
            xmin = 291.072 
            xmax = 294.61 
            text = "ikh fleg krign ale finfn vayl ikh hob shoyn gekent zeyer gut di yidishe shprakh," 
        intervals [78]:
            xmin = 294.61 
            xmax = 294.615 
            text = "" 
        intervals [79]:
            xmin = 294.615 
