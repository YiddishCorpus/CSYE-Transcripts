            text = "" 
        intervals [436]:
            xmin = 1297.881 
            xmax = 1306.232 
            text = "a varshtat fun veykhe meb- fun remont fun veykhe mebl. oyf eh Gortshe gas iz dos geven. dortn iz geven eh mit a groyse vitrine," 
        intervals [437]:
            xmin = 1306.232 
            xmax = 1309.005 
            text = "" 
        intervals [438]:
            xmin = 1309.005 
            xmax = 1317.228 
            text = "un dortn hot er mir tsugezogt er vet mir aynordenen, mir zoln nemen di initsyativ tsu makhn, in der tsayt iz dokh geven geven in yener tsayt iz geven zeyer veynik azelkhene varshtatn fun veykhe mebl," 
        intervals [439]:
            xmin = 1317.228 
            xmax = 1319.228 
            text = "zogt er, vest kenen arbetn, vest kenen fardinen." 
        intervals [440]:
            xmin = 1319.228 
            xmax = 1324.131 
            text = "nor aleyn iz er geven a bisl rizikalish, eh ikh hob es nit farshtanen vi azoy kenen men es ton." 
        intervals [441]:
            xmin = 1324.131 
            xmax = 1328.169 
            text = "hob ikh genumen tsu zikh eynem Ratshkovitshn, an alter Ratshkovitsh, a shloser aleyn fun fakh," 
