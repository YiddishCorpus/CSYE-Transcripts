            text = "" 
        intervals [498]:
            xmin = 1519.593 
            xmax = 1525.975 
            text = "mit ale luks un ale azelkhene zakhn vos iz in Viln- in gants Viln- in Vil- in Rotn- in Ratn-Farband iz dos nito." 
        intervals [499]:
            xmin = 1525.975 
            xmax = 1525.981 
            text = "" 
        intervals [500]:
            xmin = 1525.981 
            xmax = 1529.206 
            text = "un durkh aza min kurtser tsayt, zogt er, zolst kumen yedn tog, zolst geyn ot o di" 
        intervals [501]:
            xmin = 1529.206 
            xmax = 1534.806 
            text = "di di minist- minister iz geblibn der Shimo- der eh eh Shinetski iz shoyn geven geshtorbn dan." 
