            xmin = 578.97 
            xmax = 581.423 
            text = "" 
        intervals [197]:
            xmin = 581.423 
            xmax = 587.188 
            text = "ikh bin aroysgelofn a naketer durkhn tirl, a kuk tun ver vos dortn iz." 
        intervals [198]:
            xmin = 587.188 
            xmax = 587.498 
            text = "" 
        intervals [199]:
            xmin = 587.498 
            xmax = 592.251 
            text = "un ikh gib a kuk ikh bin dokh naket, darf men onton zikh vos nit iz. oyfn oyfn vant iz gehangen a shinel" 
        intervals [200]:
            xmin = 592.251 
            xmax = 592.307 
            text = "" 
        intervals [201]:
            xmin = 592.307 
            xmax = 596.013 
            text = "a a shn- nit keyn shinel nor a a a fun a" 
        intervals [202]:
            xmin = 596.013 
            xmax = 598.315 
            text = "" 
        intervals [203]:
            xmin = 598.315 
            xmax = 607.238 
            text = "iz gehangen a fun fun dem vekhter. kentik hot der vekhter er iz antlofn, hot gehat, er iz geven avek- er iz geven a ofitsir kentik. hot er iber- zikh gikh ibergeton mit tsivil," 
        intervals [204]:
            xmin = 607.238 
            xmax = 609.66 
            text = "un er hot gelozn hengen oyfn ha- oyfn vant" 
        intervals [205]:
            xmin = 609.66 
            xmax = 620.279 
            text = "zayn zayn zayn uniform. ikh hob gekhapt dem uniform oyf zikh mitn mitn shinel, un ikh hob aroysgelofn a kuk ton in vald vos far a royshn dortn, vos kumt dortn vos kumt dortn for." 
        intervals [206]:
            xmin = 620.279 
            xmax = 620.573 
            text = "" 
        intervals [207]:
            xmin = 620.573 
            xmax = 623.722 
            text = "un dort hob ikh bamerkt az durkhn vald iz durkhgegangen tankes." 
        intervals [208]:
            xmin = 623.722 
            xmax = 624.268 
            text = "" 
        intervals [209]:
            xmin = 624.268 
            xmax = 625.665 
            text = "un zey hobn mir bamerkt," 
        intervals [210]:
            xmin = 625.665 
            xmax = 629.949 
            text = "s'hot fun unter fun eyn tank iz aroysgelo- aroysgelo- aroys getantst ofitsir, a kapitan," 
        intervals [211]:
            xmin = 629.949 
            xmax = 630.242 
            text = "" 
        intervals [212]:
            xmin = 630.242 
            xmax = 633.121 
            text = "un gegebn a kuk oyf mir, oysgeshtelt di UNK tsu mir," 
        intervals [213]:
            xmin = 633.121 
            xmax = 633.735 
            text = "" 
        intervals [214]:
            xmin = 633.735 
            xmax = 636.074 
            text = "er hot gezen mayn, in oyf uniform fun a daytsher," 
        intervals [215]:
            xmin = 636.074 
