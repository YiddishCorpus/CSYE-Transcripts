            text = "" 
        intervals [306]:
            xmin = 925.96 
            xmax = 931.85 
            text = "hobn mir gehey- hobn zey geheysn di rusishe soldatn hobn undz gezogt az mir zoln iberlozn lebn ban lebn" 
