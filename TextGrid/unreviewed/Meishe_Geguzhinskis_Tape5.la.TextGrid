            text = "" 
        intervals [302]:
            xmin = 917.829 
            xmax = 920.904 
            text = "a por hoyzn iberike, a por shikh hobn zey mir gegebn dortn," 
        intervals [303]:
            xmin = 920.904 
            xmax = 923.479 
            text = "nokh eh UNK ikh gedenk shoyn nit velkhe zakhn," 
        intervals [304]:
