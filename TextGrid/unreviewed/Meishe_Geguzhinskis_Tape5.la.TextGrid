            text = "" 
        intervals [358]:
            xmin = 1066.292 
            xmax = 1074.017 
            text = "ikh hob zikh forgeshtelt az m'vet undz oyfnemen a bisl andersh. ikh hob gedarft aroysnemen a pasport khotshabe, ober m'hot keyn pasport nit gegebn mit di mentshn velkhe zenen gekumen, di" 
        intervals [359]:
