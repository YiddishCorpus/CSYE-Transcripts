            xmax = 810.41 
            text = "un eh emesn zenen gekumen tsu forn dortn forshteyer fun Yisroel, fun Erets-Yisroel." 
        intervals [266]:
            xmin = 810.41 
            xmax = 810.906 
            text = "" 
        intervals [267]:
            xmin = 810.906 
            xmax = 822.02 
            text = "un zey ongehoybn tsum onagatirn, zogn, ""khevre, yidishe khevre, ir darft forn in eygene land. vu fort ir aheym? vu fort ir? iz es ayere heym? ir hot dortn dokh farlorn ayere eltern, farlorn ayere ayere" 
