        intervals [551]:
            xmin = 1666.232 
            xmax = 1672.2 
            text = "un er iz gekumen tsu mir eyn mol eyn mol tsu gast a kuk ton vi ikh leb. vayl er hot farshtanen dem, er hot farshtanen az er iz shuldik in dem." 
        intervals [552]:
