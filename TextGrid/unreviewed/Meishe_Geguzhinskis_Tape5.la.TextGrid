            text = "" 
        intervals [256]:
            xmin = 770.338 
            xmax = 778.837 
            text = "un dortn eh fun dortn vet men vet men kenen onforn tsurik aheym in undzer foterland, in Lite." 
        intervals [257]:
            xmin = 778.837 
            xmax = 780.075 
            text = "" 
        intervals [258]:
            xmin = 780.075 
            xmax = 783.1 
            text = "in Minkhn zenen mir geven a kurtse tsayt." 
        intervals [259]:
