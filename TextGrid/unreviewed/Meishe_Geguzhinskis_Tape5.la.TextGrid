        intervals [365]:
            xmin = 1090.238 
            xmax = 1095.699 
            text = "ikh hob getrofn mayne khaveyrim velkhe zenen gekumen fun partizanik- fun partizanishe bavegung. ikh hob getrofn dortn Shimke Blokh," 
