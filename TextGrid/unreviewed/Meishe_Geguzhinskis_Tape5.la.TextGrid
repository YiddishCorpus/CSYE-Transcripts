            text = "tsu tsu dortn in shtot in Kovne." 
        intervals [280]:
            xmin = 856.631 
            xmax = 856.705 
            text = "" 
        intervals [281]:
            xmin = 856.705 
            xmax = 865.879 
            text = "un mir hobn zikh eh ikh hob dortn getrofn eh Dime Galpe- Dime Gelpern, ikh hob getrofn dortn" 
        intervals [282]:
            xmin = 865.879 
            xmax = 867.673 
            text = "" 
        intervals [283]:
            xmin = 867.673 
            xmax = 875.213 
            text = "Grinbergn, oykh a un- a aktiver unternemer fun eh fun der organizatsye fun der eh fun der un-" 
        intervals [284]:
            xmin = 875.213 
