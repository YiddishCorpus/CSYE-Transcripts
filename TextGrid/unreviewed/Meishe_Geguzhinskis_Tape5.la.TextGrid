        intervals [428]:
            xmin = 1270.913 
            xmax = 1273.238 
            text = "ikh hob im batsoygn mit di mit a shtik shtof aza min," 
        intervals [429]:
            xmin = 1273.238 
            xmax = 1277.863 
            text = "un s'gevorn a vunderbarer matrats. trakht ikh, oy, ikh bin dokh shoyn bald a a shpetsyalist, ikh ken shoyn bald arbetn." 
        intervals [430]:
            xmin = 1277.863 
            xmax = 1278.63 
            text = "" 
        intervals [431]:
            xmin = 1278.63 
            xmax = 1284.328 
            text = "nu, fun do, un dos iz geven di ershte arbet mayne, der matrats fun Silkinern, dos gedenk ikh biz hayntikn tog." 
        intervals [432]:
            xmin = 1284.328 
            xmax = 1285.768 
            text = "" 
        intervals [433]:
            xmin = 1285.768 
            xmax = 1292.768 
            text = "nu vayter bin ikh eh sof kol sof hob ikh gef- getrofn zikh mit a eynem a direktor vos fun fun a kambinat," 
        intervals [434]:
            xmin = 1292.768 
            xmax = 1297.843 
            text = "velkher hot mir forgeleygt aleyn, az er hot a lokal tsum arbetn, tsu efenen a varshtat." 
