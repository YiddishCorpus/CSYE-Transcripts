            xmin = 842.811 
            xmax = 843.289 
            text = "" 
        intervals [278]:
            xmin = 843.289 
            xmax = 854.491 
            text = "fun dest vegn geven, oyf mir hot dokh alts gevust az ikh darf zayn in der in der organizatsye in der partizanisher organizatsye fun geto, un der der un der unternemen in in der aktiver unternemen in zayn arbet hot mir alts getsoygn" 
        intervals [279]:
            xmin = 854.491 
