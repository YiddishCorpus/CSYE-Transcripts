            text = "" 
        intervals [485]:
            xmin = 1479.448 
            xmax = 1483.653 
            text = "eh Shupalis iz geven mayner a mayner a mitarbeter in undzer brigade fun dem kunst-arbeter" 
        intervals [486]:
            xmin = 1483.653 
            xmax = 1487.903 
            text = "UNK. s'geven dortn nokh azelkhe ehm eh" 
        intervals [487]:
            xmin = 1487.903 
            xmax = 1497.003 
            text = "Urbanas, oykh dortn geven a, er hot hot dortn durkhgemakht farsheydene farsheydene kinstlerishe arbet." 
