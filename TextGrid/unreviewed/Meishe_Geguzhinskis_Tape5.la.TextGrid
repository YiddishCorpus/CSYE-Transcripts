        intervals [479]:
            xmin = 1465.268 
            xmax = 1467.135 
            text = "ikh bin arayngefaln tsu der arbet dortn," 
        intervals [480]:
            xmin = 1467.135 
            xmax = 1467.546 
            text = "" 
        intervals [481]:
            xmin = 1467.546 
            xmax = 1473.65 
            text = "di arbet iz geven zeyer a shvere, mir flegn arbetn tog un un afile nekht. ikh hob zikh getrofn mit farsheydene kinstler velkhe hobn mir geholfn," 
        intervals [482]:
            xmin = 1473.65 
