            xmin = 1577.328 
            xmax = 1577.47 
            text = "" 
        intervals [519]:
            xmin = 1577.47 
            xmax = 1584.349 
            text = "zog ikh tsu ir, git iber UNK az di arbet iz fartik, Geguzhinski hot geklungen az er er iz hot oysgefirt di arbet bizn sof." 
        intervals [520]:
            xmin = 1584.349 
            xmax = 1586.059 
            text = "" 
        intervals [521]:
            xmin = 1586.059 
            xmax = 1590.17 
            text = "zogt zi, eyn minut, ot bald ot iz er arayn in kabinet. ikh vel ir shoyn zogn." 
        intervals [522]:
            xmin = 1590.17 
            xmax = 1591.206 
            text = "" 
        intervals [523]:
            xmin = 1591.206 
            xmax = 1597.224 
            text = "s'avek iber a minut, zogt ent- eh eh entfert zi tsu mir, er vil mit dir nit reydn." 
