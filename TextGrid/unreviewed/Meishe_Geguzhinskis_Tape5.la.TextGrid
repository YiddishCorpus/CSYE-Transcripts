            xmin = 1497.003 
            xmax = 1497.769 
            text = "" 
        intervals [489]:
            xmin = 1497.769 
            xmax = 1499.889 
            text = "eyn mol hot er mir gezogt, Urbanas, tsu mir." 
        intervals [490]:
            xmin = 1499.889 
            xmax = 1500.148 
            text = "" 
        intervals [491]:
            xmin = 1500.148 
            xmax = 1504.327 
            text = "Geguzhinskis, vi kenstu arbetn in azelkhene badingungen?" 
        intervals [492]:
            xmin = 1504.327 
            xmax = 1505.278 
            text = "" 
        intervals [493]:
            xmin = 1505.278 
            xmax = 1512.35 
            text = "durkh aza min kurtser tsayt oyftsuboyen aza min hoyf, a tsvey etazhn hoyz, mit mit mit mit vifl dortn e- etlekhe un tsvantsik tsimern, mit mit" 
        intervals [494]:
            xmin = 1512.35 
