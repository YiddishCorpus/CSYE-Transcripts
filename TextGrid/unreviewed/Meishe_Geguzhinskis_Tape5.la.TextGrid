            text = "f- bakante, ayere fraynt, ayere kroyvim." 
        intervals [270]:
            xmin = 824.335 
            xmax = 827.099 
            text = "kumt tsu forn mit undz in Erets-Yisroel, dortn" 
        intervals [271]:
            xmin = 827.099 
            xmax = 827.292 
            text = "" 
        intervals [272]:
            xmin = 827.292 
            xmax = 830.34 
            text = "dortn vet vet keyn lagern shoyn mer nit zayn far aykh.""" 
