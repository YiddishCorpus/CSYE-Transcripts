            text = "" 
        intervals [216]:
            xmin = 636.553 
            xmax = 638.116 
            text = "hot er gevolt mir shisn glaykh." 
        intervals [217]:
            xmin = 638.116 
            xmax = 638.14 
            text = "" 
        intervals [218]:
            xmin = 638.14 
            xmax = 641.846 
            text = "hob ikh ongehoybn tsu shrayen, ikh bin eyn JUDE! shist nit!" 
        intervals [219]:
            xmin = 641.846 
            xmax = 642.105 
            text = "" 
        intervals [220]:
            xmin = 642.105 
            xmax = 646.115 
            text = "ikh bin eyn JUDE! WAS, zogt er, bist a JUDE? ikh bin, zogt er, oykh a yid!" 
        intervals [221]:
            xmin = 646.115 
            xmax = 647.455 
            text = "" 
        intervals [222]:
            xmin = 647.455 
            xmax = 650.25 
            text = "dos iz geven a kapitan fun der a- fun der amerikaner armey." 
        intervals [223]:
            xmin = 650.25 
            xmax = 650.357 
            text = "" 
        intervals [224]:
            xmin = 650.357 
            xmax = 651.645 
            text = "ikh bin, zogt er, a yid." 
        intervals [225]:
            xmin = 651.645 
            xmax = 655.467 
            text = "ikh vel dir helfn. kum, varf avek, zogt er, dem shmutsikn shinel," 
        intervals [226]:
            xmin = 655.467 
            xmax = 665.133 
            text = "ikh vel dir gebn a amerikaner uniforme. un bist mistome hungerik, ikh vel dir on- on- on- onkormenen, ikh vel dir alts gebn. ze, mir veln dir nemen tsu zikh. er hot mir arayngezetst in tank," 
        intervals [227]:
            xmin = 665.133 
            xmax = 666.507 
            text = "" 
        intervals [228]:
            xmin = 666.507 
            xmax = 679.191 
            text = "un m'hot mir gegebn esn. glaykh do hot zikh hot zikh gefunen hot zikh gefunen dortn a a sanitar tsi a dokter. m'hot mir gegebn glaykh opholn, ikh zol kumen tsu zikh, vayl ikh bin geven zeyer shvakh opgeshvakht oyf di fis, un m'hot mir avekgefirt in di shtetele Zumergarten." 
        intervals [229]:
            xmin = 679.191 
            xmax = 680.074 
            text = "" 
        intervals [230]:
            xmin = 680.074 
            xmax = 683.443 
            text = "dortn bin ikh dortn hot men ayngeord- hot er ayngeordnt mir" 
        intervals [231]:
            xmin = 683.443 
            xmax = 683.466 
            text = "" 
        intervals [232]:
            xmin = 683.466 
            xmax = 686.261 
            text = "in a daytshisher mishpokhe, eltere mishpo- eltere mentshn," 
        intervals [233]:
            xmin = 686.261 
            xmax = 686.352 
            text = "" 
        intervals [234]:
            xmin = 686.352 
            xmax = 693.096 
            text = "zey hobn mir gegebn a tsimerl a bazundern. zey hobn mit mir zikh zeyer gut bahandlt, zey hobn mir gegebn tsum esn, zey hobn mir gegebn eh" 
        intervals [235]:
            xmin = 693.096 
            xmax = 694.57 
            text = "" 
        intervals [236]:
            xmin = 694.57 
            xmax = 708.218 
            text = "ontsuton zikh farshteyt zikh un un un un eh un mir gegebn yedn tog iz gekumen di eltere froy un iberbin- iberbi- iberbindn di vundn vos ikh hob gehat oyf di oyf di fi- oyf di hent nokh fun fun fun mayn hengen." 
        intervals [237]:
            xmin = 708.218 
            xmax = 708.691 
            text = "" 
        intervals [238]:
            xmin = 708.691 
            xmax = 713.463 
            text = "ikh ken nit zogn zey hobn UNK, zaynen do fun dest vegn daytsher daytshisher loytere mentshn velkhe ke- velkhe hobn geholfn." 
        intervals [239]:
            xmin = 713.463 
            xmax = 713.622 
            text = "" 
        intervals [240]:
            xmin = 713.622 
            xmax = 722.208 
            text = "ikh veys nit vos far a tsil zey hobn gehat. zey hobn dertseylt az zeyer zun iz gefaln oyfn va- oyfn oyfn front oyfn oyfn mizrekh front in Rusland. az dem eyntsikn zun hobn zey farlorn." 
        intervals [241]:
            xmin = 722.208 
            xmax = 724.972 
            text = "iz kentik az zey hobn derzen in mir efsher a mol dem zun zeyern." 
        intervals [242]:
            xmin = 724.972 
            xmax = 725.4 
            text = "" 
        intervals [243]:
            xmin = 725.4 
            xmax = 729.106 
            text = "un in vinkl fun tsi- fun tsimer iz geshtanen zayne tsvey kabkes, tsvey" 
        intervals [244]:
            xmin = 729.106 
            xmax = 729.349 
            text = "" 
        intervals [245]:
            xmin = 729.349 
            xmax = 733.514 
            text = "eh shtek-shikh. hot zi mir geozgt, her tsu, liber froynt," 
        intervals [246]:
            xmin = 733.514 
            xmax = 742.657 
            text = "ale, du bist eyn, du bist a balebos in in dem tsimer, ober di shtek-shikh zolstu nit tshepenen. zogt er, s'a ondenkung far undzer gefalenem undzern, bay undz iz es a min traditsye" 
        intervals [247]:
            xmin = 742.657 
            xmax = 742.9 
            text = "" 
        intervals [248]:
            xmin = 742.9 
            xmax = 746.201 
            text = "tsu haltn di shtek-shikh. ikh hob di shtek-shikh nit tsu- zikh tsugerirt tsu zey." 
        intervals [249]:
            xmin = 746.201 
            xmax = 748.62 
            text = "" 
        intervals [250]:
            xmin = 748.62 
            xmax = 753.744 
            text = "un ikh hob gelebt bay zey in dem tsimer hob ikh gelebt a lange lengere tsayt, a por monatn tsayt in di." 
        intervals [251]:
            xmin = 753.744 
            xmax = 754.037 
            text = "" 
        intervals [252]:
            xmin = 754.037 
            xmax = 767.278 
            text = "fun dortn dortn in dem in di zelbe shtetl hobn gelebt nokh oykh fa- eh fa- bafrayte yidn. ikh hob zikh mit zey ba- mit zey bakent un mir hobn bashlosn tsu forn, mir hobn gehert az in Minkhn gefinen zikh kazarmes un in di kazarmes gefinen zikh yidn," 
        intervals [253]:
            xmin = 767.278 
