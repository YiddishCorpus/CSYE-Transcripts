            text = "" 
        intervals [298]:
            xmin = 905.71 
            xmax = 910.918 
            text = "hobn di sovetishe soldatn undz glaykh tsugenumen azoy tsu zogn tsu zikh, un geheysn in der ershter rey geyn in bod." 
        intervals [299]:
            xmin = 910.918 
            xmax = 911.481 
            text = "" 
        intervals [300]:
            xmin = 911.481 
            xmax = 917.825 
            text = "un undzer, mir hobn gehat, ikh hob gehat bay zikh a ruk-zak hob ikh dortn gehat bay zikh azelkhe zakhn fun di daytshn vos ikh hob fun zey gekrogn a matone dortn a" 
        intervals [301]:
