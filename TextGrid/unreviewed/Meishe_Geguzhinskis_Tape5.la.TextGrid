        intervals [470]:
            xmin = 1427.417 
            xmax = 1437.401 
            text = "un do hot pasirt oyf aza min arbet vu ikh hob gearbet, ven mir hobn geboyt eh oyf Lako oyf Lako gas, in eh UNK," 
