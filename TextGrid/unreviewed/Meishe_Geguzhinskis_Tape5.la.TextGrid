            text = "" 
        intervals [474]:
            xmin = 1445.389 
            xmax = 1453.129 
            text = "m'hot gedarft, dos iz geven in akhtsikstn yor, m'hot gevart oyf Brezhevn. er hot gedarft kumen tsu forn in tsu gast." 
        intervals [475]:
            xmin = 1453.129 
            xmax = 1454.181 
            text = "" 
        intervals [476]:
            xmin = 1454.181 
            xmax = 1461.966 
            text = "ot di hoyz hot gerufn hot zikh ongerufn di Brezhev hoyz. un mir hot men dortn genumen als dekorator, ikh zol do forn un ikh zol dortn in ordenung brengen alts" 
        intervals [477]:
            xmin = 1461.966 
