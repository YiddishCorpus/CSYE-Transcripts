            text = "" 
        intervals [286]:
            xmin = 881.595 
            xmax = 885.672 
            text = "ikh hob getrofn dortn nokh azelkhe khevre velkhe, un mir hobn bashlosn tsu forn aheym." 
        intervals [287]:
            xmin = 885.672 
            xmax = 886.725 
            text = "" 
        intervals [288]:
            xmin = 886.725 
            xmax = 891.899 
            text = "yedn tog zenen gekumen tsu forn ruzevikes, m'hot undz arayngezetst in di in di in di last oyto- last-oytos," 
        intervals [289]:
            xmin = 891.899 
            xmax = 891.923 
            text = "" 
        intervals [290]:
            xmin = 891.923 
