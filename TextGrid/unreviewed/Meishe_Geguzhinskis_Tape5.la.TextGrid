            text = "un mir veln arayngeyn in bod, un geye- aroysgeyendik fun tsurik veln mir krign demolts tsurik di zakhn." 
        intervals [310]:
            xmin = 938.262 
            xmax = 940.562 
            text = "mir zenen arayn in bod, un mir hobn zikh oysgebodn," 
