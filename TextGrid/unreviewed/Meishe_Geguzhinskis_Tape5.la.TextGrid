            xmax = 485.083 
            text = "" 
        intervals [163]:
            xmin = 485.083 
            xmax = 491.003 
            text = "in di velder azoy in vald zenen zey mir zeyer tsu nits gekumen. mir hobn zikh beyde geteylt di kartofl di di" 
        intervals [164]:
            xmin = 491.003 
            xmax = 493.869 
            text = "di roye kartofl kedey tsu shtiln dem hunger." 
        intervals [165]:
            xmin = 493.869 
            xmax = 494.5 
            text = "" 
        intervals [166]:
            xmin = 494.5 
            xmax = 496.35 
            text = "in der fri ven mir zenen beyde oyfgeshtanen," 
        intervals [167]:
            xmin = 496.35 
            xmax = 496.508 
            text = "" 
        intervals [168]:
            xmin = 496.508 
            xmax = 499.337 
            text = "hobn mir nit gevust vu tsum vu zikh tsum kern, vu tsum geyn." 
        intervals [169]:
            xmin = 499.337 
            xmax = 499.461 
            text = "" 
        intervals [170]:
            xmin = 499.461 
            xmax = 508.938 
            text = "zenen mir gelofn durkhn vald zukhn vos nit iz oyf a ort, efsher veln mir gefinen vu s'a shtibele oder vos nit iz. un grod hobn mir getrofn a oyfn veg hobn mir gezen a kleyninke shtibele." 
        intervals [171]:
            xmin = 508.938 
            xmax = 510.666 
            text = "" 
        intervals [172]:
            xmin = 510.666 
            xmax = 518.878 
            text = "m'iz arayngelofn in shtibl, eyder m'hot undz arayngelofn in shtibl, iz fun shtibl aroysgelofn eyner der vekhter der der der eh vald vekhter," 
        intervals [173]:
            xmin = 518.878 
            xmax = 519.745 
            text = "" 
        intervals [174]:
            xmin = 519.745 
            xmax = 522.281 
            text = "ongeton shoyn in tsiviler mitn revolver in der hant," 
        intervals [175]:
            xmin = 522.281 
            xmax = 525.746 
            text = "er hot undz derzen, hot er ongehoybn tsu shisn oyf undz." 
        intervals [176]:
            xmin = 525.746 
            xmax = 525.955 
            text = "" 
        intervals [177]:
            xmin = 525.955 
            xmax = 529.661 
            text = "un eyn koyl hot getrofn mayn khaver. im UNK dem dem yat." 
        intervals [178]:
            xmin = 529.661 
            xmax = 529.701 
            text = "" 
        intervals [179]:
            xmin = 529.701 
            xmax = 534.69 
            text = "dos heyst bay lebn mir iz er gefaln. ikh bin tsugelo- ikh bin tsugegangen tsu, un der un der vekhter iz antlofn vayter." 
        intervals [180]:
            xmin = 534.69 
