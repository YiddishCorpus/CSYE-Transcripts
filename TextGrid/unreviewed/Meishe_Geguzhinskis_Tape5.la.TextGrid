            xmin = 1534.806 
            xmax = 1534.823 
            text = "" 
        intervals [503]:
            xmin = 1534.823 
            xmax = 1541.401 
            text = "es kumen tsu geyn, zogt er, di ale natshalstve ibern kop un zey lozn dir nit arbetn, yeder yeder eyntsikster zogt zayne zogt dir direktivn." 
        intervals [504]:
            xmin = 1541.401 
            xmax = 1541.408 
            text = "" 
        intervals [505]:
            xmin = 1541.408 
            xmax = 1545.317 
            text = "ikh, zogt er, ken shoyn mer nit arbetn. ikh vel oder ikh vel krign, zogt er, a ilfakt, oder a insut." 
        intervals [506]:
            xmin = 1545.317 
            xmax = 1545.458 
            text = "" 
        intervals [507]:
            xmin = 1545.458 
            xmax = 1548.591 
            text = "un azoy hot pasirt. ikh hob zikh fun der arbet nit opgelozn," 
        intervals [508]:
            xmin = 1548.591 
            xmax = 1548.698 
            text = "" 
        intervals [509]:
            xmin = 1548.698 
            xmax = 1555.998 
            text = "un ikh hob der- der- dertsoygn di arbet bizn bizn tog, bizn tsvantsikstn yuli. di arbet iz geven fartik, UNK." 
        intervals [510]:
            xmin = 1555.998 
            xmax = 1556.68 
            text = "" 
        intervals [511]:
            xmin = 1556.68 
            xmax = 1562.091 
            text = "ikh hob ongeklungen dem shef maynem, yener iz geven UNK, hot gearbet der shef, UNK, ikh hob im ongeklungen," 
        intervals [512]:
            xmin = 1562.091 
            xmax = 1562.637 
            text = "" 
        intervals [513]:
            xmin = 1562.637 
            xmax = 1565.162 
            text = "ikh hob im gedarft yedn t- yedn tog ibergebn" 
