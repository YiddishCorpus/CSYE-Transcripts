            xmin = 1597.224 
            xmax = 1597.804 
            text = "" 
        intervals [525]:
            xmin = 1597.804 
            xmax = 1601.172 
            text = "er iz farnumen. mit yidn, zogt er, hob ikh UNK tsum ton." 
        intervals [526]:
            xmin = 1601.172 
            xmax = 1602.765 
            text = "" 
        intervals [527]:
            xmin = 1602.765 
            xmax = 1608.378 
            text = "mir iz gevorn, ikh hob gehert di reyd, iz mir gevorn shlekht. ikh bin geshtanen baym telefon bay mir in kabinet," 
        intervals [528]:
            xmin = 1608.378 
            xmax = 1608.385 
            text = "" 
        intervals [529]:
            xmin = 1608.385 
            xmax = 1611.442 
            text = "un ikh hob aro- s'aruntergefaln bay mir di trubke fun hant," 
        intervals [530]:
            xmin = 1611.442 
            xmax = 1618.792 
            text = "un ikh bin aruntergefaln avek ni- ikh hob zikh nit gekent oyf. mir s'hot zikh zeyer shtark fardrosn, ikh hob arayngeleygt azoy fil arbet in dem un do mit a yidn vil er shoyn nit reydn." 
        intervals [531]:
            xmin = 1618.792 
            xmax = 1623.167 
