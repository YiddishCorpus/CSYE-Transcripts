            xmin = 1565.162 
            xmax = 1566.602 
            text = "" 
        intervals [515]:
            xmin = 1566.602 
            xmax = 1569.346 
            text = "dem raport, vi di arbet gefirt vert vert oysgefirt." 
        intervals [516]:
            xmin = 1569.346 
            xmax = 1570.99 
            text = "" 
        intervals [517]:
            xmin = 1570.99 
            xmax = 1577.328 
            text = "kling ikh im on, un ikh UNK iz geven in kabinet un s'geven di sekretarshe." 
