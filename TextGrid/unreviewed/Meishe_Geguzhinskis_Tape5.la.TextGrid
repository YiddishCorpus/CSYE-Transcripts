        intervals [443]:
            xmin = 1328.8 
            xmax = 1332.742 
            text = "er hot eh vegn tapetsireray vegn di arbet fun veykhe mebl keyn zakh nit gevust." 
        intervals [444]:
            xmin = 1332.742 
            xmax = 1332.748 
            text = "" 
        intervals [445]:
            xmin = 1332.748 
            xmax = 1334.868 
            text = "nor ikh hob gezogt, veystu vos, ikh vel dir oyslernen." 
