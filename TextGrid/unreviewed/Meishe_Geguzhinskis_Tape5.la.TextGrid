            xmin = 830.34 
            xmax = 831.021 
            text = "" 
        intervals [274]:
            xmin = 831.021 
            xmax = 840.938 
            text = "nu ikh bin nokh dan geven in gantsn nayntsn yor. ikh hob nokh alts gelebt mitn gayst fun dem eh sovetishn azoy tsu zogn umpartizanishn gayst." 
        intervals [275]:
            xmin = 840.938 
            xmax = 841.467 
            text = "" 
        intervals [276]:
            xmin = 841.467 
