            text = "" 
        intervals [533]:
            xmin = 1623.181 
            xmax = 1626.688 
            text = "az mayn mayn natsyonal dos heyst mayn mayn mayn mayn shtamung," 
        intervals [534]:
            xmin = 1626.688 
