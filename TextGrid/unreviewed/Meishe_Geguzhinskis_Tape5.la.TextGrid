            text = "un m'hot undz gefirt tsum grenets tsu Khelmits." 
        intervals [291]:
            xmin = 894.195 
            xmax = 894.353 
            text = "" 
        intervals [292]:
            xmin = 894.353 
            xmax = 898.599 
            text = "dortn iz geven der grenets tsvishn di amerikaner un di sovetn, un sovetishe armey." 
