            text = "" 
        intervals [181]:
            xmin = 535.033 
            xmax = 537.592 
            text = "vayl er hot shoyn geshpirt az di amerikaner armey iz shoyn geven nit vayt." 
        intervals [182]:
            xmin = 537.592 
            xmax = 538.83 
            text = "" 
        intervals [183]:
            xmin = 538.83 
            xmax = 544.747 
            text = "ikh bin tsugegangen tsu mayn khaver, ikh hob a kuk geton, ikh hob gezen di koyl hot im getrofn direkt glaykh in kop, er iz shoyn geven toyt." 
        intervals [184]:
            xmin = 544.747 
            xmax = 545.091 
            text = "" 
        intervals [185]:
            xmin = 545.091 
            xmax = 548.139 
            text = "nu ikh hob keyn zakh nit gekent im helfn. ikh bin arayngegangen in shtibl," 
        intervals [186]:
            xmin = 548.139 
            xmax = 548.55 
            text = "" 
        intervals [187]:
            xmin = 548.55 
            xmax = 557.977 
            text = "ikh bin geven farlayzikt, ikh bin geven shmutsik, ikh bin geven oysgematert. ikh hob kam kam zikh derkrokhn tsum tsum tsum a vinkl fun fun fun shti- fun tsimerl, ikh hob zikh avekgeleygt," 
        intervals [188]:
            xmin = 557.977 
            xmax = 558.203 
            text = "" 
        intervals [189]:
            xmin = 558.203 
            xmax = 564.676 
            text = "un ikh hob zikh un ikh hob zikh a bisl opgerut. ikh bin ayngeshlofn." 
        intervals [190]:
            xmin = 564.676 
            xmax = 566.623 
            text = "" 
        intervals [191]:
            xmin = 566.623 
            xmax = 571.983 
            text = "ikh hob fun zikh aruntergevorfn di aruntergevorfn di zakhn farshteyt zikh, un ikh bin ayngeshlofn azoy o. fardekt zikh mit a koldere" 
        intervals [192]:
            xmin = 571.983 
            xmax = 572.04 
            text = "" 
        intervals [193]:
            xmin = 572.04 
            xmax = 577.181 
            text = "vos iz dortn geven, un ay- un aroysge- un in der fri bin ikh oyfgeshtanen, hob ikh gehert a geroysh fun mashines." 
        intervals [194]:
            xmin = 577.181 
            xmax = 577.322 
            text = "" 
        intervals [195]:
            xmin = 577.322 
            xmax = 578.97 
            text = "a ge- a geroysh fun tanken." 
