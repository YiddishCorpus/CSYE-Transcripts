            text = "" 
        intervals [260]:
            xmin = 783.175 
            xmax = 789.075 
            text = "m'hot undz dortn zeyer gut gegebn esn, m'hot undz ongeton, di amerikaner hobn zikh zeyer gut tsu undz batsoygn," 
        intervals [261]:
            xmin = 789.075 
            xmax = 794.95 
            text = "un eh yedn tog flegn mir krign shokolad, fleg krign farsheydene produktn," 
        intervals [262]:
            xmin = 794.95 
            xmax = 798.85 
            text = "biz, far undz iz geven a groyse zakh, vayle gevezn gemutshete mentshn fun lager." 
        intervals [263]:
            xmin = 798.85 
            xmax = 803.425 
            text = "hob ikh zikh gikh a bisl gekumen tsu zikh, zikh a bisl shoyn far- far- bapravet azoy tsu zogn." 
        intervals [264]:
            xmin = 803.425 
            xmax = 804.595 
            text = "" 
        intervals [265]:
