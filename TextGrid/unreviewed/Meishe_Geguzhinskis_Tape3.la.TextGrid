        intervals [45]:
            xmin = 166.804 
            xmax = 176.248 
            text = "iz shoyn geven di organizatsye, di u- di untererdishe partizanishe organizatsye in geto iz shoyn geven a gants shtarke. s'hobn in ir onteyl genumen eh a sakh mitglider." 
