        intervals [27]:
            xmin = 90.141 
            xmax = 100.007 
            text = "er iz geven azoy a shoyn a gedinter a g- er iz geven shoyn in armey, er hot shoyn farshtanen in gever. mir hobn dan in dem krayzl oysge-" 
