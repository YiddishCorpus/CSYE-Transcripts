            text = "" 
        intervals [31]:
            xmin = 108.417 
            xmax = 117.771 
            text = "dos iz geven legal, dos iz geven der di der der instruktor undzerer iz geven der Yashka Davidov, velkher mir flegn zikh tsukukn vi er fleg funander nemen dem shlos fun dem biks," 
        intervals [32]:
