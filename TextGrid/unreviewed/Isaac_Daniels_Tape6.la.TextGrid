            xmax = 39.87 
            text = "" 
        intervals [11]:
            xmin = 39.87 
            xmax = 49.939 
            text = "FINALLY, ikh bin dortn gevezn, vi ikh hob gezogt, ze'mir geven zibn un nayntsik mentshn in di ROOM." 
        intervals [12]:
