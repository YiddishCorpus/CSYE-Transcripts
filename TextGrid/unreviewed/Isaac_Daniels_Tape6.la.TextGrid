            xmin = 144.742 
            xmax = 145.457 
            text = "" 
        intervals [43]:
            xmin = 145.457 
            xmax = 152.285 
            text = "az m'hot es gegebn in a hiltsern fas, gebrengt tsu firn arayn tsu tseteyln di zupn," 
