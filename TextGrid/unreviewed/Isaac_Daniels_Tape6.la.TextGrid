            text = "" 
        intervals [15]:
            xmin = 52.83 
            xmax = 59.085 
            text = "m'hot dray mol in tog gemuzt shepn di vaser, vayl di kerpers hobn hot gevaremt dos ayz fun di vent." 
        intervals [16]:
            xmin = 59.085 
            xmax = 59.496 
            text = "" 
        intervals [17]:
            xmin = 59.496 
