            text = "" 
        intervals [69]:
            xmin = 217.328 
            xmax = 222.454 
            text = "hot eyn froy hot arayngekukt, s'dortn geven a kleyn fentsterl arayntsukukn." 
        intervals [70]:
            xmin = 222.454 
            xmax = 227.733 
            text = "hot zi gezen az ale esn di zupn, un ikh es nisht." 
