        intervals [7]:
            xmin = 28.676 
            xmax = 29.847 
            text = "" 
        intervals [8]:
            xmin = 29.847 
            xmax = 36.112 
            text = "ikh hob zikh gegebn a khap oyf fun shlof. di akht un fertsikstn yor, ver vet oyshaltn azoy lang?" 
        intervals [9]:
            xmin = 36.112 
            xmax = 38.412 
            text = "ikh ken nisht arayn ikh ken nisht arumgeyn oyf di fis." 
