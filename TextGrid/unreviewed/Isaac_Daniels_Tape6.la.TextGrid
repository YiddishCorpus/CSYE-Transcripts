            xmax = 157.061 
            text = "hot zikh ongetsoygn fun der varemkeyt, m'hot es azh gefilt zikh." 
        intervals [46]:
            xmin = 157.061 
            xmax = 157.59 
            text = "" 
        intervals [47]:
            xmin = 157.59 
            xmax = 161.938 
            text = "ikh hob di monatn keyn zup in gantsn nisht gegesn." 
        intervals [48]:
            xmin = 161.938 
