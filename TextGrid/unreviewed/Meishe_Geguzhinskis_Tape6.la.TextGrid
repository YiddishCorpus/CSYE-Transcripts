item []: 
    item [1]:
        class = "IntervalTier" 
        name = "Meishe Geguzhinskis" 
        xmin = 0 
        xmax = 370.769 
        intervals: size = 115 
        intervals [1]:
            xmin = 0 
            xmax = 7.673 
            text = "" 
        intervals [2]:
            xmin = 7.673 
            xmax = 10.029 
            text = "in shpitol hot men mir zeyer gikh oysgeheylt." 
        intervals [3]:
            xmin = 10.029 
            xmax = 10.069 
            text = "" 
        intervals [4]:
            xmin = 10.069 
            xmax = 13.708 
            text = "ikh bin gelegn dort emes bay a tsvey a halb monat, biz dray monat tsayt," 
        intervals [5]:
            xmin = 13.708 
            xmax = 13.9 
            text = "" 
        intervals [6]:
            xmin = 13.9 
            xmax = 16.537 
            text = "un m'iz gekumen tsu geyn in shtub, di froy hot mir gebrakht" 
        intervals [7]:
            xmin = 16.537 
            xmax = 19.732 
            text = "tsu geyn in sh- tsu f- tsu firn in shtub shoyn oyf mayne fis." 
        intervals [8]:
            xmin = 19.732 
            xmax = 20.363 
            text = "" 
        intervals [9]:
            xmin = 20.363 
            xmax = 23.929 
            text = "un ikh hob nor dokh hob ikh zikh geshpirt moralish zeyer gesh- zeyer" 
        intervals [10]:
            xmin = 23.929 
            xmax = 31.95 
            text = "zeyer shtark dershlogn der- farshlogn. tsu arbet hob ikh shoyn nit gekent geyn vayter, un ikh hob shoyn nit gevelt geyn tsu der arbet, vayl ikh hob farshtanen az di batsiung" 
        intervals [11]:
            xmin = 31.95 
            xmax = 31.956 
            text = "" 
        intervals [12]:
            xmin = 31.956 
            xmax = 42.041 
            text = "tsu di arbeter velkhe arbetn in dem ministorn-kabinet zaynen di zeyer nit nit m'bahandlt ver- vern bahandlt nit vi keyn mentshn." 
        intervals [13]:
            xmin = 42.041 
            xmax = 44.781 
            text = "" 
        intervals [14]:
            xmin = 44.781 
            xmax = 52.234 
            text = "un ikh hob ongehoybn zikh farnemen mit literatur. in di fraye tsayt fleg ikh shraybn in yidishe tsaytungen," 
        intervals [15]:
            xmin = 52.234 
            xmax = 52.78 
            text = "" 
        intervals [16]:
            xmin = 52.78 
            xmax = 57.341 
            text = "in a sakh eyropeishe tsaytungen fleg ikh shraybn. in Parizher Tsaytung fleg ikh shraybn." 
        intervals [17]:
            xmin = 57.341 
            xmax = 62.021 
            text = "in Erets-Yisroeldike Tsaytung, di nayes, hob ikh geshribn farshidene reportazhn." 
        intervals [18]:
            xmin = 62.021 
            xmax = 64.12 
            text = "" 
        intervals [19]:
            xmin = 64.12 
            xmax = 68.63 
            text = "ikh hob geshribn mayne farsheydene, ikh hob ongehoybn shraybn dikhtung, farsheydene lider," 
        intervals [20]:
            xmin = 68.63 
            xmax = 74.744 
            text = "velkhe ikh hob eh frier gekent s'mir oysgekumen in in oyfn oyfn geza- oyfn gedank." 
        intervals [21]:
            xmin = 74.744 
            xmax = 74.829 
            text = "" 
        intervals [22]:
            xmin = 74.829 
            xmax = 84.829 
            text = "un eh ikh mit dem hob ikh a bisl zikh fargesn ale mayne vaytokn un ikh hob eh bashlosn az ikh vel," 
        intervals [23]:
            xmin = 84.829 
            xmax = 90.744 
            text = "ikh bin dan dan ersht geven zibn un fuftsik yor. keyn gantse keyn zekhtsik hob ikh hob ikh nokh nit der- der- der- dertsoygn" 
        intervals [24]:
            xmin = 90.744 
            xmax = 93.797 
            text = "keyn pensye hob ikh, keyn pe- keyn pensyoner bin ikh nit geven." 
        intervals [25]:
            xmin = 93.797 
            xmax = 94.022 
            text = "" 
        intervals [26]:
            xmin = 94.022 
            xmax = 103.179 
            text = "nor az ikh bin shoyn gevorn zekhtsik yor, trakht ikh, nu ikh vel shoyn mer mit arbet mistome mer nit kenen geyn. ikh vel zikh farnemen mit bay mit mayn eh neygung tsu literatur." 
        intervals [27]:
            xmin = 103.179 
            xmax = 104.451 
            text = "" 
        intervals [28]:
            xmin = 104.451 
            xmax = 114.083 
            text = "nu mayne a- mayne artiklen hobn mir hobn gehat a gants groysn derfolg. m'hot di di redaktorn fun Varshever Tsaytung, Katarko, hot mir nit eyn mol geshribn" 
        intervals [29]:
            xmin = 114.083 
            xmax = 118.89 
            text = "er hot gebetn ikh zol shraybn, er hot iz do gekumen bay mir tsu gast tsu forn fun Varshe" 
        intervals [30]:
            xmin = 118.89 
            xmax = 118.93 
            text = "" 
        intervals [31]:
            xmin = 118.93 
            xmax = 126.18 
            text = "tsu mir shtub, un er hot mir zikh interesirt vegn mir. er flegt drukn ale mayne lider, s'nit geven keyn eyn eyn eyn gedikht vos er zol nit drukn." 
        intervals [32]:
            xmin = 126.18 
            xmax = 129.797 
            text = "" 
        intervals [33]:
            xmin = 129.797 
            xmax = 134.595 
            text = "un dos iz farshteyt zikh, oder haynt tsum tog, ot di letste tsayt," 
        intervals [34]:
            xmin = 134.595 
            xmax = 139.297 
            text = "bin ikh vider krank gevorn do, ikh bin gelegn oyfn bet a lange tsayt, onderhalbn yor tsayt bin ikh gelegn tsu," 
        intervals [35]:
            xmin = 139.297 
            xmax = 142.255 
            text = "ikh hob gerufn bay mir kentik di ale iberlebenishn fun di lagern," 
        intervals [36]:
            xmin = 142.255 
            xmax = 144.616 
            text = "di ale veytokn vos ikh hob gehat. ikh fleg zen yedn ikh fleg" 
        intervals [37]:
            xmin = 144.616 
            xmax = 147.127 
            text = "shpirn yedn tog di veytokn fun di fun di fun di hent" 
        intervals [38]:
            xmin = 147.127 
            xmax = 150.787 
            text = "un fun ti- fun dem brust-kastn b- beys ikh bin gelegn, gehongen oyf di shtrik." 
        intervals [39]:
            xmin = 150.787 
            xmax = 153.956 
            text = "ikh fleg zen bay nakht, ikh fleg s'flegt mikh shteyn alts far di oygn." 
        intervals [40]:
            xmin = 153.956 
            xmax = 154.367 
            text = "" 
        intervals [41]:
            xmin = 154.367 
            xmax = 160.368 
            text = "un ikh hob zikh zeyer shtark tsebrokhn, ikh bin gelegn a lange tsayt biz hayntike yor," 
        intervals [42]:
            xmin = 160.368 
            xmax = 160.577 
            text = "" 
        intervals [43]:
            xmin = 160.577 
            xmax = 164.064 
            text = "fun fir un nayntsikstn bizn zeks un nayntsikstn, dort bin ikh kimat nit aroys fun shtub." 
        intervals [44]:
            xmin = 164.064 
            xmax = 164.458 
            text = "" 
        intervals [45]:
            xmin = 164.458 
            xmax = 165.532 
            text = "nor ikh fleg shraybn." 
        intervals [46]:
            xmin = 165.532 
            xmax = 166.264 
            text = "" 
        intervals [47]:
            xmin = 166.264 
            xmax = 173.463 
            text = "di letste fleg ikh zikh farnemen mi- mit in fleg ikh arbetn mitarbetn tsvishn di doktoyrim fun fun meditsinishn tsenter tsu di bay di yidishe gemeynde," 
        intervals [48]:
            xmin = 173.463 
            xmax = 173.503 
            text = "" 
        intervals [49]:
            xmin = 173.503 
            xmax = 176.478 
            text = "ikh hob dortn gehat oykh a interes tsum arbetn, mir flegn helfn dortn yidn." 
        intervals [50]:
            xmin = 176.478 
            xmax = 179.741 
            text = "oreme yidn, kranke yidn, mit meditsin, mit medikamen." 
        intervals [51]:
            xmin = 179.741 
            xmax = 179.815 
            text = "" 
        intervals [52]:
            xmin = 179.815 
            xmax = 184.635 
            text = "ikh hob dortn farnumen oykh als sekretar fun dem meditsi- fun dem fun dem komitet fun fun dem eh eh rat fun dem" 
        intervals [53]:
            xmin = 184.635 
            xmax = 184.793 
            text = "" 
        intervals [54]:
            xmin = 184.793 
            xmax = 187.774 
            text = "meditsinishn tsenter bay dokter Zak UNK." 
        intervals [55]:
            xmin = 187.774 
            xmax = 190.21 
            text = "" 
        intervals [56]:
            xmin = 190.21 
            xmax = 194.624 
            text = "nokh eh hayntike yor, fun onfang yor shoyn," 
        intervals [57]:
            xmin = 194.624 
            xmax = 194.867 
            text = "" 
        intervals [58]:
            xmin = 194.867 
            xmax = 198.489 
            text = "hob ikh dershpirt az ikh ken nokh epes vos iz ton." 
        intervals [59]:
            xmin = 198.489 
            xmax = 201.938 
            text = "" 
        intervals [60]:
            xmin = 201.938 
            xmax = 207.433 
            text = "nu ikh ken do oysleyenen mayne a a dikht UNK, oyber, yo." 
        intervals [61]:
            xmin = 207.433 
            xmax = 219.015 
            text = "" 
        intervals [62]:
            xmin = 219.015 
            xmax = 223.247 
            text = "ikh hob ongeshribn far der tsayt eh fil dikhtn, farsheydene mit farsheydene temes." 
        intervals [63]:
            xmin = 223.247 
            xmax = 227.295 
            text = "nor ikh volt voln eh oder tsum tog peysekh oder tsum tog purim." 
        intervals [64]:
            xmin = 227.295 
            xmax = 228.31 
            text = "" 
        intervals [65]:
            xmin = 228.31 
            xmax = 237.515 
            text = "mayn baym bruder-keyver iz do aza min. eh di eh di lid hot ge- di dikht hot men gedrukt in a yidisher tsaytung in Ostralyen," 
        intervals [66]:
            xmin = 237.515 
            xmax = 240.103 
            text = "der redaktor hot geshribn tsu mir ikh zol vayter shraybn." 
        intervals [67]:
            xmin = 240.103 
            xmax = 240.345 
            text = "" 
        intervals [68]:
            xmin = 240.345 
            xmax = 241.908 
            text = "ot ken ikh ir iberleyenen." 
        intervals [69]:
            xmin = 241.908 
            xmax = 244.378 
            text = "" 
        intervals [70]:
            xmin = 244.378 
            xmax = 247.784 
            text = "ikh hob dir oyf krumike vegn getrofn," 
        intervals [71]:
            xmin = 247.784 
            xmax = 248.412 
            text = "" 
        intervals [72]:
            xmin = 248.412 
            xmax = 251.224 
            text = "un hob in dayn lebn a vogler derzen." 
        intervals [73]:
            xmin = 251.224 
            xmax = 251.685 
            text = "" 
        intervals [74]:
            xmin = 251.685 
            xmax = 254.548 
            text = "es zaynen di teg dayne blinde farlofn," 
        intervals [75]:
            xmin = 254.548 
            xmax = 254.672 
            text = "" 
        intervals [76]:
            xmin = 254.672 
            xmax = 257.551 
            text = "in nakhtikn blondzhen bagleyt dir dayn pen." 
        intervals [77]:
            xmin = 257.551 
            xmax = 258.688 
            text = "" 
        intervals [78]:
            xmin = 258.688 
            xmax = 262.159 
            text = "ver binstu, farlozener, eynzamer vogler?" 
        intervals [79]:
            xmin = 262.159 
            xmax = 262.789 
            text = "" 
        intervals [80]:
            xmin = 262.789 
            xmax = 265.736 
            text = "mit zorgfule kneytshn in shtern gefarbt," 
        intervals [81]:
            xmin = 265.736 
            xmax = 266.046 
            text = "" 
        intervals [82]:
            xmin = 266.046 
            xmax = 269.077 
            text = "tsk tsi brent in dayn hartsn der vint fun a odler," 
        intervals [83]:
            xmin = 269.077 
            xmax = 269.32 
            text = "" 
        intervals [84]:
            xmin = 269.32 
            xmax = 273.583 
            text = "tsi zingt in dayn sk- in tsi zingt shoyn in skeynes dayn shotn geshtalt?" 
        intervals [85]:
            xmin = 273.583 
            xmax = 273.792 
            text = "" 
        intervals [86]:
            xmin = 273.792 
            xmax = 276.843 
            text = "vos zukhstu oyf vegn oyf blotike roye," 
        intervals [87]:
            xmin = 276.843 
            xmax = 279.475 
            text = "vos shlingstu UNK dorshtik a yetvider roysh?" 
        intervals [88]:
            xmin = 279.475 
            xmax = 285.294 
            text = "dertseyln di himlen farveytikte, groye, az eybik vet ful zayn mit trern dayn kos." 
        intervals [89]:
            xmin = 285.294 
            xmax = 286.026 
            text = "" 
        intervals [90]:
            xmin = 286.026 
            xmax = 288.753 
            text = "tsi glet dir der vint dayne hor azoy tsartik," 
        intervals [91]:
            xmin = 288.753 
            xmax = 288.844 
            text = "" 
        intervals [92]:
            xmin = 288.844 
            xmax = 291.538 
            text = "tsi hot dir farkisheft der foygl-gezang?" 
        intervals [93]:
            xmin = 291.538 
            xmax = 291.78 
            text = "" 
        intervals [94]:
            xmin = 291.78 
            xmax = 294.646 
            text = "tsi vunken dir frukhtn shoyn tsaytike fartik," 
        intervals [95]:
            xmin = 294.646 
            xmax = 297.377 
            text = "vos nem zey nit raysn, es tut zey nor bang." 
        intervals [96]:
            xmin = 297.377 
            xmax = 298.193 
            text = "" 
        intervals [97]:
            xmin = 298.193 
            xmax = 301.798 
            text = "iz ver binstu dokh, du farneplter vogler?" 
        intervals [98]:
            xmin = 301.798 
            xmax = 301.922 
            text = "" 
        intervals [99]:
            xmin = 301.922 
            xmax = 304.852 
            text = "tsi kon ikh dergreykhn dayn umklorn <gnor>," 
        intervals [100]:
            xmin = 304.852 
            xmax = 305.112 
            text = "" 
        intervals [101]:
            xmin = 305.112 
            xmax = 307.097 
            text = "du fregst un du blondzhest." 
        intervals [102]:
            xmin = 307.097 
            xmax = 307.204 
            text = "" 
        intervals [103]:
            xmin = 307.204 
            xmax = 312.413 
            text = "farvoglerster vogler, far zikh un far yenem an entfer shoyn do." 
        intervals [104]:
            xmin = 312.413 
            xmax = 317.228 
            text = "" 
        intervals [105]:
            xmin = 317.228 
            xmax = 318.178 
            text = "dos alts." 
        intervals [106]:
            xmin = 318.178 
            xmax = 323.769 
            text = "ikh hob do farsheydene lider, ober s'do s'do viln ikh hob keyn tsayt un der viln tsu dertseyln tsu tsu leyenen." 
        intervals [107]:
            xmin = 323.769 
            xmax = 332.112 
            text = "" 
        intervals [108]:
            xmin = 332.112 
            xmax = 334.513 
            text = "nu, mayn eyntsike farlang iz," 
        intervals [109]:
            xmin = 334.513 
            xmax = 339.699 
            text = "ikh ze in di kum- in di kumendike doyres ze ikh mayne kinder, mayn zun un mayn tokhter. ikh hob a zun," 
        intervals [110]:
            xmin = 339.699 
            xmax = 339.925 
            text = "" 
        intervals [111]:
            xmin = 339.925 
            xmax = 343.288 
            text = "im iz shoyn bald fertsik yor. di tokhter mayne iz" 
        intervals [112]:
            xmin = 343.288 
            xmax = 354.679 
            text = "zibn un tsvontsik shoyn, vert oykh in gikhn zibn un tsvontsik yor. zey hobn nit gevust zey hobn zey veysn nit zey hobn zey veysn nit vegn di g- vegn di laydn fun zayne fun zeyere fun zeyer eltern, zey veysn nit di laydn fun zeyer folk." 
        intervals [113]:
            xmin = 354.679 
            xmax = 361.099 
            text = "ikh vel zey veltn vintshn, nit nor mayne kinder nor ale kinder, fun undzer folk un fun ale felker," 
        intervals [114]:
            xmin = 361.099 
            xmax = 366.921 
            text = "zey zoln oysmaydn di ale di ale laydn, di ale tsores vos mir hobn gehat in undzer tsayt." 
        intervals [115]:
            xmin = 366.921 
            xmax = 370.769 
            text = "" 
