        intervals [539]:
            xmin = 1605.246 
            xmax = 1613.322 
            text = "un fun dort dort hot men undz aynvogenirt, un m'hot yedn eynem gegebn a zak," 
        intervals [540]:
            xmin = 1613.322 
            xmax = 1613.565 
            text = "" 
        intervals [541]:
            xmin = 1613.565 
            xmax = 1617.288 
            text = "un m'hot gez- undz ho'mir azoy gevust az m'firt undz hargenen." 
        intervals [542]:
            xmin = 1617.288 
            xmax = 1617.902 
            text = "" 
        intervals [543]:
            xmin = 1617.902 
            xmax = 1622.874 
            text = "iz geven toyznt froyen, un tsvey toyznt mener." 
        intervals [544]:
            xmin = 1622.874 
            xmax = 1624.5 
            text = "" 
        intervals [545]:
            xmin = 1624.5 
            xmax = 1631.43 
            text = "un vifl ze'mir geven dort in eh in Minkhn Alekh, ikh veys nisht, a khoydesh, tsvey, ikh gedenk nisht." 
        intervals [546]:
            xmin = 1631.43 
            xmax = 1632.381 
            text = "" 
        intervals [547]:
            xmin = 1632.381 
            xmax = 1634.552 
            text = "a khoydesh efsher, mer a khoydesh." 
        intervals [548]:
            xmin = 1634.552 
            xmax = 1635.857 
            text = "" 
        intervals [549]:
            xmin = 1635.857 
            xmax = 1642.095 
            text = "un m'hot undz avekgefirt oyf in di vagonen, aynvogenirt. un di mener hot men gegebn ofene vagonen," 
        intervals [550]:
            xmin = 1642.095 
            xmax = 1642.168 
            text = "" 
        intervals [551]:
            xmin = 1642.168 
            xmax = 1647.107 
            text = "un di froyen hot men gegebn tsugemakhte vagonen. finef un zibetsik mentshn in a vagon." 
        intervals [552]:
            xmin = 1647.107 
            xmax = 1648.632 
            text = "" 
        intervals [553]:
            xmin = 1648.632 
            xmax = 1655.679 
            text = "un azoy ze'mir geforn a tsvey dray vokhn. un m'hot undz shoyn nisht arayngelozt in ergets." 
        intervals [554]:
            xmin = 1655.679 
            xmax = 1655.803 
            text = "" 
        intervals [555]:
            xmin = 1655.803 
            xmax = 1662.463 
            text = "undz hot shoyn ibergenumen di Royte Kreyts. undz ho'mir shoyn bakumen a bisele esn" 
        intervals [556]:
            xmin = 1662.463 
            xmax = 1663.06 
            text = "" 
        intervals [557]:
            xmin = 1663.06 
            xmax = 1666.463 
            text = "funem Roytn Kreyts. yeder eyner hot bakumen a pekl." 
        intervals [558]:
            xmin = 1666.463 
            xmax = 1668.072 
            text = "" 
        intervals [559]:
            xmin = 1668.072 
            xmax = 1675.423 
            text = "nor azoy vi di mener iz geven in ofene vagonen, un tsugemakht mit drot, mit shtekhedik drot," 
        intervals [560]:
            xmin = 1675.423 
            xmax = 1675.8 
            text = "" 
        intervals [561]:
            xmin = 1675.8 
            xmax = 1681.886 
            text = "un undz ze'mir geven in tsugemakhte vagonen, nor in undzer vagon iz geven iberol tsu tsvey daytshn, S.S.n." 
        intervals [562]:
            xmin = 1681.886 
            xmax = 1682.787 
            text = "" 
        intervals [563]:
            xmin = 1682.787 
            xmax = 1686.561 
            text = "eh bay nakht zenen zey avek shlofn in zeye- in zeyere vagonen," 
        intervals [564]:
            xmin = 1686.561 
            xmax = 1686.651 
            text = "" 
        intervals [565]:
            xmin = 1686.651 
            xmax = 1692.315 
            text = "un zey hobn undz tsugemakht fun droysn di vagonen, un a gantsn tog zenen zey geven mit undz." 
        intervals [566]:
            xmin = 1692.315 
            xmax = 1693.03 
            text = "" 
        intervals [567]:
            xmin = 1693.03 
            xmax = 1698.93 
            text = "nu dort hot men undz gegebn aroys yedn tog di shtikl broyt, dort epes tsu dem broytl op tsu, s'shoyn geven deys" 
        intervals [568]:
            xmin = 1698.93 
            xmax = 1699.611 
            text = "" 
        intervals [569]:
            xmin = 1699.611 
            xmax = 1702.068 
            text = "dey peklekh iz shoyn geven gringer." 
        intervals [570]:
            xmin = 1702.068 
            xmax = 1702.243 
            text = "" 
        intervals [571]:
            xmin = 1702.243 
            xmax = 1707.755 
            text = "un zey hobn undz aroysgelozt azoy oyf a feld ze'mir geshtanen, iz geven a groyser shalon," 
        intervals [572]:
            xmin = 1707.755 
            xmax = 1708.133 
            text = "" 
        intervals [573]:
            xmin = 1708.133 
            xmax = 1714.911 
            text = "ze'mir geshtanen oyf a feld, un dort flegt men undz, di soldatn undz froyen, meydlekh," 
        intervals [574]:
            xmin = 1714.911 
            xmax = 1714.933 
            text = "" 
        intervals [575]:
            xmin = 1714.933 
            xmax = 1719.078 
            text = "hot men undz aroysgelozt m'zol a bisl zayn in droysn oyf der luft." 
        intervals [576]:
            xmin = 1719.078 
            xmax = 1719.253 
            text = "" 
        intervals [577]:
            xmin = 1719.253 
            xmax = 1723.044 
            text = "un ven m'hot bakumen di peklekh iz geven getriknte milkh." 
        intervals [578]:
            xmin = 1723.044 
            xmax = 1724.755 
            text = "" 
        intervals [579]:
            xmin = 1724.755 
            xmax = 1729.777 
            text = "un dort ho'mir oysgezukht shteyner, un eh sh- shpendlekh," 
        intervals [580]:
            xmin = 1729.777 
            xmax = 1729.952 
            text = "" 
        intervals [581]:
            xmin = 1729.952 
            xmax = 1737.677 
            text = "un ho'mir getrofn oyfn feld eh fun konzervns blekhlekh. un m'hot zey dort, epes iz geven vaser, un m'hot zey oysgevashn," 
        intervals [582]:
            xmin = 1737.677 
            xmax = 1740.209 
            text = "un ho'mir gemakht milkh heyse." 
