            xmin = 1311.767 
            xmax = 1312.617 
            text = "" 
        intervals [435]:
            xmin = 1312.617 
            xmax = 1321.689 
            text = "dort iz geven shtark a sakh frantsoyzn, rusn, dort iz geven tsvontsik toyznt gefangen. un akht hundert yidn." 
        intervals [436]:
            xmin = 1321.689 
            xmax = 1322.252 
            text = "" 
        intervals [437]:
            xmin = 1322.252 
            xmax = 1327.092 
            text = "nu zey hobn bakumen besere kost, undz ho'mir bakumen funem lager genug gemeyne kost." 
        intervals [438]:
            xmin = 1327.092 
            xmax = 1333.631 
            text = "gearbet ho'mir tsvelef sho. eyn vokh bay der nakht un eyn bay tog." 
        intervals [439]:
            xmin = 1333.631 
            xmax = 1338.145 
            text = "ikh hob gearbet bay pistoletn, un ikh hob zey gekukt." 
        intervals [440]:
            xmin = 1338.145 
            xmax = 1345.482 
            text = "di hent flegn bay dir tsufrirn bay der tsu di pistoletn, m'hot nisht gekent opraysn di finger." 
