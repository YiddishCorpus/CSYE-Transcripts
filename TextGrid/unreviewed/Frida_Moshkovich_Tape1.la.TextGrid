            text = "" 
        intervals [412]:
            xmin = 1245.64 
            xmax = 1250.325 
            text = "ven s'geven s'dir krank gevorn, zofort hot men ibergeshtelt in krematoryum." 
        intervals [413]:
            xmin = 1250.325 
            xmax = 1251.124 
            text = "" 
        intervals [414]:
            xmin = 1251.124 
            xmax = 1253.666 
            text = "m'hot gevust az der mentsh vet shoyn nisht lebn." 
        intervals [415]:
            xmin = 1253.666 
            xmax = 1255.107 
            text = "" 
        intervals [416]:
            xmin = 1255.107 
            xmax = 1261.075 
            text = "nu m'ho- vifl m'hot zikh gekent oyshaltn hot men zikh oysgehalt- ver s'hot gekent. un ver nisht iz gefaln." 
        intervals [417]:
            xmin = 1261.075 
            xmax = 1263.747 
