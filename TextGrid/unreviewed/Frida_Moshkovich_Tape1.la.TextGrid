            text = "" 
        intervals [339]:
            xmin = 1021.253 
            xmax = 1028.402 
            text = "tsu finef mentshn, un azoy hot men undz gegebn esn vi di khazeyrim fun di tep, fun di shmutsike vos zey hobn oyf fun der erd zikh gevalgert." 
        intervals [340]:
            xmin = 1028.402 
            xmax = 1028.728 
            text = "" 
        intervals [341]:
            xmin = 1028.728 
