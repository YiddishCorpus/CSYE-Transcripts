            xmax = 685.828 
            text = "" 
        intervals [232]:
            xmin = 685.828 
            xmax = 690.108 
            text = "a- un m'hot undz, vifl mir hobn gekent epes nemen mit zikh mit," 
        intervals [233]:
            xmin = 690.108 
            xmax = 690.52 
            text = "" 
        intervals [234]:
            xmin = 690.52 
            xmax = 692.994 
            text = "hot men undz tsamgenumen in a shul." 
        intervals [235]:
            xmin = 692.994 
            xmax = 694.165 
            text = "" 
        intervals [236]:
            xmin = 694.165 
            xmax = 698.979 
            text = "in dort iz afile nokh keyn esn nisht geven, vayl undz yidn ho'mir gehaltn peysekh," 
        intervals [237]:
            xmin = 698.979 
            xmax = 701.685 
            text = "nisht geven keyn broyt, iz nisht geven gornisht." 
        intervals [238]:
            xmin = 701.685 
            xmax = 701.826 
            text = "" 
        intervals [239]:
            xmin = 701.826 
            xmax = 708.182 
            text = "m'hot undz tsamgenumen in der shul, un dort nokh dem hobn shoyn emetser eh fun bakonte hot men arayngebrengt a shtikl broyt." 
        intervals [240]:
            xmin = 708.182 
            xmax = 708.998 
            text = "" 
        intervals [241]:
            xmin = 708.998 
            xmax = 712.142 
            text = "dort ze'mir geven a vokh tsayt. fun dort" 
        intervals [242]:
            xmin = 712.142 
            xmax = 717.024 
            text = "hot men undz vagonirt, m'hot undz avekgefirt in geto oyf Matisolke." 
        intervals [243]:
            xmin = 717.024 
            xmax = 718.313 
            text = "" 
        intervals [244]:
            xmin = 718.313 
            xmax = 737.443 
            text = "in Matisolke spn Matisolke iz geven shtark a shverer geto." 
        intervals [245]:
            xmin = 737.443 
            xmax = 738.107 
            text = "" 
        intervals [246]:
            xmin = 738.107 
            xmax = 745.796 
            text = "m'hot undz gebrengt oyf a ort vu s'geven a mol a heylik ort. a BET HAKVAROT." 
        intervals [247]:
            xmin = 745.796 
            xmax = 746.562 
            text = "" 
        intervals [248]:
            xmin = 746.562 
            xmax = 751.654 
            text = "un dort ze'mir un dort hot men undz aroyfgeleygt oyf di oyf di hoyle eh zamd." 
        intervals [249]:
            xmin = 751.654 
            xmax = 754.709 
            text = "un dort ze'mir geven a por tog. un nokh dem eh fun dort" 
        intervals [250]:
            xmin = 754.709 
            xmax = 760.123 
            text = "hot men undz avekgefirt in a hoyf, eh efsher a gas vu s'gevorn a geto." 
        intervals [251]:
            xmin = 760.123 
            xmax = 760.602 
            text = "" 
        intervals [252]:
            xmin = 760.602 
            xmax = 762.874 
            text = "dort iz geven di gas fun der geto," 
        intervals [253]:
            xmin = 762.874 
            xmax = 763.437 
            text = "" 
        intervals [254]:
            xmin = 763.437 
            xmax = 767.7 
            text = "aroysgeyn ho'mir nisht getort in ergets, nor in der geto gas," 
        intervals [255]:
            xmin = 767.7 
            xmax = 767.908 
            text = "" 
        intervals [256]:
            xmin = 767.908 
            xmax = 770.821 
            text = "eh fun zey hobn gegebn a bisl esn." 
        intervals [257]:
            xmin = 770.821 
            xmax = 770.997 
            text = "" 
        intervals [258]:
            xmin = 770.997 
            xmax = 775.463 
            text = "un ver vi s'hot gekent lebn. undz ho'mir gevoynt oyf a boydem." 
        intervals [259]:
            xmin = 775.463 
            xmax = 777.392 
            text = "" 
        intervals [260]:
            xmin = 777.392 
            xmax = 784.611 
            text = "iz dort geven shtark shver. un az m'iz adurkhgegangen der gas, iz dort geven zeyer a sakh fun di shvabn, fun di daytsher." 
        intervals [261]:
            xmin = 784.611 
            xmax = 786.65 
            text = "zey hobn shtark geshlogn di yidn." 
        intervals [262]:
            xmin = 786.65 
            xmax = 786.724 
            text = "" 
        intervals [263]:
            xmin = 786.724 
            xmax = 795.206 
            text = "un ver s'geven a bisl eh a bisl raykher, dem hobn zey internirt, dem hobn zey shtark geshlogn." 
        intervals [264]:
            xmin = 795.206 
            xmax = 796.984 
            text = "" 
        intervals [265]:
            xmin = 796.984 
            xmax = 803.984 
            text = "un nokh dem di zhondarn hobn undz ale eh zey hobn azoy geton az m'zol nisht kenen rirn zikh." 
        intervals [266]:
            xmin = 803.984 
            xmax = 807.103 
            text = "iber hoypt nisht nor nor un nor vos zey hobn gezogt." 
        intervals [267]:
            xmin = 807.103 
            xmax = 807.582 
            text = "" 
        intervals [268]:
            xmin = 807.582 
            xmax = 813.094 
            text = "nokh dem iz gekumen a tsayt a m'dar- m'vet undz firn oyf Oyshvits, ober undz ho'mir dos nisht gevust." 
        intervals [269]:
            xmin = 813.094 
            xmax = 813.589 
            text = "" 
        intervals [270]:
            xmin = 813.589 
            xmax = 818.898 
            text = "m'hot undz tsurikgefirt oyf dem plats vu ze'mir ongekumen dos ershte, oyf dem BET KVAROT," 
        intervals [271]:
            xmin = 818.898 
            xmax = 820.204 
            text = "" 
        intervals [272]:
            xmin = 820.204 
            xmax = 828.5 
            text = "un dort hot men yedn oyfgenumen vi azoy nokh dem di ge- yede familye" 
        intervals [273]:
            xmin = 828.5 
            xmax = 828.574 
            text = "" 
        intervals [274]:
            xmin = 828.574 
            xmax = 833.883 
            text = "vi azoy s'hot geheysn fun onfang, fun der tate, di mame, nokh dem di eltere, di klenste kinder." 
        intervals [275]:
            xmin = 833.883 
            xmax = 834.582 
            text = "" 
        intervals [276]:
            xmin = 834.582 
            xmax = 836.612 
            text = "un dort hot men shoyn aynvogenirt." 
        intervals [277]:
            xmin = 836.612 
            xmax = 840.498 
            text = "dort hot men tsugenumen ales vos s'geven bayn undz." 
        intervals [278]:
            xmin = 840.498 
            xmax = 840.623 
            text = "" 
        intervals [279]:
            xmin = 840.623 
            xmax = 844.61 
            text = "nor in di hoyle kleydlekh hot men undz gelozt mir di shikh. mer gornisht." 
        intervals [280]:
            xmin = 844.61 
            xmax = 847.834 
            text = "in di vagonen arayngeshtupt finef un zibetsik mentshn." 
        intervals [281]:
            xmin = 847.834 
            xmax = 850.677 
            text = "m'hot nisht gegebn keyn esn, keyn trinken, keyn gornisht." 
        intervals [282]:
            xmin = 850.677 
            xmax = 856.276 
            text = "m'hot gevorfn arayn di kleyne kinder azoy vi m'varft arayn, eh m'kopet zey, deys iz di hey." 
        intervals [283]:
            xmin = 856.276 
            xmax = 856.553 
            text = "" 
        intervals [284]:
            xmin = 856.553 
            xmax = 860.827 
            text = "azoy hot men arayngevorfn, un eltern hobn zikh moyre gehat ontsurufn a vort," 
        intervals [285]:
            xmin = 860.827 
            xmax = 863.381 
            text = "az s'zeyere kinder vayl m'hot shtark geshlogn." 
        intervals [286]:
            xmin = 863.381 
            xmax = 863.488 
            text = "" 
        intervals [287]:
            xmin = 863.488 
            xmax = 865.316 
            text = "dos blut hot zikh gegosn." 
        intervals [288]:
            xmin = 865.316 
            xmax = 868.308 
            text = "m'hot undz aroysgeshtelt in a a ring," 
        intervals [289]:
            xmin = 868.308 
            xmax = 868.888 
            text = "" 
        intervals [290]:
            xmin = 868.888 
            xmax = 874.015 
            text = "un dort di zhondarn, vemen zey hobn oysgerufn un er iz nisht gelofn zofort," 
        intervals [291]:
            xmin = 874.015 
            xmax = 876.662 
            text = "eh hot men shtark geshlogn mit rimens." 
        intervals [292]:
            xmin = 876.662 
            xmax = 878.068 
            text = "" 
        intervals [293]:
            xmin = 878.068 
            xmax = 884.812 
            text = "un ikh hob gezen az mayne briderlekh, umkumen di tsvey kleyne, kumen oyf an andern vagon." 
        intervals [294]:
            xmin = 884.812 
            xmax = 885.51 
            text = "" 
        intervals [295]:
            xmin = 885.51 
            xmax = 889.118 
            text = "un ikh bin gegangen zogn farn zhondar er zol eh bakukn" 
        intervals [296]:
            xmin = 889.118 
            xmax = 895.072 
            text = "dos tsetl vu er hot tsamgeshribn az eh zoln zayn mit undz in eyn vagon." 
        intervals [297]:
            xmin = 895.072 
            xmax = 895.163 
            text = "" 
        intervals [298]:
            xmin = 895.163 
            xmax = 901.805 
            text = "hot er gezogt, fun vu veystu? zog ikh, ikh hob gedenkt ven m'hot gemakht dem eh dem tsamshraybung." 
        intervals [299]:
            xmin = 901.805 
            xmax = 903.364 
            text = "" 
        intervals [300]:
            xmin = 903.364 
            xmax = 906.617 
            text = "er hot azoy geton. er hot es ales gekukt." 
        intervals [301]:
            xmin = 906.617 
            xmax = 912.566 
            text = "di kinder zenen ongekumen tsu mir. ikh hob mikh oysgedreyt un ikh hob im gezogt a dank vos er hot es geton." 
        intervals [302]:
            xmin = 912.566 
            xmax = 917.347 
            text = "nor er hot lang nisht shpekulirt, er hot genumen a shtekn a groysn, un hot mir gegebn a hak ibern kop." 
        intervals [303]:
            xmin = 917.347 
            xmax = 918.13 
            text = "" 
        intervals [304]:
            xmin = 918.13 
            xmax = 921.364 
            text = "nu der shtekn hot zikh tsebrokhn oyf etlekhe shtiker." 
        intervals [305]:
            xmin = 921.364 
            xmax = 922.23 
            text = "" 
        intervals [306]:
            xmin = 922.23 
            xmax = 927.084 
            text = "nor dos iz geven az di kinder zenen geven, di kleynvarg iz geven mit undz tsuzamen." 
        intervals [307]:
            xmin = 927.084 
            xmax = 927.63 
            text = "" 
        intervals [308]:
            xmin = 927.63 
            xmax = 929.683 
            text = "un dos iz geven biz Oyshvits." 
        intervals [309]:
            xmin = 929.683 
            xmax = 929.757 
            text = "" 
        intervals [310]:
            xmin = 929.757 
            xmax = 936.281 
            text = "Oyshvits ze'mir aropgekumen, hot men gezogt, di mener ekster, do froyen ekster mit di kinder." 
        intervals [311]:
            xmin = 936.281 
            xmax = 937.367 
            text = "" 
        intervals [312]:
            xmin = 937.367 
            xmax = 944.325 
            text = "hot men ongehoybn dort tsu leygn, rekhts, tsu shrayen, hot Mengele dort geshtanen, ikh veys, daytshn zenen zey dort shoyn geven, hobn zey ongehoybn" 
        intervals [313]:
            xmin = 944.325 
            xmax = 950.642 
            text = "di froyen oyf eh links, mit di kinder, un di mener oyf rekhts." 
        intervals [314]:
            xmin = 950.642 
            xmax = 950.867 
            text = "" 
        intervals [315]:
            xmin = 950.867 
            xmax = 959.568 
            text = "un nokh dem hobn zey ongehoybn tsu nemen fun der oyf der arbet. ikh bin geshtanen mit mayn mame mit di fir kleyne kinder. der klenster iz alt geven tsvey a halb yor." 
        intervals [316]:
            xmin = 959.568 
            xmax = 959.794 
            text = "" 
        intervals [317]:
            xmin = 959.794 
            xmax = 961.931 
            text = "un ikh bin alt geven fertsn yor." 
        intervals [318]:
            xmin = 961.931 
            xmax = 962.73 
            text = "" 
        intervals [319]:
            xmin = 962.73 
            xmax = 968.985 
            text = "un mikh hot men genumen oyf arbet, un zey hot men genumen in krematoryum. nor ikh hob nisht gevust derfun." 
        intervals [320]:
            xmin = 968.985 
            xmax = 970.425 
            text = "" 
        intervals [321]:
            xmin = 970.425 
            xmax = 976.438 
            text = "un mayn mame hot gekent gut sh- eh daytsh redn, hot zi geshrign, dos iz mayn tokhter." 
        intervals [322]:
            xmin = 976.438 
            xmax = 981.236 
            text = "az m'zol mikh nisht aveknemen. zi hot dikh nisht gevust az m'firt zey in krematoryum." 
        intervals [323]:
            xmin = 981.236 
            xmax = 982.356 
            text = "" 
        intervals [324]:
            xmin = 982.356 
            xmax = 985.944 
            text = "oder keyner hot nisht gefolgt. zey zenen avek," 
        intervals [325]:
            xmin = 985.944 
            xmax = 986.203 
            text = "" 
        intervals [326]:
            xmin = 986.203 
            xmax = 992.238 
            text = "un nokh dem iz shoyn gekumen bakonte, heymishe rakhover mentshn, vu ze'mir geven in eyn blok." 
        intervals [327]:
            xmin = 992.238 
            xmax = 992.7 
            text = "" 
        intervals [328]:
            xmin = 992.7 
            xmax = 995.934 
            text = "hitster in Oyshvits iz geven shtark shver." 
        intervals [329]:
            xmin = 995.934 
            xmax = 996.852 
            text = "" 
        intervals [330]:
            xmin = 996.852 
            xmax = 1001.638 
            text = "m'hot undz tsam geyogt zekhtsn akhtsn ire oyf eyn pritsh. ir veyst vos heyst a pritsh?" 
