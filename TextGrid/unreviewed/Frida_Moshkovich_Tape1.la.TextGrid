            xmin = 1345.482 
            xmax = 1346.13 
            text = "" 
        intervals [442]:
            xmin = 1346.13 
            xmax = 1352.328 
            text = "ales iz geven zeyer in a shtark a groyser fabrik. un kalt. un hungerik." 
        intervals [443]:
            xmin = 1352.328 
            xmax = 1358.606 
            text = "bay der nakht ver s'hot gearbet bay der nakht in Gaystlingen, hot er bakumen fun der kantin a bisl esn." 
