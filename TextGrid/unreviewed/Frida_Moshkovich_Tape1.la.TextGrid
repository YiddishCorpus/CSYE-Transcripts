            xmin = 1005.35 
            xmax = 1005.39 
            text = "" 
        intervals [334]:
            xmin = 1005.39 
            xmax = 1008.93 
            text = "m'hot geshlogn, m'hot geharget, m'hot keyn esn nisht gegebn." 
        intervals [335]:
            xmin = 1008.93 
            xmax = 1013.349 
            text = "s'hot zikh dort opgetun khoyshekh. gearbet hob ikh nisht in Oyshvits," 
