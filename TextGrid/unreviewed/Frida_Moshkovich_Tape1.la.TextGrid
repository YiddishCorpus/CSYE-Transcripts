            text = "m'hot tsugenumen fun undz ales, m'hot undz opgeshert di hor," 
        intervals [357]:
            xmin = 1072.664 
            xmax = 1072.873 
            text = "" 
        intervals [358]:
            xmin = 1072.873 
            xmax = 1078.25 
            text = "ze'mir gevorn nay- m'hot undz gegebn groye kleydlekh, un mer gornisht." 
