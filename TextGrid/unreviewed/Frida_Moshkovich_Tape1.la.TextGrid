        intervals [372]:
            xmin = 1115.736 
            xmax = 1126.389 
            text = "undz ho'mir gevust az dos iz Mengele, far dem vayl yeder hot gezogt in blok az dos iz der Me- der heyst Mengele." 
        intervals [373]:
            xmin = 1126.389 
            xmax = 1135.257 
            text = "un der kl- eh nemt alts, zogt, er kloybt iber di mentshn velkhe in krematoryum un velkhe nisht in krematoryum. azoy az undz ho'mir far im zeyer moyre gehat." 
        intervals [374]:
            xmin = 1135.257 
            xmax = 1142.48 
            text = "er hot eybik gehat a shtekele in di hent, un er hot alts di mentshn oysgekloybn in krematoryum." 
        intervals [375]:
            xmin = 1142.48 
            xmax = 1147.894 
            text = "azoy lang biz ze'mir nisht gegangen oyf, m'hot undz nisht avekgefirt oyf Daytshland oyf arbet." 
        intervals [376]:
            xmin = 1147.894 
            xmax = 1147.967 
            text = "" 
        intervals [377]:
            xmin = 1147.967 
            xmax = 1155.42 
            text = "ikh bin geven in Oyshvits in blok fertsn. A. blok blok fertsn." 
        intervals [378]:
            xmin = 1155.42 
            xmax = 1159.071 
            text = "" 
        intervals [379]:
            xmin = 1159.071 
            xmax = 1162.71 
            text = "Mengele hot oysgezen a hoykher mentsh, a bruneter." 
        intervals [380]:
            xmin = 1162.71 
            xmax = 1164.792 
            text = "" 
        intervals [381]:
            xmin = 1164.792 
            xmax = 1171.687 
            text = "azoy eh in ponem hob ikh im nisht zeyer gezen, vayl er iz eybik gegangen mitn mitn dashik arop." 
        intervals [382]:
            xmin = 1171.687 
            xmax = 1172.942 
            text = "" 
        intervals [383]:
            xmin = 1172.942 
            xmax = 1177.908 
            text = "ober azoy iz er geven shtark, er hot mit undz nisht geredt. keyn mol nisht." 
        intervals [384]:
            xmin = 1177.908 
            xmax = 1182.555 
            text = "nor di rekhts, links. do aher, do ahin. do aher, do ahin." 
        intervals [385]:
            xmin = 1182.555 
            xmax = 1183.962 
            text = "" 
        intervals [386]:
            xmin = 1183.962 
            xmax = 1189.052 
            text = "deys iz geven yede vokh naketerheyt ze'mir umgegangen azoy vi di shof." 
        intervals [387]:
            xmin = 1189.052 
            xmax = 1190.56 
            text = "" 
        intervals [388]:
            xmin = 1190.56 
            xmax = 1195.245 
            text = "s'geven shreklekh a kuk tsu gebn vi azoy undz ho'mir oysgezen. naket, opgeshoyrn," 
        intervals [389]:
            xmin = 1195.245 
            xmax = 1195.825 
            text = "" 
        intervals [390]:
            xmin = 1195.825 
            xmax = 1200.038 
            text = "nu, dey moment ze'mir gegangen naket ven Mengele hot undz alts gekukt." 
        intervals [391]:
            xmin = 1200.038 
            xmax = 1203.064 
            text = "" 
        intervals [392]:
            xmin = 1203.064 
            xmax = 1203.969 
            text = "NIET." 
        intervals [393]:
            xmin = 1203.969 
            xmax = 1206.372 
            text = "" 
        intervals [394]:
            xmin = 1206.372 
            xmax = 1209.268 
            text = "undz ho'mir gegesn dort, m'hot undz ongeshit esn." 
        intervals [395]:
            xmin = 1209.268 
            xmax = 1209.51 
            text = "" 
        intervals [396]:
            xmin = 1209.51 
            xmax = 1213.031 
            text = "in droysn hot zikh dort arum gevalgert a top a shmutsiker." 
        intervals [397]:
            xmin = 1213.031 
            xmax = 1213.071 
            text = "" 
        intervals [398]:
            xmin = 1213.071 
            xmax = 1219.342 
            text = "in dem hot men arayn geshit a bisl esn, vi azoy ze'mir geshtanen finef in a reye, azoy tsu biselekh hot yeder genumen." 
        intervals [399]:
            xmin = 1219.342 
            xmax = 1219.534 
            text = "" 
        intervals [400]:
            xmin = 1219.534 
            xmax = 1221.823 
            text = "un m'hot undz gegebn a bisele esn azoy." 
        intervals [401]:
            xmin = 1221.823 
            xmax = 1221.88 
            text = "" 
        intervals [402]:
            xmin = 1221.88 
            xmax = 1225.823 
            text = "koydem ho'mir iber hoypt nisht gekent. s'hot gekritst unter di tseyn di blote." 
        intervals [403]:
            xmin = 1225.823 
            xmax = 1226.655 
            text = "" 
        intervals [404]:
            xmin = 1226.655 
            xmax = 1231.829 
            text = "un m'hot opgegesn hot men aropgevorfn tsurik dem top. oyfn zamd." 
        intervals [405]:
            xmin = 1231.829 
            xmax = 1231.87 
            text = "" 
        intervals [406]:
            xmin = 1231.87 
            xmax = 1235.222 
            text = "un morgn hot men undz vayter gegebn in dem shmutsikn top." 
