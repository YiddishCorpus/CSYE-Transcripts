            text = "" 
        intervals [420]:
            xmin = 1264.995 
            xmax = 1270.524 
            text = "in Oyshvits ze'mir geven ergets zeks vokhn oder tsvey khadoshim, ikh gedenk nisht pinktlekh." 
        intervals [421]:
            xmin = 1270.524 
            xmax = 1271.897 
            text = "" 
        intervals [422]:
            xmin = 1271.897 
            xmax = 1278.405 
            text = "nu nokh dem ongekumen oyf Gaystlingen. m'hot undz avekgefirt in la- eh Gaystlingen, oyf Daytshland." 
        intervals [423]:
            xmin = 1278.405 
            xmax = 1278.799 
            text = "" 
        intervals [424]:
            xmin = 1278.799 
            xmax = 1282.927 
            text = "dortn ze'mir undz shoyn ze'mir geven akht hundert froyen, in a kleyner lager." 
        intervals [425]:
            xmin = 1282.927 
            xmax = 1284.216 
            text = "" 
        intervals [426]:
            xmin = 1284.216 
            xmax = 1286.859 
            text = "dort iz undz shoyn gringer a bisl." 
        intervals [427]:
            xmin = 1286.859 
            xmax = 1288.35 
            text = "" 
        intervals [428]:
            xmin = 1288.35 
            xmax = 1292.647 
            text = "undz hot men shoyn gegebn a bet. m'hot shoyn gegebn a teler." 
        intervals [429]:
            xmin = 1292.647 
            xmax = 1292.738 
            text = "" 
        intervals [430]:
            xmin = 1292.738 
            xmax = 1297.333 
            text = "m'hot shoyn gegebn a lefl. un m'hot zikh shoyn gekent opvashn." 
        intervals [431]:
            xmin = 1297.333 
            xmax = 1305.337 
            text = "un ho'mir shoyn bakumen kleyder. eh vi eh vi der nu di heftling kleyder, UNK." 
