        intervals [474]:
            xmin = 1402.408 
            xmax = 1404.514 
            text = "m'hot undz avekgeshtelt dortn eh" 
        intervals [475]:
            xmin = 1404.514 
            xmax = 1411.97 
            text = "m'iz geshtanen. iz ongekumen shiflekh kleyne un avekgeforn. ikh hob gevolt forn in a groyse shif Kaprakone, YOU KNOW, iz geven di greste shif in Hamburg." 
        intervals [476]:
            xmin = 1411.97 
            xmax = 1412.55 
            text = "" 
        intervals [477]:
            xmin = 1412.55 
            xmax = 1415.357 
            text = "m'nemt undz oyf di shif un di S.S.," 
