            text = "" 
        intervals [465]:
            xmin = 1374.97 
            xmax = 1384.042 
            text = "az m'hert aza NEWS, di S.S. iz gegangen frier oys, undz zenen gegangen vi di shepsn nokhgegangen. m'hot gekont antloyfn, eh ver s'hot ge- ver vet loyfn az m'fort in Roytn Kreyts?" 
