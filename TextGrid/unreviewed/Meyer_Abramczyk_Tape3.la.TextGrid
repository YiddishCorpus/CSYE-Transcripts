        intervals [526]:
            xmin = 1527.385 
            xmax = 1535.513 
            text = "un di zayt vu ikh hob geshtanen, hob ikh gekukt, spn aruntergefaln, avekgekumen. nokh eyner arunter. ikh bin geblibn eyner, ikh mit nokh eyner iz men geblibn oyf di ankers." 
