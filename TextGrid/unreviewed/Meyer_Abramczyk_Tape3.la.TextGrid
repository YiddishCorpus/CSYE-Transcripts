            text = "Kaprakone." 
        intervals [479]:
            xmin = 1416.527 
            xmax = 1417.309 
            text = "" 
        intervals [480]:
            xmin = 1417.309 
            xmax = 1423.226 
            text = "un m'nemt undz oyf di shif in di shif, si S.S. zogt oyvn, az di lager firer iz nishto nemt men enk nisht on." 
