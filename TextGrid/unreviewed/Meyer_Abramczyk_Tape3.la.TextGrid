            text = "" 
        intervals [121]:
            xmin = 354.353 
            xmax = 361.569 
            text = "m'hot undz geshlogn, ge- s'gekumen zuntik, er hot gehat a a onsharfirer, Muler hot er geheysn, mit a hunt, er iz geshtanen in der zayt." 
