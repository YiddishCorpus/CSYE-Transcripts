            text = "" 
        intervals [62]:
            xmin = 195.424 
            xmax = 198.759 
            text = "m'iz gekumen nokh keyn Fistngrube iz geshtanen," 
        intervals [63]:
            xmin = 198.759 
            xmax = 198.833 
            text = "" 
        intervals [64]:
            xmin = 198.833 
            xmax = 202.421 
            text = "ikh zog nisht keyn lign, nisht vayl, s'geven a guter lager." 
        intervals [65]:
            xmin = 202.421 
