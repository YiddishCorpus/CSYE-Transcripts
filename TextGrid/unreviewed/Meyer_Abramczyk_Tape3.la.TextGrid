            xmax = 1492.622 
            text = "" 
        intervals [512]:
            xmin = 1492.622 
            xmax = 1499.855 
            text = "yidn, ale zenen geven dortn. ale farbrent gevorn, dershtikt gevorn. geven vos a por toyznt geven dortn eh, epes geratevet dray yidn oder LESS." 
        intervals [513]:
