            text = "" 
        intervals [66]:
            xmin = 202.933 
            xmax = 208.546 
            text = "iz geshtanen opgekokht efsher finef kesl kartofl mit di sholn, veystu shoyn, kesl." 
        intervals [67]:
            xmin = 208.546 
            xmax = 209.38 
            text = "" 
        intervals [68]:
            xmin = 209.38 
            xmax = 212.11 
            text = "un m'iz tsugegangen tsu der kesl un yeder hot gekhapt" 
        intervals [69]:
            xmin = 212.11 
            xmax = 215.516 
            text = "vifl er hot gekont hot er gegesn di kartofl, YOU KNOW, s'geven a sakh kartofl gekokht." 
        intervals [70]:
            xmin = 215.516 
            xmax = 215.826 
            text = "" 
        intervals [71]:
            xmin = 215.826 
            xmax = 221.557 
            text = "OK, m'hot derkhapt, opgegesn, hot es geheysn ales arayn in di in di barakn, s'geven barakn." 
        intervals [72]:
            xmin = 221.557 
            xmax = 222.188 
            text = "" 
        intervals [73]:
            xmin = 222.188 
            xmax = 225.793 
            text = "un m'iz arayngekumen hot, DOESN'T MATTER vu eyner iz gegangen, m'iz arayn." 
        intervals [74]:
