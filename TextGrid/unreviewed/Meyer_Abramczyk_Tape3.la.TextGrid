        intervals [115]:
            xmin = 336.229 
            xmax = 344.103 
            text = "iz gekumen fun di JAILS, di rikhtike farbrekher. yeder eyner hot gehat iber zeks fus, GERMAN, daytshn, vos zenen gezitsn in JAIL." 
        intervals [116]:
