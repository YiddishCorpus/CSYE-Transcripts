            text = "fizish yo, mit a shoyvl. YOU KNOW, di a shoyvl, zamd." 
        intervals [5]:
            xmin = 27.748 
            xmax = 29.779 
            text = "" 
        intervals [6]:
            xmin = 29.779 
            xmax = 39.037 
            text = "o ikh bin a po- ikh bin a poylisher, ikh hob gekont arbetn, ikh hob gearbet in Poyln un in der heym un oyfn dorf, veyst nisht, ikh hob gehat land eh ikh hob nokh yungerheyt gearbet. geshpilt a role?" 
        intervals [7]:
            xmin = 39.037 
            xmax = 42.115 
            text = "" 
        intervals [8]:
            xmin = 42.115 
            xmax = 43.138 
            text = "o yo." 
        intervals [9]:
            xmin = 43.138 
            xmax = 46.671 
            text = "" 
        intervals [10]:
            xmin = 46.671 
            xmax = 49.533 
            text = "o ikh nisht, s'geven raykhe mentshn, oreme mentshn." 
        intervals [11]:
            xmin = 49.533 
            xmax = 50.232 
            text = "" 
        intervals [12]:
            xmin = 50.232 
            xmax = 55.102 
            text = "o yo, iz s'gevezn PLACES spn, s'geven hayzer," 
