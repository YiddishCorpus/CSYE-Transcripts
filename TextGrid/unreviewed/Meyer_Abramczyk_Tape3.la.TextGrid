            xmin = 1384.042 
            xmax = 1384.673 
            text = "" 
        intervals [467]:
            xmin = 1384.673 
            xmax = 1391.214 
            text = "un goyim m'iz gegangen tsu der arbet in der fri finef a zeyger, ikh veys fir a zeyger, hot men gefregt, s'do a port? yo, s'iz a groyse shif." 
        intervals [468]:
