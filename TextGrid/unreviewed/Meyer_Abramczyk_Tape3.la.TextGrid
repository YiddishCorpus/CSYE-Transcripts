            text = "" 
        intervals [55]:
            xmin = 181.367 
            xmax = 184.601 
            text = "iz gekumen TRUCKS, iz geshtanen far der far der toyer TRUCKS," 
        intervals [56]:
            xmin = 184.601 
            xmax = 184.725 
            text = "" 
        intervals [57]:
            xmin = 184.725 
            xmax = 187.042 
            text = "un m'hot undz oyfgelodnt, m'iz opgeforn eh" 
        intervals [58]:
            xmin = 187.042 
            xmax = 192.11 
            text = "a halbe shtune, a shtunde. Oyshvits un undzer lager iz nisht vayt, tsvontsik kilometer, YOU KNOW." 
        intervals [59]:
