            xmin = 55.102 
            xmax = 55.615 
            text = "" 
        intervals [14]:
            xmin = 55.615 
            xmax = 63.608 
            text = "polyakn, mentshn arbayters, s'gevezn nayn a zeyger iz gevezn a HALF a shtunde BREAKFAST, eh YOU KNOW, epes tsu esn." 
        intervals [15]:
            xmin = 63.608 
            xmax = 63.799 
            text = "" 
        intervals [16]:
            xmin = 63.799 
            xmax = 72.45 
            text = "iz men gelofn BETWEEN di hayzer tsu di polyakn. eyner hot gegebn a shtikl broyt, eyner hot azoy eh gornisht gegebn, azoy ale tog gevezn, dos heyst m'hot gefekhtet." 
        intervals [17]:
            xmin = 72.45 
            xmax = 72.658 
            text = "" 
        intervals [18]:
            xmin = 72.658 
            xmax = 77.276 
            text = "gelofn tsu di mentshn zoln gebn epes tsu esn. zey hobn gegebn. yo." 
        intervals [19]:
            xmin = 77.276 
            xmax = 79.881 
            text = "" 
        intervals [20]:
            xmin = 79.881 
            xmax = 81.731 
            text = "iz men gekumen keyn Gutnbrum." 
        intervals [21]:
            xmin = 81.731 
            xmax = 83.728 
            text = "" 
        intervals [22]:
            xmin = 83.728 
            xmax = 90 
            text = "eh dortn hot men gekrign a teler z- a teler zup, mit a UNK broyt," 
        intervals [23]:
            xmin = 90 
            xmax = 90.445 
            text = "" 
        intervals [24]:
            xmin = 90.445 
            xmax = 96.531 
            text = "un a kave, dos iz gevezn fir un tsvontsik shtundes. host yetst gekrign, host oyfgegesn, un in fir un shtunde vider gehat di SAME." 
        intervals [25]:
            xmin = 96.531 
            xmax = 96.655 
            text = "" 
        intervals [26]:
            xmin = 96.655 
            xmax = 102.049 
            text = "nor vos s'iz, m'hot zikh geholfn. eyner hot gekhapt an epl, eyner, fun di vagener, s'gekumen di TRAINS," 
        intervals [27]:
            xmin = 102.049 
            xmax = 102.139 
            text = "" 
        intervals [28]:
            xmin = 102.139 
            xmax = 107.325 
            text = "mit epl, mit POTATOES, m'hot aynge- iz geven oyvenes in di in Gutnbrum, m'hot eh" 
        intervals [29]:
            xmin = 107.325 
            xmax = 110.976 
            text = "genumen a meser, gegebn a shnayd do a SLICE, un gegebn a kleb tsu tsum oyvn," 
        intervals [30]:
            xmin = 110.976 
            xmax = 111.015 
            text = "" 
        intervals [31]:
            xmin = 111.015 
            xmax = 116.847 
            text = "iz geven a SECOND s'gevorn shvarts un m'hot gegesn royerheyt, nisht royerheyt, m'hot gegesn ales, vos s'iz geven hot men gegesn. bern," 
        intervals [32]:
            xmin = 116.847 
            xmax = 117.107 
            text = "" 
        intervals [33]:
            xmin = 117.107 
            xmax = 122.113 
            text = "vos m'hot gekont ganvenen hot men geganvet. azoy az eyner hot gekont oyshaltn eyner nisht." 
        intervals [34]:
            xmin = 122.113 
            xmax = 124.178 
            text = "" 
        intervals [35]:
            xmin = 124.178 
            xmax = 128.137 
            text = "NEVER. ikh bin bin NEVER nisht geven krank." 
        intervals [36]:
            xmin = 128.137 
            xmax = 135.096 
            text = "" 
        intervals [37]:
            xmin = 135.096 
            xmax = 141.924 
            text = "s'iz s'gekumen keyn Oyshvits iz men gekumen nayntsn dray un fertsik, ende eyn un in JULY in JUNE, ikh veys nisht genoy." 
        intervals [38]:
            xmin = 141.924 
            xmax = 142.116 
            text = "" 
        intervals [39]:
            xmin = 142.116 
            xmax = 143.645 
            text = "far vinter veys ikh." 
        intervals [40]:
            xmin = 143.645 
            xmax = 144.327 
            text = "" 
        intervals [41]:
            xmin = 144.327 
            xmax = 151.442 
            text = "un men iz geven dortn dray fir vokhn, oder finef vokhn, kon ikh nisht zogn genoy, vayl m'hot nisht gevust keyn tog, m'hot nisht gevust keyn vokhn. m'hot gevust m'zitst." 
        intervals [42]:
            xmin = 151.442 
            xmax = 151.6 
            text = "" 
        intervals [43]:
            xmin = 151.6 
            xmax = 157.618 
            text = "oyf eyn molt ongekumen di groyse boy-mentshn, groyse inzhenirn tsi vos," 
        intervals [44]:
            xmin = 157.618 
            xmax = 157.725 
            text = "" 
        intervals [45]:
            xmin = 157.725 
            xmax = 161.094 
            text = "zey hobn gebroykht finef hundert mentshn. dos veys ikh genoy." 
        intervals [46]:
            xmin = 161.094 
            xmax = 161.657 
            text = "" 
        intervals [47]:
            xmin = 161.657 
            xmax = 167.535 
            text = "m'hot nisht gezogt eh Abramtshik, tsi Yankel, Moyshe. m'hot gerufn hundert fertsik nayn un fertsik, dos bin ikh." 
        intervals [48]:
            xmin = 167.535 
            xmax = 168.404 
            text = "KOMME HIER." 
        intervals [49]:
            xmin = 168.404 
            xmax = 170.865 
            text = "tsugeshtanen, opgetseylt finef hundert mentshn," 
        intervals [50]:
            xmin = 170.865 
            xmax = 171.158 
            text = "" 
        intervals [51]:
            xmin = 171.158 
            xmax = 178.205 
            text = "iz adurkhgegangen a a COLLECTION, ikh veys nisht m'hot geCHECKED ober bist shtark ober bist bist konstu eh bistu." 
        intervals [52]:
            xmin = 178.205 
