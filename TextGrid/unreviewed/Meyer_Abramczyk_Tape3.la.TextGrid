        intervals [534]:
            xmin = 1551.533 
            xmax = 1559.132 
            text = "un do hot zikh di anker do nokhgelozt, ikh hob nisht ikh veys nisht vos iz geven, khvalyes tsi vos, hot mikh aroyfgevorfn azoy vi a barg, veystu di di" 
