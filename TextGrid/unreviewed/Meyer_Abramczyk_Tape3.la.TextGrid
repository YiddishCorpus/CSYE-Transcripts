            xmax = 1668.87 
            text = "iz men geshtanen bay a goye in a in a s- in a a a shtal. hintn iz geven beheymes un oyvn hot zi gehat shtroy, un m'hot geshtanen in di shtot, far a po- m- m'hot dokh," 
        intervals [576]:
