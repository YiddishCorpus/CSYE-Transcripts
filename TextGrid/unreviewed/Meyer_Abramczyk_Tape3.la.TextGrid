            text = "" 
        intervals [75]:
            xmin = 225.816 
            xmax = 231.48 
            text = "gehat a bet arayn dortn eh, m'iz arayn. dray mentshn eyns tsvey dray shtokedike bet, yeder hot gekhapt a bet, m'iz arayn." 
        intervals [76]:
            xmin = 231.48 
