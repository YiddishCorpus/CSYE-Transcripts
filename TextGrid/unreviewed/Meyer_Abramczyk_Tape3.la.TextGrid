            text = "" 
        intervals [516]:
            xmin = 1505.38 
            xmax = 1511.077 
            text = "hobn anker, geven dort di shpits iz gegangen in vaser, nor zey shteyen di ankers, azoy di ankers azoy mit azoyne keylim." 
        intervals [517]:
