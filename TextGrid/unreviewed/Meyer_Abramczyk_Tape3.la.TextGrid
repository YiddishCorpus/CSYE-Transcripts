            text = "" 
        intervals [524]:
            xmin = 1522.407 
            xmax = 1527.143 
            text = "un mit mir nokh geshtanen, fun di zayt geshtanen, ale f- ale ekn zenen geshtanen mentshn." 
        intervals [525]:
            xmin = 1527.143 
            xmax = 1527.385 
