            text = "" 
        intervals [319]:
            xmin = 765.394 
            xmax = 770.535 
            text = "zogt er, ""Pinek, kenst gornisht epes shafn dortn bay der arbet, epes trefn epes?"" zog ikh, ikh vel zen." 
