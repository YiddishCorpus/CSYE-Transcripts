            xmin = 58.797 
            xmax = 60.913 
            text = "" 
        intervals [21]:
            xmin = 60.913 
            xmax = 62.257 
            text = "zey hobn gekrign batsolt." 
        intervals [22]:
            xmin = 62.257 
            xmax = 62.584 
            text = "" 
        intervals [23]:
            xmin = 62.584 
            xmax = 64.636 
            text = "zey hobn gekrign batso- mir gornisht." 
        intervals [24]:
            xmin = 64.636 
            xmax = 69.148 
            text = "" 
        intervals [25]:
            xmin = 69.148 
            xmax = 72.686 
            text = "arum Starakhovitse. fun di shtot Starkhovits. ya." 
        intervals [26]:
            xmin = 72.686 
            xmax = 79.51 
            text = "" 
        intervals [27]:
            xmin = 79.51 
            xmax = 86.138 
            text = "di fabrik iz vayter ongegangen, di nor der lager iz gevorn likvidirt. der lager fun di yidn iz gevorn likvidirt." 
        intervals [28]:
            xmin = 86.138 
            xmax = 91.657 
            text = "un m'hot undz genumen, m'hot undz aroysgeshikt mit vagonen arayn keyn Oyshvits." 
        intervals [29]:
            xmin = 91.657 
            xmax = 93.87 
            text = "" 
        intervals [30]:
            xmin = 93.87 
            xmax = 96.344 
            text = "ikh gedenk dem tog m'iz ongekumen keyn Oyshvits." 
        intervals [31]:
            xmin = 96.344 
            xmax = 96.857 
            text = "" 
        intervals [32]:
            xmin = 96.857 
            xmax = 100.445 
            text = "un di date nisht, dos iz geven zumer, end oyf zumer," 
        intervals [33]:
            xmin = 100.445 
            xmax = 100.553 
            text = "" 
        intervals [34]:
            xmin = 100.553 
            xmax = 102.69 
            text = "un ikh bin ongekum- dos iz geven ende zumer." 
        intervals [35]:
            xmin = 102.69 
            xmax = 102.763 
            text = "" 
        intervals [36]:
            xmin = 102.763 
            xmax = 104.292 
            text = "september, oktober." 
        intervals [37]:
            xmin = 104.292 
            xmax = 105.16 
            text = "" 
        intervals [38]:
            xmin = 105.16 
            xmax = 107.871 
            text = "demolts bin ikh alt gevezn fuftsn yor." 
        intervals [39]:
            xmin = 107.871 
            xmax = 110.492 
            text = "" 
        intervals [40]:
            xmin = 110.492 
            xmax = 112.629 
            text = "un demolts ven ikh bin ongekumen" 
        intervals [41]:
            xmin = 112.629 
            xmax = 113.327 
            text = "" 
        intervals [42]:
            xmin = 113.327 
            xmax = 115.7 
            text = "hot mikh demolts bamerkt" 
        intervals [43]:
            xmin = 115.7 
            xmax = 116.078 
            text = "" 
        intervals [44]:
            xmin = 116.078 
            xmax = 122.4 
            text = "a mayns a shteterisher shtot, a shte- YOU KNOW, an Apter BOY vos hot gevoynt bay undz in hoyz," 
        intervals [45]:
            xmin = 122.4 
            xmax = 122.676 
            text = "" 
        intervals [46]:
            xmin = 122.676 
            xmax = 124.728 
            text = "Khaim Ernberg hot er geheysn." 
        intervals [47]:
            xmin = 124.728 
            xmax = 126.928 
            text = "" 
        intervals [48]:
            xmin = 126.928 
            xmax = 131.444 
            text = "zey hobn gehat in mark a sheyn gesheft, der foter. un ikh ken im, ales," 
        intervals [49]:
            xmin = 131.444 
            xmax = 132.953 
            text = "" 
        intervals [50]:
            xmin = 132.953 
            xmax = 135.259 
            text = "hot er mikh derkent, zogt er, Pinek," 
        intervals [51]:
            xmin = 135.259 
            xmax = 135.332 
            text = "" 
        intervals [52]:
            xmin = 135.332 
            xmax = 137.081 
            text = "mir dakht zikh, zogt er," 
        intervals [53]:
            xmin = 137.081 
            xmax = 138.032 
            text = "" 
        intervals [54]:
            xmin = 138.032 
            xmax = 143.46 
            text = "zolst gedenken vos ikh zog dir. ikh vil dir zogn dir, zolst dikh oyfgebn do elter." 
        intervals [55]:
            xmin = 143.46 
            xmax = 143.854 
            text = "" 
        intervals [56]:
            xmin = 143.854 
            xmax = 147.442 
            text = "du bist fuftsn yor alt, ikh gedenk dikh ven ikh fun der heym." 
        intervals [57]:
            xmin = 147.442 
            xmax = 148.427 
            text = "" 
        intervals [58]:
            xmin = 148.427 
            xmax = 150.193 
            text = "zog ikh, vos heyst ikh zol mikh oyfgebn?" 
        intervals [59]:
            xmin = 150.193 
            xmax = 150.52 
            text = "" 
        intervals [60]:
            xmin = 150.52 
            xmax = 156.622 
            text = "zolst dikh oyfgebn khotsh akhtsn, ikh vil dir nisht zogn zekhtsn, iz gib dikh oyf bist alt akhtsn yor, dray yor mer." 
        intervals [61]:
            xmin = 156.622 
            xmax = 156.983 
            text = "" 
        intervals [62]:
            xmin = 156.983 
            xmax = 158.765 
            text = "un du bist a MAHLER." 
        intervals [63]:
            xmin = 158.765 
            xmax = 159.008 
            text = "" 
        intervals [64]:
            xmin = 159.008 
            xmax = 160.706 
            text = "zolst zogn du host a baruf." 
        intervals [65]:
            xmin = 160.706 
            xmax = 160.898 
            text = "" 
        intervals [66]:
            xmin = 160.898 
            xmax = 163.642 
            text = "du host gearbet in der heym bay dayn tatn MAHLER." 
        intervals [67]:
            xmin = 163.642 
            xmax = 163.665 
            text = "" 
        intervals [68]:
            xmin = 163.665 
            xmax = 166.257 
            text = "dayn tate iz geven a MALARZ, du bist a MALARZ." 
        intervals [69]:
            xmin = 166.257 
            xmax = 167.31 
            text = "" 
        intervals [70]:
            xmin = 167.31 
            xmax = 170.78 
            text = "di verter zolstu redn. zog ikh, Khaim, gib mir a shtikl broyt, ikh gey shtarbn." 
        intervals [71]:
            xmin = 170.78 
            xmax = 171.495 
            text = "" 
        intervals [72]:
            xmin = 171.495 
            xmax = 174.324 
            text = "zogt er, vest krign a gants broyt, oyb du vest dos zogn." 
        intervals [73]:
            xmin = 174.324 
            xmax = 175.039 
            text = "" 
        intervals [74]:
            xmin = 175.039 
            xmax = 179.811 
            text = "ven m'hot gemakht rekhts un links, Monge- Mengele, ven ikh bin arayngekumen keyn Oyshvits," 
        intervals [75]:
            xmin = 179.811 
            xmax = 184.022 
            text = "hot er mir derlangt a shos, er hot gevorfn di bombe, aza baytsh," 
        intervals [76]:
            xmin = 184.022 
            xmax = 187.843 
            text = "un do iz arayn di bombe, oyfgehakt mir dos dos oyg, do lebn oyg," 
        intervals [77]:
            xmin = 187.843 
            xmax = 188.515 
            text = "he?" 
        intervals [78]:
            xmin = 188.515 
            xmax = 189.045 
            text = "" 
        intervals [79]:
            xmin = 189.045 
            xmax = 189.882 
            text = "ya." 
        intervals [80]:
            xmin = 189.882 
            xmax = 190.26 
            text = "" 
        intervals [81]:
            xmin = 190.26 
            xmax = 191.452 
            text = "Mengele," 
        intervals [82]:
            xmin = 191.452 
            xmax = 192.488 
            text = "" 
        intervals [83]:
            xmin = 192.488 
            xmax = 195.919 
            text = "ikh hob nisht gevust vi m'ruft im demolts. demolts hob ikh gezen er iz a daytsh." 
        intervals [84]:
            xmin = 195.919 
            xmax = 200.109 
            text = "un er shrayt, un m'firt op, un er shrayt oyf di mentshn un zidlt." 
        intervals [85]:
            xmin = 200.109 
            xmax = 200.183 
            text = "" 
        intervals [86]:
            xmin = 200.183 
            xmax = 202.016 
            text = """VERFLUCHTE HUNDE!""" 
        intervals [87]:
            xmin = 202.016 
            xmax = 202.748 
            text = "" 
        intervals [88]:
            xmin = 202.748 
            xmax = 211.5 
            text = "un er hot ge- un un un er hot gevorfn a bombe, un di bombe iz mir do arayn, do do in der rekhter zayt in rekhtn oyg, un s'hot do ongehoybn tsu blutikn, un s'gist zikh di blut," 
        intervals [89]:
            xmin = 211.5 
            xmax = 211.54 
            text = "" 
        intervals [90]:
            xmin = 211.54 
            xmax = 213.508 
            text = "hob ikh aropgenumen dos hitl un ikh hob tsugeleygt," 
        intervals [91]:
            xmin = 213.508 
            xmax = 213.868 
            text = "" 
        intervals [92]:
            xmin = 213.868 
            xmax = 219.434 
            text = "nu vos eh ikh hob nisht gehat. vos hob ikh gehat? eh ikh hob nisht gehat keyn tashntikhl, ikh hob nisht gehat keyn NAPKINS, ikh hob nisht gehat keyn layb keyn lebn," 
        intervals [93]:
            xmin = 219.434 
            xmax = 220.646 
            text = "hob ikh tsugeleygt." 
        intervals [94]:
            xmin = 220.646 
            xmax = 221.293 
            text = "" 
        intervals [95]:
            xmin = 221.293 
            xmax = 223.379 
            text = "hot men undz avekgeshtelt tsvishn yungvarg." 
        intervals [96]:
            xmin = 223.379 
            xmax = 223.605 
            text = "" 
        intervals [97]:
            xmin = 223.605 
            xmax = 226.754 
            text = "un m'hot undz avekgenumen undz yungvarg hot men undz avekgenumen in der zayt," 
        intervals [98]:
            xmin = 226.754 
            xmax = 228.837 
            text = "" 
        intervals [99]:
            xmin = 228.837 
            xmax = 233.289 
            text = "un der hot mikh bamerkt, Khaim Ernberg, dortn, hot er gevust az s'vart oyf mir" 
        intervals [100]:
            xmin = 233.289 
            xmax = 234.872 
            text = "zeyer a toyte zakh." 
        intervals [101]:
            xmin = 234.872 
            xmax = 235.198 
            text = "" 
        intervals [102]:
            xmin = 235.198 
            xmax = 237.093 
            text = "er hot shoyn gevust vos vart oyf mir." 
        intervals [103]:
            xmin = 237.093 
            xmax = 239.951 
            text = "zogt er, Pinekl, gib dikh oyf elter!" 
        intervals [104]:
            xmin = 239.951 
            xmax = 240.345 
            text = "" 
        intervals [105]:
            xmin = 240.345 
            xmax = 242.296 
            text = "un gib dikh oyf dray yor elter." 
        intervals [106]:
            xmin = 242.296 
            xmax = 242.573 
            text = "" 
        intervals [107]:
            xmin = 242.573 
            xmax = 245.149 
            text = "vestu kumen arbetn, zogt er, vu ikh arbet." 
        intervals [108]:
            xmin = 245.149 
            xmax = 246.471 
            text = "" 
        intervals [109]:
            xmin = 246.471 
            xmax = 250.121 
            text = "zogt er, vos zol ikh tun? zogt er, zest der S.S. man vos er dreyt zikh arum mit di shtekn?" 
        intervals [110]:
            xmin = 250.121 
            xmax = 258.665 
            text = "iz geven azelkhe yingere, eltere, hot er gehakt do iber di kep. ver s'hot geredt a vort, hot geshrign, esn, broyt, vaser, hot er gegebn a zets mit der shtekn ibern kop." 
        intervals [111]:
            xmin = 258.665 
            xmax = 258.755 
            text = "" 
        intervals [112]:
            xmin = 258.755 
            xmax = 261.061 
            text = "hot men geshvign. hot er ayngeshleft." 
        intervals [113]:
            xmin = 261.061 
            xmax = 261.523 
            text = "" 
        intervals [114]:
            xmin = 261.523 
            xmax = 263.199 
            text = "zogt er, er shlogt dokh." 
        intervals [115]:
            xmin = 263.199 
            xmax = 267.925 
            text = "zog zog du vest farlangen, vest dikh oyfshteln dikh, un vest zikh gebn a shtel oyf, vest zogn, ""ikh UNK WILL WAS" 
        intervals [116]:
            xmin = 267.925 
            xmax = 269.418 
            text = "SPRECHEN tsu dir,""" 
        intervals [117]:
            xmin = 269.418 
            xmax = 270.646 
            text = "vet er mit dir redn." 
        intervals [118]:
            xmin = 270.646 
            xmax = 271.193 
            text = "" 
        intervals [119]:
            xmin = 271.193 
            xmax = 274.528 
            text = "tomer vestu shrayen broyt, vaser, vet er dir oykh gebn a zets ibern kop." 
        intervals [120]:
            xmin = 274.528 
            xmax = 274.922 
            text = "" 
        intervals [121]:
            xmin = 274.922 
            xmax = 279.556 
            text = "du geyst dokh nisht redn keyn broyt. tsu mir redstu broyt. un ikh vel dir gebn broyt nor az du vestu dos zogn." 
        intervals [122]:
            xmin = 279.556 
            xmax = 280.66 
            text = "" 
        intervals [123]:
            xmin = 280.66 
            xmax = 286.898 
            text = "er hot zikh dernentert, hob ikh mikh gegebn a shtel oyf, zog ikh, her shturmbanfirer, zog ikh, ken ikh SPRECHEN, ken ikh VERSPREKHEN tsu du IHNEN?" 
        intervals [124]:
            xmin = 286.898 
            xmax = 287.055 
            text = "" 
        intervals [125]:
            xmin = 287.055 
            xmax = 288.584 
            text = "zogt er, WAS WOLLstu DEN?" 
        intervals [126]:
            xmin = 288.584 
            xmax = 288.844 
            text = "" 
        intervals [127]:
            xmin = 288.844 
            xmax = 291.639 
            text = "zog ikh, zey HABEN dokh eyn IRRTUM mit mir." 
        intervals [128]:
            xmin = 291.639 
            xmax = 292.523 
            text = "" 
        intervals [129]:
            xmin = 292.523 
            xmax = 296.516 
            text = "ICH BIN DOCH ACHTZEHN JAHRE ALT, WIESO KOMME ICH DEN HIER REIN?" 
        intervals [130]:
            xmin = 296.516 
            xmax = 296.843 
            text = "" 
        intervals [131]:
            xmin = 296.843 
            xmax = 299.25 
            text = "ICH HABE EIN BERUF. ICH BIN EIN MALER." 
        intervals [132]:
            xmin = 299.25 
            xmax = 300.42 
            text = "" 
        intervals [133]:
            xmin = 300.42 
            xmax = 302.152 
            text = "BITTE, MACHEN SIE UNK." 
        intervals [134]:
            xmin = 302.152 
            xmax = 302.513 
            text = "" 
        intervals [135]:
            xmin = 302.513 
            xmax = 307.637 
            text = "zogt er, ven hostu den GEARBEIT? ICH HABE GEARBEIT bay mir far der MALER. vi lang? ZWEI JAHRE." 
        intervals [136]:
            xmin = 307.637 
            xmax = 311.018 
            text = "" 
        intervals [137]:
            xmin = 311.018 
            xmax = 315.619 
            text = "shteyt un trakht un trakht un trakht un kukt mikh op un trakht. zogt er, OK, KOMME mit mir." 
        intervals [138]:
            xmin = 315.619 
            xmax = 316.35 
            text = "" 
        intervals [139]:
            xmin = 316.35 
            xmax = 321.105 
            text = "un nemt mit mikh un firt mikh aroys fun dem lager un firt mikh arayn in tsveytn lager in byuro," 
        intervals [140]:
            xmin = 321.105 
            xmax = 325.85 
            text = "shrayb im ayn tsu di tsu di UNK, tsu di tsu di a GIRL iz geshtanen." 
        intervals [141]:
            xmin = 325.85 
            xmax = 325.895 
            text = "" 
        intervals [142]:
            xmin = 325.895 
            xmax = 330.505 
            text = "shrayb im ayn tsu di do tsu di tsu di MALER KOMPANIE." 
        intervals [143]:
            xmin = 330.505 
            xmax = 331.572 
            text = "" 
        intervals [144]:
            xmin = 331.572 
            xmax = 333.608 
            text = "un shraybt mikh ayn als MALER," 
        intervals [145]:
            xmin = 333.608 
            xmax = 334.66 
            text = "" 
        intervals [146]:
            xmin = 334.66 
            xmax = 341.977 
            text = "un m'nemt mikh tsurik aroys un m'firt mikh arayn mit a khevre, un m'gibt mir a plats." 
        intervals [147]:
            xmin = 341.977 
            xmax = 343.182 
            text = "" 
        intervals [148]:
            xmin = 343.182 
            xmax = 348.477 
            text = "un m'git mir a plats vu tsu shlofn, bald gibt men bald mir a plats in blok fertsn," 
        intervals [149]:
            xmin = 348.477 
            xmax = 351.523 
            text = "dort vestu ahingeyn, kum ikh ahin dortn, m'firt mikh arayn," 
        intervals [150]:
            xmin = 351.523 
            xmax = 358.97 
            text = "un der der un der blok ALTESTER, eyder m'geyt arayn in blok arayn, blokt er der blok ALTESTER hot er gehat aza kleyn tsimerl, eyder m'geyt arayn in dem groysn blok." 
        intervals [151]:
            xmin = 358.97 
            xmax = 359.01 
            text = "" 
        intervals [152]:
            xmin = 359.01 
            xmax = 360.475 
            text = "hot er mikh ongenumen," 
        intervals [153]:
            xmin = 360.475 
            xmax = 366.277 
            text = "un vayzt un firt mikh arayn un get mir der plats oyfn dritn oyfn dritn FLOOR," 
        intervals [154]:
            xmin = 366.277 
            xmax = 366.317 
            text = "" 
        intervals [155]:
            xmin = 366.317 
            xmax = 371.896 
            text = "do iz dayn bet. dem dritn FLOOR shlofn zeks mentshn. leyg dikh do. do." 
        intervals [156]:
            xmin = 371.896 
            xmax = 372.949 
            text = "" 
        intervals [157]:
            xmin = 372.949 
            xmax = 378.528 
            text = "un demolts hoyb ikh ersht on gevoyer tsu vern mentshn, un ikh her ikh hob mikh shoyn bafrayt, un ikh zits shoyn azoy oyfn bet," 
        intervals [158]:
            xmin = 378.528 
            xmax = 378.957 
            text = "" 
        intervals [159]:
            xmin = 378.957 
            xmax = 384.638 
            text = "kumen mentshn, dertseylt men, du bist ersht gekumen? zog ikh, yo. zogt er, du veyst vos do geyt tsu? zog ikh, UNK vos veys ikh?" 
        intervals [160]:
            xmin = 384.638 
            xmax = 384.762 
            text = "" 
        intervals [161]:
            xmin = 384.762 
            xmax = 386.274 
            text = "zog ikh, vos arbet men?" 
        intervals [162]:
            xmin = 386.274 
            xmax = 386.466 
            text = "" 
        intervals [163]:
            xmin = 386.466 
            xmax = 388.94 
            text = "zogt er, do arbet men nisht. do brent men." 
        intervals [164]:
            xmin = 388.94 
            xmax = 389.875 
            text = "" 
        intervals [165]:
            xmin = 389.875 
            xmax = 391.219 
            text = "vos heyst m'brent?" 
        intervals [166]:
            xmin = 391.219 
            xmax = 391.427 
            text = "" 
        intervals [167]:
            xmin = 391.427 
            xmax = 393.007 
            text = "do brent men mentshn." 
        intervals [168]:
            xmin = 393.007 
            xmax = 394.819 
            text = "" 
        intervals [169]:
            xmin = 394.819 
            xmax = 397.324 
            text = "un dan nakher iz gekumen Khaim Ernberg tsu mir," 
        intervals [170]:
            xmin = 397.324 
            xmax = 401.389 
            text = "arayn tsu mir, ikh bin do geven in zelbn m'hot mikh arayngeshikt in zelbn lager arayn, get er a kum arayn," 
        intervals [171]:
            xmin = 401.389 
            xmax = 403.882 
            text = "khapt mikh arum, zogt er, ikh hob dikh opgeratevet fun eyn toyt." 
        intervals [172]:
            xmin = 403.882 
            xmax = 403.999 
            text = "" 
        intervals [173]:
            xmin = 403.999 
