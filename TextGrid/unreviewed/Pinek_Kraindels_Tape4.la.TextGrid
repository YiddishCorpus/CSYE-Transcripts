        intervals [290]:
            xmin = 678.319 
            xmax = 686.953 
            text = "un mit eyn mol firt mikh arayn, ikh hob shoyn gekent arbetn mer PAINTINGeray, maleray, ikh hob vos a mol bin ikh gevorn mer, ir veyst dokh, ikh bin arayn, in der in der BUSINESS arayn." 
