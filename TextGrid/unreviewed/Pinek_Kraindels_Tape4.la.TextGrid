            text = "aroysgegangen fun lager. m'hot aroys marshirt. bald in der fri mit a muzik. mit a muzik." 
        intervals [301]:
            xmin = 718.242 
            xmax = 727.267 
            text = "geshtanen der muzik, iz geshtanen der lager firer un er hot gekukt oyf ale heftlinger. yeder kapo hot gemoldn, ikh hob MAL FUNFZIG HAFTLINGE." 
