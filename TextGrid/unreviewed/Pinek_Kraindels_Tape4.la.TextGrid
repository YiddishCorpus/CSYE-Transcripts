            xmin = 758.166 
            xmax = 758.323 
            text = "" 
        intervals [315]:
            xmin = 758.323 
            xmax = 761.861 
            text = "hob ikh gebetn a blekherzh, hob ikh gezen vos dortn tut zikh," 
