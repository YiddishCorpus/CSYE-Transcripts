            text = "" 
        intervals [248]:
            xmin = 582.03 
            xmax = 589.499 
            text = "zuntik hot men SPECIAL nisht gearbet, m'hot gereynikt dem blok. yeder eyner hot gereynikt dos bet, gereynikt dem blok, gevashn ales, m'hot getun, yeder iz geven basheftikt." 
        intervals [249]:
