        intervals [2]:
            xmin = 10.778 
            xmax = 22.466 
            text = "ya, in dem lager dos iz gevorn likvidirt. s'k- mer keyn yidn dortn nisht mer gevezn. un yetst vet ir fregn vos iz gevorn mit der fabrik? der fabrik iz vayter ongegangen, ober dortn iz geblibn di polyakn arbetn." 
        intervals [3]:
            xmin = 22.466 
            xmax = 22.675 
            text = "" 
        intervals [4]:
            xmin = 22.675 
            xmax = 28.406 
            text = "un azoy vi di yidn zenen aroys, vayzt zikh oys az m'hot gebrengt avade nokh mer andere polyakn tsu der arbet." 
        intervals [5]:
            xmin = 28.406 
            xmax = 28.868 
            text = "" 
        intervals [6]:
            xmin = 28.868 
            xmax = 32.577 
            text = "ober Starakhovitse iz gevorn likvidirt." 
        intervals [7]:
            xmin = 32.577 
            xmax = 34.717 
            text = "der lager Starakhovitse iz gevorn likvidirt." 
        intervals [8]:
            xmin = 34.717 
            xmax = 39.162 
            text = "" 
        intervals [9]:
            xmin = 39.162 
            xmax = 40 
            text = "ya," 
        intervals [10]:
            xmin = 40 
            xmax = 40.765 
            text = "" 
        intervals [11]:
            xmin = 40.765 
            xmax = 43.357 
            text = "oh ya. di gantse tsayt, mit undz tsuzamen." 
        intervals [12]:
            xmin = 43.357 
            xmax = 44.781 
            text = "" 
        intervals [13]:
            xmin = 44.781 
            xmax = 50.327 
            text = "in ya. ober di polyakn aleyn hobn okyh tsugeleygt a hant, hobn oykh geshlogn." 
        intervals [14]:
            xmin = 50.327 
            xmax = 50.603 
            text = "" 
        intervals [15]:
            xmin = 50.603 
            xmax = 53.553 
            text = "s'dortn gevezn formaners fun di polyakn," 
        intervals [16]:
            xmin = 53.553 
            xmax = 55.552 
            text = "nisht eyn mol hot er mikh ongeshlogn," 
        intervals [17]:
            xmin = 55.552 
            xmax = 57.38 
            text = "nisht eyn mol hot er mikh tseharget," 
        intervals [18]:
            xmin = 57.38 
            xmax = 57.42 
            text = "" 
        intervals [19]:
            xmin = 57.42 
            xmax = 58.797 
            text = "un andere oykhet." 
