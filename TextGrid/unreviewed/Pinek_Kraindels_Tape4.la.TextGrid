        intervals [292]:
            xmin = 688.09 
            xmax = 695.509 
            text = "hot men mikh arayngefirt oyf a plats tsu kalekhn oyf a plats vu s'gelign der gold un di brilyantn iz gelign oyf der FLOOR a barg." 
