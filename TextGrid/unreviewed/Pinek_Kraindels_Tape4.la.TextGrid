            text = "eyner iz geshtanen oyfgeshribn, spn, un m'hot undz hot men marshirt." 
        intervals [305]:
            xmin = 735.334 
            xmax = 735.728 
            text = "" 
        intervals [306]:
            xmin = 735.728 
