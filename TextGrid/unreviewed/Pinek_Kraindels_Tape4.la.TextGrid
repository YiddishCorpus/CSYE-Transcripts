            text = "" 
        intervals [175]:
            xmin = 405.855 
            xmax = 407.941 
            text = "zogt er, morgn voltstu shoyn nisht gelebt." 
        intervals [176]:
            xmin = 407.941 
            xmax = 408.437 
            text = "" 
        intervals [177]:
            xmin = 408.437 
            xmax = 410.068 
            text = "dos alts lebt shoyn nisht mer." 
        intervals [178]:
            xmin = 410.068 
            xmax = 410.428 
            text = "" 
        intervals [179]:
            xmin = 410.428 
            xmax = 413.122 
            text = "do mit di ale khevre du bist geven iz gevorn farbrent di nakht." 
        intervals [180]:
            xmin = 413.122 
            xmax = 413.398 
            text = "" 
        intervals [181]:
            xmin = 413.398 
            xmax = 414.838 
            text = "zog ikh, vos heyst m'farbrent?" 
        intervals [182]:
            xmin = 414.838 
            xmax = 417.662 
            text = "m'farbrent, zogt er, mentshn, m'fargazevet, m'farbrent." 
        intervals [183]:
            xmin = 417.662 
            xmax = 422.629 
            text = "" 
        intervals [184]:
            xmin = 422.629 
            xmax = 426.878 
            text = "di hobn genoy hobn genumen dertseyln un ikh bin geblibn shteyn, ikh hob gerisn barn kop." 
        intervals [185]:
            xmin = 426.878 
            xmax = 430.655 
            text = "zog ikh, vos heyst m'farbrent mentshn? do, zogt er, bistu nisht gekumen lebn." 
        intervals [186]:
            xmin = 430.655 
            xmax = 430.898 
            text = "" 
        intervals [187]:
            xmin = 430.898 
            xmax = 435.279 
            text = "do vestu, zogt er, arbetn, biz du vest nisht kumen, vestu geyn in oyvn arayn, in gaz-kamern." 
        intervals [188]:
            xmin = 435.279 
            xmax = 439.251 
            text = "" 
        intervals [189]:
            xmin = 439.251 
            xmax = 445.25 
            text = "vos vel ikh dir zogn dir? ikh hob ongehoybn tsu arbetn, ikh zol aroysgeyn bald in der fri oyfn apel, zol ikh zukhn dem" 
        intervals [190]:
            xmin = 445.25 
            xmax = 448 
            text = "dem kapo, ikh veys geven demolts FORTY NINE," 
        intervals [191]:
            xmin = 448 
            xmax = 452.575 
            text = "nayn un fertsik NUMBER, di kapo nayn un fertsik iz geven der kapo fun dem ales," 
        intervals [192]:
            xmin = 452.575 
            xmax = 452.886 
            text = "" 
        intervals [193]:
            xmin = 452.886 
            xmax = 460.558 
            text = "un er hot shoyn gehat geredt, Khaim Ernberg, er hot gehat a man vos er iz geven der onfirer, a er iz geven a yid, a Lodzher yid, er iz geven der firer fun di MALARZEs." 
        intervals [194]:
            xmin = 460.558 
            xmax = 461.138 
            text = "" 
        intervals [195]:
            xmin = 461.138 
            xmax = 464.692 
            text = "hot er shoyn geredt, ikh shik dir a yungn BOY, zolst gedenken, er iz gornisht." 
        intervals [196]:
            xmin = 464.692 
            xmax = 465.34 
            text = "" 
        intervals [197]:
            xmin = 465.34 
            xmax = 469.45 
            text = "er ken gor nisht. ober du muzt im oyslernen epes tsu tun, du muzt im oyshaltn," 
        intervals [198]:
            xmin = 469.45 
            xmax = 469.496 
            text = "" 
        intervals [199]:
            xmin = 469.496 
            xmax = 475.996 
            text = "az s'vet emetser kumen, vestu im gebn tsu mishn a fas mit mit kalekh, a veyst dokh a mol hot men gekalekht, a fas mit kalekh a fa- epes zolstu im gebn epes tsu tun," 
        intervals [200]:
            xmin = 475.996 
            xmax = 480.071 
            text = "un du muzt fun im makhn a mentsh, vayl s'vet gornisht helfn. er zol er hot oyfgegebn er iz a MALER." 
        intervals [201]:
            xmin = 480.071 
            xmax = 482.102 
            text = "un ikh hob im aroysgenumen fun toytn lager." 
        intervals [202]:
            xmin = 482.102 
            xmax = 483.407 
            text = "un er iz do do." 
        intervals [203]:
            xmin = 483.407 
            xmax = 484.493 
            text = "" 
        intervals [204]:
            xmin = 484.493 
            xmax = 485.887 
            text = "hot er shoyn gevust," 
        intervals [205]:
            xmin = 485.887 
            xmax = 486.467 
            text = "" 
        intervals [206]:
            xmin = 486.467 
            xmax = 488.081 
            text = "in der fri, ikh kum ahin," 
        intervals [207]:
            xmin = 488.081 
            xmax = 488.88 
            text = "" 
        intervals [208]:
            xmin = 488.88 
            xmax = 491 
            text = "zogt er, du bist der BOYtshik? zogt er, yo." 
        intervals [209]:
            xmin = 491 
            xmax = 491.023 
            text = "" 
        intervals [210]:
            xmin = 491.023 
            xmax = 495.095 
            text = "zogt er, ikh hob shoyn gehert. Khaim Ernberg hot mit mir geredt. zogt er, shoyn, UNK." 
        intervals [211]:
            xmin = 495.095 
            xmax = 496.569 
            text = "ikh vel dir shoyn gebn vos tsu tun." 
        intervals [212]:
            xmin = 496.569 
            xmax = 496.828 
            text = "" 
        intervals [213]:
            xmin = 496.828 
            xmax = 502.647 
            text = "mish do a fas vaser, a brengen vaser, mish do dem kalekh, mish oys dem kalekh, breng dos, breng yents." 
        intervals [214]:
            xmin = 502.647 
            xmax = 503.859 
            text = "ikh hob genumen arbetn." 
        intervals [215]:
            xmin = 503.859 
            xmax = 504.507 
            text = "" 
        intervals [216]:
            xmin = 504.507 
            xmax = 509.192 
            text = "un er hot fun mir gemakht a layt. er hot mir gemakht, s'nisht bloyz m'darf yedes mol mishn, m'hot gedarft epes tun oykhet," 
        intervals [217]:
            xmin = 509.192 
            xmax = 509.434 
            text = "" 
        intervals [218]:
            xmin = 509.434 
            xmax = 511.894 
            text = "farshtopn lekher, farshmirn lekher," 
        intervals [219]:
            xmin = 511.894 
            xmax = 514.287 
            text = "eyn mol, tsvey mol hot men gevizn, ikh hob es gemakht." 
        intervals [220]:
            xmin = 514.287 
            xmax = 517.517 
            text = "" 
        intervals [221]:
            xmin = 517.517 
            xmax = 522.674 
            text = "un ikh ver gevoyer vos tut zikh, un di un di kremetoryums, dos ikh bin geven Birkenou," 
        intervals [222]:
            xmin = 522.674 
            xmax = 523.238 
            text = "" 
        intervals [223]:
            xmin = 523.238 
            xmax = 526.404 
            text = "dos heyst Oyshvits, ober dos iz geven in Birkenoy vu di gaz-kamern." 
        intervals [224]:
            xmin = 526.404 
            xmax = 526.444 
            text = "" 
        intervals [225]:
            xmin = 526.444 
            xmax = 531.551 
            text = "un di gaz-kamern arbetn, un m'brent, un es tut zikh, bay tog un bay nakht geyt aroys di roykh," 
        intervals [226]:
            xmin = 531.551 
            xmax = 531.743 
            text = "" 
        intervals [227]:
            xmin = 531.743 
            xmax = 534.538 
            text = "m'zet nor dort, zogt er, zest der roykh? dos iz yidn." 
        intervals [228]:
            xmin = 534.538 
            xmax = 534.595 
            text = "" 
        intervals [229]:
            xmin = 534.595 
            xmax = 536.394 
            text = "do geyen a roykh fun yidn." 
        intervals [230]:
            xmin = 536.394 
            xmax = 538.965 
            text = "" 
        intervals [231]:
            xmin = 538.965 
            xmax = 542.185 
            text = "un m'hakt, un m'shlogt, un m'kaylt!" 
        intervals [232]:
            xmin = 542.185 
            xmax = 547.987 
            text = "m'geyt aroys oyf der gas, m'geyt adurkh, m'zet an S.S. man, hostu nisht gegebn keyn a gutn kuk, KOMM MAL aher!" 
        intervals [233]:
            xmin = 547.987 
            xmax = 548.213 
            text = "" 
        intervals [234]:
            xmin = 548.213 
            xmax = 554.518 
            text = "nemt er der shtekn, er hakt im ibern kop, iber di oygn, iber di yorn, un er tseharget dikh biz tsum toyt. fertik." 
        intervals [235]:
            xmin = 554.518 
            xmax = 555.891 
            text = "" 
        intervals [236]:
            xmin = 555.891 
            xmax = 557.955 
            text = "zuntik zey hobn nisht gehat vos tsu tun." 
        intervals [237]:
            xmin = 557.955 
            xmax = 563.512 
            text = "di S.S., zey zenen nisht aroysgegangen, di vos zenen aroysgegangen oyf CHOFESH, zenen aroysgegangen oyf CHOFESH; di vos zenen nisht aroysgegangen oyf keyn CHOFESH," 
        intervals [238]:
            xmin = 563.512 
            xmax = 563.653 
            text = "" 
        intervals [239]:
            xmin = 563.653 
