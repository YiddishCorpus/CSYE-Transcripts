            text = "" 
        intervals [719]:
            xmin = 1592.32 
            xmax = 1597.207 
            text = "ikh zol blaybn lign oyfn plats un ikh zol mikh nisht rirn, er hot aropgenumen ale, ikh bin geblibn." 
        intervals [720]:
            xmin = 1597.207 
            xmax = 1597.264 
            text = "" 
        intervals [721]:
            xmin = 1597.264 
            xmax = 1600.228 
            text = "der daytsh iz geblibn. daytsher hot men nisht farbrent." 
        intervals [722]:
            xmin = 1600.228 
            xmax = 1600.386 
            text = "" 
        intervals [723]:
            xmin = 1600.386 
            xmax = 1604.885 
            text = "er hot di zelbe arbet gearbet, di zelbe esn gekrign, ober im hot men nisht farbrent." 
        intervals [724]:
            xmin = 1604.885 
            xmax = 1605.195 
            text = "" 
        intervals [725]:
            xmin = 1605.195 
            xmax = 1607.771 
            text = "farbrent nisht. er hot gelitn." 
        intervals [726]:
            xmin = 1607.771 
            xmax = 1609.296 
            text = "" 
        intervals [727]:
            xmin = 1609.296 
            xmax = 1612.769 
            text = "un azoy iz ongegangen bizkale" 
        intervals [728]:
            xmin = 1612.769 
            xmax = 1619.35 
            text = "ende fir un fertsik s'g- iz gekumen a transport, s'gekumen yedn tog transportn, yedn tog iz arayngekumen transportn yidn." 
        intervals [729]:
            xmin = 1619.35 
            xmax = 1623.33 
            text = "ober in ende fir un fertsik iz arayngekumen a transport mit mayn bruder Avram," 
        intervals [730]:
            xmin = 1623.33 
            xmax = 1623.707 
            text = "" 
        intervals [731]:
            xmin = 1623.707 
            xmax = 1626.316 
            text = "vos er lebt nisht un er iz nishto," 
        intervals [732]:
            xmin = 1626.316 
            xmax = 1626.576 
            text = "" 
        intervals [733]:
            xmin = 1626.576 
            xmax = 1633.303 
            text = "er iz arayngekumen keyn Oyshvits un ikh hob im getrofn, un ikh hob arayngenumen tsu mir in mayn blok arayn, er zol shlofn mit mir." 
        intervals [734]:
            xmin = 1633.303 
            xmax = 1634.558 
            text = "" 
        intervals [735]:
            xmin = 1634.558 
            xmax = 1638.669 
            text = "shpeter bin ikh aropgegangen oyfn tsveytn FLOOR, er iz geshlofn, ikh hob im gegebn mayn plats in der heykh." 
        intervals [736]:
            xmin = 1638.669 
            xmax = 1641.527 
            text = "" 
        intervals [737]:
            xmin = 1641.527 
            xmax = 1644.873 
            text = "un shtubn dinstn vos hobn gearbet dortn in Oyshvits," 
        intervals [738]:
            xmin = 1644.873 
            xmax = 1648.305 
            text = "iz yedn in der fri, az zey hobn gegebn a makh oyf di luft," 
        intervals [739]:
            xmin = 1648.305 
            xmax = 1648.412 
            text = "" 
        intervals [740]:
            xmin = 1648.412 
            xmax = 1652.338 
            text = """oyfshteyn, arunter fun di betn!"" hostu dikh gemuzt gebn a glitsh arop." 
        intervals [741]:
            xmin = 1652.338 
            xmax = 1653.07 
            text = "" 
        intervals [742]:
            xmin = 1653.07 
            xmax = 1655.949 
            text = "sh- naket. shteyn. koydem kol shtey untn." 
        intervals [743]:
            xmin = 1655.949 
            xmax = 1656.073 
            text = "" 
        intervals [744]:
            xmin = 1656.073 
            xmax = 1659.256 
            text = "nisht in bet. tomer a shray gebn, ""arunter fun di betn!""" 
        intervals [745]:
            xmin = 1659.256 
            xmax = 1659.634 
            text = "" 
        intervals [746]:
            xmin = 1659.634 
            xmax = 1663.613 
            text = "hostu gemuzt shteyn. mayn bruder hot zikh farshpetikt mit efsher a tsvey minut," 
        intervals [747]:
            xmin = 1663.613 
            xmax = 1668.386 
            text = "ikh shray ""Avrom! Avrom! Avrom!"" biz er krikht arop, biz er er makht zikh oyf di oygn," 
        intervals [748]:
            xmin = 1668.386 
            xmax = 1668.392 
            text = "" 
        intervals [749]:
            xmin = 1668.392 
            xmax = 1670.411 
            text = "zenen shoyn do di tsvey shtubn dinstn." 
        intervals [750]:
            xmin = 1670.411 
            xmax = 1671.312 
            text = "" 
        intervals [751]:
            xmin = 1671.312 
            xmax = 1676.368 
            text = "zey viln fardinen shoyn dos broyt vos er darf krign in der fri, ebn zey krign. er vet shoyn zayn toyt." 
        intervals [752]:
            xmin = 1676.368 
            xmax = 1676.644 
            text = "" 
        intervals [753]:
            xmin = 1676.644 
            xmax = 1678.123 
            text = "ikh hob dokh gevust vos m'tut." 
        intervals [754]:
            xmin = 1678.123 
            xmax = 1678.635 
            text = "" 
        intervals [755]:
            xmin = 1678.635 
            xmax = 1680.164 
            text = "ver s'hot zikh farshpetikt," 
        intervals [756]:
            xmin = 1680.164 
            xmax = 1680.306 
            text = "" 
        intervals [757]:
            xmin = 1680.306 
            xmax = 1687.286 
            text = "hot men gegebn, m'hot im tse- koydem hot men im tseboksevet un avekgeleygt, aroyfgeleygt a shtekele oyfn haldz. er hot do aroyf getretn un er hot do aroyf getretn, un m'hot im ayngekvetsht." 
        intervals [758]:
            xmin = 1687.286 
            xmax = 1687.9 
            text = "" 
        intervals [759]:
            xmin = 1687.9 
            xmax = 1690.124 
            text = "un vi er iz shoyn toyt a mol, avekgenumen di shtekele." 
        intervals [760]:
            xmin = 1690.124 
            xmax = 1691.235 
            text = "dos iz geven di toyt." 
        intervals [761]:
            xmin = 1691.235 
            xmax = 1692 
            text = "" 
        intervals [762]:
            xmin = 1692 
            xmax = 1698.322 
            text = "un azoy hot men geharget yedn in der fri tsvey, dray, fir. s'dokh gekumen frishe. yedes mol gekumen frishe. fun di frishe hot men azoy geharget." 
        intervals [763]:
            xmin = 1698.322 
            xmax = 1698.413 
            text = "" 
        intervals [764]:
            xmin = 1698.413 
            xmax = 1700.364 
            text = "un ikh hob gezen vos vart oyfn bruder," 
        intervals [765]:
            xmin = 1700.364 
            xmax = 1700.488 
            text = "" 
        intervals [766]:
            xmin = 1700.488 
            xmax = 1702.068 
            text = "zey geyen zikh tsun im nemen," 
        intervals [767]:
            xmin = 1702.068 
            xmax = 1703.661 
            text = "" 
        intervals [768]:
            xmin = 1703.661 
            xmax = 1712.97 
            text = "vi zey geyen zikh tsu im nemen, UNK eyder er hot nokh aroysgetsoygn a hant tsu gebn im a boks, hot er shoyn gekrign fun mir. hot er gekrign fun mir a shos, un dem andern der zayt, un ikh hob im beyde tseklapt." 
        intervals [769]:
            xmin = 1712.97 
            xmax = 1713.803 
            text = "" 
        intervals [770]:
            xmin = 1713.803 
            xmax = 1719.568 
            text = "un ikh hob zey vi azoy tseklapt. s'nisht geven genug eynem. ikh hob gegebn yedn eynem tsu finef un dem." 
        intervals [771]:
            xmin = 1719.568 
            xmax = 1719.878 
            text = "" 
        intervals [772]:
            xmin = 1719.878 
            xmax = 1721.188 
            text = "zenen geblibn lign." 
        intervals [773]:
            xmin = 1721.188 
            xmax = 1722.375 
            text = "" 
        intervals [774]:
            xmin = 1722.375 
            xmax = 1729.62 
            text = "ale mentshn shrayen tsu mir, ""Pinek, du bist meshuge?! vos hostu getun?!"" zog ikh, lozn dem bruder hargenen?! ikh hob dokh shoyn gevust m'geyt im leygn shtekele bald." 
        intervals [775]:
            xmin = 1729.62 
            xmax = 1731.999 
            text = "m'geyt im koydem tseklapn, nakher vet men hargenen." 
        intervals [776]:
            xmin = 1731.999 
            xmax = 1733.523 
            text = "dos iz dokh mayn bruder." 
        intervals [777]:
            xmin = 1733.523 
            xmax = 1736.28 
            text = "" 
        intervals [778]:
            xmin = 1736.28 
            xmax = 1741.286 
            text = "un zey geyen arayn, tseklapt, geyen zey arayn tsu dem daytsher, der f- der firer fun dem blok," 
        intervals [779]:
            xmin = 1741.286 
            xmax = 1742.068 
            text = "" 
        intervals [780]:
            xmin = 1742.068 
            xmax = 1745.42 
            text = "git er shray, ""nayntsn tsvey fir un DREISIG, kum dokh MAL aher!""" 
        intervals [781]:
            xmin = 1745.42 
            xmax = 1746.793 
            text = "" 
        intervals [782]:
            xmin = 1746.793 
            xmax = 1750.027 
            text = "zol do- er zol vayzn ver iz dos. hobn zey ongevizn, hobn mikh aher gerufn." 
