            text = "" 
        intervals [102]:
            xmin = 341.95 
            xmax = 350.466 
            text = "mit undz tsum reydn keyn sakh. er hot aleyn nit gevust oyf velkher oyf vos vos oyf velkher velt er iz, vayl er hot aleyn gekrogn aza min aza min prikaz az men zol undz gikh aroysfirn in Daytshland." 
        intervals [103]:
            xmin = 350.466 
            xmax = 351.568 
            text = "" 
        intervals [104]:
            xmin = 351.568 
            xmax = 357.772 
            text = "eygntlekh vil ikh dermonen az nokhn krig hot mir mayner a khaver ongetrofn" 
        intervals [105]:
            xmin = 357.772 
            xmax = 358.909 
            text = "" 
        intervals [106]:
            xmin = 358.909 
            xmax = 363.425 
            text = "eh un er hot mir gezogt, herstu mir, er hot gearbet, der khaver mayner hot gearbet in K.G.B." 
