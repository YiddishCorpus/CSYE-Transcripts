        intervals [111]:
            xmin = 371.495 
            xmax = 377.635 
            text = "zogt er, herstu Meyshl, zogt er, vilst zen, zogt er, dem plenik undzer, dem dem dem gevezenem komendant fun dem lager." 
        intervals [112]:
