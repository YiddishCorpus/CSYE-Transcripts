            text = "s'hot zikh geendikt der arbets- di tsayt fun der arbets-brigade," 
        intervals [343]:
            xmin = 1113.823 
            xmax = 1113.897 
            text = "" 
        intervals [344]:
            xmin = 1113.897 
            xmax = 1117.367 
            text = "un zey ze- m'hot zey avekgetribn tsurik in lager un ikh bin geblibn eyner aleyn." 
        intervals [345]:
            xmin = 1117.367 
            xmax = 1117.39 
            text = "" 
        intervals [346]:
            xmin = 1117.39 
            xmax = 1119.679 
            text = "ikh kum tsu geyn oyfn arbets-ort, keyner iz nito." 
