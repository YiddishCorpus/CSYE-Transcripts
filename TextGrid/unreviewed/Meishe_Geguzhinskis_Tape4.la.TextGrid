            text = "dos iz geven a eyne fun di greste g- greste mutshenish in di lagern fun fun OSWIECIM." 
        intervals [390]:
            xmin = 1243.561 
            xmax = 1249.838 
            text = "er iz kentik geven dortn komendant in OSWIECIM, un er hot gevust di ale farsheydene metodn vi tsu m- oys- oystsumatern mentshn." 
        intervals [391]:
            xmin = 1249.838 
            xmax = 1255.928 
            text = "hot men farbundn di hent oyf hintn mit di drotn, un hot men mir tsugebundn dem drot un mir aroyfgetsoygn oyfn shtolp in der heykh." 
