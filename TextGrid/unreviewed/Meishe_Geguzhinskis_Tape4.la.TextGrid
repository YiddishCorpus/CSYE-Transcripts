            text = "di harts ligndik di harts bay mir geven" 
        intervals [407]:
            xmin = 1299.231 
            xmax = 1308.054 
            text = "geferlekhe veytogn un di oygn bay mir geven un di kop hot mir ge- ge- geshvindlt, ikh hob nit gevust oyf velkhe velt ikh bin. un m'hot mir avekgeleygt dortn in in barak lign." 
