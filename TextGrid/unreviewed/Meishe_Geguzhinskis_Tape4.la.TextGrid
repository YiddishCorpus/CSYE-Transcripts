        intervals [315]:
            xmin = 1008.09 
            xmax = 1012.28 
            text = "di V. daytshishe V. eroplanen di letste. dortn hot men genumen" 
        intervals [316]:
            xmin = 1012.28 
            xmax = 1021.575 
            text = "yidn un m'hot oyf di oyf tsu boyen mit tsement mit eh beton fun betonirn dortn di un- di un- di un- di untererdishe" 
