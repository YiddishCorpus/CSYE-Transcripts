            xmin = 430.79 
            xmax = 431.286 
            text = "" 
        intervals [129]:
            xmin = 431.286 
            xmax = 443.382 
            text = "ya, zogt er, a dos iz der JUDE ver, mayn JUDE, ikh hob im mit marmelad ge- mit gegebn esn marmelad. zog ikh, im eh marmelad hostu undz gegebn esn, ober" 
        intervals [130]:
            xmin = 443.382 
