        intervals [1]:
            xmin = 0 
            xmax = 9.985 
            text = "" 
        intervals [2]:
            xmin = 9.985 
            xmax = 16.543 
            text = "un in Ponevezher lager, khotsh mir zaynen dortn geven a kurtse tsayt, oyf vifl ikh gedenk," 
        intervals [3]:
            xmin = 16.543 
            xmax = 16.633 
            text = "" 
        intervals [4]:
            xmin = 16.633 
            xmax = 25.149 
            text = "inem in dem grupe iz er geven dort Shmerke Spivak, mayner a khaver, velkher ikh hob zikh mit im bakent in geto, un er iz arayngefaln tsuzamen mit mir in Ponevezher lager." 
        intervals [5]:
            xmin = 25.149 
            xmax = 25.78 
            text = "" 
        intervals [6]:
            xmin = 25.78 
            xmax = 31.916 
            text = "Shmerke Spivok iz geven a a yat aza min volt ikh gezogn mer a hendler vi kemfer." 
        intervals [7]:
            xmin = 31.916 
            xmax = 32.395 
            text = "" 
        intervals [8]:
            xmin = 32.395 
            xmax = 39.628 
            text = "nor in undzer organiz- in undzer krayzl hot er azoy gepast, vayl er iz geven a dreyster yat, er hot keyn nit moyre gehat far keyn far keyn far rizikalishe arbet." 
        intervals [9]:
            xmin = 39.628 
            xmax = 39.938 
            text = "" 
        intervals [10]:
            xmin = 39.938 
            xmax = 45.478 
            text = "un mir hobn im gegebn a oyfgabe tsu krign farbindungen mit di u- mit di" 
        intervals [11]:
            xmin = 45.478 
            xmax = 48.473 
            text = "rusishe plenikes velkhe flegn kumen arbetn oyfn erodrom," 
        intervals [12]:
            xmin = 48.473 
            xmax = 52.689 
            text = "efsher mit zey zikh vos tsu derredn, far zey UNK tsu gefinen" 
        intervals [13]:
            xmin = 52.689 
            xmax = 52.898 
            text = "" 
        intervals [14]:
            xmin = 52.898 
            xmax = 59.307 
            text = "eh derredn tsu gefinen a opsh- a a a a a shprakh" 
        intervals [15]:
            xmin = 59.307 
            xmax = 63.185 
            text = "vi azoy tsu, efsher veysn zey vu es gefinen zikh partizaner arum Ponevezh." 
        intervals [16]:
            xmin = 63.185 
            xmax = 63.765 
            text = "" 
        intervals [17]:
            xmin = 63.765 
            xmax = 67.928 
            text = "Shmerke Spivok hot zikh hot gekent gut rusish," 
        intervals [18]:
            xmin = 67.928 
            xmax = 68.44 
            text = "" 
        intervals [19]:
            xmin = 68.44 
            xmax = 76.925 
            text = "un er hot zikh prubirt mit im tsunoyf reydn mi- mit di pleni- mit di plenikes mit mitn brigadir fun di plenikes, vayl der brigadir iz geven UNK mer veyniker azoy tsu zogn" 
        intervals [20]:
            xmin = 76.925 
            xmax = 81.647 
            text = "a solider mentsh, a solider soldat, er iz gevezn a soldat, oder a ofitsir," 
        intervals [21]:
            xmin = 81.647 
            xmax = 84.218 
            text = "" 
        intervals [22]:
            xmin = 84.218 
            xmax = 90.641 
            text = "un di, hot zikh aroysgevizn az bay di plenikes iz shoyn oykh geven a u- um- umlegale organizatsye, zey hobn oykh getrakht a- antloyfn." 
        intervals [23]:
            xmin = 90.641 
            xmax = 91.356 
            text = "" 
        intervals [24]:
            xmin = 91.356 
            xmax = 95.72 
            text = "un tsu- un zey hobn undz tsugezogt az zey veln baym antloyfn veln zey undz gebn a signal" 
        intervals [25]:
            xmin = 95.72 
            xmax = 95.811 
            text = "" 
        intervals [26]:
            xmin = 95.811 
            xmax = 97.729 
            text = "un mir zoln loyfn mit zey tsuzamen." 
        intervals [27]:
            xmin = 97.729 
            xmax = 100.249 
            text = "" 
        intervals [28]:
            xmin = 100.249 
            xmax = 104.647 
            text = "nokhn, mir hobn zikh zeyer opgeredt mit im, mit dem brigadir zeyern," 
        intervals [29]:
            xmin = 104.647 
            xmax = 104.89 
            text = "" 
        intervals [30]:
            xmin = 104.89 
            xmax = 110.422 
            text = "in a tog, az mir veln zikh trefn un er vet undz zogn, gebn a karte" 
        intervals [31]:
            xmin = 110.422 
            xmax = 114.874 
            text = "un vayzn vu gefinen zikh partizaner, vayl eh bay zey iz shoyn geven tsugegreyt a karte." 
        intervals [32]:
            xmin = 114.874 
            xmax = 117.985 
            text = "" 
        intervals [33]:
            xmin = 117.985 
            xmax = 127.699 
            text = "grod oyf morgn iz er shoyn nit eh iz hot men di brigade hot men di di arbeter brigade fun di plenikes nit ge- nit gekumen nit getribn tsu der arbet dortn un er mir hobn farloyrn di farbindungen in gantsn mit im." 
        intervals [34]:
            xmin = 127.699 
            xmax = 127.823 
            text = "" 
        intervals [35]:
            xmin = 127.823 
            xmax = 136.794 
            text = "hobn mir bashlosn aroystsulozn in di hinter shtot, in der in der Ponevezh iz geven a hobn mir a- iz geven a derfl," 
        intervals [36]:
            xmin = 136.794 
            xmax = 138.775 
            text = "" 
        intervals [37]:
            xmin = 138.775 
            xmax = 145.384 
            text = "vu mir hobn gehert fun di fun farsheydene arbeter velkhe hobn gearbet oyfn erodrom az dortn bavayzn zikh oft mol oft mol partizaner." 
        intervals [38]:
            xmin = 145.384 
            xmax = 145.997 
            text = "" 
        intervals [39]:
            xmin = 145.997 
            xmax = 152.218 
            text = "hobn mir gehat aroysgelozn undzerer a y- a yungn yatl, fun a yor tsvelf tsi elf iz er geven. zayn familye gedenk ikh shoyn nit." 
        intervals [40]:
            xmin = 152.218 
            xmax = 152.477 
            text = "" 
        intervals [41]:
            xmin = 152.477 
            xmax = 156.709 
            text = "a dreyster yat, mir hobn gegebn im instruktsyes vi azoy tsum firn zikh," 
        intervals [42]:
            xmin = 156.709 
            xmax = 161.735 
            text = "un er iz avekgelofn, fun der arbet iz iz er hot er zikh aroysgeganvet un antlofn in dorf," 
        intervals [43]:
            xmin = 161.735 
            xmax = 163.362 
            text = "" 
        intervals [44]:
            xmin = 163.362 
            xmax = 168.688 
            text = "un dortn hot er, tsu tsu dervisn zikh ven es kumen dortn di partizaner, kedey mit zey tsu krign a far- kontakt," 
        intervals [45]:
            xmin = 168.688 
            xmax = 169.757 
            text = "" 
        intervals [46]:
            xmin = 169.757 
            xmax = 175.066 
            text = "aroystsu- aroystsu- eh tsu antloyfn fun dortn. etlekhe mol iz geven der der yatl," 
        intervals [47]:
            xmin = 175.066 
            xmax = 176.102 
            text = "" 
        intervals [48]:
            xmin = 176.102 
            xmax = 178.698 
            text = "un er hot shoyn gehat mit zey gehat er hot gehat tsugeredt opgeredt" 
        intervals [49]:
            xmin = 178.698 
            xmax = 183.221 
            text = "vi azoy zey veln undz oyf- vi azoy zey viln, zey hobn zikh oykh oykh gevolt trefn mit undz," 
        intervals [50]:
            xmin = 183.221 
            xmax = 185.799 
            text = "mir hobn zey mir mir hobn zey gezogt mir hobn" 
        intervals [51]:
            xmin = 185.799 
            xmax = 186.278 
            text = "" 
        intervals [52]:
            xmin = 186.278 
            xmax = 191.216 
            text = "a eyn pistolet spn in gantsn, un a raketnik iz bay undz geven, a raketnik," 
        intervals [53]:
            xmin = 191.216 
            xmax = 191.256 
            text = "" 
        intervals [54]:
            xmin = 191.256 
            xmax = 193.798 
            text = "vos ikh hob gefunen oyfn eh arbetndik oyf erodrom." 
        intervals [55]:
            xmin = 193.798 
            xmax = 194.243 
            text = "" 
        intervals [56]:
            xmin = 194.243 
            xmax = 204.109 
            text = "dos iz geven optsu- optsush- optsushrekn efsher a mol mer nit di di vikh- ve- velkhe di velkhe farshteyen nit vos nit iz oyfn veg, oyb oyfn veg tsu di partizaner." 
        intervals [57]:
            xmin = 204.109 
            xmax = 206.967 
            text = "" 
        intervals [58]:
            xmin = 206.967 
            xmax = 211.736 
            text = "hot der yingl, mit dem UNK, ikh muz zogn vegn dem tragishn toyt fun dem yingl." 
        intervals [59]:
            xmin = 211.736 
            xmax = 212.383 
            text = "" 
        intervals [60]:
            xmin = 212.383 
            xmax = 215.65 
            text = "dem yingl hot men, ven m'hot undz gebrakht shpeter in Shtuthof," 
        intervals [61]:
            xmin = 215.65 
            xmax = 217.851 
            text = "" 
        intervals [62]:
            xmin = 217.851 
            xmax = 221.102 
            text = "iz der yingl aroysgegangen fun vagon," 
        intervals [63]:
            xmin = 221.102 
            xmax = 222.087 
            text = "" 
        intervals [64]:
            xmin = 222.087 
            xmax = 229.117 
            text = "un er iz aru- aruntergefaln unter vagon un der vagon un der di reder fun vagon hobn im opgeshnitn beyde fis." 
        intervals [65]:
            xmin = 229.117 
            xmax = 229.528 
            text = "" 
        intervals [66]:
            xmin = 229.528 
            xmax = 238.585 
            text = "ikh bin tsugelofn a kuk ton, er iz gelegn, der yingl, blas in gantsn, vays, on fis." 
        intervals [67]:
            xmin = 238.585 
            xmax = 239.94 
            text = "" 
        intervals [68]:
            xmin = 239.94 
            xmax = 241.65 
            text = "ikh hob poshet nit gekent oyshaltn." 
        intervals [69]:
            xmin = 241.65 
            xmax = 246.465 
            text = "aza min yunger kind, vos hot azoy fil geholfn, un er hot gehat aza min sof." 
        intervals [70]:
            xmin = 246.465 
            xmax = 247.281 
            text = "" 
        intervals [71]:
            xmin = 247.281 
            xmax = 249.536 
            text = "nu ikh vil zikh itster umkern tsurik vegn Ponevezh." 
        intervals [72]:
            xmin = 249.536 
            xmax = 253.373 
            text = "" 
        intervals [73]:
            xmin = 253.373 
            xmax = 262.445 
            text = "un UNK vartndik DA, ya unter, eh s'geven der der in Ponevezh iz geven der brigadir fun undzer brigade fun erodrom iz geven eyner" 
        intervals [74]:
            xmin = 262.445 
            xmax = 262.603 
            text = "" 
        intervals [75]:
            xmin = 262.603 
            xmax = 268.065 
            text = "Solomon Mil. dos iz geven a barimter inzhenier fun Kovne" 
        intervals [76]:
            xmin = 268.065 
            xmax = 268.645 
            text = "" 
        intervals [77]:
            xmin = 268.645 
            xmax = 271.519 
            text = "velkher hot gestroyet dortn, velkher hot geboyt dortn di garazhn," 
        intervals [78]:
            xmin = 271.519 
            xmax = 277.718 
            text = "dem barimtn garazh fun Kovne, velkher hot geboyt groyse obyektn in Kovne. er hot gearbe- er iz geven der brigadir" 
        intervals [79]:
            xmin = 277.718 
            xmax = 277.858 
            text = "" 
        intervals [80]:
            xmin = 277.858 
            xmax = 281.196 
            text = "un mir hobn im tsugesh- tsugebundn tsu undzer, mir hobn dertseylt im," 
        intervals [81]:
            xmin = 281.196 
            xmax = 284.467 
            text = "ver hobn ikh gehat, er hot eh mir hobn tsu im gehat a tsutroy epes," 
        intervals [82]:
            xmin = 284.467 
            xmax = 284.49 
            text = "" 
        intervals [83]:
            xmin = 284.49 
            xmax = 293.107 
            text = "a kleynem tsutroy, un mir hobn im dertseylt az s'do bay undz a organizatsye. er zol undz helfn, mitarbetn in undzer organizatsye, mit ikh hob im ge- mir planirn aroys tsu antloyfn fun dortn." 
        intervals [84]:
            xmin = 293.107 
            xmax = 294.075 
            text = "" 
        intervals [85]:
            xmin = 294.075 
            xmax = 295.908 
            text = "er hot ongenumen undzer forshlog," 
        intervals [86]:
            xmin = 295.908 
            xmax = 296.05 
            text = "" 
        intervals [87]:
            xmin = 296.05 
            xmax = 300.668 
            text = "er iz arayn bay undz, Solomon Mil iz gevorn bay undz sekretar als" 
        intervals [88]:
            xmin = 300.668 
            xmax = 300.741 
            text = "" 
        intervals [89]:
            xmin = 300.741 
            xmax = 306.27 
            text = "mayn zim- mayn fartreter iz er gevorn, khotsh er iz geven elter fun mir mit a yor tsen, tsvelf, mistome efsher mer." 
        intervals [90]:
