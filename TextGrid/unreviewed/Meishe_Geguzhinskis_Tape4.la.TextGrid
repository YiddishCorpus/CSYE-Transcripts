        intervals [415]:
            xmin = 1328.062 
            xmax = 1335.256 
            text = "vi azoy tsum shlogn di yidn. er iz geven a zeyer a biterer mentsh. a Lodzher yid, a Lod- fun Lodzh, a Varshe- a poylisher yid." 
