        intervals [393]:
            xmin = 1256.524 
            xmax = 1262.326 
            text = "ikh bin gehangen do oyf shtolp farshteyt zikh ikh gedenk shoyn nit vifl tsayt." 
        intervals [394]:
            xmin = 1262.326 
            xmax = 1268.331 
            text = "nor ikh veys nor eyns, az di kartofl velkhe ikh hob gehat bahaltn hobn zikh aroysgeshotn bay mir." 
