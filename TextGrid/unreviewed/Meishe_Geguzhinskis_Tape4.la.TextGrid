            xmin = 1184.898 
            xmax = 1185.042 
            text = "" 
        intervals [368]:
            xmin = 1185.042 
            xmax = 1187.28 
            text = "un tsu mir zogt er oyf daytsh, zogt er," 
        intervals [369]:
            xmin = 1187.28 
            xmax = 1187.775 
            text = "" 
        intervals [370]:
            xmin = 1187.775 
            xmax = 1194.873 
            text = """veyst, du kleyner yunger, ikh men ikh vel dikh LA- LASSEN SCHLAGEN dikh.""" 
