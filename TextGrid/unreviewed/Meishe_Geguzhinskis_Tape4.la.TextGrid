            xmin = 1194.873 
            xmax = 1195.234 
            text = "" 
        intervals [372]:
            xmin = 1195.234 
            xmax = 1199.075 
            text = "du gey foroys, un m'hot mir gefirt in lager, un er hot mir nit gelozn shlogn." 
        intervals [373]:
            xmin = 1199.075 
            xmax = 1199.908 
            text = "" 
        intervals [374]:
            xmin = 1199.908 
            xmax = 1205.212 
            text = "ven ven m- ven m'iz gekumen in lager tsuzamen mit di gantse kompanye postns velkhe zenen gegangen hinter mir mit di hint," 
        intervals [375]:
            xmin = 1205.212 
            xmax = 1207.006 
            text = "m'hot mir arayngefirt tsum komendant." 
