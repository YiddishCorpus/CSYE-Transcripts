            text = "" 
        intervals [93]:
            xmin = 313.498 
            xmax = 320.073 
            text = "daytshe mashines, un m'hot geheysn zikh onlodn, mit undzere peklekh vos hobn dortn gehat dortn, ver vos hot gehat dortn mit zikh," 
        intervals [94]:
            xmin = 320.073 
