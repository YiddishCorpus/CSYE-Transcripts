            xmin = 1030.46 
            xmax = 1032.053 
            text = "" 
        intervals [320]:
            xmin = 1032.053 
            xmax = 1041.801 
            text = "ikh muz aykh dertseyln vegn dem vi azoy ikh bin ikh bin gegangen tsu der arbet dortn yedn tog," 
        intervals [321]:
            xmin = 1041.801 
            xmax = 1042.954 
            text = "" 
        intervals [322]:
            xmin = 1042.954 
            xmax = 1048.246 
            text = "vos heyst gegangen? m'hot undz getribn tsu der arbet yedn tog. gegesn gegesn hot men undz gegebn zeyer shvakh, zeyer veynik," 
        intervals [323]:
            xmin = 1048.246 
