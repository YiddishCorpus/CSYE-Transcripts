            xmin = 1474.709 
            xmax = 1480.095 
            text = "di shraybst in dayne memuarn vegn musulman, zogt er, ikh veys vos dos heyst, zogt er, in Sibir hobn mir es oykh gehat azelkhene musulmanen." 
        intervals [464]:
            xmin = 1480.095 
            xmax = 1480.489 
            text = "" 
        intervals [465]:
            xmin = 1480.489 
            xmax = 1482.575 
            text = "aza min bin ikh geven oykh shoyn gevorn." 
        intervals [466]:
            xmin = 1482.575 
            xmax = 1483.459 
            text = "" 
        intervals [467]:
            xmin = 1483.459 
            xmax = 1487.891 
            text = "nor plutsung, ya, geyendik azoy bay di barakn hob ikh" 
        intervals [468]:
            xmin = 1487.891 
            xmax = 1488.049 
            text = "" 
        intervals [469]:
            xmin = 1488.049 
            xmax = 1493.859 
            text = "eh gezukht vu tsu a shtik- khapn a shtikl broyt oder a shtikl kartofl, kedey tsu shtiln shtiln dem hunger." 
        intervals [470]:
            xmin = 1493.859 
            xmax = 1499.546 
            text = "un mertsn teyl hob hob ikh zikh bin bin ikh arayn in di zone vu es zenen gelegn di tifus kranke." 
        intervals [471]:
            xmin = 1499.546 
            xmax = 1503.028 
            text = "vayl dortn flegn di kranke shoyn, a sakh kranke flegn farn shtarbn" 
        intervals [472]:
            xmin = 1503.028 
            xmax = 1503.051 
            text = "" 
        intervals [473]:
            xmin = 1503.051 
            xmax = 1506.043 
            text = "flegn zey iberlozn di shtikele broyt vos zeyer portsye broyt," 
        intervals [474]:
            xmin = 1506.043 
            xmax = 1510.875 
            text = "un fun zey hob ikh getrakht efsher, hob ikh ge- gevelt vos nit far zikh vos nit iz gefinen." 
        intervals [475]:
            xmin = 1510.875 
            xmax = 1511.877 
            text = "" 
        intervals [476]:
            xmin = 1511.877 
            xmax = 1517.912 
            text = "ikh efn di tir fun a barak, ikh gib a kuk unter a koldre, es ligt a bavaksener mentsh" 
        intervals [477]:
            xmin = 1517.912 
            xmax = 1518.087 
            text = "" 
        intervals [478]:
            xmin = 1518.087 
            xmax = 1520.983 
            text = "aza min, ober mit azelkhene shey- sheyne gute oygn." 
        intervals [479]:
            xmin = 1520.983 
            xmax = 1521.377 
            text = "" 
        intervals [480]:
            xmin = 1521.377 
            xmax = 1525.415 
            text = "ikh gib a kuk, epes a bakanter, ver iz er?" 
        intervals [481]:
            xmin = 1525.415 
            xmax = 1529.136 
            text = "ikh hob es dermont. dos iz mayn amoliker lerer Yisroel Kaplan." 
        intervals [482]:
            xmin = 1529.136 
            xmax = 1535.09 
            text = "ikh hob im dakht zikh vegn dem dermont, er iz geven mayn ershter lerer in Slabodke." 
        intervals [483]:
            xmin = 1535.09 
            xmax = 1538.151 
            text = "" 
        intervals [484]:
            xmin = 1538.151 
            xmax = 1546.852 
            text = "er hot mir derzen, zogt er, o Gegele! er hot mir gerufn, in der tsayt fun lernen hot er hob ikh gehat a tsunomen Gegele, loyt der familye Geguzhinski." 
        intervals [485]:
            xmin = 1546.852 
            xmax = 1547.702 
            text = "" 
        intervals [486]:
            xmin = 1547.702 
            xmax = 1550.261 
            text = "Gegele, zogt er, bist do, zogt er, bist mayner a shiler!" 
        intervals [487]:
            xmin = 1550.261 
            xmax = 1550.402 
            text = "" 
        intervals [488]:
            xmin = 1550.402 
            xmax = 1553.403 
            text = "her tsu, efsher kenstu mir ton a toyve?" 
        intervals [489]:
            xmin = 1553.403 
            xmax = 1555.374 
            text = "zog mir, efsher kenstu mir brengen" 
        intervals [490]:
            xmin = 1555.374 
            xmax = 1555.431 
            text = "" 
        intervals [491]:
            xmin = 1555.431 
            xmax = 1561.46 
            text = "a pa- shtikl papir vayse. ot, zogt er, ikh kentik kentik gey ikh shoyn nit oyshaltn, zogt er, vayle zest dokh vi ikh lig oyf tifus krank." 
        intervals [492]:
            xmin = 1561.46 
            xmax = 1565.634 
            text = "ikh vel shoyn mistome shtarbn, ober farn toyt vil ikh onshraybn khotshabe vegn mayn lebn." 
        intervals [493]:
            xmin = 1565.634 
            xmax = 1565.725 
            text = "" 
        intervals [494]:
            xmin = 1565.725 
            xmax = 1567.018 
            text = "ikh hob nit oyf vos." 
        intervals [495]:
            xmin = 1567.018 
            xmax = 1568.307 
            text = "" 
        intervals [496]:
            xmin = 1568.307 
            xmax = 1574.859 
            text = "un a shtik papir iz geven shver tsu krign in lager. nor fun dest vegn bin ikh aroysgelofn fun fun zayn barak un ikh hob gezukht ikh hob gefunen a shtikl" 
        intervals [497]:
            xmin = 1574.859 
            xmax = 1577.227 
            text = "tsekneytshte papir un ikh hob im gegebn." 
        intervals [498]:
            xmin = 1577.227 
            xmax = 1577.79 
            text = "" 
        intervals [499]:
            xmin = 1577.79 
            xmax = 1582.61 
            text = "un azoy hot der eh der lerer Kaplan geshribn vegn zayn lebn in lager." 
        intervals [500]:
            xmin = 1582.61 
            xmax = 1583.089 
            text = "" 
        intervals [501]:
            xmin = 1583.089 
            xmax = 1585.592 
            text = "tsvishn andere vil ikh zogn az ersht nokhn krig," 
        intervals [502]:
            xmin = 1585.592 
            xmax = 1588.686 
            text = "tsufelik hob ikh geleyent a tsaytung, in der Yerusholaim Belite," 
        intervals [503]:
            xmin = 1588.686 
            xmax = 1588.776 
            text = "" 
        intervals [504]:
            xmin = 1588.776 
            xmax = 1593.326 
            text = "az s'gevorn nayntsik yor eynem a Yisroel Kaplan. nayntsik yor iz im gevorn." 
        intervals [505]:
            xmin = 1593.326 
            xmax = 1594.108 
            text = "" 
        intervals [506]:
            xmin = 1594.108 
            xmax = 1596.856 
            text = "m'hot im bagrist. un mit aza mit zayn fotografye." 
        intervals [507]:
            xmin = 1596.856 
            xmax = 1604.492 
            text = "ikh hob gegebn a kuk di fotografye, ikh geb a kuk, s'rikhtik s'mayn lerer. vi azoy iz er geblibn lebn? ikh hob zikh nit forgeshtelt az a mentsh velkher iz gelegn shoyn oyfn toytn bet" 
        intervals [508]:
            xmin = 1604.492 
            xmax = 1608.109 
            text = "hot zikh hot nokh derlebt biz nayntsik yor, er lebt in Yisroel." 
        intervals [509]:
            xmin = 1608.109 
            xmax = 1609.11 
            text = "" 
        intervals [510]:
            xmin = 1609.11 
            xmax = 1610.892 
            text = "un ikh hob gikh avekgeshikt a telegrame" 
        intervals [511]:
            xmin = 1610.892 
            xmax = 1611.895 
            text = "" 
        intervals [512]:
            xmin = 1611.895 
            xmax = 1615.297 
            text = "tsu im un ikh hob im bagrist mit zayn nayntsik yorikn iberley." 
        intervals [513]:
            xmin = 1615.297 
            xmax = 1616.299 
            text = "" 
        intervals [514]:
            xmin = 1616.299 
            xmax = 1617.899 
            text = "hob ikh glaykh tsurik gekrogn a briv," 
        intervals [515]:
            xmin = 1617.899 
            xmax = 1620.312 
            text = "mayn liber talmed, shraybt er tsu mir," 
        intervals [516]:
            xmin = 1620.312 
            xmax = 1623.974 
            text = "mir freyt zeyer vu du lebst un ikh vil dir zen. kum tsu forn." 
