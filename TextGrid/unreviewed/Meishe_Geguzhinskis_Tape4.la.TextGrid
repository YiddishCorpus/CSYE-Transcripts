            xmin = 1121.4 
            xmax = 1123.144 
            text = "" 
        intervals [350]:
            xmin = 1123.144 
            xmax = 1127.862 
            text = "in der zelber tsayt hot men shoyn oysgetseylt in arbets-lager az s'felt eyn mentsh." 
        intervals [351]:
            xmin = 1127.862 
            xmax = 1128.814 
            text = "" 
        intervals [352]:
            xmin = 1128.814 
            xmax = 1134.916 
            text = "hot men aroysgelozn di postns mit hint tsum zukhn dem mentshn. der mentsh bin geven UNK bin mir geven." 
        intervals [353]:
            xmin = 1134.916 
            xmax = 1137.252 
            text = "" 
        intervals [354]:
            xmin = 1137.252 
            xmax = 1138.657 
            text = "s'shoyn geven shpet," 
        intervals [355]:
            xmin = 1138.657 
            xmax = 1144.226 
            text = "un ikh hob eh farlorn di oryentatsye vu der lager gefint zikh, ikh hob ongehoybn tsu blondzhenen. ikh hob gevolt kumen shoyn aleyn in lager dokh vi nit iz," 
        intervals [356]:
            xmin = 1144.226 
            xmax = 1151.403 
            text = "vayl ikh hob farshtanen az m- az s'vet feln a mentsh veln mir shpeter vet men shpeter eh kenen derfar eh laydn di iberike oykh fun lager." 
        intervals [357]:
            xmin = 1151.403 
            xmax = 1152.321 
            text = "" 
        intervals [358]:
            xmin = 1152.321 
            xmax = 1156.123 
            text = "hob ikh genumen hob ikh eh ongehoybn blondzhenen, un ikh hob derhert" 
        intervals [359]:
            xmin = 1156.123 
            xmax = 1164.299 
            text = "es biln hint geferlekh, di m'hot aroysgef- aroysgekukt postns mit hint zukhn, mit shpir-hint zukhn dem ge- antlofenem mentshn." 
        intervals [360]:
            xmin = 1164.299 
            xmax = 1167.215 
            text = "un zey hobn mir gekhapt. zey farshteyt zikh mir glaykh gekhapt." 
        intervals [361]:
            xmin = 1167.215 
            xmax = 1167.323 
            text = "" 
        intervals [362]:
            xmin = 1167.323 
            xmax = 1173.713 
            text = "zey hobn mikh gekhapt, un avekge- tsu ersht hobn zey mir gut ongeshlogn, gegebn, gekrogn fun zey ge- gu- gute klep," 
        intervals [363]:
            xmin = 1173.713 
            xmax = 1174.123 
            text = "" 
        intervals [364]:
            xmin = 1174.123 
            xmax = 1178.998 
            text = "nor eyn daytsh velkher iz geven dortn der sh- der der eltster fun zey hot nit gelozt hargenen mir." 
        intervals [365]:
            xmin = 1178.998 
            xmax = 1181.473 
            text = "zogt er tsu mir, zogt er tsu zey tsu zey," 
        intervals [366]:
            xmin = 1181.473 
            xmax = 1184.898 
            text = "ikh vel zikh mit zey mit im, zogt er, aleyn oprekhenen. tshepet im nit." 
