            text = "" 
        intervals [125]:
            xmin = 420.385 
            xmax = 427.399 
            text = "bay di eh eh zayendik in in in lager, in Ponevezher lager. ikh hob gegebn a kuk oyf im," 
        intervals [126]:
            xmin = 427.399 
            xmax = 428.687 
            text = "" 
        intervals [127]:
            xmin = 428.687 
            xmax = 430.79 
            text = "er hot mir derkent, zogt er tsu mir," 
