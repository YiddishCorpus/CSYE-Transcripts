        intervals [324]:
            xmin = 1048.995 
            xmax = 1050.857 
            text = "un geven hungerik un oysgemutshet," 
        intervals [325]:
            xmin = 1050.857 
            xmax = 1057.016 
            text = "un ikh hob bash- ikh hob der- dersh- der- geyendik farbay geyendik tsu der ar- tsu der arbet, hob ikh bamerkt az s'do a feld" 
        intervals [326]:
            xmin = 1057.016 
            xmax = 1063.08 
            text = "bamerkt a feld fun kartofl. vos iz ge- vos dortn hobn opgevaksn kartofl." 
