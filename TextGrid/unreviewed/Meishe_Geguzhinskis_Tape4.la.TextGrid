        intervals [138]:
            xmin = 462.167 
            xmax = 470.432 
            text = "eh mayn eyntsiker veg vi noykem tsu noykem tsu zayn fun mayn gevezenem komendant. er hot mir oft mol andersh mol gemutshet mit ma- mit zayn gimnastik. ot er iz geven a a m-" 
