            text = "mir hobn im gekhapt. un mir darfn" 
        intervals [114]:
            xmin = 380.655 
            xmax = 381.538 
            text = "" 
        intervals [115]:
            xmin = 381.538 
            xmax = 389.412 
            text = "onnemen, m- m'darf hobn an eydes az er iz take geven, er leyknt, er zogt, er iz nit geven keyn komendant, er iz keyn, s'shoyn geven UNK in di nokhn krig." 
        intervals [116]:
            xmin = 389.412 
            xmax = 389.52 
            text = "" 
        intervals [117]:
            xmin = 389.52 
            xmax = 396.478 
            text = "m'darf hobn an eydes. az du vest kenen eydes az eh az er iz take geven a komendant fun yidishn lager un azoy vayter." 
        intervals [118]:
            xmin = 396.478 
            xmax = 404.055 
            text = "vayl m'darf im makhn oyf im a gerikht. darf im oder im oder im shisn, oder im vos nit iz dortn avek, araynzetsn efsher in turme." 
        intervals [119]:
            xmin = 404.055 
            xmax = 410.186 
            text = "ikh bin mit a groysn eh mit groys eh gevilt, gezen take," 
        intervals [120]:
            xmin = 410.186 
            xmax = 410.277 
            text = "" 
        intervals [121]:
            xmin = 410.277 
            xmax = 415.316 
            text = "ikh bin shoyn geven frayer mentsh, bin ikh gekumen tsu geyn in in K.G.B. un m'hot mir aroysgefirt" 
        intervals [122]:
            xmin = 415.316 
            xmax = 415.592 
            text = "" 
        intervals [123]:
            xmin = 415.592 
            xmax = 420.378 
            text = "dem komend- mayn mayn komendant un ikh hob im shoyn ge- ikh hob im gekent un er hot mir oykh gekent" 
        intervals [124]:
