            text = "" 
        intervals [328]:
            xmin = 1064.25 
            xmax = 1067.855 
            text = "hob ikh bashlosn zikh aroys tsu ganvenen funem arbets-ort ibern parkan," 
        intervals [329]:
            xmin = 1067.855 
            xmax = 1069.262 
            text = "" 
        intervals [330]:
            xmin = 1069.262 
            xmax = 1078.166 
            text = "in mitn der arbet az der postn zol mir nit bamerkn, un ikh zol efsher kenen on- on grablen a bisl kartofl un arayntsuleygn zikh bay zikh un arayntrogn in lager arayn." 
        intervals [331]:
            xmin = 1078.166 
            xmax = 1080.518 
            text = "" 
        intervals [332]:
            xmin = 1080.518 
            xmax = 1084.95 
            text = "ikh hob eh fun dem feld fun di kartofl fun dest vegn gefunen," 
        intervals [333]:
            xmin = 1084.95 
            xmax = 1085.175 
            text = "" 
        intervals [334]:
            xmin = 1085.175 
            xmax = 1089.86 
            text = "un ikh hob ongehoybn grablen untern shney, nor di- dine shikhtn shney, un ikh hob ongehoybn ganvenen di kartofl" 
        intervals [335]:
            xmin = 1089.86 
            xmax = 1090.002 
            text = "" 
        intervals [336]:
            xmin = 1090.002 
            xmax = 1092.402 
            text = "un geven zeyer tsufridn vos ikh zol kenen" 
        intervals [337]:
            xmin = 1092.402 
            xmax = 1097.977 
            text = "mit di kartoflekh efsher helfn zikh un dem f- mayn foter iz oykh geven in dem zelbn lager, khotsh helfn im, er iz gelegn krank." 
        intervals [338]:
            xmin = 1097.977 
            xmax = 1102.802 
            text = "un ikh hob im gevolt khotshik oysbrengen etlekhe kartofl tsum shtiln zayn hunger." 
        intervals [339]:
            xmin = 1102.802 
            xmax = 1103.653 
            text = "" 
        intervals [340]:
            xmin = 1103.653 
            xmax = 1108.797 
            text = "ikh hob zikh arayngeton in der a- in in dem grablen, az ikh hob fargesn di tsayt," 
        intervals [341]:
            xmin = 1108.797 
            xmax = 1111.329 
            text = "un in der zelber tsayt iz der arbets-brigade," 
        intervals [342]:
            xmin = 1111.329 
