            xmax = 74.582 
            text = "" 
        intervals [20]:
            xmin = 74.582 
            xmax = 82.238 
            text = "SO hot genumen a a gevise tsayt, epes ikh gedenk nisht genoy vifl vokhn zi iz geven in HOSPITAL." 
        intervals [21]:
            xmin = 82.238 
            xmax = 82.648 
            text = "" 
        intervals [22]:
            xmin = 82.648 
