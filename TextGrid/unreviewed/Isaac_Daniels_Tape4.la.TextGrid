        intervals [2]:
            xmin = 10.12 
            xmax = 19.124 
            text = "ikh bin ikh bin mit mayn froy bay t- akht ts- tsen teg, ven ikh bin gekumen." 
        intervals [3]:
            xmin = 19.124 
            xmax = 19.958 
            text = "" 
        intervals [4]:
            xmin = 19.958 
            xmax = 31.646 
            text = "mayn froy vert krank, krigt a tifus. m'nemt ir tsu in a HOSPITAL." 
        intervals [5]:
            xmin = 31.646 
            xmax = 33.593 
            text = "" 
        intervals [6]:
            xmin = 33.593 
            xmax = 43.357 
            text = "s'vayl di in mitn der nakht ho'mir nisht gevust vos s'iz geshen. m'hot hot ongehoybn tsu zingen fun groyse hits," 
        intervals [7]:
            xmin = 43.357 
            xmax = 43.954 
            text = "" 
        intervals [8]:
            xmin = 43.954 
            xmax = 49.635 
            text = "in der fri hob ikh gerufn a dokter un der dokter hot gezogt az zi hot a tifus, m'darf ir tsunemen in HOSPITAL arayn." 
        intervals [9]:
            xmin = 49.635 
            xmax = 49.945 
            text = "" 
        intervals [10]:
            xmin = 49.945 
            xmax = 54.579 
            text = "m'hot ir tsugenumen in HOSPITAL arayn, ikh hob shoyn nisht gekent geyn arbetn." 
        intervals [11]:
            xmin = 54.579 
            xmax = 54.67 
            text = "" 
        intervals [12]:
            xmin = 54.67 
            xmax = 56.452 
            text = "gemuzt zikh opgebn mitn kind." 
        intervals [13]:
            xmin = 56.452 
            xmax = 58.703 
            text = "" 
        intervals [14]:
            xmin = 58.703 
            xmax = 60.958 
            text = "MEANWHILE iz mayn bruder gekumen." 
        intervals [15]:
            xmin = 60.958 
            xmax = 61.808 
            text = "" 
        intervals [16]:
            xmin = 61.808 
            xmax = 67.843 
            text = "un er hot nisht gekent zayn mit mir, er hot gezen di situatsye, iz er avek keyn Byalistok." 
        intervals [17]:
            xmin = 67.843 
            xmax = 68.423 
            text = "" 
        intervals [18]:
            xmin = 68.423 
            xmax = 72.399 
            text = "eh ikh hob im azoy lib gehat az az ikh hob gekhalesht far im." 
