            xmax = 244.75 
            text = "" 
        intervals [78]:
            xmin = 244.75 
            xmax = 248.675 
            text = "in untern barg. azoy in barg iz geven tuneln." 
        intervals [79]:
            xmin = 248.675 
            xmax = 249.019 
            text = "" 
        intervals [80]:
            xmin = 249.019 
            xmax = 253.485 
            text = "m'hot gerisn di shteyn, un undz ho'mir gelodnt dem shteyn oyf azelkhe" 
        intervals [81]:
