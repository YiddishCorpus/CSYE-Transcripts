            xmax = 140.007 
            text = "" 
        intervals [43]:
            xmin = 140.007 
            xmax = 144.456 
            text = "fun Bukhnvald ikh veys nisht vifl, tsi a sho, tsvey sho, ikh veys nisht vifl m'iz geforn." 
        intervals [44]:
            xmin = 144.456 
            xmax = 145.356 
            text = "" 
        intervals [45]:
            xmin = 145.356 
            xmax = 149.569 
            text = "un dort, der lager iz gevezn azoy a bisl vi in a barg," 
        intervals [46]:
            xmin = 149.569 
            xmax = 150.064 
            text = "" 
        intervals [47]:
            xmin = 150.064 
            xmax = 155.39 
            text = "ibern lager iz geven ongetsoygn aza nets tunkl grin mit LIGET grin," 
        intervals [48]:
            xmin = 155.39 
            xmax = 155.7 
            text = "" 
        intervals [49]:
            xmin = 155.7 
            xmax = 161.466 
            text = "az m'zol nisht zen fun di luftn, dos iz gevezn gleyb ikh epes a sekretisher lager." 
        intervals [50]:
            xmin = 161.466 
            xmax = 163.024 
            text = "" 
        intervals [51]:
            xmin = 163.024 
            xmax = 165.33 
            text = "dortn iz geven blokn." 
        intervals [52]:
            xmin = 165.33 
            xmax = 166.652 
            text = "" 
        intervals [53]:
            xmin = 166.652 
            xmax = 172.771 
            text = "dem ershtn tog, undz ze'mir ongekumen nokh mitog, dos iz gevezn ober shvues ober erev shvues." 
        intervals [54]:
            xmin = 172.771 
            xmax = 175.174 
            text = "" 
        intervals [55]:
            xmin = 175.174 
            xmax = 185.006 
            text = "hot men undz genumen un m'hot undz avekgefirt oyf a barg, un m'hot undz gegebn azolkhe, veyst ir, grobn, azoy vi m'grobt leym, azolkhe deys fun ayzn," 
        intervals [56]:
            xmin = 185.006 
            xmax = 185.215 
            text = "" 
        intervals [57]:
            xmin = 185.215 
            xmax = 190.474 
            text = "hot men undz gegebn grobn, dos iz geven a shteyn, der shteyn iz geven a harter shteyn," 
        intervals [58]:
            xmin = 190.474 
            xmax = 190.53 
            text = "" 
        intervals [59]:
            xmin = 190.53 
            xmax = 193.595 
            text = "er hot gehart a farb bloyer farb vi dem himl." 
        intervals [60]:
            xmin = 193.595 
            xmax = 193.669 
            text = "" 
        intervals [61]:
            xmin = 193.669 
            xmax = 196.312 
            text = "un m'hot undz geheysn grobn dem shteyn." 
        intervals [62]:
            xmin = 196.312 
            xmax = 197.623 
            text = "" 
        intervals [63]:
            xmin = 197.623 
            xmax = 205.883 
            text = "grobn. dos hot men nisht gekont grobn, tsores oysteyln. m'hot undz geheysn grobn dem shteyn, dos hot geshpritst azolkhe shtikelekh funem shteyn," 
        intervals [64]:
            xmin = 205.883 
            xmax = 208.108 
            text = "dos ponem iz gevezn blutik," 
        intervals [65]:
            xmin = 208.108 
            xmax = 208.333 
            text = "" 
        intervals [66]:
            xmin = 208.333 
            xmax = 213.93 
            text = "un fun untn hobn di S.S. geshrign LASS! LASS! vu m'hot geharget un geshlogn." 
        intervals [67]:
            xmin = 213.93 
            xmax = 214.425 
            text = "" 
        intervals [68]:
            xmin = 214.425 
            xmax = 221.473 
            text = "vi men hot dos geendikt, m'hot undz gebrengt arop hot men undz gezogt, az deys a matone oyf shvues." 
        intervals [69]:
            xmin = 221.473 
            xmax = 223.673 
            text = "" 
        intervals [70]:
            xmin = 223.673 
            xmax = 226.485 
            text = "nu m'hot m'hot geharget un geshlogn, m'hot undz geplogt." 
        intervals [71]:
            xmin = 226.485 
            xmax = 228.769 
            text = "" 
        intervals [72]:
            xmin = 228.769 
            xmax = 235.006 
            text = "dernokh dem hob ikh dortn gearbet, dos iz ales geven in a tunel, untern tunel," 
        intervals [73]:
            xmin = 235.006 
            xmax = 235.215 
            text = "" 
        intervals [74]:
            xmin = 235.215 
            xmax = 242.397 
            text = "m'hot gerisn alts tifer un unter dem tunel iz geven farshidene apteylungen, ikh gleyb s'hot gedarft zayn militerishe fabrikn." 
        intervals [75]:
            xmin = 242.397 
            xmax = 243.417 
            text = "" 
        intervals [76]:
            xmin = 243.417 
            xmax = 244.406 
            text = "dort," 
        intervals [77]:
