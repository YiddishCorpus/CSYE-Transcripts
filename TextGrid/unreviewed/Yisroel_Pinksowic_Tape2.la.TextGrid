            xmax = 520.808 
            text = "" 
        intervals [171]:
            xmin = 520.808 
            xmax = 525.779 
            text = "shtarbn vel ikh nisht oyshaltn oyf der arbet naketerheyt, un ikh vel do vet men mikh hargenen." 
