        intervals [152]:
            xmin = 452.852 
            xmax = 455.175 
            text = "un m'hot genumen oyskokhn di zakhn." 
        intervals [153]:
            xmin = 455.175 
            xmax = 456.75 
            text = "" 
        intervals [154]:
            xmin = 456.75 
            xmax = 464.742 
            text = "bay nakht hot men gebrengt di zakhn, m'hot gezogt yeder zol vartn, m'vet rufn yedern's numer un yeder's vet zikh kumen mit dem numer tsunemen in blok." 
        intervals [155]:
            xmin = 464.742 
            xmax = 466.977 
            text = "" 
        intervals [156]:
            xmin = 466.977 
            xmax = 470.498 
            text = "NO, m'hot dos genumen un m'hot dos m'hot dem" 
        intervals [157]:
            xmin = 470.498 
            xmax = 472.714 
            text = "" 
        intervals [158]:
            xmin = 472.714 
            xmax = 477.28 
            text = "m'hot nisht gevasht gornisht. gornisht hot men nisht gevashn." 
        intervals [159]:
            xmin = 477.28 
            xmax = 479.667 
            text = "" 
        intervals [160]:
            xmin = 479.667 
            xmax = 486.276 
            text = "m'hot ongehoybn tsu rufn, ikh hob gevart un gevart, m'hot nisht gerufn. nokh dem, s'shoyn ales tsegangen, ikh bin shoyn geven zeyer shvakh," 
        intervals [161]:
            xmin = 486.276 
            xmax = 487.007 
            text = "" 
        intervals [162]:
            xmin = 487.007 
            xmax = 492.451 
            text = "bin ikh avek ikh hob getrofn dortn kleyder, ikh hob ongetun di kleyder, s'nisht mayn numer," 
        intervals [163]:
            xmin = 492.451 
            xmax = 493.791 
            text = "" 
        intervals [164]:
            xmin = 493.791 
            xmax = 502.762 
            text = "s'iz di kni iz im naket, ales tserisn di kleyder in gantsn, yeder iz tseklapt. un ikh hob ongehoybn tsu veynen, vi zol ikh geyn? un m'shrayt shoyn, ""geyn aroys oyf der arbet!""" 
        intervals [165]:
            xmin = 502.762 
            xmax = 504.912 
            text = "" 
        intervals [166]:
            xmin = 504.912 
            xmax = 511.641 
            text = "ikh bin aroysgega- arayngegangen in di SHIRUTIM iz dort geven azoy vu dort iz geven rusishe gefangene," 
        intervals [167]:
            xmin = 511.641 
            xmax = 518.641 
            text = "zey hobn gehat azelkhe tserisene kleyder, zey hobn avekgevorfn in der kanalizatsye, in BIYUV, un ikh hob mayn oykhet aropgevorfn in BIYUV." 
        intervals [168]:
