        intervals [125]:
            xmin = 381.522 
            xmax = 388.434 
            text = "Dora, keyn Ha- Hartsungen un keyn Erlikh. nor Erlikh hot men gefirt, dos iz geven vayt, hot men gefirt mitn tsug." 
