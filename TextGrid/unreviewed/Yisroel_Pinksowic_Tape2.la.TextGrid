            xmax = 38.399 
            text = "A-" 
        intervals [13]:
            xmin = 38.399 
            xmax = 40.981 
            text = "Avraham. dernokh dem iz er gekumen," 
        intervals [14]:
            xmin = 40.981 
            xmax = 46.634 
            text = "hot er mir gezogt az im hot men fotografirt, un dort iz geven ven m'hot fotografirt," 
        intervals [15]:
            xmin = 46.634 
            xmax = 50.31 
            text = "m'hot avekgefirt un m'hot fotografirt mitn," 
        intervals [16]:
            xmin = 50.31 
            xmax = 50.502 
            text = "" 
        intervals [17]:
            xmin = 50.502 
            xmax = 57.128 
            text = "der numer iz geven oyfn hemd un m'hot opgefotografirt dos ponem, eyn mol in hitl un eyn onem hitl," 
        intervals [18]:
            xmin = 57.128 
            xmax = 58.703 
            text = "" 
        intervals [19]:
            xmin = 58.703 
            xmax = 63.27 
            text = "az hot er zikh fun mir opgezegnt az m- im firt men avek." 
        intervals [20]:
            xmin = 63.27 
            xmax = 63.478 
            text = "" 
        intervals [21]:
            xmin = 63.478 
            xmax = 70.559 
            text = "ober er hot zikh nisht geshtelt oyfn MASAIT, iz er tsurikgekumen, iz er gekumen er hot mir tsurik gezogt az er iz nisht avekgeforn," 
        intervals [22]:
            xmin = 70.559 
            xmax = 71.275 
            text = "" 
        intervals [23]:
            xmin = 71.275 
            xmax = 74.981 
            text = "un in dem tog hot men mikh avekgefirt fotografirn," 
        intervals [24]:
            xmin = 74.981 
            xmax = 75.78 
            text = "" 
        intervals [25]:
            xmin = 75.78 
            xmax = 84.481 
            text = "hob ikh im gezogt az mikh hot men shoyn fotografirt, dem andern tog hot men undz gefirt avek, iz er gekumen er hot mikh baleyt azoy fun der vaytns," 
        intervals [26]:
            xmin = 84.481 
            xmax = 86.125 
            text = "" 
        intervals [27]:
            xmin = 86.125 
            xmax = 103.466 
            text = "er hot geveynt, undz hot men oyfgelodnt oyf a MASAIT, oyf aza gedektn MASAIT," 
        intervals [28]:
            xmin = 103.466 
            xmax = 104.113 
            text = "" 
        intervals [29]:
            xmin = 104.113 
            xmax = 106.756 
            text = "un m'hot undz avekgefirt, ikh veys nisht vifl," 
        intervals [30]:
            xmin = 106.756 
            xmax = 107.877 
            text = "" 
        intervals [31]:
            xmin = 107.877 
            xmax = 110.486 
            text = "neyn, er iz geblibn dort in lager." 
        intervals [32]:
            xmin = 110.486 
            xmax = 111.049 
            text = "" 
        intervals [33]:
            xmin = 111.049 
            xmax = 112.798 
            text = "un mikh hot men avekgefirt." 
        intervals [34]:
            xmin = 112.798 
            xmax = 113.175 
            text = "" 
        intervals [35]:
            xmin = 113.175 
            xmax = 119.987 
            text = "un m'hot undz avekgefirt, ikh veys nisht vifl tsayt mir ze'mir geforn, a por sho." 
        intervals [36]:
            xmin = 119.987 
            xmax = 120.178 
            text = "" 
        intervals [37]:
            xmin = 120.178 
            xmax = 127.091 
            text = "ze'mir ongekumen in a filyal fun Bukhnvald Dora. a lager Dora." 
        intervals [38]:
            xmin = 127.091 
            xmax = 133.375 
            text = "" 
        intervals [39]:
            xmin = 133.375 
            xmax = 135.428 
            text = "an arbayts-lager Dora." 
        intervals [40]:
            xmin = 135.428 
            xmax = 136.108 
            text = "" 
        intervals [41]:
            xmin = 136.108 
            xmax = 137.435 
            text = "der arbayts-" 
