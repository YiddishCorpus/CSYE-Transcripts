        intervals [148]:
            xmin = 442.71 
            xmax = 444.577 
            text = "ir veyst vos kinim heyst?" 
        intervals [149]:
            xmin = 444.577 
            xmax = 445.073 
            text = "" 
        intervals [150]:
            xmin = 445.073 
            xmax = 452.424 
            text = "iz men gekumen, m'hot geheysn far yedern oystun di zakhn un tsambindn di zakhn in aza pekele, un oyvn zol blaybn di numer," 
        intervals [151]:
            xmin = 452.424 
            xmax = 452.852 
