            text = "nu in vagondlekh kleyne, un gefirt aroys dem shteyn." 
        intervals [83]:
            xmin = 257.687 
            xmax = 258.975 
            text = "" 
        intervals [84]:
            xmin = 258.975 
            xmax = 265.823 
            text = "ikh bin gevezn dortn oyf der arbet beerekh efsher a finef zeks vokhn." 
        intervals [85]:
            xmin = 265.823 
            xmax = 269.013 
            text = "un dernokh dem hot men mikh shoyn nisht gebrengt" 
        intervals [86]:
            xmin = 269.013 
