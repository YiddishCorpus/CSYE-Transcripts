            xmax = 124.296 
            text = "" 
        intervals [36]:
            xmin = 124.296 
            xmax = 130.246 
            text = "in eh s'hot gekent zayn demolts ikh veys eh efsher APRIL. far APRIL, APRIL." 
        intervals [37]:
