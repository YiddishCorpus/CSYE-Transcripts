            text = "" 
        intervals [98]:
            xmin = 332.179 
            xmax = 337.32 
            text = "hot zi mir geshikt a pak mit esn mit trinken mit shokolad mit ale gute zakhn, un do a por shikh." 
        intervals [99]:
            xmin = 337.32 
            xmax = 337.377 
            text = "" 
        intervals [100]:
            xmin = 337.377 
            xmax = 339.565 
            text = "zogt er na dir, di mame hot dir geshikt a por shikh." 
