            xmax = 1422.284 
            text = "ikh hob im getrofn in Sandormierzh, un dan bin ikh gegangen ikh hob im aribergefirt un tsurik keyn Daytshland tsu mir aheym." 
        intervals [407]:
            xmin = 1422.284 
            xmax = 1427.647 
