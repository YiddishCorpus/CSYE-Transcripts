            text = "y- neyn." 
        intervals [48]:
            xmin = 153.208 
            xmax = 157.5 
            text = "vi lang ikh bin gevezn dortn bin ikh yedes mol tsugeforn tsu zey. vi lang ikh bin geven in Daytshland." 
        intervals [49]:
            xmin = 157.5 
            xmax = 157.911 
            text = "" 
        intervals [50]:
            xmin = 157.911 
            xmax = 162.5 
            text = "ANYWAYS eh hot er gen- eh genumen, er hot mikh arayngefirt, m'hot mikh opgevashn mikh" 
        intervals [51]:
            xmin = 162.5 
            xmax = 162.522 
            text = "" 
        intervals [52]:
            xmin = 162.522 
            xmax = 168.454 
            text = "in vald, m'hot mikh ongetun amerikaner kleyder, mit shikh, mit alem. yeder eyner hot mir gegebn a por dolar in tash arayn, mit a tayster." 
        intervals [53]:
            xmin = 168.454 
            xmax = 171.227 
            text = "m'hot mikh ongetun a brandzelet, m'hot mir gegebn a zeyger," 
        intervals [54]:
            xmin = 171.227 
            xmax = 174.636 
            text = "un ongetun a brandzelet oyf der hant, a gevorn a gantser amerikaner." 
        intervals [55]:
            xmin = 174.636 
            xmax = 179.693 
            text = "zogt zi mir der ofitsir, ""morgn darf vern Minkhn genumen." 
        intervals [56]:
            xmin = 179.693 
            xmax = 185.608 
            text = "morgn vet faln Minkhn,"" zogt er, vet men araynforn in shtot arayn, ikh vel dikh arayngebn, zogt er, in a plats," 
        intervals [57]:
            xmin = 185.608 
            xmax = 190.119 
            text = "vu du vest dikh erhoyln dikh. ikh hob gevoygn demolts draysik kilo." 
        intervals [58]:
