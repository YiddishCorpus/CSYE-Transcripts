        intervals [145]:
            xmin = 498.398 
            xmax = 510.542 
            text = "mir zenen in TROUBLE, mir zenen gekumen farkhapn vos shneler di yunge khevre vos hobn zikh bafrayt brengen keyn Yisroel, untershraybn far a yor. shpeter hostu dayn rekht, kenst aroysforn, kenst forn keyn Amerike, vu du vest veln." 
        intervals [146]:
            xmin = 510.542 
            xmax = 510.548 
            text = "" 
        intervals [147]:
            xmin = 510.548 
            xmax = 518.666 
            text = "kum HELP US, mir zenen on mentshn. di arabishe velt kemft kegn undz, un mir hobn atsind a medine vos mir viln onhaltn." 
        intervals [148]:
            xmin = 518.666 
            xmax = 521.702 
            text = "" 
        intervals [149]:
            xmin = 521.702 
            xmax = 525.257 
            text = "dos iz gevezn in akht un fertsikstn yor." 
