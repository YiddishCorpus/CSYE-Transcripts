            xmax = 1011.364 
            text = "" 
        intervals [293]:
            xmin = 1011.364 
            xmax = 1016.64 
            text = "zey makhn op, zey hobn oyfgemakht aza min fayer az m'hot gekent zen di mentshn oykhet." 
        intervals [294]:
            xmin = 1016.64 
            xmax = 1016.663 
            text = "" 
        intervals [295]:
            xmin = 1016.663 
            xmax = 1019.444 
            text = "zey hobn gevorfn azelkhe vos heyst MEVAYER." 
        intervals [296]:
            xmin = 1019.444 
            xmax = 1026.675 
            text = "un do ze ikh az m'kumt arayn in mitn feld un di mentshn loyfn tsurik. un di ofitsirn shrayen KADIMA!" 
        intervals [297]:
            xmin = 1026.675 
            xmax = 1034.223 
            text = "un m'hakt. vifl s'vet blaybn, tsu tsu der vant. az ikh loyf tsu der vant, er shteyt in der heykh, ken nisht, er ken mir shisn nor vi lang du shteyst dortn." 
        intervals [298]:
