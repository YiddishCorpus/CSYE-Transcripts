            xmax = 627.53 
            text = "un dos iz es. m'iz arayngeforn keyn Marsel," 
        intervals [177]:
            xmin = 627.53 
            xmax = 633.56 
            text = "un ikh bin dortn gezisn efsher tsvey vokhn, biz m'hot tsugegreyt m'hot tsugegreyt a shif, un di shif hot geheysn Pan York," 
        intervals [178]:
            xmin = 633.56 
