            text = "" 
        intervals [104]:
            xmin = 342.945 
            xmax = 345.979 
            text = "ver eh vi an <yidishn> briv <gefinen> azoy fil yorn." 
        intervals [105]:
            xmin = 345.979 
            xmax = 354.56 
            text = "un er hot mir gezogt mir efsher vilstu mitforn? zog ikh, NO, un vi ken ikh avekforn avekforn, tomer ikh vil dokh geyn FAMILY, ikh vil dokh geyn, efsher iz geblibn a bruder, a shvester, iz geblibn emetsn, vi ken ikh a," 
        intervals [106]:
            xmin = 354.56 
            xmax = 354.579 
            text = "" 
        intervals [107]:
            xmin = 354.579 
            xmax = 359.539 
            text = "ikh hob gemeynt Amerike iz der sof der velt, fertik, ver vet visn fun mir UNK ikh bin geblibn lebn?" 
        intervals [108]:
            xmin = 359.539 
            xmax = 359.719 
            text = "" 
        intervals [109]:
            xmin = 359.719 
            xmax = 362.559 
            text = "ANYWAYS, er iz a- tsurik avekgeforn un ikh bin geblibn." 
        intervals [110]:
            xmin = 362.559 
            xmax = 367.499 
            text = "ikh bin aroysgegangen fun der ARMY, un ikh bin arayngegangen bay tsu di daytshn un ikh hob gebetn zol mir gebn a voynung." 
        intervals [111]:
            xmin = 367.499 
            xmax = 372.067 
            text = "hot men mir gegebn tsen adresn, ikh zol mir geyn zukhn velkhe vile. in Minkhn aleyn." 
        intervals [112]:
            xmin = 372.067 
            xmax = 377.067 
            text = "hob ikh gezukht, Minkhn iz geven tsehakt, nor di di forshtot iz gevezn fayn," 
        intervals [113]:
            xmin = 377.067 
            xmax = 382.977 
            text = "hob ikh gegangen un ikh hob ge- ikh bin arayngekumen ershtn plats, un vu ikh hob ge- aray- arayngegangen, gezen aza sheyne vile, aza sheyne hoyz," 
        intervals [114]:
            xmin = 382.977 
            xmax = 382.978 
            text = "" 
        intervals [115]:
            xmin = 382.978 
            xmax = 386.73 
            text = "zogt di froy, ""JA, KANST MAL blaybn. bistu MAL farheyrat?"" zog ikh, UNK farheyrat?" 
        intervals [116]:
            xmin = 386.73 
            xmax = 386.77 
            text = "" 
        intervals [117]:
            xmin = 386.77 
            xmax = 390.476 
            text = "spn ver farheyrat? ikh bin dokh gantsn gantsn yung." 
        intervals [118]:
            xmin = 390.476 
            xmax = 390.769 
            text = "" 
        intervals [119]:
            xmin = 390.769 
            xmax = 398.88 
            text = "tsk demolts bin ikh alt geven zibetsn un a halbn yor. loyt loyt dem loyt dem nayem TARICH vos hob ikh gegebn. ANYWAYS, dos iz gevezn" 
        intervals [120]:
            xmin = 398.88 
            xmax = 398.937 
            text = "" 
        intervals [121]:
            xmin = 398.937 
            xmax = 402.147 
            text = "un ikh bin geblibn dortn, ikh hob genumen dos hoyz," 
        intervals [122]:
            xmin = 402.147 
            xmax = 407.665 
            text = "un eh un zi hot ge- zi hot gefregt mikh tsi zi darft aroysgeyn. vayl ikh nem iber, darfn zey aroysgeyn." 
        intervals [123]:
            xmin = 407.665 
            xmax = 415.739 
            text = "keyn kinder hobn zey nisht gehat, er iz shoyn geven an elterer mentsh, er hot gearbet bay di, a a tsug firer iz er gevezn, bay di RAKEVET. a firer." 
        intervals [124]:
            xmin = 415.739 
            xmax = 422.332 
            text = "hob ikh mir getrakht ven vi? ikh darf dokh say vi hobn emetsn ver s'zol kokhn, ver s'zol mir vashn, ver s'zol mir tun, ikh bin dokh a BOY aleyn. vos vel ikh zey geyn zogn, blaybts." 
        intervals [125]:
            xmin = 422.332 
            xmax = 426.999 
            text = "un zey iz geven tsufridn, di gantse gas hot geredt derfun, get nor a kuk vos far a gutn mentsh zey hobn arayn gekrign," 
        intervals [126]:
            xmin = 426.999 
            xmax = 431.651 
            text = "az ikh loz zey loz- az zey hobn gedorfn aroysgeyn di TSRAFIM. zog ikh, ir kent blaybn." 
        intervals [127]:
            xmin = 431.651 
            xmax = 431.944 
            text = "" 
        intervals [128]:
            xmin = 431.944 
            xmax = 433.44 
            text = "un dort bin ikh geblibn," 
        intervals [129]:
            xmin = 433.44 
            xmax = 436.973 
            text = "" 
        intervals [130]:
            xmin = 436.973 
            xmax = 440.749 
            text = "yo. ven ikh volt gevolt, geyen zey glaykh aroys. zey hobn badorfn aroysgeyn." 
        intervals [131]:
            xmin = 440.749 
            xmax = 450.166 
            text = "azoy vi zey hobn mir gegebn dos tsetl hobn zey mir gezogt mir du kumst tsurik un du zogst s'gefelt dir dos hoyz, krigstu a tsetl az di kenst tsugeyn tsu der POLICE, di POLICE vet mit dir mitgeyn az zey zoln shoyn aroysgeyn." 
        intervals [132]:
            xmin = 450.166 
            xmax = 454.467 
            text = "du nemst iber dos hoyz. bin ikh gegangen aleyn. ober," 
        intervals [133]:
            xmin = 454.467 
            xmax = 464.282 
            text = "ikh bin dortn geblibn un ikh hob zikh farshribn oykhet tsu forn keyn Amerike, un m'hot mir ge- tsugegreyt eh HORIM, eltern do in Amerike, un tsu vemen ikh zol arayngeyn, vu ikh zol arayngeyn," 
        intervals [134]:
            xmin = 464.282 
            xmax = 467.541 
            text = "un zey hobn mir alts erleydikt mir, un ikh hob gevart." 
        intervals [135]:
            xmin = 467.541 
            xmax = 474.134 
            text = "bizkale azoy akht un fertsikstn yor, hob ikh geshvoyrn, m'hot mikh gerufn tsu der amerikaner konsul" 
        intervals [136]:
            xmin = 474.134 
            xmax = 477.097 
            text = "in Minkhn, un ikh hob opgeshvoyrn far Amerike," 
        intervals [137]:
            xmin = 477.097 
            xmax = 483.764 
            text = "un m'hot mir gezogt mir dos iz es. gey aheym, pak di valizkes, m'veyst nisht ven der transport vet opforn, biz s'vet zayn genug mentshn" 
        intervals [138]:
            xmin = 483.764 
            xmax = 483.767 
            text = "" 
        intervals [139]:
            xmin = 483.767 
            xmax = 486.393 
            text = "vet men makhn a transport, un m'vet dikh avekshikn." 
        intervals [140]:
            xmin = 486.393 
