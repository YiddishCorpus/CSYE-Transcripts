            text = "" 
        intervals [88]:
            xmin = 293.704 
            xmax = 301.758 
            text = "ikh vil dikh oysheyln un makhn hundert protsentik. ikh vil dir aroysnemen dem gantse vorem fun Oyshvits, un aroysnemen fun dir ales.""" 
        intervals [89]:
            xmin = 301.758 
            xmax = 311.175 
            text = "du torst nisht, un dan hot er mir gegebn a DIET dos yo, un dos haynt yo, un dos nisht, un dos yo. un biz ikh gelign dortn fir vokhn, bin ikh aroys a yung." 
        intervals [90]:
            xmin = 311.175 
            xmax = 315.402 
            text = "a gantser SOLDIER. un er iz gekumen der ofitsir mikh yedn tog bafr- eh yedn tog mir VISITn." 
        intervals [91]:
            xmin = 315.402 
            xmax = 320.361 
            text = "un ikh bin aroysgekumen hob ho- hot er mir, bin ikh bay im geven bay im in der TZAVA, bay dem in der ARMY," 
        intervals [92]:
