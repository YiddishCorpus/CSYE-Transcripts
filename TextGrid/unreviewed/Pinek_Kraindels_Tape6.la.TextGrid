            text = "" 
        intervals [327]:
            xmin = 1137.437 
            xmax = 1142.797 
            text = "un geyt mit di FLASHLIGHT un er CHECKt arum, zogt er, host ale opgeha- ale opgehakt mit di kep. ale zenen toyt." 
        intervals [328]:
            xmin = 1142.797 
            xmax = 1143.394 
            text = "" 
        intervals [329]:
            xmin = 1143.394 
            xmax = 1148.822 
            text = "un m'hot farnumen dem gantsn EMDA, tsu morgns, m'hot gehat toyte genug," 
