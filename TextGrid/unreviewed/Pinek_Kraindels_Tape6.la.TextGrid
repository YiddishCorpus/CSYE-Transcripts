            xmax = 193.517 
            text = "" 
        intervals [59]:
            xmin = 193.517 
            xmax = 197.915 
            text = "un azoy iz es gevezn, tsu morgns, un ikh bin geven mit zey, m'hot mir gegebn" 
        intervals [60]:
            xmin = 197.915 
            xmax = 198.057 
            text = "" 
        intervals [61]:
            xmin = 198.057 
            xmax = 206.423 
            text = "eh vos tsu esn nisht keyn SPECIAL, vayl vayl a sakh zenen avekgegangen fun esn bald toyt. ober m'hot mir gege- gegebn nor vos nor tsu derkhapn dos harts." 
        intervals [62]:
            xmin = 206.423 
            xmax = 209.086 
            text = "zogt er, ""morgn vestu ales visn vos du darfst esn.""" 
        intervals [63]:
            xmin = 209.086 
            xmax = 209.11 
            text = "" 
        intervals [64]:
            xmin = 209.11 
            xmax = 216.832 
            text = "tsu morgns tsvey a zeyger kumt a PHONE CALL, Minkhn iz gevorn genumen, durkh di amerikaner, bafrayt." 
        intervals [65]:
            xmin = 216.832 
            xmax = 222.432 
            text = "iz aroysgegangen di SHAYAROT, aroysgeforn ale di tanken, ikh bin geforn mit dem ofitsir bay im in Dzhip" 
        intervals [66]:
            xmin = 222.432 
            xmax = 225.266 
            text = "biz m'iz arayngekumen keyn Minkhn. m'iz arayngekumen keyn Minkhn," 
        intervals [67]:
            xmin = 225.266 
            xmax = 231.433 
            text = "iz er gegangen zukhn dem plats vu arayntsugebn mikh, un er hot getrofn dem plats, vayl dortn zenen arayngekumen oykhet amerikaner tsu erhoyln zikh," 
        intervals [68]:
            xmin = 231.433 
            xmax = 235.599 
            text = "vos zey hobn farloyrn a sakh vog un azoy vayter, zenen geven opgeshvakht," 
        intervals [69]:
            xmin = 235.599 
            xmax = 243.433 
            text = "zenen oykh dortn arayngekumen. ikh geb a kum arum, un get a kum zitsn mit dem firer fun der HOSPITAL, iz oykhet dortn, geyt er a f- a fartekh, ver veyst dokh ver dos iz." 
        intervals [70]:
            xmin = 243.433 
            xmax = 243.489 
            text = "" 
        intervals [71]:
            xmin = 243.489 
            xmax = 245.809 
            text = "zogt er, PAPER, PAPER." 
        intervals [72]:
            xmin = 245.809 
            xmax = 251.466 
            text = "zogt er mir der amerikaner tsu im, zog nisht keyn PAPER, er iz nisht keyn amerikaner. ikh bin gegangen ongetun amerikaner kleyder." 
        intervals [73]:
            xmin = 251.466 
            xmax = 251.541 
            text = "" 
        intervals [74]:
            xmin = 251.541 
            xmax = 260.975 
            text = "zogt er iz a a yid fun Poyln vos iz bafrayt fun Oyshvits. mir hobn im bafrayt. mir hobn im getrofn in zayn PASIAK mit alem." 
        intervals [75]:
            xmin = 260.975 
            xmax = 265.675 
            text = "m'hot ongetun amerikaner kleyder. ""oyb azoy yingele, kum aher."" redt er oykh tsu mir yidish." 
        intervals [76]:
            xmin = 265.675 
            xmax = 270.951 
            text = "un leygt mikh avek un zogt on di ale shvesters zey zoln afile nisht aropgegangen vegn TOILET, az m'zol alts far mir tun." 
        intervals [77]:
