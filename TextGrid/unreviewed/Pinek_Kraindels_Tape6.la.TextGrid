        intervals [84]:
            xmin = 280.68 
            xmax = 285.68 
            text = "hob ikh gezogt tsum dokter, ""lomikh shoyn aroys, lomikh zen di mapole fun di daytshn."" zogt er, yingele, zogt er," 
        intervals [85]:
            xmin = 285.68 
            xmax = 291.16 
            text = """ikh vel dikh aroyslozn ven ikh vel dir zogn gey. vi lang ikh zog nisht get vestu do zayn." 
        intervals [86]:
            xmin = 291.16 
            xmax = 293.66 
            text = "un du vest mikh gedenken dos gantse lebn." 
        intervals [87]:
            xmin = 293.66 
