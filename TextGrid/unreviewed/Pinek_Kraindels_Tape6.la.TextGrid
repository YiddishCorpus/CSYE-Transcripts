            text = "" 
        intervals [301]:
            xmin = 1037.367 
            xmax = 1041.327 
            text = "ikh hob nor gekemft mit di egipter. nor mit di egipter." 
        intervals [302]:
            xmin = 1041.327 
            xmax = 1041.486 
            text = "" 
        intervals [303]:
            xmin = 1041.486 
            xmax = 1048.207 
            text = "un ikh heyb mikh oyf un ikh gib a a loyf aroys, ir hert, fun di shure aroys, un gib zikh a ruk avek in der linker zayt," 
        intervals [304]:
            xmin = 1048.207 
            xmax = 1053.194 
            text = "un ikh loyf tsu tsu der vant, tsum barg, un ikh loyf aroys oyfn barg," 
        intervals [305]:
            xmin = 1053.194 
            xmax = 1059.772 
            text = "un der ofitsir shrayt, Pinek! ANI LO SHOMEA OTCHA. e- der eyntsiker mashin-GUN, er hert nisht er hert nisht mayn mashin arbetn." 
        intervals [306]:
            xmin = 1059.772 
            xmax = 1061.28 
            text = "" 
        intervals [307]:
            xmin = 1061.28 
            xmax = 1072.31 
            text = "un ikh tor nisht redn. ikh loyf aroys oyfn barg, un di mashin-GUNS fun di araber klapn do oyf di khevre. zey hobn gehat di di Vikers, englisher mashinen. azoy hot es geshosn." 
        intervals [308]:
            xmin = 1072.31 
            xmax = 1072.367 
            text = "" 
        intervals [309]:
            xmin = 1072.367 
            xmax = 1081.878 
            text = "un ikh gib mikh a khap aroyf oyfn barg un ikh shtey shoyn in di zelbe DARGA mit zey. ikh hob nor gehat eyn tash mit vos ikh bin gegangen, ikh hob gehat MISPAR SHTAYIM a tsveyter vos hot getrogn dos kestl koyln." 
        intervals [310]:
            xmin = 1081.878 
            xmax = 1082.02 
            text = "" 
        intervals [311]:
            xmin = 1082.02 
            xmax = 1085.861 
            text = "ikh hob im oykh ibergelozt. ikh trog nor a tashme VRAZHE," 
        intervals [312]:
            xmin = 1085.861 
            xmax = 1085.952 
            text = "" 
        intervals [313]:
            xmin = 1085.952 
            xmax = 1092.648 
            text = "dos argste darf zayn bay mir eyn tashme, a tashme fun hundert koyln. un ikh gib mir a khap aroyf oyfn barg aroyf," 
        intervals [314]:
            xmin = 1092.648 
            xmax = 1100.2 
            text = "un ikh gib a shtel avek dem mashin-GUN un ikh gib a leyg arayn di tashme, un dos harts makht <yoyre>, zog ikh, gotenyu, ikh zol nor matsliekh zayn." 
        intervals [315]:
            xmin = 1100.2 
            xmax = 1100.3 
            text = "" 
        intervals [316]:
            xmin = 1100.3 
            xmax = 1107.917 
            text = "un ikh shtey direkt tsu dem KIVUN fun di araber, un ikh makh oyf di tashme un ikh shekht avek ale. ale opgehakt di kep." 
        intervals [317]:
            xmin = 1107.917 
            xmax = 1108.227 
            text = "" 
        intervals [318]:
            xmin = 1108.227 
            xmax = 1110.484 
            text = "ale di gantse tashme arayn in dem bunker." 
        intervals [319]:
            xmin = 1110.484 
            xmax = 1114.126 
            text = "finef shtik opgehakt vos di hobn gemakht toyt far undz." 
        intervals [320]:
            xmin = 1114.126 
            xmax = 1115.297 
            text = "" 
        intervals [321]:
            xmin = 1115.297 
            xmax = 1122.564 
            text = "un in dem shray ikh, Mendi! tsum ofitsir, er zol aroyf. vu, EYFA ATA? zog ikh, ANI LEMALA." 
        intervals [322]:
