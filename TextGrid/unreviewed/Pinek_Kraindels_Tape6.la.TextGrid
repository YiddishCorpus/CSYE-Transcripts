            text = "" 
        intervals [32]:
            xmin = 104.67 
            xmax = 112.747 
            text = "m'hot mikh ongetun amerikaner kleyder. ikh hob gebetn dos ershte bayn im, gib mir a por shikh. zogt er, ""yingele, ales vestu krign, kum mit mir.""" 
        intervals [33]:
