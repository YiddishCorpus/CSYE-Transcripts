            text = "" 
        intervals [286]:
            xmin = 978.947 
            xmax = 989.977 
            text = "m'iz gegangen arayn far EGYPT, hot men gehat tsu kemfn, iz geven dray groyse EMDOT fun di araber, fun di mitsrim." 
