            xmin = 989.977 
            xmax = 990.591 
            text = "" 
        intervals [288]:
            xmin = 990.591 
            xmax = 995.85 
            text = "un m'hot dos gedorfn farnemen. az m'farnemt dos iz der veg fray." 
        intervals [289]:
            xmin = 995.85 
            xmax = 996.092 
            text = "" 
        intervals [290]:
            xmin = 996.092 
            xmax = 1002.906 
            text = "un zey hobn oyf undz geshosn, m'iz gegangen hobn zey gegebn aza fayer, ir hert, az ikh bin arayn oyf a feld," 
        intervals [291]:
            xmin = 1002.906 
            xmax = 1010.733 
            text = "dos heyst SHETACH MET, zey shteyen oyfn barg, un zey kenen undz zen, bay nakht, ober ven m'shist" 
