            text = "" 
        intervals [95]:
            xmin = 322.392 
            xmax = 328.607 
            text = "un di muter hot mir geshribn bald, azoy vi er hot geshribn a brivele aheym az er hot bafrayt a yidishn boytshik fun Poyln fun Oyshvits," 
        intervals [96]:
            xmin = 328.607 
            xmax = 332.156 
            text = "hob ikh di mame gebetn a por shikh, fun vanet hot er gevust az er hot shikh." 
        intervals [97]:
            xmin = 332.156 
