            text = "" 
        intervals [171]:
            xmin = 604.879 
            xmax = 613.524 
            text = "hob ikh dortn arayngenumen un dan nakher m'hot gemakht a transport, ikh veys dort efsher a fuftsik khevre hot men aroyfgeleygt undz oyf a T- oyf a oyto MASA, UNK ikh veys nisht, a a TRUCK," 
        intervals [172]:
            xmin = 613.524 
            xmax = 613.671 
            text = "" 
        intervals [173]:
            xmin = 613.671 
            xmax = 615.687 
            text = "un m'hot undz arayngefirt keyn Marsel." 
        intervals [174]:
            xmin = 615.687 
            xmax = 624.768 
            text = "keyn Frankraykh. m'hot undz arayngefirt keyn Frankraykh, dortn iz shoyn geven a lager fun yidn vos fun iberal ver s'geforn keyn Yisroel hot men nokh do gezamlt m'zol makhn transport." 
        intervals [175]:
            xmin = 624.768 
