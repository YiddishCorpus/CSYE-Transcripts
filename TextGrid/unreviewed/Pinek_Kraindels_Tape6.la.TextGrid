        intervals [2]:
            xmin = 7.538 
            xmax = 15.125 
            text = "ya, avekgenumen di revolvern un zey hobn ongehoybn rufn un fayfn nokh eynemen. iz eyner tsugekumen, a vayser ofitsir," 
        intervals [3]:
            xmin = 15.125 
            xmax = 15.57 
            text = "" 
        intervals [4]:
            xmin = 15.57 
            xmax = 18.956 
            text = "un er redt tsu mir, zogt er, ver bistu?" 
        intervals [5]:
            xmin = 18.956 
            xmax = 20.143 
            text = "" 
        intervals [6]:
            xmin = 20.143 
            xmax = 24.845 
            text = "zog ikh, ikh bin, zog ikh, a JEWISH BOY fun POLAND." 
        intervals [7]:
            xmin = 24.845 
            xmax = 25.307 
            text = "" 
        intervals [8]:
            xmin = 25.307 
            xmax = 29.756 
            text = "ikh bin avek fun Oyshvits un ikh bin geven do oyf ander lagern." 
        intervals [9]:
            xmin = 29.756 
            xmax = 30.403 
            text = "" 
        intervals [10]:
            xmin = 30.403 
            xmax = 36.337 
            text = "ikh bin arayngekumen do tsu di mentshn un zey hobn mikh oysbahaltn do biz yetst, biz ir zent gekumen." 
        intervals [11]:
            xmin = 36.337 
            xmax = 37.947 
            text = "" 
        intervals [12]:
            xmin = 37.947 
            xmax = 43.475 
            text = "vos far a shprakh redstu? redstu, zogt er, er hot geredt tsu mir daytsh. zog ikh red daytsh." 
        intervals [13]:
            xmin = 43.475 
            xmax = 43.718 
            text = "" 
        intervals [14]:
            xmin = 43.718 
            xmax = 49.174 
            text = "vos nokh redstu? zog ikh, du redst yidish? zog ikh, yo. red tsu mir in yidish." 
        intervals [15]:
            xmin = 49.174 
            xmax = 55.423 
            text = "hob ikh gezogt yidish. ikh bin arayngekumen do tsu zey. zey hobn mikh oysbahaltn un zenen geven zeyer gut tsu mir." 
        intervals [16]:
            xmin = 55.423 
            xmax = 56.442 
            text = "" 
        intervals [17]:
            xmin = 56.442 
            xmax = 62.257 
            text = "zogt er, ikh bin oykh a yid. hob ikh shoyn ongehoybn tsu veynen. un er hot geveynt." 
        intervals [18]:
            xmin = 62.257 
            xmax = 63.681 
            text = "" 
        intervals [19]:
            xmin = 63.681 
            xmax = 67.269 
            text = "zogt er, ""yingele, ales vet zayn in ordenung. du kumst yetst mit mir.""" 
        intervals [20]:
            xmin = 67.269 
            xmax = 67.714 
            text = "" 
        intervals [21]:
            xmin = 67.714 
            xmax = 74.525 
            text = "zogt er tsu dem balbos, er nemt mikh tsu. zogn zey, neyn. zey hobn mikh oysbahaltn, mir viln er zol do blaybn bay undz." 
        intervals [22]:
            xmin = 74.525 
            xmax = 74.97 
            text = "" 
        intervals [23]:
            xmin = 74.97 
            xmax = 83.877 
            text = "hot er gebetn, er ken nisht blaybn yetst. di ale velder zenen ful mit S.S., s'nokh nisht CLEAR. er darf kumen mit undz." 
        intervals [24]:
            xmin = 83.877 
            xmax = 90.675 
            text = "mir veln im ophitn vet dir nisht fargesn, er vet tsu dir kumen. ikh bin take gekumen yedes mol, VISITn, vet er kumen VISITN, er vet tsu aykh kumen." 
        intervals [25]:
            xmin = 90.675 
            xmax = 90.883 
            text = "" 
        intervals [26]:
            xmin = 90.883 
            xmax = 93.425 
            text = "er veyst az du host im opgetun a guts." 
        intervals [27]:
            xmin = 93.425 
            xmax = 93.904 
            text = "" 
        intervals [28]:
            xmin = 93.904 
            xmax = 102.234 
            text = "un er hot mikh genumen avek in vald arayn. Dzhek! Mek! un genumen rufn ale genereler, ALL groyse ofitsirn, yidn." 
        intervals [29]:
            xmin = 102.234 
            xmax = 102.325 
            text = "" 
        intervals [30]:
