            xmax = 1278.296 
            text = "ikh hob aroysgenumen a aza AWIADECTWO, aza list, fun di amerikaner un fun di rusn az ikh vil brengen mayn FAMILY." 
        intervals [367]:
            xmin = 1278.296 
