            xmin = 1130.124 
            xmax = 1130.265 
            text = "" 
        intervals [325]:
            xmin = 1130.265 
            xmax = 1137.043 
            text = "zog ikh, yetst gey tsu mitn FLASHLIGHT, un ze tsi s'nokh do emetser lebedik dortn, efsher iz nokh emetser dortn geblibn, az du vest tsukumen vet er dikh avek shisn." 
        intervals [326]:
            xmin = 1137.043 
