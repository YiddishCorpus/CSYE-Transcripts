        intervals [340]:
            xmin = 1177.942 
            xmax = 1187.364 
            text = "SAMAR, RAV SAMAL, RASAB, RASAR, un dan nakher bay NINETEEN SIXTY SEVEN, bin ikh shoyn gevorn ofitsir," 
