            text = "az ikh ken forn brengen mayn FAMILY." 
        intervals [388]:
            xmin = 1354.199 
            xmax = 1356.865 
            text = "un ikh for arayn keyn Poyln, kum ikh arayn keyn keyn Apt," 
        intervals [389]:
            xmin = 1356.865 
            xmax = 1361.399 
            text = "ikh kum arayn keyn Apt, zogt men mir UNK du host do a bruder, vayl s'geven a por apter yidn shoyn bafrayter." 
        intervals [390]:
            xmin = 1361.399 
            xmax = 1363.566 
            text = "un m'hot gevoynt in eyn in eyn hoyz." 
        intervals [391]:
            xmin = 1363.566 
            xmax = 1365.866 
            text = "vu iz der bruder? in Sandormierzh." 
        intervals [392]:
            xmin = 1365.866 
            xmax = 1368.557 
            text = "" 
        intervals [393]:
            xmin = 1368.557 
            xmax = 1372.553 
            text = "ven ikh bin arayngekumen keyn Apt, dentsmol, nokh der bafrayung, demolts hob ikh getrofn," 
        intervals [394]:
            xmin = 1372.553 
            xmax = 1378.864 
            text = "s'gevezn mer, dos iz dokh geven bald in der BEGINNING. ven ikh bin arayngeforn keyn Apt hob ikh getrofn, demolts in dem hoyz vu ikh bin gevezn," 
        intervals [395]:
            xmin = 1378.864 
            xmax = 1380.616 
            text = "iz gevezn zeks oder akht yidn." 
        intervals [396]:
            xmin = 1380.616 
            xmax = 1386.883 
            text = "" 
        intervals [397]:
            xmin = 1386.883 
            xmax = 1393.171 
            text = "fun der gantser shtot? s'nisht geblibn keyn sakh. s'hot gekent efsher efsher hot gehat blaybn a hundert BOYS," 
        intervals [398]:
            xmin = 1393.171 
