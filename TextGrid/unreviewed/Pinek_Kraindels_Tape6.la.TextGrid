            text = "un get er a shik tsu a SAMAL, un er zol mir gebn shnel a kurs. vi azoy on tsu lodenen un vi oys tsu lodenen, un vi oyftsu- oyftsumakhn, vi tsu tsenemen," 
        intervals [280]:
            xmin = 957.709 
