            text = "" 
        intervals [153]:
            xmin = 534.426 
            xmax = 538.818 
            text = "no no no. ven s'shoyn geven Yisroel. m'hot shoyn d- derklert Yisroel, ISRAEL." 
        intervals [154]:
            xmin = 538.818 
            xmax = 547.188 
            text = "m'hot shoyn gehert in Daytshland ISRAEL. un der un der goy hot tsu mir gezogt, spn, zogt er, YOU HAVE YOU HAVE, zogt er, A COUNTRY, NOW YOU GOT A, zogt er, YOUR COUNTRY, A JEWISH COUNTRY, ISRAEL." 
        intervals [155]:
            xmin = 547.188 
            xmax = 551.154 
            text = "in RADIO hot men ibergegebn. vu iz geven demolts TELEVISION? in di RADIOS hot men ibergegebn." 
        intervals [156]:
            xmin = 551.154 
            xmax = 555.415 
            text = "un demolts un demolts ikh bin geven barn konsul, nokh akht kumen aroyf tsvey ofitsirn," 
        intervals [157]:
            xmin = 555.415 
            xmax = 562.671 
            text = "un m'redt tsu mir. un ikh bin gevezn a Beytarnik, ikh bin geven a farbrenter far far Yisroel, un ikh hob lib gehat dos lebn," 
        intervals [158]:
            xmin = 562.671 
            xmax = 566.972 
            text = "hob ikh gezogt, veystu vos? ikh for. mer darf men nisht redn." 
        intervals [159]:
            xmin = 566.972 
            xmax = 567.028 
            text = "" 
        intervals [160]:
            xmin = 567.028 
            xmax = 570.636 
            text = "zog ikh, ikh gey tsu tsum konsul, UNK, un zey hobn mikh ven tsugeforn tsum konsul," 
        intervals [161]:
            xmin = 570.636 
            xmax = 573.978 
            text = "az ikh zol nemen INFORMATION fun konsul, tsi der konsul vet mir zogn dos zelbe." 
        intervals [162]:
            xmin = 573.978 
            xmax = 577.285 
            text = "zogt der konsul, du host rekht tsu forn a yor keyn Yisroel," 
        intervals [163]:
            xmin = 577.285 
            xmax = 581.222 
            text = "un shpeter, zogt er, az du vilst farlozn, hostu di zelbe rekht. kumts tsurik, du krigst di zelbe rekht." 
        intervals [164]:
            xmin = 581.222 
            xmax = 586.111 
            text = "ikh shik dikh avek, on alem, darfst gornisht batsoln. hobn zelbn plats un zelbe eltern, vest krigstu ales." 
        intervals [165]:
            xmin = 586.111 
            xmax = 586.178 
            text = "" 
        intervals [166]:
            xmin = 586.178 
            xmax = 593.094 
            text = "vest nemen lernen dortn, far geshvoyrn hob ikh dokh shoyn gehat geshvoyrn, ales iz fertik. hot der konsulat mir gegebn a yor keyn Yisroel un kumen tsurik." 
