            text = "eh ikh ho- ikh bin shoyn lang nisht gekumen tsu zey. s'dokh shoyn fuftsik yor adurkh, ober" 
        intervals [45]:
            xmin = 147.065 
            xmax = 151.188 
            text = "SURE veys ikh vu tsu forn. az ikh kum on haynt keyn Daytshland ken ikh visn glaykh tsutsuforn tsu zey." 
        intervals [46]:
