        intervals [428]:
            xmin = 1496.976 
            xmax = 1505.593 
            text = "in der tsayt iz epes andersh geven. in der tsayt fun der milkhome iz hot men gedankt got az m'hot tsu esn. ober nokh der milkhome hob ikh oyfgegebn oykh oyfgegebn di RELIGIOUS." 
        intervals [429]:
            xmin = 1505.593 
            xmax = 1505.97 
            text = "" 
        intervals [430]:
            xmin = 1505.97 
            xmax = 1510.739 
            text = "oyfgegebn. ikh hob gezogt dos alts iz gornisht, eh OK vi eyner nemt dos op." 
        intervals [431]:
            xmin = 1510.739 
            xmax = 1510.813 
            text = "" 
        intervals [432]:
            xmin = 1510.813 
            xmax = 1515.582 
            text = "az m'zol zogn, az ikh hob gekent aroysgeyn fun vald ken eyner zog- oystaytshn got hot mikh gefirt." 
        intervals [433]:
            xmin = 1515.582 
            xmax = 1515.69 
            text = "" 
        intervals [434]:
            xmin = 1515.69 
            xmax = 1518.969 
            text = "ikh bin gelofn a gantsn tog in vald ven m'hot mikh geshosn, ikh hob nisht gezen keyn ek." 
        intervals [435]:
            xmin = 1518.969 
            xmax = 1521.995 
            text = "un tsu morgns in tsayt in tsen minut hob ikh getrofn aroystsugeyn." 
        intervals [436]:
            xmin = 1521.995 
            xmax = 1522.035 
            text = "" 
        intervals [437]:
            xmin = 1522.035 
            xmax = 1531.294 
            text = "treft op a a yid, a khosid, vet er es ontrefn un zogn got hot im gefirt. zol zayn a got hot im gefirt, dos iz gevezn mayn UNK. ikh veys nisht vos iz gevezn. ikh bin bald aroys. tsu morgns." 
        intervals [438]:
            xmin = 1531.294 
            xmax = 1532.937 
            text = "" 
        intervals [439]:
            xmin = 1532.937 
            xmax = 1533.656 
            text = "neyn." 
        intervals [440]:
            xmin = 1533.656 
            xmax = 1542.184 
            text = "" 
        intervals [441]:
            xmin = 1542.184 
            xmax = 1550.795 
            text = "ikh bin gegangen a bisl in a shule in der Ort shule, un dan nakher hob ikh genumen ongehoybn arbetn far mir tsu makhn a por dolar, vayl m'hot dokh nisht gekent lebn ales nor vos der Unra gibt." 
        intervals [442]:
            xmin = 1550.795 
            xmax = 1557.689 
            text = "hob ikh genumen a bisl arbetn, firn mit skhoyre, gearbet mit skhoyre, gevorn gehandlt, un THAT'S ALL. biz ikh bin avekgeforn nakher keyn Yisroel." 
        intervals [443]:
            xmin = 1557.689 
            xmax = 1558.935 
            text = "ikh bin arayn in der armey arayn." 
        intervals [444]:
            xmin = 1558.935 
            xmax = 1559.818 
            text = "" 
        intervals [445]:
            xmin = 1559.818 
            xmax = 1565.482 
            text = "ikh hob ge- ikh hob ge- ikh hob geheyrat in Yisroel, ikh hob bakent mayn vayb dortn, un ikh hob ikh hob dray kinder geboyrn dortn," 
        intervals [446]:
            xmin = 1565.482 
            xmax = 1570.264 
            text = "" 
        intervals [447]:
            xmin = 1570.264 
            xmax = 1580.568 
            text = "ikh hob bagegnt mayn froy iz geven durkh a tsufal eh oyf a khasene, ikh bin geven oyf a khasene als als <sarver>, bin ikh geven tsu oyf a khasene, ikh hob zi bakent, un m'hot zikh bakent fun demolts on hot men zikh genumen trefn." 
        intervals [448]:
            xmin = 1580.568 
            xmax = 1580.997 
            text = "" 
        intervals [449]:
            xmin = 1580.997 
            xmax = 1582.138 
            text = "un m'hot geheyrat." 
        intervals [450]:
            xmin = 1582.138 
            xmax = 1584.085 
            text = "" 
        intervals [451]:
            xmin = 1584.085 
            xmax = 1584.855 
            text = "Lea." 
        intervals [452]:
            xmin = 1584.855 
            xmax = 1587.831 
            text = "" 
        intervals [453]:
            xmin = 1587.831 
            xmax = 1589.715 
            text = "Shmueli, Shmueli." 
        intervals [454]:
            xmin = 1589.715 
            xmax = 1590.463 
            text = "" 
        intervals [455]:
            xmin = 1590.463 
            xmax = 1599.772 
            text = "dos heyst shoyn dos iz a ivrit nomen. der foter fun der heym hot geheysn Shmuali, panye Shmuali. un nu Shmuali oyf ivrit hot men es ibergearbet oyf Shmueli." 
        intervals [456]:
            xmin = 1599.772 
            xmax = 1601.955 
            text = "" 
        intervals [457]:
            xmin = 1601.955 
            xmax = 1604.733 
            text = "mayn vayb iz gekumen mit tsvey yor alt keyn Yisroel." 
        intervals [458]:
            xmin = 1604.733 
            xmax = 1607.288 
            text = "" 
        intervals [459]:
            xmin = 1607.288 
            xmax = 1615.584 
            text = "zey zenen gekumen, der foter iz avek nakher der foter iz avek eh keyn Ungarn, fun Ungarn iz er arayn keyn Rumenye un er hot dortn geheyrat," 
        intervals [460]:
            xmin = 1615.584 
            xmax = 1615.843 
            text = "" 
        intervals [461]:
            xmin = 1615.843 
            xmax = 1621.895 
            text = "un er hot dortn gehat di kinder, nakher iz er aroyf eh arayngeforn. dos iz nokh far der milkhome. zey zenen nisht geven, der foter hot nisht gevust fun keyn milkhome." 
        intervals [462]:
            xmin = 1621.895 
            xmax = 1621.986 
            text = "" 
        intervals [463]:
            xmin = 1621.986 
            xmax = 1624.95 
            text = "zey hobn nokh gevoynt dortn efsher in fuftsn tsvontsik yor far der milkhome." 
        intervals [464]:
            xmin = 1624.95 
            xmax = 1627.302 
            text = "" 
        intervals [465]:
            xmin = 1627.302 
            xmax = 1628.899 
            text = "in Rumenye nokh." 
        intervals [466]:
            xmin = 1628.899 
            xmax = 1628.922 
            text = "" 
        intervals [467]:
            xmin = 1628.922 
            xmax = 1629.72 
            text = "ya." 
        intervals [468]:
            xmin = 1629.72 
            xmax = 1631.956 
            text = "zi iz arayngekumen, zi iz alt geven tsvey yor, keyn Yisroel." 
