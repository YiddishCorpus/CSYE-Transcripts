        intervals [382]:
            xmin = 1325.796 
            xmax = 1335.223 
            text = "er iz geblibn nisht in Patov, in Patov hot men geharget. di di A.K. di bande hobn gehat yidn nokh der milkhome. iz er geblibn in Tsozemir, in Sandormierzh." 
