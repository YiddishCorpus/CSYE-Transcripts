            text = "" 
        intervals [141]:
            xmin = 486.4 
            xmax = 491.861 
            text = "ikh bin aheymgekumen, ikh hob mir tsu gepakt mir, a vokh shpeter gebn a kum aroys tsu mir tsvey khevre," 
