            text = "" 
        intervals [168]:
            xmin = 593.623 
            xmax = 596.497 
            text = "hob ikh gezogt ikh bin READY. hob ikh gehat di peklekh fertik," 
        intervals [169]:
            xmin = 596.497 
            xmax = 604.147 
            text = "tsvey tog shpeter iz gekumen a TRUCK, hot mikh avekgefirt in a vald arayn. dortn iz gevezn aza yu- a yidisher lager, dortn hinter Mondri- hinter MUNICH," 
        intervals [170]:
