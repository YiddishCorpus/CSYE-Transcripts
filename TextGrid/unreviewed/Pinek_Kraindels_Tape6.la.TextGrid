            xmin = 1335.223 
            xmax = 1335.634 
            text = "" 
        intervals [384]:
            xmin = 1335.634 
            xmax = 1339.966 
            text = "mit zayne FRIEND, er hot gehat FRIEND, iz er geblibn in Sandormierzh. dortn iz geven a bisl mer BEZPIECZNE." 
        intervals [385]:
            xmin = 1339.966 
            xmax = 1347.399 
            text = "mer zikhere vi in Apt. iz er geblibn dortn, un ikh heyb zikh oyf un ikh nem aroys a papir fun di amerikaner," 
        intervals [386]:
            xmin = 1347.399 
            xmax = 1352.432 
            text = "un ikh nem aroys a papir ALSO fun danet fun eh fun di rusn, zey hobn nokh gearbet tsuzamen." 
        intervals [387]:
            xmin = 1352.432 
