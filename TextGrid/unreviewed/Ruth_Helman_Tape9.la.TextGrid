            text = "" 
        intervals [16]:
            xmin = 51.43 
            xmax = 61.616 
            text = "dervayl iz gevorn aktuel di tsen toyznt tsertifikatn, un fun der amerikaner zone flegn zey kumen batsoln finef t- tsen toyznt dolar far a sertifikat." 
        intervals [17]:
            xmin = 61.616 
            xmax = 61.622 
            text = "" 
        intervals [18]:
