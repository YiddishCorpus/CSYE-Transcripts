            text = "" 
        intervals [43]:
            xmin = 143.787 
            xmax = 146.65 
            text = "ober yetst tsurik dos, keyn Givat Olga." 
        intervals [44]:
            xmin = 146.65 
            xmax = 148.478 
            text = "" 
        intervals [45]:
            xmin = 148.478 
            xmax = 151.189 
            text = "far rosheshone ikh gedenk nisht genoy ven." 
        intervals [46]:
