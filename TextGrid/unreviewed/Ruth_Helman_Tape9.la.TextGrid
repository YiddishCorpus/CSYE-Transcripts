            text = "un ikh shlof nisht azoy shle- azoy fil ikh zol hobn ven tsu kholemen." 
        intervals [156]:
            xmin = 537.609 
            xmax = 537.632 
            text = "" 
        intervals [157]:
            xmin = 537.632 
            xmax = 541.544 
            text = "az ikh z- ikh az az ikh her her ikh ikh nayes," 
        intervals [158]:
            xmin = 541.544 
            xmax = 546.675 
            text = "gey ikh shlofn eynse, halb eyns, mit a NUMBER nokh azoy fil tabletn," 
        intervals [159]:
            xmin = 546.675 
            xmax = 552.134 
            text = "haynt finef un ikh hob shoyn badorfn nemen dos tsveyte mol, hob ikh shoyn genumen tsvelef tabletn," 
        intervals [160]:
            xmin = 552.134 
            xmax = 552.212 
            text = "" 
        intervals [161]:
            xmin = 552.212 
            xmax = 559.85 
            text = "eyder ikh nem di tabletn, eyb- i- eyder ikh derken, s'iz oys- s'iz oyssortirt, oyfn tish dortn zenen alts mayne retseptn." 
        intervals [162]:
            xmin = 559.85 
            xmax = 564.396 
            text = "" 
        intervals [163]:
            xmin = 564.396 
            xmax = 571.072 
            text = "un far vegn dem kind vegn, ir tort nisht, ir muzt mir tsuzogn ayer ern-vort er vet nisht dermanen zey." 
        intervals [164]:
            xmin = 571.072 
            xmax = 571.112 
            text = "" 
        intervals [165]:
            xmin = 571.112 
            xmax = 573.181 
            text = "rayst oys di bletlekh." 
        intervals [166]:
            xmin = 573.181 
            xmax = 573.593 
            text = "" 
        intervals [167]:
            xmin = 573.593 
            xmax = 581.011 
            text = "vayl ikh hob ir gegebn epes haynt a zog, ikh ken aykh nisht forshteln, ikh shem mikh tsu dertseyln vi vosere sof ikh hob gehat." 
        intervals [168]:
            xmin = 581.011 
            xmax = 581.355 
            text = "" 
        intervals [169]:
            xmin = 581.355 
            xmax = 583.391 
            text = "ikh kokh in gantsn." 
        intervals [170]:
            xmin = 583.391 
            xmax = 590.113 
            text = "" 
        intervals [171]:
            xmin = 590.113 
            xmax = 591.052 
            text = "dos vil ikh." 
        intervals [172]:
            xmin = 591.052 
            xmax = 595.378 
            text = "" 
        intervals [173]:
            xmin = 595.378 
            xmax = 603.438 
            text = "yo, koydem vil ikh zogn far di gelernte, far di profesorn. s'do a profesor Bauer, a u- a a a ungarisher." 
        intervals [174]:
            xmin = 603.438 
            xmax = 603.664 
            text = "" 
        intervals [175]:
            xmin = 603.664 
            xmax = 608.426 
            text = "er hot nokh, zey hobn in gantsn di ungarn, er hot dokh zey gedekt, der keyser," 
        intervals [176]:
            xmin = 608.426 
            xmax = 608.449 
            text = "" 
        intervals [177]:
            xmin = 608.449 
            xmax = 614.236 
            text = "zey hobn dokh fir, zenen dokh arayngeforn keyn Bergn-Belzn fir vokhn farn endikn di milkhome." 
        intervals [178]:
            xmin = 614.236 
            xmax = 614.818 
            text = "" 
        intervals [179]:
            xmin = 614.818 
            xmax = 622.996 
            text = "zey hobn d- di rumener mer a bisl. di ungarisher hobn dokh in gantsn nisht ge- un hobn zikh gekent oysbahaltn, ikh ken a sakh." 
        intervals [180]:
            xmin = 622.996 
            xmax = 623.661 
            text = "" 
        intervals [181]:
            xmin = 623.661 
            xmax = 637.577 
            text = "eh zogt er az er hot nokh gornisht gevust. a halbe milyon yidn iz hot gelebt in gantsn a sho. ikh hob aykh gevolt dertseyln, az dos gantse lebn keyn Treblinke hot gedoyert a sho. fun di transportn," 
        intervals [182]:
            xmin = 637.577 
            xmax = 637.701 
            text = "" 
        intervals [183]:
            xmin = 637.701 
            xmax = 640.648 
            text = "m'hot zey nisht s'nisht s'bald geven a toytn-lager." 
        intervals [184]:
            xmin = 640.648 
            xmax = 640.907 
            text = "" 
        intervals [185]:
            xmin = 640.907 
            xmax = 652.427 
            text = "yetst dos m'ruft on az s'iz geven eh tsum ersht, s'iz geven bald keyn shum ander zakh in Varsheve, bald a toytn lager." 
        intervals [186]:
            xmin = 652.427 
            xmax = 653.614 
            text = "" 
        intervals [187]:
            xmin = 653.614 
            xmax = 660.819 
            text = "bald tsu shtarbn. un s'iz take ge- ale vegelekh mit alding. undz ho'mir gehat a shokhn voynen" 
        intervals [188]:
            xmin = 660.819 
            xmax = 660.846 
            text = "" 
        intervals [189]:
            xmin = 660.846 
            xmax = 664.764 
            text = "vos hot gearbet oyfn beys-almen, oyfn algemeynem fun Varshe." 
        intervals [190]:
            xmin = 664.764 
            xmax = 671.2 
            text = "hot er gefirt, in di kantselarye iz er geven an ongeshtelter. a frumer mentsh nor a eleganter azoy fun di sheyn geputste." 
        intervals [191]:
            xmin = 671.2 
            xmax = 673.3 
            text = "hobn undz geha- un mayn man iz geven" 
        intervals [192]:
            xmin = 673.3 
            xmax = 673.325 
            text = "" 
        intervals [193]:
            xmin = 673.325 
            xmax = 679.125 
            text = "der vos hot tsunoyf genumen di dos gelter vi lang s'geven a por pyaster yede eh yedes mol" 
        intervals [194]:
            xmin = 679.125 
            xmax = 683.625 
            text = "oyf tsu kenen bagrobn, oder aroyshelfn azelkhe vos zenen shtar- eh geshtanen." 
        intervals [195]:
            xmin = 683.625 
            xmax = 686.375 
            text = "azoy az m'hot gev- geven gut bakant." 
        intervals [196]:
            xmin = 686.375 
            xmax = 690.5 
            text = "di mindst vos m'hot ongefirt in masn-kvorim," 
        intervals [197]:
            xmin = 690.5 
            xmax = 695.775 
            text = "iz geven tsuzamen dos on registratsyes, zey hobn nisht gekent zdonzhen tsu makhn keyn registratsyes," 
        intervals [198]:
            xmin = 695.775 
            xmax = 695.9 
            text = "" 
        intervals [199]:
            xmin = 695.9 
            xmax = 702.795 
            text = "tsvey hundert un zibetsik, tsvey hundert un akhtsik toyte, dray hundert toyte iz geven yedn tog. fun hunger." 
        intervals [200]:
            xmin = 702.795 
            xmax = 707.567 
            text = "un koydem zenen geganen di vos zenen gevorn arayngeyogt oykhet. ober bald fun ershtn tog" 
        intervals [201]:
            xmin = 707.567 
            xmax = 712.908 
            text = "iz dokh gev- funem bombardirn fir fir vokhn zikh nisht untergebn iz dokh bald geven a hunger." 
        intervals [202]:
            xmin = 712.908 
            xmax = 717.158 
            text = "meyle dos hobn di polyakn oykhet, ober zey hobn zikh ender an eytse gegebn." 
        intervals [203]:
            xmin = 717.158 
            xmax = 723.931 
            text = "hobn zikh aroysgekrign oyf a provints, gebrengt fun fun di fun di derfer epes, ober yidn hobn dokh bald gelitn." 
        intervals [204]:
            xmin = 723.931 
            xmax = 723.999 
            text = "" 
        intervals [205]:
            xmin = 723.999 
            xmax = 726.112 
            text = "nor nokh dem vi m'hot undz farmakht," 
        intervals [206]:
            xmin = 726.112 
            xmax = 734.044 
            text = "un eh un nisht vayl, eh ven s'hot zikh geendikt di bombardi- di di di un zey hobn zikh er hot zikh untergegebn Stazhinski." 
        intervals [207]:
            xmin = 734.044 
            xmax = 740.249 
            text = "iz bald geven toyt. nisht geven vi tsu fardinen, nisht gevezn keyner hot gornisht farmogt, alts iz geven bombardirt," 
        intervals [208]:
            xmin = 740.249 
            xmax = 744.716 
            text = "zeltn s'geblibn a gantse shtub, dos iz bald geven a toytn lager." 
        intervals [209]:
            xmin = 744.716 
            xmax = 750.24 
            text = "" 
        intervals [210]:
            xmin = 750.24 
            xmax = 755.297 
            text = "o. bay Kshyevitskin hob ikh gezdonzhet, eh Varshe iz dokh geven in gantsn, yeder," 
        intervals [211]:
            xmin = 755.297 
            xmax = 759.135 
            text = "dos der poylisher gegnt iz oykh geblibn nor a por hayzer vu di" 
        intervals [212]:
            xmin = 759.135 
            xmax = 763.621 
            text = "vu di di daytshn hobn zikh farhaltn biz der letster minut vi zey hobn opgetretn." 
        intervals [213]:
            xmin = 763.621 
            xmax = 767.162 
            text = "eh oyf a oyf der gro- oyfn poylishn gegnt iz es gevezn." 
        intervals [214]:
            xmin = 767.162 
            xmax = 771.891 
            text = "ikh bin dort geven take, s'geven der oysern MINISTERSTWO, ikh bin gegangen gevoyer vern vegn Kuba," 
        intervals [215]:
            xmin = 771.891 
            xmax = 774 
            text = "ven s'mir geven akte- aktuel." 
        intervals [216]:
            xmin = 774 
            xmax = 781.081 
            text = "bin ikh eyn mol adurkhgeyendik eh adurkh geganen oyf der dire vu er hot gevoynt," 
        intervals [217]:
            xmin = 781.081 
            xmax = 781.78 
            text = "" 
        intervals [218]:
            xmin = 781.78 
            xmax = 785.469 
            text = "di tsveyte dire vos ikh bin mit zey geshlofn in shlof-tsimer," 
        intervals [219]:
            xmin = 785.469 
            xmax = 785.56 
            text = "" 
        intervals [220]:
            xmin = 785.56 
            xmax = 789.351 
            text = "iz keyner nisht geven, di tir eh dire geven ofn." 
        intervals [221]:
            xmin = 789.351 
            xmax = 790.099 
            text = "" 
        intervals [222]:
            xmin = 790.099 
            xmax = 796.23 
            text = "s'geshtanen nisht keyn me- di ikh hob aykh dertseylt az di shlof-tsimer iz geven azoy mit gold azoy vi dos." 
        intervals [223]:
            xmin = 796.23 
            xmax = 801.467 
            text = "bay a raykhe hayzer, ver hot gehat tsvey azelkhe groyse tsimern in Varshe, yidn?" 
        intervals [224]:
            xmin = 801.467 
            xmax = 801.81 
            text = "" 
        intervals [225]:
            xmin = 801.81 
            xmax = 808.554 
            text = "zeyer raykhe mentshn gemuzt zayn. vayl in Varshe a a dire iz geven MASHEHU, nisht tsutsukumen." 
        intervals [226]:
            xmin = 808.554 
            xmax = 809.59 
            text = "" 
        intervals [227]:
            xmin = 809.59 
            xmax = 812.317 
            text = "bin ikh aroyfgeganen, s'keyner nisht geven." 
        intervals [228]:
            xmin = 812.317 
            xmax = 812.425 
            text = "" 
        intervals [229]:
            xmin = 812.425 
            xmax = 820.176 
            text = "eyns hob ikh gevust take fun Vroblevskin, az der bruder iz gefaln. in oyfshtand, ir bruder." 
        intervals [230]:
            xmin = 820.176 
            xmax = 826.503 
            text = "un s'fun zey lebt ver s'geven a zun vos iz geganen in TICHON arayn, ge- zey hobn gelernt um- umlegal," 
        intervals [231]:
            xmin = 826.503 
            xmax = 829.782 
            text = "di polyakn, s'hot dokh nisht getort zayn keyn shum shule nisht, gornisht." 
        intervals [232]:
            xmin = 829.782 
            xmax = 830.312 
            text = "" 
        intervals [233]:
            xmin = 830.312 
            xmax = 834.491 
            text = "iz eh a zun mit a tokhter. un a mame zayne." 
        intervals [234]:
            xmin = 834.491 
            xmax = 834.497 
            text = "" 
        intervals [235]:
            xmin = 834.497 
            xmax = 837.528 
            text = "keyner iz nisht geven, m'voynt nisht dortn." 
        intervals [236]:
            xmin = 837.528 
            xmax = 837.552 
            text = "" 
        intervals [237]:
            xmin = 837.552 
            xmax = 847.029 
            text = "nor epes a a s'geshtanen aza, dos hot geheysn aza GABLOTKA hot es geheysn, mit shpiglen, a a a a shank," 
        intervals [238]:
            xmin = 847.029 
            xmax = 847.525 
            text = "" 
        intervals [239]:
            xmin = 847.525 
            xmax = 856.007 
            text = "iz gelegn der kapelyush fun mayn man a hitl. fun di beste kapelyushn, mayn man's hitl." 
        intervals [240]:
            xmin = 856.007 
            xmax = 856.182 
            text = "" 
        intervals [241]:
            xmin = 856.182 
            xmax = 860.378 
            text = "oysgeleydikte shtubn, ikh hob keynem nisht getrofn oyfn fertn shtok." 
        intervals [242]:
            xmin = 860.378 
            xmax = 861.244 
            text = "" 
        intervals [243]:
            xmin = 861.244 
            xmax = 864.748 
            text = "ikh ho- neyn. ikh hob nisht gevust tsi er lebt tsi nisht." 
        intervals [244]:
            xmin = 864.748 
            xmax = 865.632 
            text = "" 
        intervals [245]:
            xmin = 865.632 
            xmax = 869.861 
            text = "dem Vroblevski vu dos kind iz geven iz tsurikgekumen fun Daytshland," 
        intervals [246]:
            xmin = 869.861 
            xmax = 870.525 
            text = "" 
        intervals [247]:
            xmin = 870.525 
            xmax = 872.679 
            text = "bin ikh geven afilek mit mayn man" 
        intervals [248]:
            xmin = 872.679 
            xmax = 872.753 
            text = "" 
        intervals [249]:
            xmin = 872.753 
            xmax = 876.392 
            text = "un ikh hob im gevizn az vos der forheng, dos alts iz" 
        intervals [250]:
            xmin = 876.392 
            xmax = 876.668 
            text = "" 
        intervals [251]:
            xmin = 876.668 
            xmax = 884.199 
            text = "vos ikh hob gege- ober ikh hob im gezogt, ikh hob nisht gez- ikh hob nisht gezogt az er zol hern. er iz bay un- er hot im er hot mikh er hot bazukht oykhet." 
        intervals [252]:
            xmin = 884.199 
            xmax = 886.331 
            text = "un m'iz geven in gute batsiungen." 
        intervals [253]:
            xmin = 886.331 
            xmax = 888.615 
            text = "" 
        intervals [254]:
            xmin = 888.615 
            xmax = 895.679 
            text = "un bay dem Droshn bin ikh gevezn, hob ikh dertseylt aykh, der on dem fus, vos ikh hob dos kind oysgetsupt di nis." 
        intervals [255]:
            xmin = 895.679 
            xmax = 896.547 
            text = "" 
        intervals [256]:
            xmin = 896.547 
            xmax = 905.968 
            text = "un im Kshevyitskin hob ikh nisht ge- gehat ven, vayl ikh bin geven faryogt. ikh hob gearbet, un dernokh hot er mir ge- mayn man, der der man hot mikh gehitn," 
        intervals [257]:
            xmin = 905.968 
            xmax = 907.61 
            text = "azoy vi an oyg in kop," 
        intervals [258]:
            xmin = 907.61 
            xmax = 907.853 
            text = "" 
        intervals [259]:
            xmin = 907.853 
            xmax = 913.686 
            text = "ikh hob nokh im aroysgegebn dos esn vos der prezident hot gegesn hob ikh oykh gegesn, di zelbe kokh." 
        intervals [260]:
            xmin = 913.686 
            xmax = 913.793 
            text = "" 
        intervals [261]:
            xmin = 913.793 
            xmax = 920.782 
            text = "m'hot mir gevashn dos zelbe azoy vi haynt, m'nemt fun far di far di fun fun eh fun far far di alte," 
        intervals [262]:
            xmin = 920.782 
            xmax = 926.161 
            text = "di vesh, azoy hot men gegebn di zelbe vesheray hob ikh avekgege- vos eh vos Byerut," 
        intervals [263]:
            xmin = 926.161 
            xmax = 927.124 
            text = "" 
        intervals [264]:
            xmin = 927.124 
            xmax = 931.303 
            text = "un ikh hob gehat a pensye eh vi er. dray hundert un fuftsik zlotes." 
        intervals [265]:
            xmin = 931.303 
            xmax = 933.418 
            text = "" 
        intervals [266]:
            xmin = 933.418 
            xmax = 940.314 
            text = "a klal, az ikh ho- az ikh hob mikh nisht gekent optshepen, zog ikh, for UNK, heyb on handlen, bay dem man, er hot gornisht gevolt tun, er hot gevolt mikh hitn." 
        intervals [267]:
            xmin = 940.314 
            xmax = 940.388 
            text = "" 
        intervals [268]:
            xmin = 940.388 
            xmax = 948.802 
            text = "heyb on oykh forn azoy vi ale. heyb on handlen. zogt er, ikh hob nisht mit vos ontsuheybn. hob ikh genumen tsvey pensyes foroys, zibn toyznt zlotes," 
        intervals [269]:
            xmin = 948.802 
            xmax = 949.129 
            text = "" 
        intervals [270]:
            xmin = 949.129 
            xmax = 953.325 
            text = "far tsvey pensyes. iz er tsu morgns, ge- zogn mir di shikses," 
        intervals [271]:
            xmin = 953.325 
            xmax = 953.466 
            text = "" 
        intervals [272]:
            xmin = 953.466 
            xmax = 956.669 
            text = "Ruta, UNK." 
        intervals [273]:
            xmin = 956.669 
            xmax = 959.839 
            text = "dayn tseratene kapete shteyt shoyn in droysn." 
        intervals [274]:
            xmin = 959.839 
            xmax = 960.368 
            text = "" 
        intervals [275]:
            xmin = 960.368 
            xmax = 964.007 
            text = "er iz gef- er hot er hot er iz nisht geforn in gantsn handlen." 
        intervals [276]:
            xmin = 964.007 
            xmax = 969.025 
            text = "" 
        intervals [277]:
            xmin = 969.025 
            xmax = 970.624 
            text = "vos nokh vilt ir visn?" 
        intervals [278]:
            xmin = 970.624 
            xmax = 975.82 
            text = "dos muzt ir mikh, vu hot ir dose vos ir hot farshribn vegn mayn tokhter? ikh hob aykh oyfgegebn dem adres," 
        intervals [279]:
            xmin = 975.82 
            xmax = 979.902 
            text = "un ikh hob ay- ikh hob oyfgegebn di pletser vu zey arbetn. ir zolt visn," 
        intervals [280]:
            xmin = 979.902 
            xmax = 981.902 
            text = "vifl ikh hob ongehakt di yorn," 
        intervals [281]:
            xmin = 981.902 
            xmax = 984.766 
            text = "tsi ikh vel yo lebn, tsi ikh vel yo hobn an oyg, tsi," 
        intervals [282]:
            xmin = 984.766 
            xmax = 988.712 
            text = "an oyg vel ikh shoyn nisht z-, keyn gants oyg nisht, ikh vel nor zen a bisele," 
        intervals [283]:
            xmin = 988.712 
            xmax = 988.748 
            text = "" 
        intervals [284]:
            xmin = 988.748 
            xmax = 994.798 
            text = "vayl say vi un di, s'nishto keyn groyse hofenungen. ikh bin say vi nisht yung," 
        intervals [285]:
            xmin = 994.798 
            xmax = 998.381 
            text = "un ikh bin k- eh s'nishto keyn krenk vos ikh hob nisht," 
        intervals [286]:
            xmin = 998.381 
            xmax = 999.687 
            text = "" 
        intervals [287]:
            xmin = 999.687 
            xmax = 1004.321 
            text = "eh eh eh dos ginokologish bin ikh dokh eh an akelt fun di daytshn." 
        intervals [288]:
            xmin = 1004.321 
            xmax = 1004.563 
            text = "" 
        intervals [289]:
            xmin = 1004.563 
            xmax = 1010.935 
            text = "ikh bin dokh eh ikh bin gelegn, yo, in Bergn-Belzn bin ikh gelegn, in Bergn-Belzn bin ikh gelegn fir monat in shpitol." 
        intervals [290]:
            xmin = 1010.935 
            xmax = 1026.99 
            text = "" 
        intervals [291]:
            xmin = 1026.99 
            xmax = 1029.763 
            text = "eh eh az nisht zolt visn," 
        intervals [292]:
            xmin = 1029.763 
            xmax = 1032.035 
            text = "s'mir biter shlekht mit ir." 
        intervals [293]:
            xmin = 1032.035 
            xmax = 1038.306 
            text = "nor dos vos zi muz mir helfn, zi muz mikh, zi muz mit mir geyn in shpitol arayn forn, nemt zi zikh CHOFESH" 
        intervals [294]:
            xmin = 1038.306 
            xmax = 1039.333 
            text = "ekstere." 
        intervals [295]:
            xmin = 1039.333 
            xmax = 1045.873 
            text = "zolt ir visn ikh vel dos oy- mer keyn hilf zet ir nisht. ir kent azoy zen keyn lebedikn mentshn kumt nisht tsu mir." 
        intervals [296]:
            xmin = 1045.873 
            xmax = 1045.878 
            text = "" 
        intervals [297]:
            xmin = 1045.878 
            xmax = 1047.262 
            text = "ikh hob nisht keynemen." 
        intervals [298]:
            xmin = 1047.262 
            xmax = 1051.199 
            text = "di fun eh fun MOADON a sakh lebn nisht un s'do frishe," 
        intervals [299]:
            xmin = 1051.199 
            xmax = 1051.392 
            text = "" 
        intervals [300]:
            xmin = 1051.392 
            xmax = 1054.891 
            text = "keyn frishe iz nishto, keyn ibergelebte tref ikh nisht on," 
        intervals [301]:
            xmin = 1054.891 
            xmax = 1054.929 
            text = "" 
        intervals [302]:
            xmin = 1054.929 
            xmax = 1058.388 
            text = "ikh hob nor di eyn do iz aleyn a khorevdik, a kranke, un der man" 
        intervals [303]:
            xmin = 1058.388 
            xmax = 1064.199 
            text = "vart men nor oyf a plats avektsugeyn, er iz fartralet, er vey- eh di krenk vos er hot." 
        intervals [304]:
            xmin = 1064.199 
