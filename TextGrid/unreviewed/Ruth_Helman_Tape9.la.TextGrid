            text = "" 
        intervals [305]:
            xmin = 1064.419 
            xmax = 1068.007 
            text = "un zi aleyn iz kranke, <a nes> mitn kind <vos oyf>." 
        intervals [306]:
            xmin = 1068.007 
            xmax = 1068.52 
            text = "" 
        intervals [307]:
