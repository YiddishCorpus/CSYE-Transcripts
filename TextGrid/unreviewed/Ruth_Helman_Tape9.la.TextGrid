        intervals [10]:
            xmin = 30.505 
            xmax = 34.923 
            text = "un di rusishe misye hot dos oyfgekoyft, in Berlin iz gezesn a rusishe misye." 
        intervals [11]:
            xmin = 34.923 
            xmax = 40.609 
            text = "dos iz gevezn biz peysekh. peysekh hot zikh di misye farmakht, hot er oyfgehert handlen." 
        intervals [12]:
            xmin = 40.609 
            xmax = 47.812 
            text = "azoy, un in tsvishn tsayt iz gekumen a a briv fun mayn bruder az er ken mayn man nisht aribernemen" 
        intervals [13]:
            xmin = 47.812 
            xmax = 48.561 
            text = "" 
        intervals [14]:
            xmin = 48.561 
            xmax = 50.951 
            text = "keyn Kuba, nor mikh mitn kind." 
        intervals [15]:
            xmin = 50.951 
