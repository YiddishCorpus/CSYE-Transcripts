            text = "Shmetenet, Smetana hot er geheysn." 
        intervals [102]:
            xmin = 336.521 
            xmax = 341.64 
            text = "er iz dafke nisht er iz nisht gekumen keyn Yisroel, nor ergets farforn keyn Zid-Amerike." 
        intervals [103]:
            xmin = 341.64 
