            text = "" 
        intervals [72]:
            xmin = 238.37 
            xmax = 244.703 
            text = "azoy nokher hob i- mir gehat dem adres fun Nakhlat Binyamin zeks, dort iz geven der fotografist Progres," 
        intervals [73]:
            xmin = 244.703 
            xmax = 244.716 
            text = "" 
        intervals [74]:
