            text = "" 
        intervals [80]:
            xmin = 259.752 
            xmax = 264.796 
            text = "hot do oykhet gearbet eh, ober di eltern hobn gevoynt in Varshe, zenen gekumen fun Varshe." 
        intervals [81]:
