            text = "" 
        intervals [49]:
            xmin = 156.797 
            xmax = 161.28 
            text = "nayntsn zibn un fertsik far rosheshone, iz ven, oygust? oygust?" 
        intervals [50]:
            xmin = 161.28 
            xmax = 161.303 
            text = "" 
        intervals [51]:
            xmin = 161.303 
            xmax = 166.927 
            text = "un un eh m'iz ongekumen eh a a a dray vokhn far rosheshone." 
        intervals [52]:
            xmin = 166.927 
            xmax = 170.983 
            text = "ikh gedenk nisht genoy dem termin, di minut gedenk ikh, azoy gedenk ikh yo." 
