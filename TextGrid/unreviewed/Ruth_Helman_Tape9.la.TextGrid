            text = "un zey zenen geven in der heykh, oyfn ershtn shtok hobn zey gehat," 
        intervals [75]:
            xmin = 249.08 
            xmax = 249.103 
            text = "" 
        intervals [76]:
            xmin = 249.103 
            xmax = 255.999 
            text = "in in Varshe oykh gehat a fabrikn fun fotoraln. fotoraln heyst oyf fidlen di di dose." 
        intervals [77]:
            xmin = 255.999 
