        intervals [106]:
            xmin = 347.666 
            xmax = 353.555 
            text = "in eh in Histadrut eh ts- binyen oyf Brener iz gevezn di linke politsye." 
        intervals [107]:
            xmin = 353.555 
            xmax = 356.037 
            text = "ikh bin aroyfgekumen, ikh hob getrofn epes a hoykerl," 
        intervals [108]:
            xmin = 356.037 
            xmax = 360.814 
            text = "ikh hob mikh for- ikh hob nokh a legitimatsye, az m'iz geven mitglider in Bergn-Belzn." 
        intervals [109]:
            xmin = 360.814 
            xmax = 364.592 
            text = "zogt er, eh eh iz ruf ikh mikh on, zog ikh" 
        intervals [110]:
            xmin = 364.592 
            xmax = 370.185 
            text = "ikh hob gehert az eh, SHIKUNIM hob ikh nisht gekent zogn, ikh hob nisht gevust in gantsn keyn UNK." 
        intervals [111]:
            xmin = 370.185 
            xmax = 376.148 
            text = "vi azoy zog ikh, iz ho'mir ho'mir nisht keyn dire, un az m'hot eh m'hot gornisht genumen barn Sokhnut oykh gornisht." 
        intervals [112]:
            xmin = 376.148 
            xmax = 378.111 
            text = "m'veyst nisht vu iz der Sokhnut." 
        intervals [113]:
            xmin = 378.111 
            xmax = 389.34 
            text = "zogt er, undz boyen mir, ober vos, zogt er, s'hot a, vos iz der vider fun vanet du kumst yetst geyn darfstu bald hobn a BAYIT MESHUTAF hot er gerufn. zey hobn geboyt oyf Aleksander Yanay." 
        intervals [114]:
            xmin = 389.34 
            xmax = 393.955 
            text = "sheyne tsvey eh tsvey eh anderthalbn tsimern, heyst tsvey tsimern." 
        intervals [115]:
            xmin = 393.955 
            xmax = 396.216 
            text = "a sheyne voynung, ikh bin dernokh gekumen in ir." 
        intervals [116]:
            xmin = 396.216 
            xmax = 399.743 
            text = "zogt er, ir zent naye OLIM, darf men zen fun vanet tsu fardinen." 
        intervals [117]:
            xmin = 399.743 
            xmax = 403.976 
            text = "s'take nisht ge- mayn man hot take nisht gekent fardinen keyn keyn lire tsen." 
        intervals [118]:
            xmin = 403.976 
            xmax = 404.168 
            text = "" 
        intervals [119]:
            xmin = 404.168 
            xmax = 411.367 
            text = "s'iz take geven zeyer shver. alzo vos m'hot gehat, di brilantn gedekt oyf Kuba tsu forn, iz gevorn farkoyft," 
        intervals [120]:
            xmin = 411.367 
            xmax = 411.694 
            text = "" 
        intervals [121]:
            xmin = 411.694 
            xmax = 415.08 
            text = "ikh hob arayngeleygt alts in der dire, zekhtsik shtign," 
        intervals [122]:
            xmin = 415.08 
            xmax = 415.558 
            text = "" 
        intervals [123]:
            xmin = 415.558 
            xmax = 424.142 
            text = "punkt keygn iber dem metshet, di ershte koyln, eyder s'nokh geven a melukhe, eyder s'geven a regirung, hob ikh gehat in shtub, zekhtsik shtign heykh," 
        intervals [124]:
            xmin = 424.142 
            xmax = 424.553 
            text = "" 
        intervals [125]:
            xmin = 424.553 
            xmax = 432.081 
            text = "un dernokhn in a tsayt eh m'hot oysgegebn dos gelt un aroysnemen punkt in tog fun tsvelef yor dortn voynen," 
        intervals [126]:
            xmin = 432.081 
            xmax = 440.156 
            text = "hot men fun UNK tsen toyznt dolar, toyznt eh eh eh shekl opgekrign dray hundert. tsu di dire tsu." 
        intervals [127]:
            xmin = 440.156 
            xmax = 443.571 
            text = "" 
        intervals [128]:
            xmin = 443.571 
            xmax = 446.94 
            text = "nu dos iz dos, ets vilt mit dem farendikn?" 
