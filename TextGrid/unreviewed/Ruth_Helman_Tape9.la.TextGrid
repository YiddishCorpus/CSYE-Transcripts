            text = "" 
        intervals [82]:
            xmin = 264.844 
            xmax = 268.381 
            text = "er iz do ahergekumen in land tsu nisht geyn in militer." 
        intervals [83]:
            xmin = 268.381 
            xmax = 268.662 
            text = "" 
        intervals [84]:
            xmin = 268.662 
            xmax = 273.566 
            text = "eh iz mayn shvoger iz un ongekumen mit Ander's armey, iz er farforn tsu im," 
        intervals [85]:
            xmin = 273.566 
            xmax = 273.657 
            text = "" 
        intervals [86]:
            xmin = 273.657 
            xmax = 280.834 
            text = "un m'iz geven bay im, iz gevezn etlekhene tekhter, di tsveyte tokhter hot er genumen far a froy, un beyde lebn nisht." 
        intervals [87]:
