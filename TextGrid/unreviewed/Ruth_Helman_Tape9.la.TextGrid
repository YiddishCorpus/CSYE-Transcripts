            text = "" 
        intervals [54]:
            xmin = 171.411 
            xmax = 172.614 
            text = "fertsik." 
        intervals [55]:
            xmin = 172.614 
            xmax = 178.865 
            text = "alzo, mir hobn afilek nisht arayn in keyn balatke, m'hot nisht gebetn gornisht, s'nisht geven keyn keyn keyn az ma-" 
        intervals [56]:
            xmin = 178.865 
            xmax = 178.883 
            text = "" 
        intervals [57]:
            xmin = 178.883 
            xmax = 183.674 
            text = "az dakht zikh dos kind iz oykh gezesn mit undz unter a boym, biz s'iz lekhtik gevorn," 
        intervals [58]:
            xmin = 183.674 
            xmax = 183.768 
            text = "" 
        intervals [59]:
            xmin = 183.768 
            xmax = 188.999 
            text = "ze'mir ho'mir genumen ze'mir arayn in shtot arayn, arayn oyfn KVISH," 
        intervals [60]:
            xmin = 188.999 
            xmax = 194.314 
            text = "m'hot genumen a oyto, m'iz arayn keyn Tel-Aviv. vayl in Tel-Aviv oyf Binyamin zeks" 
        intervals [61]:
            xmin = 194.314 
            xmax = 200.314 
            text = "iz gevezn mayn shvogerl, a yingerer bruder fun mayn man, gekumen do mit Ander's armey." 
        intervals [62]:
            xmin = 200.314 
            xmax = 200.374 
            text = "" 
        intervals [63]:
            xmin = 200.374 
            xmax = 207.343 
            text = "un dos iz geven a mishpokhe vu er iz gevezn oykhet, vu er iz ayngeshtanen, un er hot dortn take mit a tokhter khasene gehat." 
        intervals [64]:
            xmin = 207.343 
            xmax = 211.787 
            text = "er lebt shoyn nisht un zi lebt shoyn oykh nisht. yingerer bruder fun mayn man." 
        intervals [65]:
            xmin = 211.787 
            xmax = 214.122 
            text = "" 
        intervals [66]:
            xmin = 214.122 
            xmax = 220.022 
            text = "f- iz mit Ander's armey iz er do arayngekumen, azoy az er iz geven mit mit in kontakt," 
        intervals [67]:
            xmin = 220.022 
            xmax = 220.838 
            text = "" 
        intervals [68]:
            xmin = 220.838 
            xmax = 223.264 
            text = "er hot gekro- er hot gevust az ikh leb," 
        intervals [69]:
            xmin = 223.264 
            xmax = 232.537 
            text = "un fun vanet hot er gevust az ikh leb? vayl a sh- der shvoger, der advokat, iz gekumen hot iz geven in kontakt mit dem eh mit dem bruder vos ikh hob do gehat," 
        intervals [70]:
            xmin = 232.537 
            xmax = 238.296 
            text = "un er hot azoy nokher dervust zikh az ikh leb mitn kind kind, nor der t- un zayn bruder nisht." 
        intervals [71]:
