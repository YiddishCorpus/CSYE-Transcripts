        intervals [19]:
            xmin = 64.147 
            xmax = 64.39 
            text = "" 
        intervals [20]:
            xmin = 64.39 
            xmax = 73.946 
            text = "un un mayn man iz gevezn a mitglid in linke politsye, hot er geshmirt mit finef toyznt dolar far undz ale dray, farn kind, far mir un far im." 
        intervals [21]:
            xmin = 73.946 
            xmax = 79.875 
            text = "un biz der tsveyter TUR iz gekumen do aher, ze'mir tsvelef tog geven in tranzit lager," 
        intervals [22]:
            xmin = 79.875 
            xmax = 80.607 
            text = "" 
        intervals [23]:
            xmin = 80.607 
            xmax = 87.432 
            text = "un eh iz geforn epes oyf a balye vos iz shoyn geforn dos eh eh dos letste mol," 
        intervals [24]:
            xmin = 87.432 
            xmax = 92.164 
            text = "un m'iz ongekumen in land arayn iz shoyn geven, eh oyf der shif, oyf dem shifl," 
        intervals [25]:
            xmin = 92.164 
            xmax = 97.813 
            text = "iz shoyn gevezn, biz s'iz aroyfgekumen fun Sokhnut epes fregn, iz shoyn geven shpet bay nakht," 
        intervals [26]:
            xmin = 97.813 
            xmax = 98.072 
            text = "" 
        intervals [27]:
            xmin = 98.072 
            xmax = 104.799 
            text = "eynse, tsveleve, eh ver veyst, alnfals, un m'hot undz oyfgenumen undz o," 
        intervals [28]:
            xmin = 104.799 
            xmax = 105.379 
            text = "" 
        intervals [29]:
            xmin = 105.379 
            xmax = 111.785 
            text = "eh m'hot gornisht farlangt, m'hot gornisht gevust, nor er hot proponirt az m'zol geyn in a KIBBUTZ arayn, BECHEN s'do a kind." 
        intervals [30]:
            xmin = 111.785 
            xmax = 111.792 
            text = "" 
        intervals [31]:
            xmin = 111.792 
            xmax = 114.716 
            text = "mayn man hot fun dem nisht gevolt hern, er iz nisht geven keyn tip." 
        intervals [32]:
            xmin = 114.716 
            xmax = 118.282 
            text = "bemeyle vos er hot getun hob ikh gemuzt tun, s'geven mayn man." 
        intervals [33]:
            xmin = 118.282 
            xmax = 119.419 
            text = "" 
        intervals [34]:
            xmin = 119.419 
            xmax = 126.534 
            text = "ze'mir ongekumen keyn Givat Olga, iz nisht geven afile keyn balatake, shoyn tsveye bay nakht," 
        intervals [35]:
            xmin = 126.534 
            xmax = 127.097 
            text = "" 
        intervals [36]:
            xmin = 127.097 
            xmax = 133.368 
            text = "ho'mir zikh gezetst, nisht genumen keyn betl, nisht keyn kots, nisht keyn akht lires, nisht gornisht," 
        intervals [37]:
            xmin = 133.368 
            xmax = 133.577 
            text = "" 
        intervals [38]:
            xmin = 133.577 
            xmax = 137.911 
            text = "un in lager in tranzit, ikh m- mish UNK eyns in andern," 
        intervals [39]:
            xmin = 137.911 
            xmax = 141.064 
            text = "hot men undz oysgeshit alts un tsugenumen a farmegn." 
        intervals [40]:
            xmin = 141.064 
            xmax = 141.475 
            text = "" 
        intervals [41]:
            xmin = 141.475 
            xmax = 143.646 
            text = "un ikh hob nisht gehat far vemen optsushraybn." 
        intervals [42]:
            xmin = 143.646 
