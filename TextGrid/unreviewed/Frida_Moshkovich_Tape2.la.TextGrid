            text = "m'hot nisht gekent helfn farn kind. nisht vi azoy, nisht gornisht." 
        intervals [513]:
            xmin = 1511.212 
            xmax = 1512.855 
            text = "" 
        intervals [514]:
            xmin = 1512.855 
            xmax = 1517.979 
            text = "nor m- efsher azoy vi m'hot iz er hot gezogt, Eykhman," 
        intervals [515]:
            xmin = 1517.979 
            xmax = 1519.167 
            text = "" 
        intervals [516]:
            xmin = 1519.167 
            xmax = 1523.245 
            text = "m- az undz yidishe froyen veln nisht kenen keyn kinder hobn." 
        intervals [517]:
            xmin = 1523.245 
            xmax = 1523.723 
            text = "" 
        intervals [518]:
            xmin = 1523.723 
            xmax = 1527.244 
            text = "un zey veln nisht kenen keyn mol nisht eh oyslebn lang." 
        intervals [519]:
            xmin = 1527.244 
            xmax = 1528.195 
            text = "" 
        intervals [520]:
            xmin = 1528.195 
            xmax = 1533.065 
            text = "nor eh s'nisht gelungen. s'vi azoy m'zogt, geloybt tsu got az s'nisht emes." 
        intervals [521]:
            xmin = 1533.065 
            xmax = 1533.392 
            text = "" 
        intervals [522]:
            xmin = 1533.392 
            xmax = 1536.997 
            text = "vi undz hot men dort gegebn in lager far ale froyen," 
        intervals [523]:
            xmin = 1536.997 
            xmax = 1537.138 
            text = "" 
        intervals [524]:
            xmin = 1537.138 
            xmax = 1541.823 
            text = "az zoln nisht hobn keyn eh UNK." 
        intervals [525]:
            xmin = 1541.823 
            xmax = 1543.821 
            text = "" 
        intervals [526]:
            xmin = 1543.821 
            xmax = 1544.895 
