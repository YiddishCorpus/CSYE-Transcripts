            text = "undz ze'mir geven shkheynim, hot ir tate gezogt," 
        intervals [127]:
            xmin = 386.454 
            xmax = 391.792 
            text = "az deys vos er vet esn vel ikh oys esn, un mikh lot er nisht in ergets vayl ikh hob nisht vu tsu geyn." 
        intervals [128]:
            xmin = 391.792 
            xmax = 393.148 
            text = "" 
        intervals [129]:
