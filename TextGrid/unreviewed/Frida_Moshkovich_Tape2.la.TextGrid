        intervals [538]:
            xmin = 1556.134 
            xmax = 1558.08 
            text = "" 
        intervals [539]:
            xmin = 1558.08 
            xmax = 1559.93 
            text = "in lager hot keyner nisht gehat." 
        intervals [540]:
            xmin = 1559.93 
            xmax = 1560.308 
            text = "" 
        intervals [541]:
            xmin = 1560.308 
