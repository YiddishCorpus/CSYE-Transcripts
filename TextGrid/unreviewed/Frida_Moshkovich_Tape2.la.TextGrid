            xmax = 1562.181 
            text = "" 
        intervals [543]:
            xmin = 1562.181 
            xmax = 1564.048 
            text = "m'hot gegebn in esn bron." 
        intervals [544]:
            xmin = 1564.048 
            xmax = 1564.054 
            text = "" 
        intervals [545]:
            xmin = 1564.054 
            xmax = 1565.972 
            text = "un dos gleybt keyner nisht." 
        intervals [546]:
            xmin = 1565.972 
            xmax = 1567.952 
            text = "" 
        intervals [547]:
            xmin = 1567.952 
            xmax = 1568.756 
            text = "DA." 
        intervals [548]:
            xmin = 1568.756 
            xmax = 1569.893 
            text = "" 
        intervals [549]:
            xmin = 1569.893 
            xmax = 1572.705 
            text = "m'hot undz vi m'zogt ineveynik geharget." 
        intervals [550]:
            xmin = 1572.705 
            xmax = 1577.301 
            text = "" 
        intervals [551]:
            xmin = 1577.301 
            xmax = 1580.585 
            text = "DA UNK" 
        intervals [552]:
            xmin = 1580.585 
            xmax = 1580.71 
            text = "" 
        intervals [553]:
            xmin = 1580.71 
            xmax = 1583.623 
            text = "zoln lebn biz hundert tsvontsik yor. ikh hob tsvey zinen," 
        intervals [554]:
            xmin = 1583.623 
            xmax = 1583.815 
            text = "" 
        intervals [555]:
            xmin = 1583.815 
            xmax = 1588.072 
            text = "ikh hob finef eyniklekh, tsvey shnurn," 
        intervals [556]:
            xmin = 1588.072 
            xmax = 1590.659 
            text = "geloybt tsu got. ales iz gut, normal." 
        intervals [557]:
            xmin = 1590.659 
            xmax = 1600.234 
            text = "" 
        intervals [558]:
            xmin = 1600.234 
            xmax = 1606.286 
            text = "UNK zog ikh dikh, bay di ungarn nokh, het er geven antisemitizm farshidene." 
        intervals [559]:
            xmin = 1606.286 
            xmax = 1606.63 
            text = "" 
        intervals [560]:
            xmin = 1606.63 
            xmax = 1612.597 
            text = "nor <Posyovaner> dos iz shoyn geven finef un fertisker yor. demolts nisht." 
        intervals [561]:
            xmin = 1612.597 
            xmax = 1613.346 
            text = "" 
        intervals [562]:
            xmin = 1613.346 
            xmax = 1622.519 
            text = "demolts momental, zenen di goyim velkhe zenen geblibn, zenen zey geven gants kemayse. z- nu m'hot gezen az eh undz ze'mir ale naket un borves gekumen." 
        intervals [563]:
            xmin = 1622.519 
            xmax = 1622.56 
            text = "" 
        intervals [564]:
            xmin = 1622.56 
            xmax = 1625.231 
            text = "zey hobn tsugenumen di yidishe zakhn ales." 
        intervals [565]:
            xmin = 1625.231 
            xmax = 1628.223 
            text = "keyner hot fun er- keyner hot gornisht bakumen tsurik." 
        intervals [566]:
            xmin = 1628.223 
            xmax = 1629.141 
            text = "" 
        intervals [567]:
            xmin = 1629.141 
            xmax = 1631.919 
            text = "nu iz avade iz geven, far zey iz geven gut." 
        intervals [568]:
            xmin = 1631.919 
            xmax = 1633.343 
            text = "" 
        intervals [569]:
            xmin = 1633.343 
            xmax = 1638.098 
            text = "zey zeen ven di yidn's eh stradayen, demolts iz far zey gut." 
        intervals [570]:
            xmin = 1638.098 
            xmax = 1643.144 
            text = "nu demolts eh zenen iz nisht geven keyn shum in- eh deys az vos heyst eh" 
        intervals [571]:
            xmin = 1643.144 
            xmax = 1647.393 
            text = "dey mentshn velkhe zenen geven fashistn, dey hot men opgehaltn." 
        intervals [572]:
            xmin = 1647.393 
            xmax = 1647.4 
            text = "" 
        intervals [573]:
            xmin = 1647.4 
            xmax = 1650.026 
            text = "un dey di iberike proste mentshn zenen geven." 
        intervals [574]:
            xmin = 1650.026 
            xmax = 1651.416 
            text = "" 
        intervals [575]:
            xmin = 1651.416 
            xmax = 1656.152 
            text = "undz ho'mir nisht geshpirt keyn shum min antisemitshaft. gornisht." 
        intervals [576]:
            xmin = 1656.152 
            xmax = 1656.377 
            text = "" 
        intervals [577]:
            xmin = 1656.377 
            xmax = 1660.201 
            text = "nokh eh nokh dem makht zikh alts. alts hot men nisht lib keyn yid." 
        intervals [578]:
            xmin = 1660.201 
            xmax = 1662.469 
            text = "" 
        intervals [579]:
            xmin = 1662.469 
            xmax = 1670.664 
            text = "ikh undz ho'mir gearbet, undz hobn gehat groys koved bay mentshn. undz hot men uvazhayet, nu." 
        intervals [580]:
            xmin = 1670.664 
            xmax = 1670.839 
            text = "" 
        intervals [581]:
            xmin = 1670.839 
            xmax = 1674.14 
            text = "keyn shum, ze'mir yidn, ze'mir antlofn oyf Erets." 
        intervals [582]:
            xmin = 1674.14 
            xmax = 1677.657 
            text = "" 
        intervals [583]:
            xmin = 1677.657 
            xmax = 1679.153 
            text = "UNK" 
        intervals [584]:
            xmin = 1679.153 
            xmax = 1681.538 
            text = "" 
        intervals [585]:
            xmin = 1681.538 
            xmax = 1686.898 
            text = "mayn man iz geven krank. er hot shoyn gehat dort tsveyte grupe INVALIDNOST." 
        intervals [586]:
            xmin = 1686.898 
            xmax = 1687.258 
            text = "" 
        intervals [587]:
            xmin = 1687.258 
            xmax = 1696.281 
            text = "er hot shoyn nisht gearbet. un er hot gezogt az er geyt nisht oyf Izrael. a kranker mentsh hot nisht vos tsu ton in Izrael." 
        intervals [588]:
            xmin = 1696.281 
            xmax = 1696.455 
            text = "" 
        intervals [589]:
            xmin = 1696.455 
            xmax = 1702.873 
            text = "undz ho'mir im gezogt, kuk aher, undz ze'mir shoyn nisht, s'shoyn nisht keyn kleyne kinder, der elterer zun iz shoyn geven a khasene gehater" 
        intervals [590]:
            xmin = 1702.873 
            xmax = 1708.785 
            text = "der yingerer iz geven mit undz, eh ikh vel arbetn, er vet arbetn, m'vet fardinen." 
        intervals [591]:
            xmin = 1708.785 
            xmax = 1708.842 
            text = "" 
        intervals [592]:
            xmin = 1708.842 
            xmax = 1716.43 
            text = "m'vet lebn. vayle m'hot zikh ibergeshribn mit khaveyrim, mit yedn eynem, hobn gezogt, YOU KNOW, s'shver dos lebn, ober ver vi azoy, s'nemt." 
        intervals [593]:
            xmin = 1716.43 
            xmax = 1717.583 
            text = "" 
        intervals [594]:
            xmin = 1717.583 
            xmax = 1721.908 
            text = "undz ze'mir gekumen aher, undz ho'mir gebrengt. deys ales ales ho'mir undz gebrengt." 
        intervals [595]:
            xmin = 1721.908 
            xmax = 1725.165 
            text = "undz ho'mir gornisht nisht POCHTI do gekoyft UNK." 
        intervals [596]:
            xmin = 1725.165 
            xmax = 1727.938 
            text = "nor dem televizye, di lekter TOVAREs." 
        intervals [597]:
            xmin = 1727.938 
            xmax = 1728.096 
            text = "" 
        intervals [598]:
            xmin = 1728.096 
            xmax = 1731.009 
            text = "oder deys iz nisht azoy vi azoy undz ho'mir geklert." 
        intervals [599]:
            xmin = 1731.009 
            xmax = 1731.42 
            text = "" 
        intervals [600]:
            xmin = 1731.42 
            xmax = 1733.779 
            text = "mir iz geven do zeyer shver tsvey yor." 
        intervals [601]:
            xmin = 1733.779 
            xmax = 1738.012 
            text = "er hot nisht bakumen keyn nisht keyn pensye, nisht gornisht." 
        intervals [602]:
            xmin = 1738.012 
            xmax = 1738.086 
            text = "" 
        intervals [603]:
            xmin = 1738.086 
            xmax = 1744.982 
            text = "a yor hot undz der Sakhnut geholfn, bifl er hot gekent, arbetn hot er nisht gekent," 
        intervals [604]:
            xmin = 1744.982 
            xmax = 1746.152 
            text = "" 
        intervals [605]:
            xmin = 1746.152 
            xmax = 1752.305 
            text = "ikh bin avek arbetn vu ikh hob gekent oykhet. ikh bin geven in a restorant hob ikh gearbet, ikh hob gevashn geshir." 
        intervals [606]:
            xmin = 1752.305 
            xmax = 1753.527 
            text = "" 
        intervals [607]:
            xmin = 1753.527 
            xmax = 1760.254 
            text = "un eh kinder hob ikh TAPELET, nokh dem hob ikh im nisht gevolt iberlozn aleyn, spn shoyn." 
        intervals [608]:
            xmin = 1760.254 
            xmax = 1761.205 
            text = "" 
        intervals [609]:
            xmin = 1761.205 
            xmax = 1767.021 
            text = "UNK ikh hob nisht gevolt iberlozn aleyn, bin ikh genumen kinder TAPELET." 
        intervals [610]:
            xmin = 1767.021 
            xmax = 1767.432 
            text = "" 
        intervals [611]:
            xmin = 1767.432 
            xmax = 1774.145 
            text = "un eh do bin ikh ikh bin geven alts mit im er zol im nisht er iz arumgegangen tsu bislekh, oder er iz geven zeyer," 
