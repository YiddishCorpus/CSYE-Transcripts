        intervals: size = 611 
        intervals [1]:
            xmin = 0 
            xmax = 4.872 
            text = "" 
        intervals [2]:
            xmin = 4.872 
            xmax = 11.16 
            text = "in Oyshvits hob ikh gehat a khavertorin, a undz ze'mir geven shkheynes meydlekh geven." 
        intervals [3]:
            xmin = 11.16 
            xmax = 11.318 
            text = "" 
        intervals [4]:
            xmin = 11.318 
            xmax = 17.809 
            text = "zi iz elter geven fun mir mit a yor. zi iz geven hoykh, un ikh bin geven niderik un dar." 
        intervals [5]:
            xmin = 17.809 
            xmax = 19.148 
            text = "" 
        intervals [6]:
            xmin = 19.148 
            xmax = 23.057 
            text = "zi hot men shtendik oysgekloybn in krematoryum arayn." 
        intervals [7]:
            xmin = 23.057 
            xmax = 24.025 
            text = "" 
        intervals [8]:
            xmin = 24.025 
            xmax = 27.006 
            text = "zi iz oykh koydem gekumen mit mir oyf arbet," 
        intervals [9]:
            xmin = 27.006 
            xmax = 27.214 
            text = "" 
        intervals [10]:
            xmin = 27.214 
            xmax = 35.544 
            text = "in Oyshvits hot zi Mengele oysgekloybn. un nokh dem yedes mol, vifl mol Mengele hot ibergekloybn, hot er zi alts aroysgevorfn." 
        intervals [11]:
            xmin = 35.544 
            xmax = 36.715 
            text = "" 
        intervals [12]:
            xmin = 36.715 
            xmax = 40.944 
            text = "un eh ze'mir geven fir sh- meydlekh, fir shkheynim," 
        intervals [13]:
            xmin = 40.944 
            xmax = 41.608 
            text = "" 
        intervals [14]:
            xmin = 41.608 
            xmax = 46.124 
            text = "ale fir meydlekh, zey zenen geven ale elter, ikh bin geven di yingste." 
        intervals [15]:
            xmin = 46.124 
            xmax = 47.042 
            text = "" 
        intervals [16]:
            xmin = 47.042 
            xmax = 52.47 
            text = "zey hobn alts geklert vos m'ken ton, eh mayn khavertorin Goldi," 
        intervals [17]:
            xmin = 52.47 
            xmax = 52.527 
            text = "" 
        intervals [18]:
            xmin = 52.527 
            xmax = 57.498 
            text = "m'zol zi kenen eh eh rateven fun Mengele's hent." 
        intervals [19]:
            xmin = 57.498 
            xmax = 59.04 
            text = "" 
        intervals [20]:
            xmin = 59.04 
            xmax = 65.649 
            text = "ze'mir gegan dort eh hot men undz geshikt eyn mol in der vokh hot men undz gefirt bodn. dort hot undz Mengele oyfbakukt." 
        intervals [21]:
            xmin = 65.649 
            xmax = 65.689 
            text = "" 
        intervals [22]:
            xmin = 65.689 
            xmax = 67.843 
            text = "dos heyst geheysn di zone." 
        intervals [23]:
            xmin = 67.843 
            xmax = 69.098 
            text = "" 
        intervals [24]:
            xmin = 69.098 
            xmax = 74.132 
            text = "dort, fun dort mikh hot men alts oysgekloybn oyf arbet." 
        intervals [25]:
            xmin = 74.132 
            xmax = 81.123 
            text = "un zi hot alts avekgevorfn. zi hot men alts geleygt, az m'hot alts gefunen oyf ir epes a shprenkele." 
        intervals [26]:
            xmin = 81.123 
            xmax = 81.923 
            text = "" 
        intervals [27]:
            xmin = 81.923 
            xmax = 86.776 
            text = "bin ikh antlofn fun dort, m'hot mir gekent shisn." 
        intervals [28]:
            xmin = 86.776 
            xmax = 87.66 
            text = "" 
        intervals [29]:
            xmin = 87.66 
            xmax = 94.741 
            text = "mikh hot men avek gevolt aveknemen in der arbet. ikh hob nisht gevolt geyn, vayl ale mayne mentshn, mayne bakonte, zenen geblibn." 
        intervals [30]:
            xmin = 94.741 
            xmax = 95.44 
            text = "" 
        intervals [31]:
            xmin = 95.44 
            xmax = 98.049 
            text = "mikh hot men koydem gevolt oyf Daytshland firn." 
        intervals [32]:
            xmin = 98.049 
            xmax = 98.46 
            text = "" 
        intervals [33]:
            xmin = 98.46 
            xmax = 107.331 
            text = "bin ikh antlofn durkh ir. zi ho- ho'mir gefunen un zi iz vayter geven mit undz." 
        intervals [34]:
            xmin = 107.331 
            xmax = 108.265 
            text = "" 
        intervals [35]:
            xmin = 108.265 
            xmax = 114.452 
            text = "nokh dem vayter hot men undz vayter ongehoybn tsu kloybn, zi hot men vayter aroysgevorfn." 
        intervals [36]:
            xmin = 114.452 
            xmax = 114.947 
            text = "" 
        intervals [37]:
            xmin = 114.947 
            xmax = 119.379 
            text = "undz ze'mir shoyn geven oder in transport tsu geyn" 
        intervals [38]:
            xmin = 119.379 
            xmax = 119.689 
            text = "" 
        intervals [39]:
            xmin = 119.689 
            xmax = 124.965 
            text = "oyf Daytshland. undz hot men shoyn nisht aroysgelozt, undz ho'mir shoyn geheysn blok SPERRE." 
        intervals [40]:
            xmin = 124.965 
            xmax = 126.27 
            text = "" 
        intervals [41]:
            xmin = 126.27 
            xmax = 136.591 
            text = "vi m'hot zey aroys- iz eh vi ze- ze'mir gekumen ahin in der zone, hot zi Mengele vayter aroysgevorfn." 
        intervals [42]:
            xmin = 136.591 
            xmax = 137.273 
            text = "" 
        intervals [43]:
            xmin = 137.273 
            xmax = 141.975 
            text = "un fun dort iz geven, m'hot zi avekgefirt in a revir." 
        intervals [44]:
            xmin = 141.975 
            xmax = 142.96 
            text = "" 
        intervals [45]:
            xmin = 142.96 
            xmax = 147.175 
            text = "a revir eh UNK. dos iz a eh neyn." 
        intervals [46]:
            xmin = 147.175 
            xmax = 150.024 
            text = "dos iz a UNK." 
        intervals [47]:
            xmin = 150.024 
            xmax = 151.532 
            text = "" 
        intervals [48]:
            xmin = 151.532 
            xmax = 155.728 
            text = "un undz ho'mir nisht gevust vu dos iz, un undz hot men nisht aroysgelozt." 
        intervals [49]:
            xmin = 155.728 
            xmax = 157.152 
            text = "" 
        intervals [50]:
            xmin = 157.152 
            xmax = 163.507 
            text = "di meydlekh hobn gezogt m'darf Go- Goldi zol zayn mit undz, vayl oyb nisht, Goldi geyt in krematoryum arayn." 
        intervals [51]:
            xmin = 163.507 
            xmax = 165.167 
            text = "" 
        intervals [52]:
            xmin = 165.167 
            xmax = 171.202 
            text = "iz tsugegan- iz es, bin ikh gegangen UNK m'hot undz nisht aroysgelozt, vayl s'geven blok SPERRE." 
        intervals [53]:
            xmin = 171.202 
            xmax = 171.664 
            text = "" 
        intervals [54]:
            xmin = 171.664 
            xmax = 176.079 
            text = "hobn zey gezogt di meydlekh az zol ikh veynen az s'tut mikh vey di boykh." 
        intervals [55]:
            xmin = 176.079 
            xmax = 176.237 
            text = "" 
        intervals [56]:
            xmin = 176.237 
            xmax = 178.931 
            text = "az m'zol mikh lozn UNK tualet." 
        intervals [57]:
            xmin = 178.931 
            xmax = 179.342 
            text = "" 
        intervals [58]:
            xmin = 179.342 
            xmax = 184.803 
            text = "ikh hob ongehoybn tsu veynen s'tut mikh vey der boykh, un ikh bin gelofn zukhn Goldin." 
        intervals [59]:
            xmin = 184.803 
            xmax = 184.928 
            text = "" 
        intervals [60]:
            xmin = 184.928 
            xmax = 190.662 
            text = "dos iz geven in lager dort. nor dort hot men eh s'geven ful eh bra- barakn," 
        intervals [61]:
            xmin = 190.662 
            xmax = 196.633 
            text = "oder m'hot nisht getort geyn in ergets fun eyn barak in andern arayn. un ikh hob zi gefunen." 
        intervals [62]:
            xmin = 196.633 
            xmax = 198.563 
            text = "" 
        intervals [63]:
            xmin = 198.563 
            xmax = 206.184 
            text = "nor un ikh hob shoyn gekent tun az zi zol aroyskumen fun dort, vayl dort iz geven a kalitke." 
        intervals [64]:
            xmin = 206.184 
            xmax = 206.95 
            text = "" 
        intervals [65]:
            xmin = 206.95 
            xmax = 209.306 
            text = "nor di kalitke hot men gekent oyfmakhn." 
        intervals [66]:
            xmin = 209.306 
            xmax = 210.19 
            text = "" 
        intervals [67]:
            xmin = 210.19 
            xmax = 216.562 
            text = "un undz hot men shoyn oyfgenumen loyt dem nomen un undz ze'mir shoyn gedarft avekforn." 
        intervals [68]:
            xmin = 216.562 
            xmax = 218.357 
            text = "" 
        intervals [69]:
            xmin = 218.357 
            xmax = 224.409 
            text = "un do hot men eh do iz shoyn nisht do keyn shum min, azoy vi ikh hob zi geho- getrofn," 
        intervals [70]:
            xmin = 224.409 
            xmax = 224.668 
            text = "" 
        intervals [71]:
            xmin = 224.668 
            xmax = 227.964 
            text = "ze'm- m'hot undz aroysgelozt oyfn hoyf makhn apel," 
        intervals [72]:
            xmin = 227.964 
            xmax = 233.758 
            text = "vu s'geven poylishe meydlekh, di shrayberins, vos zey hobn undz oyfgenumen, zey zenen shoyn geven fir yor in lager." 
        intervals [73]:
            xmin = 233.758 
            xmax = 234.625 
            text = "" 
        intervals [74]:
            xmin = 234.625 
            xmax = 238.82 
            text = "hobn zey gezogt, yo ho'mir undz gezogt az mir viln mir baytn." 
        intervals [75]:
            xmin = 238.82 
            xmax = 238.877 
            text = "" 
        intervals [76]:
            xmin = 238.877 
            xmax = 243.278 
            text = "az zi zol kumen tsun undz un an andere zol geyn ahin." 
        intervals [77]:
            xmin = 243.278 
            xmax = 250.56 
            text = "hot zi gezogt, vayl undz ho'mir getrofn a froy, undz ho'mir in hoyf ongehoybn tsu shrayen ver s'vil geyn ahin in revir arayn." 
        intervals [78]:
            xmin = 250.56 
            xmax = 253.35 
            text = "hot zikh ongerufn eyn froy az zi vil geyn." 
        intervals [79]:
            xmin = 253.35 
            xmax = 254.52 
            text = "" 
        intervals [80]:
            xmin = 254.52 
            xmax = 260.001 
            text = "un zi iz avek ahin in revir, eh UNK, hot zi gezogt, di shrayberin, az zi ken gornisht tun." 
        intervals [81]:
            xmin = 260.001 
            xmax = 264.605 
            text = "vayl dos iz shoyn oyfgenumen yedn loyt dem nomen un zi ken gornisht tun." 
        intervals [82]:
            xmin = 264.605 
            xmax = 265.27 
            text = "" 
        intervals [83]:
            xmin = 265.27 
            xmax = 268.639 
            text = "un hot zi gezogt far der froy, ""nokh vos geystu ahin?" 
        intervals [84]:
            xmin = 268.639 
            xmax = 268.662 
            text = "" 
        intervals [85]:
            xmin = 268.662 
            xmax = 271.153 
            text = "du veyst vos dort iz?"" zogt zi, yo." 
        intervals [86]:
            xmin = 271.153 
            xmax = 271.378 
            text = "" 
        intervals [87]:
            xmin = 271.378 
            xmax = 277.16 
            text = "zogt zi, far vos vilstu geyn ahin? zogt zi, far dort iz mayn mame un ikh vil shtarbn in eynem mit mayn mame." 
        intervals [88]:
            xmin = 277.16 
            xmax = 279.917 
            text = "" 
        intervals [89]:
            xmin = 279.917 
            xmax = 286.155 
            text = "iz di ze'mir gegangen un hobn zi avekgefirt un Goldin aroysgenumen." 
        intervals [90]:
            xmin = 286.155 
            xmax = 286.617 
            text = "" 
        intervals [91]:
            xmin = 286.617 
            xmax = 291.504 
            text = "Goldi iz vayter gegangen mit undz in transport, oder do heybt zikh on vayter a Mengele." 
        intervals [92]:
            xmin = 291.504 
            xmax = 292.303 
            text = "" 
        intervals [93]:
            xmin = 292.303 
            xmax = 296.431 
            text = "un di vagonen zenen shoyn geshtanen un do iz shoyn nisht geven keyn shum min hilf." 
        intervals [94]:
            xmin = 296.431 
            xmax = 298.615 
            text = "" 
        intervals [95]:
            xmin = 298.615 
            xmax = 302.473 
            text = "hobn di meydlekh gezogt az ikh zol geyn foroys, vayl ikh vel durkhgeyn." 
        intervals [96]:
            xmin = 302.473 
            xmax = 303.576 
            text = "" 
        intervals [97]:
            xmin = 303.576 
            xmax = 306.214 
            text = "un zey ebn blaybn fun hintn mit Goldin." 
        intervals [98]:
            xmin = 306.214 
            xmax = 308.615 
            text = "ober dos iz geven azoy vi a <PE> gemakht." 
        intervals [99]:
            xmin = 308.615 
            xmax = 308.757 
            text = "" 
        intervals [100]:
            xmin = 308.757 
            xmax = 312.81 
            text = "zey hobn mikh gekent fun hintn zen, vi azoy ikh bin arayn do un Mengele hot mikh bakukt," 
        intervals [101]:
            xmin = 312.81 
            xmax = 316.31 
            text = "m'hot gedarft arayngeyn in der zone bodn zikh un fun dort aroysgeyn" 
        intervals [102]:
            xmin = 316.31 
            xmax = 320.472 
            text = "iz shoyn geven an ander plats, nor vi azoy zey zenen ges- -shtanen fun hintn," 
        intervals [103]:
            xmin = 320.472 
            xmax = 325.17 
            text = "hobn zey mikh gezen ale. vi azoy ikh, zey hobn gekukt vi azoy ikh gey aroys." 
        intervals [104]:
            xmin = 325.17 
            xmax = 325.547 
            text = "" 
        intervals [105]:
            xmin = 325.547 
            xmax = 327.532 
            text = "ikh bin aroysgegangen shnel fun dort," 
        intervals [106]:
            xmin = 327.532 
            xmax = 327.775 
            text = "" 
        intervals [107]:
            xmin = 327.775 
            xmax = 331.644 
            text = "ikh hob gekukt az s'zol zayn shoyn a tsen fuftsn mentshn," 
        intervals [108]:
            xmin = 331.644 
            xmax = 337.606 
            text = "un ikh hob ge- tsiterdike hent gehaltn dos vaser in di hent, un a shray gegebn, ""Goldi, loyf!""" 
        intervals [109]:
            xmin = 337.606 
            xmax = 338.068 
            text = "" 
        intervals [110]:
            xmin = 338.068 
            xmax = 343.305 
            text = "un Goldi iz gelofn. zi hot zikh geshtelt geven tsu shmirn un eh, undz ze'mir ale naket geven." 
        intervals [111]:
            xmin = 343.305 
            xmax = 347.785 
            text = "ikh hob ir afile gegebn a shtroy vaser, vifl ikh hob gehat in di hent," 
        intervals [112]:
            xmin = 347.785 
            xmax = 351.953 
            text = "un UNK di daytshn hobn in akht genumen, az emetser iz gelofn." 
        intervals [113]:
            xmin = 351.953 
            xmax = 356.304 
            text = "nor az m'hot ibergetseylt, zey hobn nisht farshtanen vos dos iz." 
        intervals [114]:
            xmin = 356.304 
            xmax = 356.631 
            text = "" 
        intervals [115]:
            xmin = 356.631 
            xmax = 362.092 
            text = "un azoy ze'mir arayn, avekgeforn ale oyf Daytshland. SO mer keyn Mengele iz shoyn nisht geven." 
        intervals [116]:
