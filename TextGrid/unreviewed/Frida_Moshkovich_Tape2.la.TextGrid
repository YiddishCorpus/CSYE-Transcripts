            xmax = 750.031 
            text = "nor fun dort ze'mir durkhgeforn oyf Prag," 
        intervals [252]:
            xmin = 750.031 
            xmax = 750.561 
            text = "" 
        intervals [253]:
            xmin = 750.561 
            xmax = 755.029 
            text = "Prag hot men undz oykhet iberol, der Dzhoynt hot shoyn gevart undz iberol." 
        intervals [254]:
            xmin = 755.029 
            xmax = 758.7 
            text = "iberol hot men gegebn esn, iberol hot men gegebn a por eh heler." 
        intervals [255]:
            xmin = 758.7 
            xmax = 761.203 
            text = "un fun dort ze'mir ongekumen oyf Bratislava." 
        intervals [256]:
            xmin = 761.203 
            xmax = 762.205 
            text = "" 
        intervals [257]:
            xmin = 762.205 
            xmax = 768.459 
            text = "Bratislava ze'mir geven epes tsvey vokhn oykhet, in a shul, in a hotel hot men oysgeleydikt." 
        intervals [258]:
            xmin = 768.459 
            xmax = 768.718 
            text = "" 
        intervals [259]:
            xmin = 768.718 
