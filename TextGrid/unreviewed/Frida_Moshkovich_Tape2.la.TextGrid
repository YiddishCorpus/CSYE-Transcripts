            text = "" 
        intervals [266]:
            xmin = 785.56 
            xmax = 792.051 
            text = "in Budapest ze'mir vayter geven a tsvey dray vokhn, un dort iz shoyn geven fray. ver vemen hot gevolt hot er shoyn gekent geyn." 
        intervals [267]:
            xmin = 792.051 
