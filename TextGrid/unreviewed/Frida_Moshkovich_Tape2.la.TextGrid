            xmax = 854.488 
            text = "un er eh hot er iz arayn in a dire, zayn dire iz oykh geven tsebrokhn. er iz arayn in an anderer dire." 
        intervals [292]:
            xmin = 854.488 
            xmax = 855.574 
            text = "" 
        intervals [293]:
            xmin = 855.574 
            xmax = 863.398 
            text = "un er hot mikh oyfgehaltn vayl ikh hob nisht gehat vu tsu zayn. er im ho'mir mir getrofn in Budapest. nisht in Budapest, in Bratislava." 
        intervals [294]:
            xmin = 863.398 
            xmax = 864.636 
            text = "" 
        intervals [295]:
            xmin = 864.636 
            xmax = 870.435 
            text = "er iz oykh bafrayt gevorn. er aleyn hot gornisht gehat tsu esn, nokh di shlakht, ales tsugenumen." 
        intervals [296]:
            xmin = 870.435 
            xmax = 871.572 
            text = "" 
        intervals [297]:
            xmin = 871.572 
            xmax = 877.927 
            text = "nor er eh hot gezogt, afile eyn mol in tog, deys vos er vet esn, vet er mir oykh gebn." 
        intervals [298]:
            xmin = 877.927 
            xmax = 878.457 
            text = "" 
        intervals [299]:
            xmin = 878.457 
            xmax = 884.306 
            text = "ikh hob keynem nisht gehat, mir iz keyner nisht aheymgekumen, ikh bin eyner aleyn," 
        intervals [300]:
            xmin = 884.306 
            xmax = 884.785 
            text = "" 
        intervals [301]:
            xmin = 884.785 
            xmax = 887.192 
            text = "far mir iz geven shtark shver dos lebn." 
        intervals [302]:
            xmin = 887.192 
            xmax = 888.598 
            text = "" 
        intervals [303]:
            xmin = 888.598 
            xmax = 894.515 
            text = "un fun dort ho'mir gehert az s'do a Dzhoynt in Usharod." 
        intervals [304]:
            xmin = 894.515 
            xmax = 894.657 
            text = "" 
        intervals [305]:
            xmin = 894.657 
            xmax = 898.211 
            text = "un bin ikh geforn, ober dos iz nisht lang geven." 
        intervals [306]:
            xmin = 898.211 
            xmax = 898.977 
            text = "" 
        intervals [307]:
            xmin = 898.977 
            xmax = 902.531 
            text = "dos iz dort ze'mir geven, ho'mir bakumen a OBSHCHEZHITIE," 
        intervals [308]:
            xmin = 902.531 
            xmax = 903.887 
            text = "" 
        intervals [309]:
            xmin = 903.887 
            xmax = 906.783 
            text = "biz oykhet di Dzhoynt hot undz gehaltn." 
        intervals [310]:
            xmin = 906.783 
            xmax = 907.431 
            text = "" 
        intervals [311]:
            xmin = 907.431 
            xmax = 912.673 
            text = "un hobn mentshn hobn zikh mit dem farnumen un dey mentshn hot men nokh dem opgehaltn," 
        intervals [312]:
            xmin = 912.673 
            xmax = 913 
            text = "" 
        intervals [313]:
            xmin = 913 
            xmax = 915.221 
            text = "dos tsu aveknemen ale opgehaltn." 
        intervals [314]:
            xmin = 915.221 
            xmax = 915.295 
            text = "" 
        intervals [315]:
            xmin = 915.295 
            xmax = 919.929 
            text = "di gantse deys iz shoyn gevorn, ales hot men tsugenumen fun undz," 
        intervals [316]:
            xmin = 919.929 
            xmax = 920.357 
            text = "" 
        intervals [317]:
            xmin = 920.357 
            xmax = 928.89 
            text = "un m'hot undz ibergefirt oyf a eh iz shoyn gevorn UNK, shtatlekh," 
        intervals [318]:
            xmin = 928.89 
            xmax = 929.554 
            text = "" 
        intervals [319]:
            xmin = 929.554 
            xmax = 936.225 
            text = "un dos iz shoyn geven <Shveyna Bovna Fabrika>. aza nomen hot es gehat." 
        intervals [320]:
            xmin = 936.225 
            xmax = 940.078 
            text = "un s'zeyer shver geven, fardint hot men veynik," 
        intervals [321]:
            xmin = 940.078 
            xmax = 940.742 
            text = "" 
        intervals [322]:
            xmin = 940.742 
            xmax = 943.908 
            text = "undz ze'mir nokh geven a gelernt a, vos bisl neyen," 
        intervals [323]:
            xmin = 943.908 
            xmax = 944.337 
            text = "" 
        intervals [324]:
            xmin = 944.337 
            xmax = 949.916 
            text = "nor azoy vi m'zogt, shvere arbet, konfektsyon arbet, ober keyner hot mikh gornisht gekent." 
        intervals [325]:
            xmin = 949.916 
            xmax = 950.175 
            text = "" 
        intervals [326]:
            xmin = 950.175 
            xmax = 956.565 
            text = "iz geven shtark shver. ehm biz ze'mir a bisele tsu zikh gekumen, biz ho'mir zikh oysgelernt arbetn." 
        intervals [327]:
            xmin = 956.565 
            xmax = 956.908 
            text = "" 
        intervals [328]:
            xmin = 956.908 
            xmax = 963.027 
            text = "nor undz ho'mir shoyn nisht bakumen keyn esn, undz ho'mir shoyn gornisht bakumen. m'hpt shoyn fun undz tsugenumen di OBSHCHEZHITIE." 
        intervals [329]:
            xmin = 963.027 
            xmax = 963.355 
            text = "" 
        intervals [330]:
            xmin = 963.355 
            xmax = 968.884 
            text = "iz yede meydlekh khasene gehat, velekh mit vemen, zey hobn zikh bakont gemakht, az m'zol nisht zayn aleyn." 
        intervals [331]:
            xmin = 968.884 
            xmax = 968.907 
            text = "" 
        intervals [332]:
            xmin = 968.907 
            xmax = 976.832 
            text = "un zeyer a sakh ire hobn khasene gehat tsu eltere mentshn, DAZHE finef un tsvontsik yor RAZNITSA, iz geven an untershid." 
