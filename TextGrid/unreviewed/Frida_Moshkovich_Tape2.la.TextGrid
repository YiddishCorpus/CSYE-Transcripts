            text = "oykh gegebn a bisl un a bisele esn. iberol hot men undz gegebn esn." 
        intervals [260]:
            xmin = 773.178 
            xmax = 778.618 
            text = "un fun dortn ze'mir avekgegangen, hot men undz avekgefirt, zeyer shver geven tsu forn mit di tseger," 
        intervals [261]:
            xmin = 778.618 
            xmax = 779.13 
