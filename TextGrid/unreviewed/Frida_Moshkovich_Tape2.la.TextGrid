        intervals [242]:
            xmin = 726.345 
            xmax = 728.342 
            text = "eh tsi mir nem'mir on a bisl." 
        intervals [243]:
            xmin = 728.342 
            xmax = 731.554 
            text = "un m'hot shtark opgehit az m'zol nisht epes a khap ton." 
        intervals [244]:
            xmin = 731.554 
            xmax = 733.213 
            text = "" 
        intervals [245]:
            xmin = 733.213 
            xmax = 737.51 
            text = "nokh dem, un zey hobn undz gefirt shoyn oyf Tshekhoslovakay." 
        intervals [246]:
            xmin = 737.51 
            xmax = 738.445 
            text = "" 
        intervals [247]:
            xmin = 738.445 
            xmax = 741.746 
            text = "ze'mir ongekumen di ershte shtot oyf Belzn." 
        intervals [248]:
            xmin = 741.746 
