            text = "nisht aher nisht ahin." 
        intervals [171]:
            xmin = 511.911 
            xmax = 514.189 
            text = "nor fornt mit undz iz geven" 
        intervals [172]:
            xmin = 514.189 
            xmax = 521.117 
            text = "ale daytsher, di ofitsirn, di soldatn, velkhe zenen geven mit undz in eynem in Gaystlingen un in Minkhn Alekh," 
        intervals [173]:
            xmin = 521.117 
            xmax = 528.041 
            text = "iz dey ale gegangen mit undz. nor zey hobn gehat a gute kuper, a sheynem <tsugnish> geven un undz ho'mir gehat eh proste vagonen." 
        intervals [174]:
            xmin = 528.041 
            xmax = 528.823 
            text = "" 
        intervals [175]:
            xmin = 528.823 
            xmax = 533.503 
            text = "un eh ven undz ho'm- m'hot shoyn gezen az der front nentert zi" 
        intervals [176]:
            xmin = 533.503 
            xmax = 540.278 
            text = "un zey hobn shoyn nisht gekent geyn in ergets nisht, vayl shoyn di amerikaner zenen shoyn ongekumen. iz ongekumen di tanken," 
        intervals [177]:
            xmin = 540.278 
            xmax = 546.165 
            text = "ho'mir undz gezen az di daytshn velkhe zenen geven mit undz in di vagonen az zey nemen zikh epes tsu pakn zikh." 
        intervals [178]:
            xmin = 546.165 
            xmax = 546.559 
            text = "" 
        intervals [179]:
            xmin = 546.559 
            xmax = 550.091 
            text = "ober keyner hot nisht gevust vos dos iz. zey hobn zikh tsamgepakt," 
        intervals [180]:
            xmin = 550.091 
            xmax = 552.999 
            text = "di tsvey soldatn vos zenen gezesn in vagon," 
        intervals [181]:
            xmin = 552.999 
            xmax = 553.073 
            text = "" 
        intervals [182]:
            xmin = 553.073 
            xmax = 557.522 
            text = "un zenen avek un zey hobn undz tsugeshpart fun droysn undz zol'mir nisht kenen aroysgeyn." 
        intervals [183]:
            xmin = 557.522 
            xmax = 558.777 
            text = "" 
        intervals [184]:
            xmin = 558.777 
            xmax = 564.626 
            text = "un di mener hobn gezen az di tanken geyen. vayl zey zenen dokh geven in ofene vagonen." 
        intervals [185]:
            xmin = 564.626 
            xmax = 565.56 
            text = "" 
        intervals [186]:
            xmin = 565.56 
            xmax = 568.878 
            text = "hobn zey gezen di tanken. un v- m'hot gevolt shisn." 
        intervals [187]:
            xmin = 568.878 
            xmax = 568.911 
            text = "" 
        intervals [188]:
            xmin = 568.911 
            xmax = 574.884 
            text = "zenen zey gegangen, ver vos hot ge- vi azoy er hot gekent, di shtikl hemd hobn zey tserisn, un zey hobn aroysgeleygt vayse fonen," 
        intervals [189]:
            xmin = 574.884 
            xmax = 574.948 
            text = "" 
        intervals [190]:
            xmin = 574.948 
            xmax = 579.29 
            text = "un azoy ze'mir undz gevo- hot men oyfgehert tsu shisn. az s'iz yidn." 
        intervals [191]:
            xmin = 579.29 
            xmax = 580.933 
            text = "" 
        intervals [192]:
            xmin = 580.933 
            xmax = 591.521 
            text = "un un u- undz ale meydlekh ho'mir gemeynt az m'harget undz. undz ze'mir geven oyf dem gegreyt, vayl ale m'hot bakumen a zekl az m'vet undz aro- m'firt undz oyf di Tirol berg un m'vet undz aropvarfn." 
        intervals [193]:
            xmin = 591.521 
            xmax = 595.305 
            text = "vi azoy, vos, veyst men nisht. az yedn vet men araynleygn in a zak arayn." 
        intervals [194]:
            xmin = 595.305 
            xmax = 596.61 
            text = "" 
        intervals [195]:
            xmin = 596.61 
            xmax = 602.291 
            text = "ven m'hot ongehoybn tsu shisn ho'mir zikh ale meydlekh tsamgenumen tsuzamen, in vagon," 
        intervals [196]:
            xmin = 602.291 
            xmax = 602.398 
            text = "" 
        intervals [197]:
            xmin = 602.398 
            xmax = 610.661 
            text = "un ho'mir gezogt in eynem vil'mir shtarbn. s-UNK vos a khilek in tsi ekster tsi vi azoy, ale in eynem." 
        intervals [198]:
            xmin = 610.661 
            xmax = 611.14 
            text = "" 
        intervals [199]:
            xmin = 611.14 
            xmax = 614.199 
            text = "un oyf dem hobn oyfgemakht di amerikaner di tir." 
        intervals [200]:
            xmin = 614.199 
            xmax = 619.959 
            text = "un zey hobn gezogt, ir zent fray. undz ho'mir nisht geshtelt zikh nisht gekent forshteln az ze'mir bafrayt gevorn." 
        intervals [201]:
            xmin = 619.959 
            xmax = 620.556 
            text = "" 
        intervals [202]:
            xmin = 620.556 
            xmax = 623.132 
            text = "nokh dem s'shoyn oyfgemakht ale vagonen," 
        intervals [203]:
            xmin = 623.132 
            xmax = 623.205 
            text = "" 
        intervals [204]:
            xmin = 623.205 
            xmax = 627.384 
            text = "m'hot shoyn gekhapt di ale daytshn velkhe zenen antlofn, m'hot zey shoyn avekgefirt," 
        intervals [205]:
            xmin = 627.384 
            xmax = 627.812 
            text = "" 
        intervals [206]:
            xmin = 627.812 
            xmax = 631.468 
            text = "un undz ho'mir shoyn ongehoybn tsu geyn zukhn a shtikl broyt." 
        intervals [207]:
            xmin = 631.468 
            xmax = 631.879 
            text = "" 
        intervals [208]:
            xmin = 631.879 
            xmax = 636.719 
            text = "iz geven a vagonen, epes eyn vagon iz geven vos iz geven esnvarg." 
        intervals [209]:
            xmin = 636.719 
            xmax = 640.597 
            text = "i far undz i far di daytshn. nu, zey hobn bakumen besers." 
        intervals [210]:
            xmin = 640.597 
            xmax = 640.722 
            text = "" 
        intervals [211]:
            xmin = 640.722 
            xmax = 644.681 
            text = "iz vifl mener zey hobn gekent nebekh, velkhe zey hobn nokh gehat koyekh," 
        intervals [212]:
            xmin = 644.681 
            xmax = 645.683 
            text = "" 
        intervals [213]:
            xmin = 645.683 
            xmax = 651.414 
            text = "zenen zey gegangen hobn oyfgerisn di vagonen un yeder hot gekh- gerisn zikh gekhapt a bisl esn." 
        intervals [214]:
            xmin = 651.414 
            xmax = 654.458 
            text = "" 
        intervals [215]:
            xmin = 654.458 
            xmax = 659.146 
            text = "un un nokh dem ze'mir hot men undz arayngefirt in dorf. dos iz geven i der Ifldorf," 
        intervals [216]:
            xmin = 659.146 
            xmax = 661.927 
            text = "i der Sh- i Lishtaltaykh. ikh gedenk nisht." 
        intervals [217]:
            xmin = 661.927 
            xmax = 662.17 
            text = "" 
        intervals [218]:
            xmin = 662.17 
            xmax = 664.951 
            text = "un dort tsu dray tog hobn undz di amerikaner," 
        intervals [219]:
            xmin = 664.951 
            xmax = 668.727 
            text = "in di hayzer ze'mir geven. mer keyn daytsh iz shoyn dort nisht geven." 
        intervals [220]:
            xmin = 668.727 
            xmax = 669.443 
            text = "" 
        intervals [221]:
            xmin = 669.443 
            xmax = 673.671 
            text = "un undz ho'mir gedarft nor esn. nor esn ho'mir gekukt," 
        intervals [222]:
            xmin = 673.671 
            xmax = 679.135 
            text = "ze'mir arayn in di hayzer zukhn esn. vu nor geblibn esn hot men genumen. a bisl ontun zikh," 
        intervals [223]:
            xmin = 679.135 
            xmax = 679.956 
            text = "" 
        intervals [224]:
            xmin = 679.956 
            xmax = 681.688 
            text = "m'iz dokh geven naket POCHTI." 
        intervals [225]:
            xmin = 681.688 
            xmax = 683.331 
            text = "" 
        intervals [226]:
            xmin = 683.331 
            xmax = 688.59 
            text = "un nokh dem hot men undz avekgenumen. dray tog hot men gelozt m'zol UNK tun vos m'vil," 
        intervals [227]:
            xmin = 688.59 
            xmax = 688.849 
            text = "" 
        intervals [228]:
            xmin = 688.849 
            xmax = 692.572 
            text = "un m'hot men tsamgenumen un m'hot undz avekgefirt oyf Landsberg." 
        intervals [229]:
            xmin = 692.572 
            xmax = 693.642 
            text = "" 
        intervals [230]:
            xmin = 693.642 
            xmax = 697.466 
            text = "iz geven a groyser kanzarm, dort iz geven a daytsher kazarm." 
        intervals [231]:
            xmin = 697.466 
            xmax = 698.248 
            text = "" 
        intervals [232]:
            xmin = 698.248 
            xmax = 704.114 
            text = "un di amerikaner, shtark a sakh mentshn geven, nokh fremde oykhet, rusishe, farshidene mentshn iz geven dort." 
        intervals [233]:
            xmin = 704.114 
            xmax = 704.256 
            text = "" 
        intervals [234]:
            xmin = 704.256 
            xmax = 708.755 
            text = "un dort azoy vi ze'mir geven shtark opgehungert un opgemogerte," 
        intervals [235]:
            xmin = 708.755 
            xmax = 709.015 
            text = "" 
        intervals [236]:
            xmin = 709.015 
            xmax = 711.658 
            text = "hot men undz shoyn nisht gegebn oyf a mol esn," 
        intervals [237]:
            xmin = 711.658 
            xmax = 711.85 
            text = "" 
        intervals [238]:
            xmin = 711.85 
            xmax = 717.159 
            text = "az m'zol zikh nisht eh fardarbn, m'zol nisht oysshtarbn, vayl zeyer a sakh mentshn zenen geshtorbn." 
        intervals [239]:
            xmin = 717.159 
            xmax = 717.857 
            text = "" 
        intervals [240]:
            xmin = 717.857 
            xmax = 726.221 
            text = "hot men undz gegebn gemoln fleysh mit kashe. yedn tog hot men undz gekokht gemoln fleysh un yede vokh hot men undz gevoygn," 
        intervals [241]:
            xmin = 726.221 
