            text = "" 
        intervals [146]:
            xmin = 429.885 
            xmax = 438.097 
            text = "der di mener zenen avek ekster, un ikh mit der mame mit di kinder mit di fir briderlekh ze'mir geven in eynem." 
        intervals [147]:
            xmin = 438.097 
            xmax = 438.964 
            text = "" 
        intervals [148]:
            xmin = 438.964 
            xmax = 447.261 
            text = "s'hot nisht gedoyert a tsen minut eh hot der tate gezen vu undz ze'mir, hot er mir gebrengt a shtikl broyt," 
        intervals [149]:
            xmin = 447.261 
            xmax = 447.52 
            text = "" 
        intervals [150]:
            xmin = 447.52 
            xmax = 452.627 
            text = "un a keml, az ikh zol zikh hobn mit vos tsu kemen vayl ales hot men undz tsugenumen. er hot dos gefunen oyf der erd dort." 
        intervals [151]:
            xmin = 452.627 
            xmax = 453.308 
            text = "" 
        intervals [152]:
            xmin = 453.308 
            xmax = 458.989 
            text = "un m'ot ongehoybn, di daytshn hobn ongehoybn tsu shrayen, iz er tsurik antlofn. SO deys hob ikh im gezen, nisht mer." 
        intervals [153]:
            xmin = 458.989 
