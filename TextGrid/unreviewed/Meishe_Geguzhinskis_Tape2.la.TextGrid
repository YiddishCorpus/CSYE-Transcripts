            text = "" 
        intervals [196]:
            xmin = 581.862 
            xmax = 587.672 
            text = "in hoyf, ikh geb a kuk, es shteyt a groyse od- a groyse rey shoyn fun mentshn, mentshn hobn shoyn dersh- dershpirt az s'iz a krig," 
        intervals [197]:
            xmin = 587.672 
            xmax = 590.715 
            text = "un di ershte rey in a krigs-tsayt heybt on tsu feln produktn." 
