            text = "nor di ershte zakh vos bay mir iz do, ikh hob, zogt er, a pistolet arayngetrogn <in tog fun>," 
        intervals [482]:
            xmin = 1537.228 
            xmax = 1543.241 
            text = "mitgenumen mit zikh. un er hot mir aroysgenumen, mir gevizn dem pistolet mit etlekhe koyln. zogt er, ot iz undzer" 
        intervals [483]:
            xmin = 1543.241 
            xmax = 1543.467 
            text = "" 
        intervals [484]:
            xmin = 1543.467 
            xmax = 1545.317 
            text = "gever velkhe mir hobn haynt tsum tog." 
        intervals [485]:
            xmin = 1545.317 
            xmax = 1545.981 
            text = "" 
        intervals [486]:
            xmin = 1545.981 
            xmax = 1548.256 
            text = "ikh hob genumen dem ershtn mol in hant dem pistolet," 
        intervals [487]:
            xmin = 1548.256 
            xmax = 1554.361 
            text = "un ikh hob farshtanen az m'darf, az s'vet zayn mit vos zikh tsu farteydikn kegn di fashistn, kegn di daytshn." 
        intervals [488]:
            xmin = 1554.361 
            xmax = 1557.355 
            text = "" 
        intervals [489]:
            xmin = 1557.355 
            xmax = 1563.654 
            text = "mir hobn or- organizirt a kleyninkn kemerl azoy tsu zogn fun a krayzl fun etlekhe man bay Elke Tenko" 
        intervals [490]:
            xmin = 1563.654 
            xmax = 1565.364 
            text = "in shtub flegn mir zikh mir trefn." 
        intervals [491]:
            xmin = 1565.364 
            xmax = 1566.197 
            text = "" 
        intervals [492]:
            xmin = 1566.197 
            xmax = 1572.744 
            text = "undzer arbet iz geven vegn dem ershtn zakh hobn mir batrakht dem gantsn konstruktsye fun dem pistolet." 
        intervals [493]:
            xmin = 1572.744 
            xmax = 1572.765 
            text = "" 
        intervals [494]:
            xmin = 1572.765 
            xmax = 1577.744 
            text = "m'iz di kin- di khevre zoln kenen zikh m'kenen farshteyn vi zikh tsu farteydikn" 
        intervals [495]:
            xmin = 1577.744 
            xmax = 1583.127 
            text = "oder vi ontsugrayfn di daytshn in fal fun a fun eh letstn moment." 
        intervals [496]:
            xmin = 1583.127 
            xmax = 1597.899 
            text = "un mir f- un mir flegn eh oft eh zikh trefn dortn bay im hern a umlegale radyo hot er gehat, a a radyo aparat fun Moskve." 
        intervals [497]:
            xmin = 1597.899 
            xmax = 1598.412 
            text = "" 
        intervals [498]:
            xmin = 1598.412 
            xmax = 1607.062 
            text = "mir flegn firn a min eh arbet azoy tsu zogn agitatsyone ar- agitatsye arbet tsvishn di khevre." 
        intervals [499]:
            xmin = 1607.062 
            xmax = 1609.617 
            text = "" 
        intervals [500]:
            xmin = 1609.617 
            xmax = 1613.863 
            text = "nor do in a gutn frimorgn ven ikh bin gekumen tsu Elken in shtub," 
        intervals [501]:
            xmin = 1613.863 
            xmax = 1614.139 
            text = "" 
        intervals [502]:
            xmin = 1614.139 
            xmax = 1621.743 
            text = "hob ikh gefunen farmakht di farmakht far- farklapt di tir. ikh hob nokhgefregt di shkheynim, vos kumt do for? vu iz der Elke farfaln gevorn?" 
        intervals [503]:
            xmin = 1621.743 
            xmax = 1621.8 
            text = "" 
        intervals [504]:
            xmin = 1621.8 
            xmax = 1627.144 
            text = "vayzt zikh aroys, in der tsayt iz geven a aktsye, m'hot gefirt yidn toyznt," 
        intervals [505]:
            xmin = 1627.144 
            xmax = 1628.365 
            text = "" 
        intervals [506]:
            xmin = 1628.365 
            xmax = 1631.7 
            text = "tsi zibn hundert dakht zikh yidn, zibn hundert yidn hot men avekgefirt in Estland." 
        intervals [507]:
            xmin = 1631.7 
            xmax = 1631.841 
            text = "" 
        intervals [508]:
            xmin = 1631.841 
            xmax = 1639.682 
            text = "un Elke iz arayngefaln tsvishn der tsvishn der tsvishn di khe- tsvishn di mentshn di <ashirim> fun geto" 
