            xmin = 154.328 
            xmax = 154.587 
            text = "" 
        intervals [49]:
            xmin = 154.587 
            xmax = 160.587 
            text = "nit oysgenutst azoy tsu zogn mayn mayn mayn arbet, mayn mayn mayne karyere vos ikh hob gemakht in dem magazin." 
        intervals [50]:
            xmin = 160.587 
            xmax = 165.859 
            text = "" 
        intervals [51]:
            xmin = 165.859 
            xmax = 172.029 
            text = "mir hobn dan gelebt oyf Vayse gas, oyfn UNK oyfn grinem barg." 
        intervals [52]:
            xmin = 172.029 
            xmax = 172.795 
            text = "" 
        intervals [53]:
            xmin = 172.795 
            xmax = 181.546 
            text = "derbay iz bay undz geven a shokhn a beker. Glabin hot er geheysn. Abe Glabin." 
        intervals [54]:
            xmin = 181.546 
            xmax = 181.755 
            text = "" 
        intervals [55]:
            xmin = 181.755 
            xmax = 184.967 
            text = "er hot gehat tsvey zin, vifl ikh gedenk." 
        intervals [56]:
            xmin = 184.967 
            xmax = 190.136 
            text = "eyn zun iz geven, der elterer zun, iz geven a sportler." 
        intervals [57]:
