        intervals [4]:
            xmin = 12.988 
            xmax = 14.495 
            text = "ven s'hot bay mir pasirt" 
        intervals [5]:
            xmin = 14.495 
            xmax = 24.289 
            text = "der <umendlekhe> ume- ume- ume- um- um- spn der u- der der nit keyn ven s'hot nit ayngegebn tsu arbetn vayter in dem ze- magazin," 
        intervals [6]:
            xmin = 24.289 
            xmax = 25.307 
            text = "" 
        intervals [7]:
            xmin = 25.307 
            xmax = 27.624 
            text = "un ikh bin nokh dertsu geven a komyugist," 
        intervals [8]:
            xmin = 27.624 
            xmax = 30.515 
            text = "ikh hob gehert tsu a komyugisher organizatsye fun dem handls-opteylung," 
        intervals [9]:
            xmin = 30.515 
            xmax = 31.264 
            text = "" 
        intervals [10]:
            xmin = 31.264 
            xmax = 34.498 
            text = "hot men mir aroysgerufn oyf a farzamlung fun Komyug." 
        intervals [11]:
            xmin = 34.498 
            xmax = 35.061 
            text = "" 
        intervals [12]:
            xmin = 35.061 
            xmax = 37.282 
            text = "der sekretar fun Komyug iz bay undz geven" 
        intervals [13]:
            xmin = 37.282 
            xmax = 38.605 
            text = "" 
        intervals [14]:
            xmin = 38.605 
            xmax = 43.88 
            text = "a yidisher yat, vifl ikh gedenk Yankl Zhin hot er geheysn." 
        intervals [15]:
            xmin = 43.88 
            xmax = 46.671 
            text = "" 
        intervals [16]:
            xmin = 46.671 
            xmax = 54.613 
            text = "er hot gehat a feikeyt er hot a feikeyt tsum sheyn tsum redn, er iz geven a vunderbar orator." 
        intervals [17]:
            xmin = 54.613 
            xmax = 54.889 
            text = "" 
        intervals [18]:
            xmin = 54.889 
            xmax = 60.978 
            text = "un di khevre, di komyugistn, flegn im kukn poshet in moyl arayn, vi azoy er flegt reydn," 
        intervals [19]:
            xmin = 60.978 
            xmax = 64.636 
            text = "vi azoy oys- oysnutsn zayne oratorishe feikeytn." 
        intervals [20]:
            xmin = 64.636 
            xmax = 65.335 
            text = "" 
        intervals [21]:
            xmin = 65.335 
            xmax = 68.653 
            text = "di farzamlung iz geven a spetsyele. m'hot aroysgerufn mir," 
        intervals [22]:
            xmin = 68.653 
            xmax = 69.418 
            text = "" 
        intervals [23]:
            xmin = 69.418 
            xmax = 73.057 
            text = "m'hot, un der Zhidn, Yankl Zhidn, hot bashlosn" 
        intervals [24]:
            xmin = 73.057 
            xmax = 73.485 
            text = "" 
        intervals [25]:
            xmin = 73.485 
            xmax = 76.567 
            text = "er hot shoyn gekrogn onvayzungen mistome fun dem Shtromen," 
        intervals [26]:
            xmin = 76.567 
            xmax = 77.097 
            text = "" 
        intervals [27]:
            xmin = 77.097 
            xmax = 83.976 
            text = "az ikh hob gehat a <feler> heyst tsu zogn, ikh hob es ikh hob s'hot bay mir gefelt in magazin un m'darf mikh bashtrofn derfar." 
        intervals [28]:
            xmin = 83.976 
            xmax = 84.471 
            text = "" 
        intervals [29]:
            xmin = 84.471 
            xmax = 88.4 
            text = "hot er forgeleygt az m'zol mir oysshlisn fun Komyu- fun Komyug." 
        intervals [30]:
            xmin = 88.4 
            xmax = 90.574 
            text = "m'hot mikh poshet aroysgevorfn fun Komyug." 
        intervals [31]:
            xmin = 90.574 
            xmax = 91.339 
            text = "" 
        intervals [32]:
            xmin = 91.339 
            xmax = 96.33 
            text = "er hot geredt aroysgeshtelt er hot er hot aroysgetrotn mit aza min sharfe rede kegn mir," 
        intervals [33]:
            xmin = 96.33 
            xmax = 104.871 
            text = "un gezogt ""<vot> vi azoy ken a sovetisher komyugist zikh farnemen mit azelkhene zakhn? vu iz farfaln gevorn di gelt?"" un azoy vayter. ikh hob zikh farentfert az" 
        intervals [34]:
            xmin = 104.871 
            xmax = 108.106 
            text = "ikh bin geven poshet, ikh hob nit gehat keyn derfarnkeyt in dem," 
        intervals [35]:
            xmin = 108.106 
            xmax = 108.191 
            text = "" 
        intervals [36]:
            xmin = 108.191 
            xmax = 115 
            text = "un ikh hob nit gevust vi ontsuhoybn handlen, vi tsum ton, vi tsum firn a magazin, un s'hot pasirt mit mir aza min faln, nit mit mayn eygenem viln." 
        intervals [37]:
            xmin = 115 
            xmax = 116.854 
            text = "" 
        intervals [38]:
            xmin = 116.854 
            xmax = 123.918 
            text = "nor s'hot keyn zakh nit geholfn, kentik er hot shoyn gekrogn a sh- gevise onvayzungen m'zol mir fun dem Komyug aroystraybn. m'hot mir fun dortn aroysgetribn." 
        intervals [39]:
            xmin = 123.918 
            xmax = 124.347 
            text = "" 
        intervals [40]:
            xmin = 124.347 
            xmax = 128.171 
            text = "ikh ibn aroys fun der farzamlung a farfintsterter," 
        intervals [41]:
            xmin = 128.171 
            xmax = 129.729 
            text = "" 
        intervals [42]:
            xmin = 129.729 
            xmax = 132.511 
            text = "geferlekh, mit a geferlekher mit a geferlekher shtimung," 
        intervals [43]:
            xmin = 132.511 
            xmax = 137.317 
            text = "ikh gedenk ikh bin arayngegangen in kafe Asta, un ikh hob dortn," 
        intervals [44]:
            xmin = 137.317 
            xmax = 139.078 
            text = "" 
        intervals [45]:
            xmin = 139.078 
            xmax = 148.168 
            text = "far kaas oder far far far far iberlebung, oysgetrunken dray kufl bir un tsvey un tsvey portsyes <tshashiskes>." 
        intervals [46]:
            xmin = 148.168 
            xmax = 149.052 
            text = "" 
        intervals [47]:
            xmin = 149.052 
            xmax = 154.328 
            text = "un in shtub bin ikh gekumen un ikh hob keynem dertseylt, vayl es iz geven a shande far mayne famil vi azoy ikh hob" 
