        intervals [199]:
            xmin = 592.037 
            xmax = 594.7 
            text = "ikh hob zikh arayngerisn in bekeray durkh a hintershtn tir," 
        intervals [200]:
            xmin = 594.7 
            xmax = 599.017 
            text = "un ikh bin arayn tsum balebos mitn tsetele funem partogni, un ikh hob im gezogt, her tsu, m'darf helfn." 
        intervals [201]:
            xmin = 599.017 
            xmax = 599.142 
            text = "" 
        intervals [202]:
            xmin = 599.142 
            xmax = 602.429 
            text = "zogt er, yo, oyber, zogt er, me- mentshn zenen hungerik, darf men helfn." 
        intervals [203]:
            xmin = 602.429 
            xmax = 605.852 
            text = "nu, zogt er, keyner zol nit zen, zogt er. zoln di mentshn velkhe shteyen in rey nit zen" 
