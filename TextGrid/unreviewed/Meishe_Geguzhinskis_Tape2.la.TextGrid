            xmin = 608.738 
            xmax = 610.228 
            text = "" 
        intervals [207]:
            xmin = 610.228 
            xmax = 614.238 
            text = "makh dos azoy zol keyner nit zen, un ikh hob onge- ongelodn oyfn velosiped" 
