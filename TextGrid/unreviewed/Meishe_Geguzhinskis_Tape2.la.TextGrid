            text = "" 
        intervals [211]:
            xmin = 618.835 
            xmax = 626.163 
            text = "un ikh bin geforn, ikh hob geforn tsurik tsu der arbet, tsum helfn di hungerike mentshn." 
        intervals [212]:
            xmin = 626.163 
            xmax = 631.13 
            text = "ikh bin farbaygeforn di, mir hobn gelebt oyf Vayse gas, nor farbaygeforn bin ikh farbay undzer shtub." 
