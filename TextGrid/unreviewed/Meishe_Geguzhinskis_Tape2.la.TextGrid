            xmax = 566.607 
            text = "" 
        intervals [188]:
            xmin = 566.607 
            xmax = 569.267 
            text = "dos iz geven a korev fun dem par- undzer partog." 
        intervals [189]:
            xmin = 569.267 
            xmax = 572.203 
            text = "er hot mir gegebn dem adres, ikh zol zikh vendn tsu dem balebos fun dem" 
