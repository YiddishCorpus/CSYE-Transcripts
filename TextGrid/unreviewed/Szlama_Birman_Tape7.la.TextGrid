        intervals [1]:
            xmin = 0 
            xmax = 1.345 
            text = "" 
        intervals [2]:
            xmin = 1.345 
            xmax = 2.571 
            text = "SIX O'CLOCK." 
        intervals [3]:
            xmin = 2.571 
            xmax = 11.115 
            text = "" 
        intervals [4]:
            xmin = 11.115 
            xmax = 14.45 
            text = "yo, zey hobn zey hobn bash- gevolt ibernemen di makht." 
        intervals [5]:
            xmin = 14.45 
            xmax = 14.811 
            text = "" 
        intervals [6]:
            xmin = 14.811 
            xmax = 17.927 
            text = "un eh tsum sof iz zey nisht gerotn," 
        intervals [7]:
            xmin = 17.927 
            xmax = 18.135 
            text = "" 
        intervals [8]:
            xmin = 18.135 
            xmax = 23.346 
            text = "eh un zey hobn oyf- gevolt zukhn yidn tsu sh- zey hobn nor geshosn." 
        intervals [9]:
            xmin = 23.346 
            xmax = 25.861 
            text = "zey hobn ayngehaltn tseger, banen," 
        intervals [10]:
            xmin = 25.861 
            xmax = 29.367 
            text = "zey hobn aropgenumen yidn, arayn in vald, zey hobn geshosn, in mitn veg." 
        intervals [11]:
            xmin = 29.367 
            xmax = 29.526 
            text = "" 
        intervals [12]:
            xmin = 29.526 
            xmax = 35.527 
            text = "un azoy az in yedern gegnt vu s'gegangen banen zenen zey geven, vayl a ban geyt adurkh nokh velder, nokh ruzhne gegnter." 
        intervals [13]:
            xmin = 35.527 
            xmax = 35.635 
            text = "" 
        intervals [14]:
            xmin = 35.635 
            xmax = 38.694 
            text = "hot men ayngehaltn in mitn veg di ban un zey hobn aropgenumen" 
        intervals [15]:
            xmin = 38.694 
            xmax = 44.91 
            text = "yidn un arayn in vald arayn, geshosn. zenen geven zeyer a sakh yidn zenen gefaln nokhn bafrayen oykhet." 
        intervals [16]:
            xmin = 44.91 
            xmax = 45.422 
            text = "" 
        intervals [17]:
            xmin = 45.422 
            xmax = 48.566 
            text = "zey vayter di dos militer, dos yidishe mit di" 
        intervals [18]:
            xmin = 48.566 
            xmax = 51.528 
            text = "mit di gever, zey zenen farblibn in dem" 
        intervals [19]:
            xmin = 51.528 
            xmax = 56.067 
            text = "Bakhst undz tsu bahitn. shtel dikh for az s'geven az s'gekumen a yontev," 
        intervals [20]:
            xmin = 56.067 
            xmax = 60.927 
            text = "gedenk ikh zayendik in Lublin zenen zey geven bay di shul, front mit di mashin-gever," 
        intervals [21]:
            xmin = 60.927 
            xmax = 64.603 
            text = "vayl zey hobn ongemakht khurves di A.K., zenen arayn in ale shtubn arayn." 
        intervals [22]:
            xmin = 64.603 
            xmax = 64.845 
            text = "" 
        intervals [23]:
            xmin = 64.845 
            xmax = 66.813 
            text = "azoy az m'hot moyre gehat far zey." 
        intervals [24]:
            xmin = 66.813 
            xmax = 67.663 
            text = "" 
        intervals [25]:
            xmin = 67.663 
            xmax = 71.504 
            text = "un ikh bin in dem bl- in Lublin geven a lengere tsayt." 
        intervals [26]:
            xmin = 71.504 
            xmax = 71.511 
            text = "" 
        intervals [27]:
            xmin = 71.511 
            xmax = 74.222 
            text = "azoy az dort in Lublin hob ikh" 
        intervals [28]:
            xmin = 74.222 
            xmax = 74.43 
            text = "" 
        intervals [29]:
            xmin = 74.43 
            xmax = 77.158 
            text = "ongehoybn tsu zukhn eh a basheftikung." 
        intervals [30]:
            xmin = 77.158 
            xmax = 78.632 
            text = "" 
        intervals [31]:
            xmin = 78.632 
            xmax = 82.136 
            text = "un ikh bin a KNIT oyfn fakh, ikh ken der KNITTING." 
        intervals [32]:
            xmin = 82.136 
            xmax = 82.26 
            text = "" 
        intervals [33]:
            xmin = 82.26 
            xmax = 86.743 
            text = "un ikh bin gevoyer gevorn fun aza fabrik, fun aza varshtat, a groyse varshtat," 
        intervals [34]:
            xmin = 86.743 
            xmax = 87.103 
            text = "" 
        intervals [35]:
            xmin = 87.103 
            xmax = 92.379 
            text = "un ikh bin arayn in dem varshtat arayn, geb ikh kuk, s'zitsn, der bal- ikh gey tsum balbos, ikh veys dokh ver s'der," 
        intervals [36]:
            xmin = 92.379 
            xmax = 92.622 
            text = "" 
        intervals [37]:
            xmin = 92.622 
            xmax = 94.489 
            text = "veys ikh, direktor oder ver," 
        intervals [38]:
            xmin = 94.489 
            xmax = 94.714 
            text = "" 
        intervals [39]:
            xmin = 94.714 
            xmax = 98.319 
            text = "zogt mir un vayzt mir der, ikh gey tsu, zey zenen tsvey yidn." 
        intervals [40]:
            xmin = 98.319 
            xmax = 98.629 
            text = "" 
        intervals [41]:
            xmin = 98.629 
            xmax = 101.503 
            text = "zey hobn far der krig gehat di FACTORY," 
        intervals [42]:
            xmin = 101.503 
            xmax = 106.709 
            text = "un zenen avek keyn Rusland un zenen tsurikgekumen un zey gobn o- ibergenumen tsurik di FACTORY." 
        intervals [43]:
            xmin = 106.709 
            xmax = 111.518 
            text = "un ikh hob zey gezogt az ikh vil fardinen a por z- dos in poylish, zlotes." 
        intervals [44]:
            xmin = 111.518 
            xmax = 115.447 
            text = "ikh vil fardinen epes tsu ikh zol kenen lebn, az ikh bin ersht fun di lagern gekumen." 
        intervals [45]:
            xmin = 115.447 
            xmax = 115.605 
            text = "" 
        intervals [46]:
            xmin = 115.605 
            xmax = 119.649 
            text = "un er hot mikh tsugeshtelt tsu a mashin, iz geven bloyz kristn, shkotsim dortn," 
        intervals [47]:
            xmin = 119.649 
            xmax = 119.824 
            text = "" 
        intervals [48]:
            xmin = 119.824 
            xmax = 123.311 
            text = "un zey hobn ale gearbet, un ikh bin geshtanen bay mayn mashin, ikh hob mir oykhet gearbet." 
        intervals [49]:
            xmin = 123.311 
            xmax = 123.925 
            text = "" 
        intervals [50]:
            xmin = 123.925 
            xmax = 129.487 
            text = "dernokhn, azoy gey ikh a mol tsum balbos nokh a geviser tsayt onarbetn dort, er hot mir batsolt," 
        intervals [51]:
            xmin = 129.487 
            xmax = 129.83 
            text = "" 
        intervals [52]:
            xmin = 129.83 
            xmax = 133.363 
            text = "un ikh hob shoyn gekent aynkoyfn zikh, s'geven a mark fun kol-tuv." 
        intervals [53]:
            xmin = 133.363 
            xmax = 138.954 
            text = "iz geven a guter eyn ort fun Lublin iz gornisht tsehakt gevorn, zenen arayn, hot zikh untergegebn di shtot," 
        intervals [54]:
            xmin = 138.954 
            xmax = 139.028 
            text = "" 
        intervals [55]:
            xmin = 139.028 
            xmax = 141.809 
            text = "un dortn arum un arum iz do zeyer a sakh derfer," 
        intervals [56]:
            xmin = 141.809 
            xmax = 144.897 
            text = "un poyern m'hot arayngebrengt hiner un gendz un" 
        intervals [57]:
            xmin = 144.897 
            xmax = 146.972 
            text = "un antfl- ruzhne erley kezn," 
        intervals [58]:
            xmin = 146.972 
            xmax = 150.935 
            text = "azoy az der mark iz geven ful mit esnvarg az hob ikh shoyn nisht gezen azoy fil yorn." 
        intervals [59]:
            xmin = 150.935 
            xmax = 151.127 
            text = "" 
        intervals [60]:
            xmin = 151.127 
            xmax = 154.229 
            text = "farshteyst, bin ikh mikh bay dem tsugegangen tsu dem" 
        intervals [61]:
            xmin = 154.229 
            xmax = 157.247 
            text = "tsu dem eygntimer, un ikh hob im gezogt, efsher kenstu" 
        intervals [62]:
            xmin = 157.247 
            xmax = 157.303 
            text = "" 
        intervals [63]:
            xmin = 157.303 
            xmax = 163.096 
            text = "epes eh ikh zol nisht darfn shteyn bay di m- neyn, farkert, er iz tsugekumen tsu mir, zogt er, a yid," 
        intervals [64]:
            xmin = 163.096 
            xmax = 169.458 
            text = "nokh azelkhe lagern, darfstu shteyn bay a mashin arbetn punkt azoy vi di poyern, ot er azoy gerufene." 
        intervals [65]:
            xmin = 169.458 
            xmax = 171.422 
            text = "vayl er iz dokh oykhet geven oyfgekokht" 
        intervals [66]:
            xmin = 171.422 
            xmax = 171.529 
            text = "" 
        intervals [67]:
            xmin = 171.529 
            xmax = 176.147 
            text = "beyz oyf di khevre. er hot zey gehaltn vayl er hot zey badorfn hobn, s'nisht geven keyn yidn nokh dem." 
        intervals [68]:
            xmin = 176.147 
            xmax = 176.693 
            text = "" 
        intervals [69]:
            xmin = 176.693 
            xmax = 178.83 
            text = "du vest shteyn bay a mashin arbetn? neyn!" 
        intervals [70]:
            xmin = 178.83 
            xmax = 179.089 
            text = "" 
        intervals [71]:
            xmin = 179.089 
            xmax = 181.077 
            text = "arayngerufn nokhn magazin arayn," 
        intervals [72]:
            xmin = 181.077 
            xmax = 184.584 
            text = "un er hot mir aroysgegebn fertike zakhn az ikh zol geyn oyfn MARKET" 
        intervals [73]:
            xmin = 184.584 
            xmax = 184.742 
            text = "" 
        intervals [74]:
            xmin = 184.742 
            xmax = 187.599 
            text = "un farkoyfn, un handlen, onheybn handlen." 
        intervals [75]:
            xmin = 187.599 
            xmax = 191.058 
            text = "un azoy iz geven, er hot mir aroysgegebn damen-zokn un ruzhne erley" 
        intervals [76]:
            xmin = 191.058 
            xmax = 194.895 
            text = "andere mayses, sveters, un ikh hob farkoyft un ikh hob mir gants sheyn fardint." 
        intervals [77]:
            xmin = 194.895 
            xmax = 194.985 
            text = "" 
        intervals [78]:
            xmin = 194.985 
            xmax = 198.407 
            text = "un ikh hob im gedankt un eh azoy opgezisn in Lublin," 
        intervals [79]:
            xmin = 198.407 
            xmax = 200.272 
            text = "a lengere tsayt. nokh dem" 
        intervals [80]:
            xmin = 200.272 
            xmax = 203.453 
            text = "iz shoyn ongekumen shtitse fun Hilfs Fond, fun" 
        intervals [81]:
            xmin = 203.453 
            xmax = 209.647 
            text = "fun oysland, veys ikh, fun Unra, m'hot shoyn fun di magazinen aroysnemen andere ontuekhtser." 
        intervals [82]:
            xmin = 209.647 
            xmax = 213.609 
            text = "azoy s'gegangen op a lebn. in tsvishn tsayt, zayendik in Lublin," 
        intervals [83]:
            xmin = 213.609 
            xmax = 214.645 
            text = "" 
        intervals [84]:
            xmin = 214.645 
            xmax = 216.461 
            text = "mayn froy, yetstike," 
        intervals [85]:
            xmin = 216.461 
            xmax = 216.518 
            text = "" 
        intervals [86]:
            xmin = 216.518 
            xmax = 219.6 
            text = "iz geven fun Rusland tsurikgekumen," 
        intervals [87]:
            xmin = 219.6 
            xmax = 219.977 
            text = "" 
        intervals [88]:
            xmin = 219.977 
            xmax = 223.379 
            text = "mit der mame, un mit nokh tsvey shvestern," 
        intervals [89]:
            xmin = 223.379 
            xmax = 223.723 
            text = "" 
        intervals [90]:
            xmin = 223.723 
            xmax = 225.387 
            text = "hobn gevoynt in dem" 
        intervals [91]:
            xmin = 225.387 
            xmax = 225.428 
            text = "" 
        intervals [92]:
            xmin = 225.428 
            xmax = 228.324 
            text = "in in dem hoyz, in Perets hoyz, m'geyt zikh azoy." 
        intervals [93]:
            xmin = 228.324 
            xmax = 228.347 
            text = "" 
        intervals [94]:
            xmin = 228.347 
            xmax = 232.391 
            text = "hot zikh di mame, zi iz a feike froy geven, zi lebt shoyn haynt nisht," 
        intervals [95]:
            xmin = 232.391 
            xmax = 233.292 
            text = "" 
        intervals [96]:
            xmin = 233.292 
            xmax = 235.075 
            text = "hot zikh gemakht a kokh." 
        intervals [97]:
            xmin = 235.075 
            xmax = 235.873 
            text = "" 
        intervals [98]:
            xmin = 235.873 
            xmax = 240.339 
            text = "mentshn fardinen shoyn a bisl in gas, m'loyft shoyn arop, m'fardint, s'do gelt, m'ken fardinen." 
        intervals [99]:
            xmin = 240.339 
            xmax = 240.632 
            text = "" 
        intervals [100]:
            xmin = 240.632 
            xmax = 244.355 
            text = "a gute kukhn iz zi, zi hot gekent gut sheyn kokhn, yidishe maykholim," 
        intervals [101]:
            xmin = 244.355 
            xmax = 244.598 
            text = "" 
        intervals [102]:
            xmin = 244.598 
            xmax = 250.397 
            text = "hot zi ongehoybn tsu kokhn un gebn mitog dortn, mentshn zenen gekumen esn mitog. un tsvishn andere bin ikh oykhet arayn esn mitog." 
        intervals [103]:
            xmin = 250.397 
            xmax = 251.027 
            text = "" 
        intervals [104]:
            xmin = 251.027 
            xmax = 253.133 
            text = "eyn mol, tsvey mol, dray mol." 
        intervals [105]:
            xmin = 253.133 
            xmax = 257.723 
            text = "nokh dem hot zikh dort iz dort geven a zal vu m'hot zikh tsunoyfgenumen nokh a geviser tsayt," 
        intervals [106]:
            xmin = 257.723 
            xmax = 259.948 
            text = "gemakht zikh a tants-ovnt," 
        intervals [107]:
            xmin = 259.948 
            xmax = 260.427 
            text = "" 
        intervals [108]:
            xmin = 260.427 
            xmax = 263.323 
            text = "un s'geven a kleyner vos hot tsugeshpilt," 
        intervals [109]:
            xmin = 263.323 
            xmax = 263.329 
            text = "" 
        intervals [110]:
            xmin = 263.329 
            xmax = 268.419 
            text = "un un m'hot getantst shoyn un tsvishn andere iz geven m- mayn ershtike froy," 
        intervals [111]:
            xmin = 268.419 
            xmax = 268.847 
            text = "" 
        intervals [112]:
            xmin = 268.847 
            xmax = 270.978 
            text = "i- ikh hob ir farbetn tsum tantsn." 
        intervals [113]:
            xmin = 270.978 
            xmax = 274.528 
            text = "hob ikh mit ir getantst eyn mol, tsvey mol, ikh bin gut in tantsn." 
        intervals [114]:
            xmin = 274.528 
            xmax = 274.77 
            text = "" 
        intervals [115]:
            xmin = 274.77 
            xmax = 276.941 
            text = "ikh hob a mol gelernt tantsn far der krig." 
        intervals [116]:
            xmin = 276.941 
            xmax = 277.015 
            text = "" 
        intervals [117]:
            xmin = 277.015 
            xmax = 278.561 
            text = "un ir hot es gefoln." 
        intervals [118]:
            xmin = 278.561 
            xmax = 279.208 
            text = "" 
        intervals [119]:
            xmin = 279.208 
            xmax = 284.31 
            text = "shoyn, azoy iz mir opgegangen a tsayt, m'hot zikh farvaylt tsuzamen, m'hot gegesn, m'iz aroysgegangen a mol," 
        intervals [120]:
            xmin = 284.31 
            xmax = 286.138 
            text = "azoy hot men zikh bakent." 
        intervals [121]:
            xmin = 286.138 
            xmax = 286.431 
            text = "" 
        intervals [122]:
            xmin = 286.431 
            xmax = 289.192 
            text = "in tsvishn tsayt bin ikh nokh avek" 
        intervals [123]:
            xmin = 289.192 
            xmax = 289.468 
            text = "" 
        intervals [124]:
            xmin = 289.468 
            xmax = 292.111 
            text = "ikh bin avek, nokh zi iz nokh nisht geven farheyrat," 
        intervals [125]:
            xmin = 292.111 
            xmax = 292.489 
            text = "" 
        intervals [126]:
            xmin = 292.489 
            xmax = 295.776 
            text = "ikh hob oyf a ku- ikh hob gezogt ikh gey forn avek oyf a kurtser tsayt." 
        intervals [127]:
            xmin = 295.776 
            xmax = 298.459 
            text = "dort hot men nokh gekent fardinen meyn a por," 
        intervals [128]:
            xmin = 298.459 
            xmax = 302.506 
            text = "vayl ikh bin arayn in doytshishn gegnt arayn. vos heyst in doytshishn? di Poyln," 
        intervals [129]:
            xmin = 302.506 
            xmax = 302.783 
            text = "" 
        intervals [130]:
            xmin = 302.783 
            xmax = 306.776 
            text = "di doytshn zenen dertlofn fun dem gegnt, di polyakn hobn dos ibergenumen." 
        intervals [131]:
            xmin = 306.776 
            xmax = 306.917 
            text = "" 
        intervals [132]:
            xmin = 306.917 
            xmax = 309.96 
            text = "bin ikh arayn in di gevezene gegnter fun di doytshn," 
        intervals [133]:
            xmin = 309.96 
            xmax = 314.099 
            text = "bin ikh arayn, dos iz geven Nidershlezye, heyst es oyf doytshish." 
        intervals [134]:
            xmin = 314.099 
            xmax = 314.325 
            text = "" 
        intervals [135]:
            xmin = 314.325 
            xmax = 318.675 
            text = "arayn in a shtot arayn, a groyse shtot, di shtot vu ikh bin adurkhgegangen in di lagern," 
        intervals [136]:
            xmin = 318.675 
            xmax = 320.63 
            text = "Bro- Breslau, UNK." 
        intervals [137]:
            xmin = 320.63 
            xmax = 320.873 
            text = "" 
        intervals [138]:
            xmin = 320.873 
            xmax = 325.44 
            text = "un dortn iz geven a groyse shtot, iz geven a zeyer polyakn, gesheftn, s'geven a a handl." 
        intervals [139]:
            xmin = 325.44 
            xmax = 325.868 
            text = "" 
        intervals [140]:
            xmin = 325.868 
            xmax = 329.459 
            text = "un dort bin ikh arayn un dort hob ikh getrofn oykhet a yid vos hot gehat" 
        intervals [141]:
            xmin = 329.459 
            xmax = 334.671 
            text = "a zeyfn-geve- a zeyfn-fabrik vos er hot gemakht zeyf. oysgearbet zeyf." 
        intervals [142]:
            xmin = 334.671 
            xmax = 335.453 
            text = "" 
        intervals [143]:
            xmin = 335.453 
            xmax = 337.489 
            text = "fun fets, aroys gearbet zeyf." 
        intervals [144]:
            xmin = 337.489 
            xmax = 337.579 
            text = "" 
        intervals [145]:
            xmin = 337.579 
            xmax = 340.475 
            text = "ikh bin dortn arayn, hot er mir gegebn ikh zol arumforn" 
        intervals [146]:
            xmin = 340.475 
            xmax = 340.515 
            text = "" 
        intervals [147]:
            xmin = 340.515 
            xmax = 343.226 
            text = "mitn tram, tsi in gevelber arayn farkoyfn." 
        intervals [148]:
            xmin = 343.226 
            xmax = 343.266 
            text = "" 
        intervals [149]:
            xmin = 343.266 
            xmax = 344.967 
            text = "ikh hob zikh UNK tsu fardint." 
        intervals [150]:
            xmin = 344.967 
            xmax = 346.567 
            text = "nokh a geviser tsayt," 
        intervals [151]:
            xmin = 346.567 
            xmax = 346.708 
            text = "" 
        intervals [152]:
            xmin = 346.708 
            xmax = 349.554 
            text = "iz der bruder oykhet gekumen fun Rusland," 
        intervals [153]:
            xmin = 349.554 
            xmax = 349.577 
            text = "" 
        intervals [154]:
            xmin = 349.577 
            xmax = 351.911 
            text = "iz der eyntsiker vos ikh hob gezogt er" 
        intervals [155]:
            xmin = 351.911 
            xmax = 354.869 
            text = "er iz geven in Rusland, der eyner vos iz geven in PALESTINE." 
        intervals [156]:
            xmin = 354.869 
            xmax = 355.028 
            text = "" 
        intervals [157]:
            xmin = 355.028 
            xmax = 358.363 
            text = "iz eyn bruder, er iz yinger fun mir a sakh," 
        intervals [158]:
            xmin = 358.363 
            xmax = 358.842 
            text = "" 
        intervals [159]:
            xmin = 358.842 
            xmax = 362.711 
            text = "hot iz er gegangen arum in di in di in di in di" 
        intervals [160]:
            xmin = 362.711 
            xmax = 365.602 
            text = "eh in di shtetlekh arayn, in di shtet arayn," 
        intervals [161]:
            xmin = 365.602 
            xmax = 365.608 
            text = "" 
        intervals [162]:
            xmin = 365.608 
            xmax = 369.095 
            text = "un zukhn adresn, zukhn a Birman, zukhn efsher ver iz geblibn." 
        intervals [163]:
            xmin = 369.095 
            xmax = 369.355 
            text = "" 
        intervals [164]:
            xmin = 369.355 
            xmax = 371.661 
            text = "akht brider zol men nisht kenen trefn vemen?" 
        intervals [165]:
            xmin = 371.661 
            xmax = 372.173 
            text = "" 
        intervals [166]:
            xmin = 372.173 
            xmax = 377.08 
            text = "un er hot gezukht un gezokht un arayn dort in dem Varshe in dem Prage, er iz arayn." 
        intervals [167]:
            xmin = 377.08 
            xmax = 378.647 
            text = "neyn, zi hot im gezogt," 
        intervals [168]:
            xmin = 378.647 
            xmax = 378.653 
            text = "" 
        intervals [169]:
            xmin = 378.653 
            xmax = 380.894 
            text = "d- di mayn ershtike froy," 
        intervals [170]:
            xmin = 380.894 
            xmax = 383.863 
            text = "hot gezogt a Birman iz, er iz gekumen keyn Lublin oykhet," 
