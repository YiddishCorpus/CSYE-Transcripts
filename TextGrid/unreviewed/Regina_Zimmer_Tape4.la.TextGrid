            text = "zenen aroysgeganen fun di hayzer. ikh bin zeyer shlekht geganen, vayl ikh hob gehat a holts shikh. ikh hob nisht gekent geyn azoy, bin ikh IMMER geblibn fun hintn." 
        intervals [377]:
            xmin = 908.609 
            xmax = 916.903 
            text = "di mame iz eybik geganen NACH VORNE, bay di ershte ts- tsvey rayes. di mame iz geganen, un ikh bin oykhet mit dray khavertes tsuzamen, zenen mir azoy ale dray geganen." 
        intervals [378]:
            xmin = 916.903 
