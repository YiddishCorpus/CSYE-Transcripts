        intervals [694]:
            xmin = 1680.598 
            xmax = 1684.901 
            text = "azoy hot zi <di> mame bald geshikt, es hot zi oysgeheylt di shvester in shpitol" 
        intervals [695]:
            xmin = 1684.901 
            xmax = 1687.558 
            text = "un zi hot bald geshikt UNK keyn MAUTHAUSEN" 
        intervals [696]:
            xmin = 1687.558 
            xmax = 1692.146 
            text = "iz zenen geblibn beyde tsuzamen lebn, got zay dank. zi hot gehat nokh dray kinder nokh di krig." 
