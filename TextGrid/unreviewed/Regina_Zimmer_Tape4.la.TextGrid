            text = "" 
        intervals [674]:
            xmin = 1623.91 
            xmax = 1625.788 
            text = "vu? in Poyln?" 
        intervals [675]:
            xmin = 1625.788 
            xmax = 1631.649 
            text = "di Poyln iz azoy, leyder, leyder. azoy vi zey kumen keyn Poyln, iz bald ongekumen di papirn fun MAUTHAUSEN" 
        intervals [676]:
            xmin = 1631.649 
            xmax = 1631.993 
            text = "" 
        intervals [677]:
            xmin = 1631.993 
            xmax = 1638.951 
            text = "un iz gekumen di papirn fun ale lager, ver lebt yo, ver lebt, di yekes zenen geven zeyer in ordenung. yedn mentsh hot er ayngeshribn" 
        intervals [678]:
            xmin = 1638.951 
            xmax = 1641.133 
            text = "vemen m'hot <zey> geleygt in krematoryum arayn" 
        intervals [679]:
            xmin = 1641.133 
            xmax = 1641.763 
            text = "" 
        intervals [680]:
            xmin = 1641.763 
            xmax = 1645.38 
            text = "hot di mame bald getrofn leyder az der tate iz nisht" 
        intervals [681]:
            xmin = 1645.38 
            xmax = 1646.87 
            text = "nifter gevorn" 
        intervals [682]:
            xmin = 1646.87 
            xmax = 1647.13 
            text = "" 
        intervals [683]:
            xmin = 1647.13 
            xmax = 1653.621 
            text = "un eh iz gevezn dort, hobn zey oysgerekhnt, es iz a tog for khanike iz di yortsayt fun im." 
        intervals [684]:
            xmin = 1653.621 
            xmax = 1654.065 
            text = "" 
        intervals [685]:
            xmin = 1654.065 
            xmax = 1660.218 
            text = "demolts iz azoy gevezn. haynt iz shoyn andersh. UNK eybik yednfal me halt mir a tog for khanike yortsayt" 
        intervals [686]:
            xmin = 1660.218 
            xmax = 1661.085 
            text = "" 
        intervals [687]:
            xmin = 1661.085 
            xmax = 1666.715 
            text = "un shpeter iz zi tsurikgekumen a shvester fun di, takesh fun RAVENSBRUCK. zi iz nebekh gevorn" 
        intervals [688]:
            xmin = 1666.715 
            xmax = 1666.738 
            text = "" 
        intervals [689]:
            xmin = 1666.738 
            xmax = 1669.452 
