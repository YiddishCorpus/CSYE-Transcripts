            text = "" 
        intervals [700]:
            xmin = 1698.818 
            xmax = 1702.206 
            text = "der frumer oylem hot keyn mol nisht geklert tsu forn keyn Yisroel." 
        intervals [701]:
            xmin = 1702.206 
            xmax = 1704.6 
            text = "undz ho'mir geklert tsu forn keyn Amerike." 
