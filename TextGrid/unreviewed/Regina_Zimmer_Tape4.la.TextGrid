        intervals [667]:
            xmin = 1607.473 
            xmax = 1610.634 
            text = "farshteyst dos vort? oyf poylish iz dokh andersh oysdrikn" 
        intervals [668]:
            xmin = 1610.634 
            xmax = 1613.052 
            text = "d- vi eyner zogt ""du lebst nokh?""" 
        intervals [669]:
            xmin = 1613.052 
            xmax = 1615.118 
            text = "" 
        intervals [670]:
            xmin = 1615.118 
            xmax = 1618.571 
            text = "s'iz nokh gevezn, dos vos ikh bin geblibn lebn iz nokh gevezn tsu fil" 
