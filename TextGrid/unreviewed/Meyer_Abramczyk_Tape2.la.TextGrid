        intervals [9]:
            xmin = 32.073 
            xmax = 37.974 
            text = "NO, ikh hob nisht geven in ergets nisht. eh ikh bin nisht keyn Lodzh, nisht Praminits, nisht nisht keyn Pyetekov do shtetlekh," 
