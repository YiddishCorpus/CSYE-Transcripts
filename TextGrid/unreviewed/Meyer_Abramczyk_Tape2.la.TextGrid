            xmax = 74.14 
            text = "m'hot nisht gevust. undz iz do UNK, ikh hob shoyn, m'hot dortn gezogt, m'hot gevoynt in a dorf," 
        intervals [20]:
            xmin = 74.14 
            xmax = 81.478 
            text = "in ikh veys nisht genoy, in finef draysik, fir un draysik, iz gevezn di antisemitn UNK m'hot gehert, di andekes hot es geheysn." 
