            text = "" 
        intervals [85]:
            xmin = 269.151 
            xmax = 275.72 
            text = "eh der iz do, der iz do, der iz do, a kuzin, a bruder, keyner, nisht keyn kuzin, nisht keyn bruder, gornisht keyn shvester, nisht keyn familye." 
        intervals [86]:
            xmin = 275.72 
            xmax = 279.019 
            text = "" 
        intervals [87]:
            xmin = 279.019 
            xmax = 284.113 
            text = "yo, zenen gevezn, zenen gekumen fun Rusland zenen zey gekumen keyn Belkhatov aheym." 
        intervals [88]:
