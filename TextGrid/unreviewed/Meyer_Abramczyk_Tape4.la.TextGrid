            text = "" 
        intervals [4]:
            xmin = 3.841 
            xmax = 7.953 
            text = "fun fun nayn- eh fir yor bin ikh geven in lager, iber fir yor," 
        intervals [5]:
            xmin = 7.953 
            xmax = 9.141 
            text = "" 
        intervals [6]:
            xmin = 9.141 
            xmax = 19.288 
            text = "iz gevezn ALRIGHT, m'hot gekont ganvenen, m'hot gehaltn a KITCHEN, m'hot gekhapt a meyer, gekhapt a kartofl, m'hot gegesn royerheyt. a beyn hot men gekont nudzhen. a gantsn tog hot men haltn a beyn, ir veyst vos a beyn iz, fun fleysh." 
        intervals [7]:
            xmin = 19.288 
            xmax = 21.69 
            text = "un m'hot gebisn di beyn biz m'hot gegesn." 
        intervals [8]:
            xmin = 21.69 
            xmax = 22.067 
            text = "" 
        intervals [9]:
            xmin = 22.067 
            xmax = 26.212 
            text = "nor di letste, fun akhtstn yanuar biz in dritn in may, iz geven di ergst-" 
        intervals [10]:
            xmin = 26.212 
            xmax = 26.337 
            text = "" 
        intervals [11]:
            xmin = 26.337 
            xmax = 32.895 
            text = "di ergste tsayt. m'hot nisht gekont gornisht khapn, m'hot gornisht gekont eh, m'hot gemuzt lebn fun shney, un un THAT'S ALL vos s'gevezn." 
        intervals [12]:
            xmin = 32.895 
            xmax = 38.74 
            text = "" 
        intervals [13]:
            xmin = 38.74 
            xmax = 40.236 
            text = "horkh." 
        intervals [14]:
            xmin = 40.236 
            xmax = 40.393 
            text = "" 
        intervals [15]:
            xmin = 40.393 
            xmax = 43.824 
            text = "s'geven mentshn m'hot gearbet tsuker befor." 
        intervals [16]:
            xmin = 43.824 
            xmax = 46.347 
            text = "m'hot gearbet oyf di boy-shtele hot es geheysn." 
        intervals [17]:
            xmin = 46.347 
            xmax = 53.465 
            text = "m'hot gekopet, a mentshn gezogt vos iz vikhtik? tsi ikh shtarb haynt tsi ikh shtarb morgn? zogt er, zol er mikh yetst hargenen. YOU KNOW WHAT I MEAN?" 
        intervals [18]:
            xmin = 53.465 
            xmax = 54.13 
            text = "" 
        intervals [19]:
            xmin = 54.13 
            xmax = 56.438 
            text = "ikh hob gezogt, mayn viln gevezn NO." 
        intervals [20]:
            xmin = 56.438 
            xmax = 60.168 
            text = "az ikh vel shtarbn, ikh vel arbetn vi lang ikh vel konen, ober nor zogn nor," 
        intervals [21]:
            xmin = 60.168 
            xmax = 62.173 
            text = "s'geven mentshn vos zey hobn gearbet" 
        intervals [22]:
            xmin = 62.173 
            xmax = 62.196 
            text = "" 
        intervals [23]:
            xmin = 62.196 
            xmax = 69.716 
            text = "un zey hobn mit di shoyvl, veyst dokh vos s'iz, hobn zey untergeshtelt azoy, der kapo hot nisht do gevezn, oder ver andersh s'geven, zenen zey geshtanen azoy. az der kapo iz gekumen hobn zey ongehoybn tsu grabn." 
        intervals [24]:
            xmin = 69.716 
            xmax = 69.84 
            text = "" 
        intervals [25]:
            xmin = 69.84 
            xmax = 72.621 
            text = "ikh hob gearbet. zog ikh, s'NO GOOD LIKE THIS." 
        intervals [26]:
            xmin = 72.621 
            xmax = 77.782 
            text = "yo, zogt er, vos iz mir vikhtik? tsu hargenen morg- tsu morgn, zogt er, ikh vel nisht blaybn lebn." 
        intervals [27]:
            xmin = 77.782 
            xmax = 78.514 
            text = "" 
        intervals [28]:
            xmin = 78.514 
            xmax = 82.743 
            text = "ikh vel dos zogn, ikh hob gearbet vi, mit di koykhim ikh hob gearbet." 
        intervals [29]:
            xmin = 82.743 
            xmax = 82.969 
            text = "" 
        intervals [30]:
            xmin = 82.969 
            xmax = 89.46 
            text = "s'gekumen vagener mit zamd, ikh hob geshoyvlt zamd, keyner hot nisht gekent eh BEATn mir." 
        intervals [31]:
            xmin = 89.46 
            xmax = 89.685 
            text = "" 
        intervals [32]:
            xmin = 89.685 
            xmax = 91.538 
            text = "zog ikh tsu di, du shtey, ikh vel shoyvlen." 
        intervals [33]:
            xmin = 91.538 
            xmax = 95.669 
            text = "ikh hob geshoyvlt, gevorfn, geales un s'gut gevezn. far dem, ikh hob gehat a mut tsu lebn." 
        intervals [34]:
            xmin = 95.669 
            xmax = 96.132 
            text = "" 
        intervals [35]:
            xmin = 96.132 
            xmax = 98.235 
            text = "ikh hob gevolt lebn, ikh hob nisht gevust" 
        intervals [36]:
            xmin = 98.235 
            xmax = 98.713 
            text = "" 
        intervals [37]:
            xmin = 98.713 
            xmax = 105.237 
            text = "a- az s'do a Oyshvits, ikh hob nisht gevust eh OK eh a monat shpeter, a monat frier, ikh vel aheymkumen un zen di FAMILY." 
        intervals [38]:
            xmin = 105.237 
            xmax = 105.261 
            text = "" 
        intervals [39]:
            xmin = 105.261 
            xmax = 107.443 
            text = "hob ikh gevolt lebn. un mentshn z-" 
        intervals [40]:
            xmin = 107.443 
            xmax = 113.079 
            text = "un mentshn hobn gezogt, o, ikh vel, tsi ikh vel haynt tog UNK tsi morgns. dos iz mir nisht vikhtik, ikh vel say vi nisht blaybn lebn." 
        intervals [41]:
            xmin = 113.079 
            xmax = 116.342 
            text = "hob ikh gearbet hob ikh gearbet." 
        intervals [42]:
            xmin = 116.342 
            xmax = 119.652 
            text = "" 
        intervals [43]:
            xmin = 119.652 
            xmax = 121.083 
            text = "NO, shtendik gevolt lebn." 
        intervals [44]:
            xmin = 121.083 
            xmax = 121.275 
            text = "" 
        intervals [45]:
            xmin = 121.275 
            xmax = 125.184 
            text = "shtendik gehat in zinen lebn lebn. ober tsi ikh vel blaybn lebn hob ikh gevust veys ikh nisht." 
        intervals [46]:
            xmin = 125.184 
            xmax = 125.41 
            text = "" 
        intervals [47]:
            xmin = 125.41 
            xmax = 126.771 
            text = "ober ikh hob gevolt lebn." 
        intervals [48]:
            xmin = 126.771 
            xmax = 127.603 
            text = "" 
        intervals [49]:
            xmin = 127.603 
            xmax = 132.288 
            text = "FIRST OF ALL, m'hot nisht gevust vos tut zikh un m'hot nisht gevust keyn Oyshvits, m'hot nisht gevust eh vos tut zikh in der velt." 
        intervals [50]:
            xmin = 132.288 
            xmax = 132.548 
            text = "" 
        intervals [51]:
            xmin = 132.548 
            xmax = 135.512 
            text = "zey hobn azoy klug gearbet az m'hot nisht gevust vos tut zikh." 
        intervals [52]:
            xmin = 135.512 
            xmax = 145.159 
            text = "" 
        intervals [53]:
            xmin = 145.159 
            xmax = 158.18 
            text = "oy dos vos undz ho'mir gebetn nor di got hot nisht geholfn, veys ikh nisht vos tsu zogn. m'hot gebetn m'hot geshrign Shma-Yisroel, rateve, shemeye, got eh an eyntsiker, du bist an eyntsiker, rateve. di ende hot go- hot gornisht geratevet." 
        intervals [54]:
            xmin = 158.18 
            xmax = 158.502 
            text = "" 
        intervals [55]:
            xmin = 158.502 
            xmax = 164.605 
            text = "m'hot undz gebrotn, nisht mikh iz es geven, azoy zeks milyon mentshn, veyst dokh, nisht in eyn tog, m'hot gebrotn," 
        intervals [56]:
            xmin = 164.605 
            xmax = 164.847 
            text = "" 
        intervals [57]:
            xmin = 164.847 
            xmax = 169.922 
            text = "bist geven in Oyshvits dort vu ikh hob gearbet, hostu geshme- geSMELT di di di geshmak" 
        intervals [58]:
            xmin = 169.922 
            xmax = 176.906 
            text = "fun fleysh fun beyner, YOU KNOW. m'hot gebetn, s'gekumen rosheshone ho'mir ale tsamgenumen, un yom-kiper, m'hot gebetn, m'hot geveynt." 
        intervals [59]:
            xmin = 176.906 
            xmax = 177.503 
            text = "" 
        intervals [60]:
            xmin = 177.503 
            xmax = 183.065 
            text = "oy un yeder hot gevolt zen dem tatn mame, yeder hot gevolt zen shvester, der a vayb, kinder, YOU KNOW eh." 
        intervals [61]:
            xmin = 183.065 
            xmax = 183.696 
            text = "" 
        intervals [62]:
            xmin = 183.696 
            xmax = 185.833 
            text = "alts umgekumen. ales um-" 
        intervals [63]:
            xmin = 185.833 
            xmax = 187.341 
            text = "" 
        intervals [64]:
            xmin = 187.341 
            xmax = 198.033 
            text = "un nokh di milkhome bin ikh geven in Doytshland, ale zenen tselofn, tsefloygn. eyner iz gevorn Ar- Argentine, eyner Brezil, eyner in Nyu York, eyner iz Oystralye un eyner iz PARIS, YOU KNOW vi z-, a sakh zenen geshtorbn shoyn." 
        intervals [65]:
            xmin = 198.033 
            xmax = 198.917 
            text = "" 
        intervals [66]:
            xmin = 198.917 
            xmax = 204.226 
            text = "s'bald in nokh di milkhome zenen geshtorbn vayl zey hobn gehat dis- disenterye, veystu shoyn, tsugekhapt tsum esn." 
        intervals [67]:
            xmin = 204.226 
            xmax = 205.212 
            text = "" 
        intervals [68]:
            xmin = 205.212 
            xmax = 208.75 
            text = "zenen geshtorbn. ikh bin ales SLOW, ikh hob gegesn un getrunken ales." 
        intervals [69]:
            xmin = 208.75 
            xmax = 209.008 
            text = "" 
        intervals [70]:
            xmin = 209.008 
            xmax = 220.494 
            text = "ikh hob nor gevolt lebn nor, ikh hob gekukt alts komitet oyber s'emetser iz do, keyner iz nishto. Poyln hob ikh nisht gevolt forn, zog ikh, volt emetser gevezn, aher brengen, volt ikh geforn. zol ikh forn Poyln, zen Poyln?" 
        intervals [71]:
            xmin = 220.494 
            xmax = 222.16 
            text = "" 
        intervals [72]:
            xmin = 222.16 
            xmax = 226.806 
            text = "keyn mol nisht tsurikgeforn. s'a shtetl, ver kon mikh dort iz eh keyn eyn yid nishto, bloyz polyakn." 
        intervals [73]:
            xmin = 226.806 
            xmax = 227.318 
            text = "" 
        intervals [74]:
            xmin = 227.318 
            xmax = 229.826 
            text = "FIRST OF ALL, hobn zey gekont mikh hargenen oykhet, YOU KNOW." 
        intervals [75]:
            xmin = 229.826 
            xmax = 231.621 
            text = "" 
        intervals [76]:
            xmin = 231.621 
            xmax = 238.314 
            text = "bin ikh nisht tsurikgeforn. ven ikh hob a shvester, a bruder, a tate mame, un ikh for brengen zey keyn Doytshland tsi vu, ober ikh hob keyner nisht gehat, vos zol ikh zen?" 
        intervals [77]:
            xmin = 238.314 
            xmax = 245.273 
            text = "" 
        intervals [78]:
            xmin = 245.273 
            xmax = 249.013 
            text = "yo, SURE." 
        intervals [79]:
            xmin = 249.013 
            xmax = 249.205 
            text = "" 
        intervals [80]:
            xmin = 249.205 
            xmax = 254.666 
            text = "o host nisht gezen landsman zenen gekumen fun Rusland un gekumen fun di lagers. s'dokh geblibn le- geblibn lebn a bisl mentshn." 
        intervals [81]:
            xmin = 254.666 
            xmax = 255.723 
            text = "" 
        intervals [82]:
            xmin = 255.723 
            xmax = 259.327 
            text = "eyner hot mir gezogt, geshosn dayn bruder in shtot, YOU KNOW WHAT I MEAN?" 
        intervals [83]:
            xmin = 259.327 
            xmax = 269.01 
            text = "eyner hot gezen vi di shvester brider geven in di geto, veys ikh, ober keyner iz nisht geblibn lebn. mentshn hobn ge- mentshn hobn gezukht, m'iz gegangen in kom- s'gevezn a komite, di yedn tog gevezn eh a bulet," 
        intervals [84]:
            xmin = 269.01 
