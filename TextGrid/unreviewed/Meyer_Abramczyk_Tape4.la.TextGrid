            text = "eh an orem BOY, ikh hob gornisht gegat. ikh hob gornisht gegat." 
        intervals [99]:
            xmin = 306.365 
            xmax = 311.433 
            text = "ikh bin gekumen finef hundert dolar hob ikh gekumen. dos iz avekgegangen, ikh hob nisht gearbet, bay di ershte zeks monat hob ikh nisht gearbet." 
        intervals [100]:
