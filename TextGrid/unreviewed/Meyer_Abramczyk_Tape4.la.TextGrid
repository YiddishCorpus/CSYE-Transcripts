            text = "" 
        intervals [91]:
            xmin = 287.815 
            xmax = 292.399 
            text = "eh keyn, vu zey hobn gekont zenen avek. a sakh mentshn geforn keyn Yisroel, ikh bin gevezn," 
        intervals [92]:
