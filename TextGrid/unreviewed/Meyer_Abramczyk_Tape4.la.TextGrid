        intervals [96]:
            xmin = 299.948 
            xmax = 302.827 
            text = "ikh hob gevolt hobn kinder a familye. bin ikh geforn keyn Yisroel," 
        intervals [97]:
            xmin = 302.827 
            xmax = 303.087 
            text = "" 
        intervals [98]:
            xmin = 303.087 
