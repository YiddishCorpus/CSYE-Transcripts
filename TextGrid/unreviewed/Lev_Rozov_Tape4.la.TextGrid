            text = "" 
        intervals [7]:
            xmin = 22.185 
            xmax = 26.721 
            text = "hob ikh gezen, undzer eyn shtub iz geshtanen," 
        intervals [8]:
            xmin = 26.721 
            xmax = 28.794 
            text = "nor gelebt hot dortn a krist." 
