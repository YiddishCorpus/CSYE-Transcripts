            text = "" 
        intervals [12]:
            xmin = 36.495 
            xmax = 42.58 
            text = "iz az ikh bin gekumen, bin ikh avekgegangen kukn vu di froy's eltern hobn <ge- di> froy's muter <hot gelebt>." 
        intervals [13]:
            xmin = 42.58 
            xmax = 46.617 
            text = "iz dortn zeyer shtub iz geven, iz geven shoyn a gesheft bay zey in shtub," 
