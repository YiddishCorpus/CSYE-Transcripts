            xmax = 1614.268 
            text = "hobn zey undz geshikt vayter keyn yeke land. dos iz BERGEN BELSEN" 
        intervals [662]:
            xmin = 1614.268 
            xmax = 1614.46 
            text = "" 
        intervals [663]:
            xmin = 1614.46 
            xmax = 1617.744 
            text = "un dort hot men undz geshikt, s'iz nisht gevezn afile keyn barakn" 
        intervals [664]:
            xmin = 1617.744 
            xmax = 1618.847 
            text = "" 
        intervals [665]:
            xmin = 1618.847 
            xmax = 1621.591 
            text = "nor s'iz gevezn, m'hot oyfgeshtelt TENTn" 
        intervals [666]:
            xmin = 1621.591 
            xmax = 1621.75 
            text = "" 
        intervals [667]:
            xmin = 1621.75 
            xmax = 1624.174 
            text = "un aroysgeyn fun p- OSWIECIM" 
        intervals [668]:
            xmin = 1624.174 
            xmax = 1624.618 
            text = "" 
        intervals [669]:
            xmin = 1624.618 
            xmax = 1627.835 
            text = "iz vider gevezn a, iz gevezn do di selektsye" 
        intervals [670]:
            xmin = 1627.835 
            xmax = 1627.892 
            text = "" 
        intervals [671]:
            xmin = 1627.892 
            xmax = 1635.44 
            text = "un do, az bist arayngeganen in UNK in a, tsu bodn zikh, un do arum un arum bistu yene zayt aroysgeganen" 
        intervals [672]:
            xmin = 1635.44 
            xmax = 1639.124 
            text = "iz di mame tsvey mol adurkhgelofn. ikh bin zi nokhgelofn" 
        intervals [673]:
            xmin = 1639.124 
            xmax = 1639.452 
            text = "" 
        intervals [674]:
            xmin = 1639.452 
            xmax = 1641.65 
            text = "un nebekh tsvey mol hot men zi tsurikgesh-" 
        intervals [675]:
            xmin = 1641.65 
            xmax = 1643.208 
            text = "-shikt di S.S. man." 
        intervals [676]:
            xmin = 1643.208 
