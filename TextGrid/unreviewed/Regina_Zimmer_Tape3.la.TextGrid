            text = "" 
        intervals [681]:
            xmin = 1646.607 
            xmax = 1650.347 
            text = "bay di s- eybik ven bist aroysgeganen, bistu gan in a selektsye." 
        intervals [682]:
            xmin = 1650.347 
            xmax = 1650.471 
            text = "" 
        intervals [683]:
            xmin = 1650.471 
            xmax = 1653.673 
            text = "tsi bist gezunt, tsi geyst in di arbet, <tsi> nisht bald UNK farbrenen" 
        intervals [684]:
            xmin = 1653.673 
            xmax = 1656.081 
            text = "yedes plats vu bist aroysgeganen" 
        intervals [685]:
            xmin = 1656.081 
            xmax = 1659.678 
            text = "vayl ze'mir, far vos zenen mir azoy moyre gehat? alts durkh dem vos zenen mir nokh gevezn" 
        intervals [686]:
            xmin = 1659.678 
            xmax = 1659.988 
            text = "" 
        intervals [687]:
            xmin = 1659.988 
            xmax = 1664.876 
            text = "gekretst, nisht keyn kretsn, nor s'iz nokh geblibn azolkhene flekn oyf, oyfn kerper." 
        intervals [688]:
            xmin = 1664.876 
            xmax = 1667.835 
            text = "" 
        intervals [689]:
            xmin = 1667.835 
            xmax = 1670.465 
            text = "neyn, z- vider tsurik zol zi adurkhgeyn" 
        intervals [690]:
            xmin = 1670.465 
            xmax = 1674.235 
            text = "eh tsu di <zaln>, vos zey, do hot men gedarft arayngeyn vu me bodt zikh" 
        intervals [691]:
            xmin = 1674.235 
            xmax = 1674.332 
            text = "" 
        intervals [692]:
            xmin = 1674.332 
            xmax = 1676.789 
            text = "un undz ze'mir adurkhgelofn do aher" 
        intervals [693]:
            xmin = 1676.789 
            xmax = 1676.796 
            text = "" 
        intervals [694]:
            xmin = 1676.796 
            xmax = 1681.914 
            text = "un, un UNK <zol men> nisht adurkhgeyn di, vu me geyt dort arayn, zol men undz nisht zen" 
        intervals [695]:
            xmin = 1681.914 
            xmax = 1683.539 
            text = "az hobn mir kretser oyfn layb." 
        intervals [696]:
            xmin = 1683.539 
            xmax = 1688.372 
            text = "" 
        intervals [697]:
            xmin = 1688.372 
            xmax = 1693.141 
            text = "ABER yednfal oyf letst hot men nisht gehat keyn breyre, hobn mir dokh gemuzt arayngeyn." 
        intervals [698]:
            xmin = 1693.141 
            xmax = 1693.536 
            text = "" 
        intervals [699]:
            xmin = 1693.536 
            xmax = 1699.388 
            text = "un dort iz gevezn a <SAUM> eh vos eh bret- eh" 
        intervals [700]:
            xmin = 1699.388 
            xmax = 1704.735 
            text = "benk, azoy vi UNK oybn aroyf, zenen mir ganen gantsn hintn, zol undz keyner nisht zen" 
        intervals [701]:
            xmin = 1704.735 
            xmax = 1705.416 
            text = "" 
        intervals [702]:
            xmin = 1705.416 
            xmax = 1710.843 
            text = "zoln mir zikh kenen dort opbodn, un ze'mir aroysgeganen, <got zay dank, ze'mir> ganen keyn BERGEN BELSEN." 
        intervals [703]:
            xmin = 1710.843 
            xmax = 1712.2 
            text = "" 
        intervals [704]:
            xmin = 1712.2 
            xmax = 1713.142 
            text = "yo, kh'hob gezen." 
