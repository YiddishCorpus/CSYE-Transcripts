            text = "ongelodnt di vagonen, farshlosn di vagonen, ir hert? un m'firt undz." 
        intervals [497]:
            xmin = 1244.013 
            xmax = 1244.087 
            text = "" 
        intervals [498]:
            xmin = 1244.087 
            xmax = 1251.084 
            text = "dort men ahin, m'fort tsurik. m'fort ahin, un m'fort tsurik. teg un nakht." 
        intervals [499]:
            xmin = 1251.084 
            xmax = 1251.681 
            text = "" 
        intervals [500]:
            xmin = 1251.681 
            xmax = 1254.037 
            text = "m'varft undz arayn a shtikl broyt a tog," 
        intervals [501]:
            xmin = 1254.037 
            xmax = 1255.528 
            text = "" 
        intervals [502]:
            xmin = 1255.528 
            xmax = 1260.736 
            text = "in di vagonen? efsher hot gekont zayn dentsmolt efsher a finef hundert mentshn." 
        intervals [503]:
            xmin = 1260.736 
            xmax = 1264.067 
            text = "" 
        intervals [504]:
            xmin = 1264.067 
            xmax = 1269.36 
            text = "s'arayngegangen az m'hot nisht gehat keyn otem. m'hot nisht gekont UNK." 
        intervals [505]:
            xmin = 1269.36 
            xmax = 1270.935 
            text = "" 
        intervals [506]:
            xmin = 1270.935 
            xmax = 1279.907 
            text = "un ikh hob nokh gehat a tsvey kartofl in mayn tash vos ikh hob es nisht gerirt, roye. ir hert? roye kartofl in der tash." 
        intervals [507]:
            xmin = 1279.907 
            xmax = 1280.655 
            text = "" 
        intervals [508]:
            xmin = 1280.655 
            xmax = 1285.61 
            text = "un az m'fort in di vagonen, m'git nisht keyn broyt, un m'git gornisht, mayn bruder farkhalesht zikh," 
        intervals [509]:
            xmin = 1285.61 
            xmax = 1285.65 
            text = "" 
        intervals [510]:
            xmin = 1285.65 
            xmax = 1291.769 
            text = "hot men ayngeribn mit a shtikl kartofl hot men im gegebn, un do dortn, ayngeribn di shleyfn. halt dikh." 
        intervals [511]:
            xmin = 1291.769 
            xmax = 1293.312 
            text = "" 
        intervals [512]:
            xmin = 1293.312 
            xmax = 1297.963 
            text = "un Got mit eyn mol gibn di S.S. a for avek," 
        intervals [513]:
            xmin = 1297.963 
            xmax = 1298.037 
            text = "" 
        intervals [514]:
            xmin = 1298.037 
            xmax = 1304.004 
            text = "un m'lozt undz iber fray, un m'freyt zikh, mir zenen bafrayt gevorn. di S.S. zenen antlofn." 
        intervals [515]:
            xmin = 1304.004 
            xmax = 1304.618 
            text = "" 
        intervals [516]:
            xmin = 1304.618 
            xmax = 1307.109 
            text = "m'hot gevust az di un di krig di krig geyt tsu ende." 
        intervals [517]:
            xmin = 1307.109 
            xmax = 1308.465 
            text = "" 
        intervals [518]:
            xmin = 1308.465 
            xmax = 1318.027 
            text = "un m'shteyt zikh un m'freyt zikh un m'freyt zikh. mit eyn mol nokh a sho tsayt get a kum op a tsveyte vagon oyf der tsveyter zayt un UNK geyen aroys S.S. azoy vi in a front arayn." 
        intervals [519]:
            xmin = 1318.027 
            xmax = 1318.303 
            text = "" 
        intervals [520]:
            xmin = 1318.303 
            xmax = 1325.57 
            text = "HELMETS, mit hant-granatn, mit mashin-gever, m- ayngeshtekt hant-granatn, vey iz mir nebekh, in a front arayn." 
        intervals [521]:
            xmin = 1325.57 
            xmax = 1325.644 
            text = "" 
        intervals [522]:
            xmin = 1325.644 
            xmax = 1333.164 
            text = "un m'shrayt, JUDEN RAUS! HUNDE RAUS! un m'heybt on oyftsushlisn di vagonen, m'shlist oyf di vagonen, RAUS!" 
        intervals [523]:
            xmin = 1333.164 
            xmax = 1334.723 
            text = "" 
        intervals [524]:
            xmin = 1334.723 
            xmax = 1343.604 
            text = "un m'hoybt undz op aroystsushikn, un ikh zog tsum bruder, un bay yeder aroysgeyn get men a shtekn oyfn kop. on dem heybt zikh dokh nisht on. a shtekn oyfn kop, yeder eyner vos geyt aroys fun vagon." 
        intervals [525]:
            xmin = 1343.604 
            xmax = 1350.866 
            text = "ikh zog tsum bruder, du zolst gebn a shpring arop, zolst nisht khapn keyn shtekn, vayl tomer khapstu a shtekn bistu shoyn farloyrn. du darfst nisht mer nor a klap." 
        intervals [526]:
            xmin = 1350.866 
            xmax = 1351.193 
            text = "" 
        intervals [527]:
            xmin = 1351.193 
            xmax = 1352.722 
            text = "eyn klap bistu fertik." 
        intervals [528]:
            xmin = 1352.722 
            xmax = 1353.437 
            text = "" 
        intervals [529]:
            xmin = 1353.437 
            xmax = 1360.147 
            text = "zogt er, vi makht men dos? du vest es muzn makhn. gib dikh a sh- varf aroys, du zolst flien. az du vest nisht khapn keyn shtekn vestu dikh oyfheybn." 
        intervals [530]:
            xmin = 1360.147 
            xmax = 1360.879 
            text = "" 
        intervals [531]:
            xmin = 1360.879 
            xmax = 1366.054 
            text = "un azoy iz gevezn. ikh hob im gegebn kuk vi er flit aroys, er hot nisht gekhapt keyn shtekn, Got tsu dank." 
        intervals [532]:
            xmin = 1366.054 
            xmax = 1366.279 
            text = "" 
        intervals [533]:
            xmin = 1366.279 
            xmax = 1371.994 
            text = "ikh bin gefloygn vayter. geven yung, gegebn a shprung aroys. vi hot er aza lange shtekn tsu mir?" 
        intervals [534]:
            xmin = 1371.994 
            xmax = 1372.388 
            text = "" 
        intervals [535]:
            xmin = 1372.388 
            xmax = 1374.317 
            text = "ver s'hot gekhapt hot gekhapt, ver s'hot nisht gekhapt," 
        intervals [536]:
            xmin = 1374.317 
            xmax = 1378.727 
            text = "un m'hot undz gefirt durkh di felder glaykh arayn in vald arayn." 
        intervals [537]:
            xmin = 1378.727 
            xmax = 1379.526 
            text = "" 
        intervals [538]:
            xmin = 1379.526 
            xmax = 1384.532 
            text = "zog ikh tsum bruder, dos iz undzer letster veg. dos iz es." 
        intervals [539]:
            xmin = 1384.532 
            xmax = 1384.842 
            text = "" 
        intervals [540]:
            xmin = 1384.842 
            xmax = 1389.865 
            text = "m'shlept undz arayn in vald oystsushisn. nor gedenk eyn zakh zog ikh tsun im, in geyn," 
        intervals [541]:
            xmin = 1389.865 
            xmax = 1390.022 
            text = "" 
        intervals [542]:
            xmin = 1390.022 
            xmax = 1392.395 
            text = "m'kumt arayn in vald arayn, mir veln beyde antloyfn." 
        intervals [543]:
            xmin = 1392.395 
            xmax = 1393.279 
            text = "" 
        intervals [544]:
            xmin = 1393.279 
            xmax = 1397.273 
            text = "azoy vi m'derzet di beymer, azoy heybn mir on tsu loyfn." 
        intervals [545]:
            xmin = 1397.273 
            xmax = 1397.616 
            text = "" 
        intervals [546]:
            xmin = 1397.616 
            xmax = 1401.12 
            text = "un dos iz gevezn. m'iz arayngekumen in vald arayn, m'hot ongehoybn tsu loyfn," 
        intervals [547]:
            xmin = 1401.12 
            xmax = 1401.767 
            text = "" 
        intervals [548]:
            xmin = 1401.767 
            xmax = 1411.498 
            text = "loyfn undz nokh tsvey S.S., ""ir HUNDE shteyn blaybn!"" m'shist, ""shteyn blaybn!"" m'shist. un ikh zog tsum bruder, kuk dikh nisht um un loyf!" 
        intervals [549]:
            xmin = 1411.498 
            xmax = 1411.656 
            text = "" 
        intervals [550]:
            xmin = 1411.656 
            xmax = 1413.118 
            text = "ikh bin gelofn unter im." 
        intervals [551]:
            xmin = 1413.118 
            xmax = 1414.558 
            text = "" 
        intervals [552]:
            xmin = 1414.558 
            xmax = 1423.87 
            text = "un m'loyft un m'loyft, undz ze'mir gelofn efsher a sho. un di tsvey kholeres lo- geyn lozn zikh nisht op. un m'loyft nokh undz, un m'shrayt, HUNDE shteyn blaybn!" 
        intervals [553]:
            xmin = 1423.87 
            xmax = 1431.36 
            text = "un mir loyfn, zey loyfn. un der bruder Avram khapt a koyl in kop arayn, un falt arop," 
        intervals [554]:
            xmin = 1431.36 
            xmax = 1431.552 
            text = "" 
        intervals [555]:
            xmin = 1431.552 
            xmax = 1435.629 
            text = "un ikh shray, Avrom! Avrom! ikh hob shoyn nisht vemen tsu redn." 
        intervals [556]:
            xmin = 1435.629 
            xmax = 1436.023 
            text = "" 
        intervals [557]:
            xmin = 1436.023 
            xmax = 1441.012 
            text = "un nokh dem geb ikh a kuk, di tsvey S.S. dernentern zikh tsu mir. bin ikh oyfgehoybn un antlofn." 
        intervals [558]:
            xmin = 1441.012 
            xmax = 1442.082 
            text = "" 
        intervals [559]:
            xmin = 1442.082 
            xmax = 1447.982 
            text = "ikh bin antlofn, hobn zey mikh shoyn nisht nokhgeyogt. zey hobn shoyn gezen er iz shoyn toyt, hobn zikh getrakht zikh, loyf." 
        intervals [560]:
            xmin = 1447.982 
            xmax = 1448.528 
            text = "" 
        intervals [561]:
            xmin = 1448.528 
            xmax = 1453.584 
            text = "un ikh bin gelofn a gantsn tog biz shpet fintster in der nakht in di velder." 
        intervals [562]:
            xmin = 1453.584 
            xmax = 1455.379 
            text = "" 
        intervals [563]:
            xmin = 1455.379 
            xmax = 1459.726 
            text = "ikh hob nisht gornisht gezen nor loyfn. ikh hob afile nisht gevolt umkukn zikh." 
        intervals [564]:
            xmin = 1459.726 
            xmax = 1459.935 
            text = "" 
        intervals [565]:
            xmin = 1459.935 
            xmax = 1464.024 
            text = "un dan nakher bin ikh antshlofn gevorn. ikh hob zikh aropgezetst antshlofn gevorn," 
        intervals [566]:
            xmin = 1464.024 
            xmax = 1468.738 
            text = "oyfgevekt fir in der fri, in der fri, s'hot ongehoybn tsu togn," 
        intervals [567]:
            xmin = 1468.738 
            xmax = 1469.706 
            text = "" 
        intervals [568]:
            xmin = 1469.706 
            xmax = 1476.028 
            text = "un ikh shtey un veyn, reboyne-shel-oylem, vos hostu mit mir gemakht? ikh hob gehat eyn bruder, host mikh shoyn avekgeharget oykhet." 
        intervals [569]:
            xmin = 1476.028 
            xmax = 1476.143 
            text = "" 
        intervals [570]:
            xmin = 1476.143 
            xmax = 1481.2 
            text = "vos hostu mit mir gemakht? vi nemt men yetst esn? vi geyt men aroys fun vald aroys?" 
        intervals [571]:
            xmin = 1481.2 
            xmax = 1481.451 
            text = "" 
        intervals [572]:
            xmin = 1481.451 
            xmax = 1485.445 
            text = "vu gey ikh? a gantser tog bin ikh gelofn in vald on an ek." 
        intervals [573]:
            xmin = 1485.445 
            xmax = 1486.935 
            text = "" 
        intervals [574]:
            xmin = 1486.935 
            xmax = 1493.983 
            text = "hob ikh genumen raysn groz. ikh hob gerisn groz, ikh zol hobn dem kvas, dem dos, dem eh di a bisl epes in moyl aroys." 
        intervals [575]:
            xmin = 1493.983 
            xmax = 1495.474 
            text = "" 
        intervals [576]:
            xmin = 1495.474 
            xmax = 1496.885 
            text = "un ikh hoyb on tsu geyn." 
        intervals [577]:
            xmin = 1496.885 
            xmax = 1496.993 
            text = "" 
        intervals [578]:
            xmin = 1496.993 
            xmax = 1503.686 
            text = "ikh hoyb on tsu geyn, bin ikh gegangen efsher tsen fuftsn minut, geb ikh a derze a hoyz un nokh a hoyz, oy iz dos a derfl. ikh gey arayn." 
        intervals [579]:
            xmin = 1503.686 
            xmax = 1504.165 
            text = "" 
        intervals [580]:
            xmin = 1504.165 
            xmax = 1509.741 
            text = "zol shoyn dortn zayn Hitler, zol zayn Himler, ver s'zol nisht zayn. ikh gey arayn, ikh geb zikh unter, ikh ken nisht mer." 
        intervals [581]:
            xmin = 1509.741 
            xmax = 1514.446 
            text = "un der toyt ligt in di oygn, ikh ken nisht mer, ikh ken nisht mer kemfn. ikh gib zikh unter." 
        intervals [582]:
            xmin = 1514.446 
            xmax = 1514.627 
            text = "" 
        intervals [583]:
            xmin = 1514.627 
            xmax = 1516.595 
            text = "un bin arayn in dem hoyz arayn," 
        intervals [584]:
            xmin = 1516.595 
            xmax = 1518.222 
            text = "" 
        intervals [585]:
            xmin = 1518.222 
            xmax = 1525.016 
            text = "un ikh red tsu der froy, ikh klap on bay der tir, zog ikh, ""ken ICH bite EINE CAFE HABBEN? ikh hob nisht gevolt nemen keyn broyt, efsher hobn zey oykh nisht tsulib der milkhome." 
        intervals [586]:
            xmin = 1525.016 
            xmax = 1525.022 
            text = "" 
        intervals [587]:
            xmin = 1525.022 
            xmax = 1532.528 
            text = "kukt zi mikh on, ikh red tsu zi a eh nayes daytsh un EVERYTHING un zi hot moyre gehat far mir, ikh ikh hob oysgezen punkt vi a payats mit aza hitl, mit" 
        intervals [588]:
            xmin = 1532.528 
            xmax = 1534.567 
            text = "holtserne shikh mit aza PASIAK." 
        intervals [589]:
            xmin = 1534.567 
            xmax = 1534.573 
            text = "" 
        intervals [590]:
            xmin = 1534.573 
            xmax = 1540.054 
            text = "ruft zi dem man, der man get a kum tsu, JA WAS WUNSCHEN SIE? zog ikh zog ikh, koydem kol zog ikh, gris Got, gris Got." 
        intervals [591]:
            xmin = 1540.054 
            xmax = 1544.389 
            text = "un ikh hob mikh mit im tseredt, un un un ikh dertseyl im dos ales." 
        intervals [592]:
            xmin = 1544.389 
            xmax = 1546.757 
            text = "" 
        intervals [593]:
            xmin = 1546.757 
            xmax = 1556.352 
            text = "un er veyst er, er hot mikh oyfgeheybn, un er makht mir kave. un er zogt mir, kum arayn bite, ikh zol arayngeyn mit ineveynik." 
        intervals [594]:
            xmin = 1556.352 
            xmax = 1556.967 
            text = "" 
        intervals [595]:
            xmin = 1556.967 
            xmax = 1568.031 
            text = "kum arayn, zets zikh avek barn tish, un er gibt mir kave. un brengt arayn azoy vi a halber tish. un ikh ze dos broyt," 
        intervals [596]:
            xmin = 1568.031 
            xmax = 1568.408 
            text = "" 
        intervals [597]:
            xmin = 1568.408 
            xmax = 1570.581 
            text = "un zey hobn gehat dortn a tokhter oyfgevekt," 
        intervals [598]:
            xmin = 1570.581 
            xmax = 1574.595 
            text = "hobn zey geshnitn gantse reftlekh un ongeshmirt mit der mit mit marmelad." 
        intervals [599]:
            xmin = 1574.595 
            xmax = 1574.719 
            text = "" 
        intervals [600]:
            xmin = 1574.719 
            xmax = 1578.594 
            text = "un vi lang er shmirt dray reftlekh, hob ikh shoyn arayngelozt. aza," 
        intervals [601]:
            xmin = 1578.594 
            xmax = 1579.579 
            text = "" 
        intervals [602]:
            xmin = 1579.579 
            xmax = 1580.383 
            text = "he?" 
        intervals [603]:
            xmin = 1580.383 
            xmax = 1580.642 
            text = "" 
        intervals [604]:
            xmin = 1580.642 
            xmax = 1585.845 
            text = "no no. er hot mikh gefregt ver ikh bin. zog ikh, ICH bin, zog ikh, EIN POLE. zogt er, SIE SPRECHEN dokh SO SO UNK." 
        intervals [605]:
            xmin = 1585.845 
            xmax = 1585.885 
            text = "" 
        intervals [606]:
            xmin = 1585.885 
            xmax = 1590.955 
            text = "SO NICE doytsh. zog ikh, ICH bin a P- a POLE, heyst a goy. ikh bin a po- ikh bin nisht keyn yid. ikh hob nisht gezogt ikh bin a yid." 
        intervals [607]:
            xmin = 1590.955 
            xmax = 1591.729 
            text = "" 
        intervals [608]:
            xmin = 1591.729 
            xmax = 1594.912 
            text = "ANYWAYS, hin un aher, ikh hoyb on tsu esn un tsu trinken," 
        intervals [609]:
            xmin = 1594.912 
            xmax = 1595.661 
            text = "" 
        intervals [610]:
            xmin = 1595.661 
            xmax = 1601.173 
            text = "un dos iz es. un er shrayt tsu mir, nakher fregt zi mikh, di froy, vi azoy HABEN SIE SO hunger?" 
        intervals [611]:
            xmin = 1601.173 
            xmax = 1601.533 
            text = "" 
        intervals [612]:
            xmin = 1601.533 
            xmax = 1604.027 
            text = "hob ikh gezogt, ikh kum fun Oyshvits, fun di lagern," 
        intervals [613]:
            xmin = 1604.027 
            xmax = 1607.681 
            text = "o! mayn Got! UNK DARUM HABEN SIE SO hunger!" 
        intervals [614]:
            xmin = 1607.681 
            xmax = 1613.95 
            text = "hin aher, zog ikh, ""ICH vil ZICH dos dos badanken, ikh hob UNK, keyn gelt. viln SIE mayn MUTZE HABBEN?" 
        intervals [615]:
            xmin = 1613.95 
            xmax = 1614.558 
            text = "" 
        intervals [616]:
            xmin = 1614.558 
            xmax = 1621.541 
            text = "viln SIE mayne shikh HABBEN?"" ""neyn. vu WOLLEN SIE den geyn?"" ""ikh vil geyn zukhn di COMPANY, di khevre.""" 
        intervals [617]:
            xmin = 1621.541 
            xmax = 1622.928 
            text = "" 
        intervals [618]:
            xmin = 1622.928 
            xmax = 1626.843 
            text = "zi hot gevust vos tut zikh. zogt zi tsu mir, di fir, geyen SIE bite nisht RAUS," 
        intervals [619]:
            xmin = 1626.843 
            xmax = 1630.604 
            text = "zi hot shoyn moyre gehat di shkheynim zoln mikh nisht zen. az di shkheynim veln mikh hobn gezen," 
        intervals [620]:
            xmin = 1630.604 
            xmax = 1632.491 
            text = "ebn zey fornemen tsu di zhandamerye, far vos hot" 
        intervals [621]:
            xmin = 1632.491 
            xmax = 1632.493 
            text = "" 
        intervals [622]:
            xmin = 1632.493 
            xmax = 1636.222 
            text = "gehaltn do a yid. zi hot im gelozt aroysgeyn. far vos zey hobn nisht gefodert far di POLICE." 
        intervals [623]:
            xmin = 1636.222 
            xmax = 1637.14 
            text = "" 
        intervals [624]:
            xmin = 1637.14 
            xmax = 1642.669 
            text = "nokh nisht gevust. ober vi kenen zey araynnemen a mentshn fun in aza PASIAK un azelkhes, vayl ikh hob gezogt ikh bin fun lager." 
        intervals [625]:
            xmin = 1642.669 
            xmax = 1642.675 
            text = "" 
        intervals [626]:
            xmin = 1642.675 
            xmax = 1646.584 
            text = "az ikh bin fun lager, trakht vos du vilst. zi hot dokh gezen ikh bin fun lager." 
        intervals [627]:
            xmin = 1646.584 
            xmax = 1646.64 
            text = "" 
        intervals [628]:
            xmin = 1646.64 
            xmax = 1653.03 
            text = "hob ikh gezogt, zogt zi mikh gebetn, zogt zi, mayne NEIGHBOURS, veln ICH WOLTE nisht di NEIGHBOURS zoln DICH zen." 
        intervals [629]:
            xmin = 1653.03 
            xmax = 1653.205 
            text = "" 
        intervals [630]:
            xmin = 1653.205 
            xmax = 1654.94 
            text = "bite GEHEN SIE nisht HERAUS." 
        intervals [631]:
            xmin = 1654.94 
            xmax = 1660.168 
            text = "un er heybt zikh on tsu tseylemen. ikh, ikh vel IHN ophitn, ICH vel IHN ales gebn, blaybn SIE NUR HIER." 
        intervals [632]:
            xmin = 1660.168 
            xmax = 1660.562 
            text = "" 
        intervals [633]:
            xmin = 1660.562 
            xmax = 1663.019 
            text = "hob ikh mikh epes gelozt tsuredn, ikh bin geblibn." 
        intervals [634]:
            xmin = 1663.019 
            xmax = 1663.195 
            text = "" 
        intervals [635]:
            xmin = 1663.195 
            xmax = 1668.524 
            text = "un ikh hob gehert di CHADASHOT yedes mol di NEWS vos s'geyt on UNK tsvishn di daytshn un di amerikaner." 
        intervals [636]:
            xmin = 1668.524 
            xmax = 1674 
            text = "un dervayl iz ongekumen in droysn STRASSE kamfn in a shtetl, ponem tsu ponem hobn zey gekemft." 
        intervals [637]:
            xmin = 1674 
            xmax = 1680.073 
            text = "hob ikh im gefregt nakher dem goy, vi vayt iz dos fun danet biz danet, ven ikh gehert di, ikh hob nisht gevust vu ikh gefin zikh." 
        intervals [638]:
            xmin = 1680.073 
            xmax = 1682.333 
            text = "ober ikh hob gehert vu di kamfn kumen for," 
        intervals [639]:
            xmin = 1682.333 
            xmax = 1690.444 
            text = "vos heyst di nemen, hob ikh im gezogt vi vayt? zogt er epes a fertsik kilometer. fertsik kilometer, zog ikh, MY mayne yorn, morgn veln di amerikaner do zayn!" 
        intervals [640]:
            xmin = 1690.444 
            xmax = 1690.65 
            text = "" 
        intervals [641]:
            xmin = 1690.65 
            xmax = 1696.736 
            text = "fir tog hot genumen biz zey zenen arayn in dem dorf arayn, un zey zenen arayn in dorf arayn un zey hobn farnumen ales," 
        intervals [642]:
            xmin = 1696.736 
            xmax = 1698.092 
            text = "" 
        intervals [643]:
            xmin = 1698.092 
            xmax = 1705.292 
            text = "zey gebn a kum tsu, di amerikaner, geyt aroys der mentsh, er vil ahin geyn tsu der ferd gebn esn, shteyn tsvey NEIGHBOURS." 
        intervals [644]:
            xmin = 1705.292 
            xmax = 1705.416 
            text = "" 
        intervals [645]:
            xmin = 1705.416 
            xmax = 1709.412 
            text = "HALT! hot er moyre gekrign, iz er gelofn tsu mir, Pinek, tsien ZICH MAL ayn." 
        intervals [646]:
            xmin = 1709.412 
            xmax = 1711.041 
            text = "zogt er, s'geven mentshn DRAUSSEN." 
        intervals [647]:
            xmin = 1711.041 
            xmax = 1715.518 
            text = "hob ikh gezogt, ver iz in droysn? di Vermakht? di natsis? ver iz in droysn?" 
        intervals [648]:
            xmin = 1715.518 
            xmax = 1715.658 
            text = "" 
        intervals [649]:
            xmin = 1715.658 
            xmax = 1718.751 
            text = "zogt er, di AMI. ikh hob nisht gekont farshteyn vos er zogt di AMI." 
        intervals [650]:
            xmin = 1718.751 
            xmax = 1722.528 
            text = "dort in BAVARIA zogn zey oyf di amerikaner AMI, a halbe vort." 
        intervals [651]:
            xmin = 1722.528 
            xmax = 1727.491 
            text = "un ikh hob nisht farshtanen, zog ikh, ir veyst dokh nisht vos zey WOLLEN. WAS vi iz dortn? far vos zol ikh mikh on-" 
        intervals [652]:
            xmin = 1727.491 
            xmax = 1727.809 
            text = "" 
        intervals [653]:
            xmin = 1727.809 
            xmax = 1732.296 
            text = "zogt er tsu mir, Doytshland HAT nokh keyn NEGRO, NEGRO. NEGRO?" 
        intervals [654]:
            xmin = 1732.296 
            xmax = 1732.41 
            text = "" 
        intervals [655]:
            xmin = 1732.41 
            xmax = 1734.447 
            text = "iz dos nisht di amerikaner? zogt er JA!" 
        intervals [656]:
            xmin = 1734.447 
            xmax = 1741.114 
            text = "ikh geb mikh a tu on dem PASIAK, gib a gey aroys, get mir a gey tsu mit tsvey revolvern, git mir a shtel tsu, ARE YOU GERMAN?" 
        intervals [657]:
            xmin = 1741.114 
            xmax = 1741.613 
            text = "" 
        intervals [658]:
            xmin = 1741.613 
            xmax = 1747.862 
            text = "oy, zog ikh, I'M NOT GERMAN. ikh hob nor gevust tsvey tsvey verter tsu redn. I'M JEWISH, I'M CONCENTRATION CAMP, un ikh vayz zey dos." 
        intervals [659]:
            xmin = 1747.862 
            xmax = 1750.637 
            text = "hobn zey avekgenumen di revolvern fun mir, m'hot ongehoybn tsu rufn," 
        intervals [660]:
            xmin = 1750.637 
            xmax = 1757.252 
            text = "iz gekumen eyner a vayser, un der vayser heybt on mit mir tsu redn, zogt er," 
        intervals [661]:
            xmin = 1757.252 
            xmax = 1762.721 
            text = "tsum, OK OK OK." 
