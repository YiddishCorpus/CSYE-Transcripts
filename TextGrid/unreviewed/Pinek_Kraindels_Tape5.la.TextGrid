            text = """brilantn.""" 
        intervals [129]:
            xmin = 308.126 
            xmax = 308.267 
            text = "" 
        intervals [130]:
            xmin = 308.267 
            xmax = 310.69 
            text = "zogt er, ""brilantn? du host brilantn?""" 
        intervals [131]:
            xmin = 310.69 
            xmax = 311.625 
            text = "" 
        intervals [132]:
            xmin = 311.625 
            xmax = 316.023 
            text = """oyb du vest tsuzogn, gebn dos vort, du zolt aroys dem BOY, breng ikh dir groyse brilantn.""" 
        intervals [133]:
            xmin = 316.023 
            xmax = 317.548 
            text = "" 
        intervals [134]:
            xmin = 317.548 
            xmax = 322.79 
            text = "ver iz der BOY? s'a BOY, zogt er, mayns a shteterisher. ikh vil er zol zayn mit mir tsuzamen." 
        intervals [135]:
            xmin = 322.79 
            xmax = 324.72 
            text = "" 
        intervals [136]:
            xmin = 324.72 
            xmax = 329.118 
            text = "un vos vet dir zayn UNK vest hobn fir NINETY NINE, tsi du host finef? eyner veyniker." 
        intervals [137]:
            xmin = 329.118 
            xmax = 331.048 
            text = "" 
        intervals [138]:
            xmin = 331.048 
            xmax = 339.108 
            text = "zogt er tsun im, ""oyb du vest haltn dos moyl, vel ikh mir du makhn dos BUSINESS, nor du muzt onzogn dem BOY er zol nisht dervegn tsu dertseyln er iz geven in dem blok.""" 
        intervals [139]:
            xmin = 339.108 
            xmax = 339.368 
            text = "" 
        intervals [140]:
            xmin = 339.368 
            xmax = 342.788 
            text = "zogt er, fun dem vet zayn hundert protsent. keyner vet nisht visn." 
        intervals [141]:
            xmin = 342.788 
            xmax = 343.182 
            text = "" 
        intervals [142]:
            xmin = 343.182 
            xmax = 347.867 
            text = "un er iz avekgelofn, un er hot im gebrengt im dray shteyner, yeder shteyn iz shoyn finef karat tsen karat." 
        intervals [143]:
            xmin = 347.867 
            xmax = 347.873 
            text = "" 
        intervals [144]:
            xmin = 347.873 
            xmax = 350.257 
            text = "un er hot im gegebn a leyg avek oyfn tish, ""ze vos do tut zikh!" 
        intervals [145]:
            xmin = 350.257 
            xmax = 352.355 
            text = "vest mir gebn di hant? tsvishn undz.""" 
        intervals [146]:
            xmin = 352.355 
            xmax = 352.665 
            text = "" 
        intervals [147]:
            xmin = 352.665 
            xmax = 360.219 
            text = "zogt er, vi iz zayn numer? nayntsn tsvey fir un draysik. geyt arayn in blok, get er a kum arayn, zogt er, ""nayntsn tsvey fir un DREISSIG KAMME DOCH MAL aher!""" 
        intervals [148]:
            xmin = 360.219 
            xmax = 361.103 
            text = "" 
        intervals [149]:
            xmin = 361.103 
            xmax = 367.276 
            text = "un shrayt tsvey dray mol. zog ikh, a brokh tsu mayne yorn. ikh veys dokh gornisht vos Khaim hot in droysn getun, vos er hot far mir gemakht." 
        intervals [150]:
            xmin = 367.276 
            xmax = 370.243 
            text = "un shrayt mikh. zog ikh, ""ikh bin shoyn der ershter?""" 
        intervals [151]:
            xmin = 370.243 
