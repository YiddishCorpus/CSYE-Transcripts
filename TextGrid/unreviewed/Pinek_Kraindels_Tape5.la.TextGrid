            text = "" 
        intervals [350]:
            xmin = 894.893 
            xmax = 897.654 
            text = "undz hot men gemakht vu m'iz geshtanen. er iz gegangen in TOILET." 
        intervals [351]:
            xmin = 897.654 
            xmax = 897.677 
            text = "" 
        intervals [352]:
            xmin = 897.677 
            xmax = 900.641 
            text = "hot er mir ibergegebn dem OFNAYIM, ikh zol haltn." 
