            xmin = 863.735 
            xmax = 864.501 
            text = "" 
        intervals [336]:
            xmin = 864.501 
            xmax = 868.191 
            text = "LASSEN SIE MICH <oysraysn>, ikh zol nor kenen antloyfn." 
        intervals [337]:
