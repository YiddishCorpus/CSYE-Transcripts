        intervals [420]:
            xmin = 1059.12 
            xmax = 1064.497 
            text = "oy, hobn zey shoyn gevust di tshekhn az do kumen zey on mater- az do kumen zey op a transport vos zey geyen tsu fus oyfn toytn-marsh." 
