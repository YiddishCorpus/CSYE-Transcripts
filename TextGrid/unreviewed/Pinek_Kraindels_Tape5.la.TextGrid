            xmax = 901.187 
            text = "" 
        intervals [354]:
            xmin = 901.187 
            xmax = 905.467 
            text = "vi ikh hob gezen fun der vaytns er geyt arayn in TOILET arayn, hob ikh gegebn a makh oyf gegebn dem zak," 
        intervals [355]:
            xmin = 905.467 
            xmax = 906.148 
            text = "" 
        intervals [356]:
            xmin = 906.148 
            xmax = 910.681 
            text = "hot er gehat lign farshidene shtiker broytn dortn, halb broyt, halbe broytn a sakh." 
        intervals [357]:
            xmin = 910.681 
            xmax = 910.823 
            text = "" 
        intervals [358]:
            xmin = 910.823 
            xmax = 915.857 
            text = "hob ikh gegebn a khap aroys a halb broyt, ir hert? mit a shtik vursht," 
        intervals [359]:
            xmin = 915.857 
            xmax = 919.422 
            text = "gegebn dem bruder, un gegebn mir, tsurik tsugemakht dem zak," 
        intervals [360]:
            xmin = 919.422 
            xmax = 919.48 
            text = "" 
        intervals [361]:
            xmin = 919.48 
            xmax = 923.979 
            text = "m'hot oyfge- biz er iz tsurikgekumen hot men es oyfgegesn. m'iz gekumen tsu zikh." 
        intervals [362]:
            xmin = 923.979 
            xmax = 924.137 
            text = "" 
        intervals [363]:
            xmin = 924.137 
            xmax = 927.86 
            text = "er hot mir gegebn dem zak tsu haltn mitn OFNAYIM. mit dem BICYCLE." 
        intervals [364]:
            xmin = 927.86 
            xmax = 929.757 
            text = "" 
        intervals [365]:
            xmin = 929.757 
            xmax = 933.699 
            text = "er kumt tsurik, geyt er esn. er geyt esn, shtey ikh un kuk." 
        intervals [366]:
            xmin = 933.699 
            xmax = 934.093 
            text = "" 
        intervals [367]:
            xmin = 934.093 
            xmax = 938.948 
            text = "git er shnayd op nokh a shtikl broyt, zogt er, na dir du yunger! na dir! git er mir shtikl broyt." 
        intervals [368]:
            xmin = 938.948 
            xmax = 939.122 
            text = "" 
        intervals [369]:
            xmin = 939.122 
            xmax = 940.854 
            text = "nem ikh a halbs, gib dem bruder." 
