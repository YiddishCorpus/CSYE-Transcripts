            text = "" 
        intervals [398]:
            xmin = 1006.369 
            xmax = 1009.265 
            text = "ikh hoyb on tsu esn. nem ikh arop dos hitl un ful op a ful hitl," 
        intervals [399]:
            xmin = 1009.265 
            xmax = 1009.98 
            text = "" 
        intervals [400]:
            xmin = 1009.98 
            xmax = 1016.859 
            text = "un ikh breng arayn dos tsu mayn bruder tsum oyfn oyfn bet. zogt er, reboyne-shel-oylem. es, zogt er, vifl du vilst. ikh gey tsurik brengen nokh." 
        intervals [401]:
            xmin = 1016.859 
