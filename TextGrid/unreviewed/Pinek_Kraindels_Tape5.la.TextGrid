        intervals [408]:
            xmin = 1029.369 
            xmax = 1036.501 
            text = "un ikh vayter, ikh hob ongeleygt zikh ful mit nokh mit POTATOES, un ikh bin aroysgeshprungen fun fentster, hobn nisht espiet mir tsu gebn a klap" 
        intervals [409]:
            xmin = 1036.501 
            xmax = 1036.693 
            text = "" 
        intervals [410]:
            xmin = 1036.693 
            xmax = 1039.572 
            text = "un ikh bin gelofn arayn tsum bruder, nokh mit ful mit kartofl." 
