            text = "" 
        intervals [6]:
            xmin = 16.093 
            xmax = 20.778 
            text = "nu, iz gegangen un m'hot mikh gerufn tsu dem tsum blok-ALTESTER," 
        intervals [7]:
            xmin = 20.778 
            xmax = 21.122 
            text = "" 
        intervals [8]:
            xmin = 21.122 
            xmax = 22.854 
            text = "un er hot tsu mir gezogt," 
        intervals [9]:
            xmin = 22.854 
            xmax = 23.113 
            text = "" 
        intervals [10]:
            xmin = 23.113 
            xmax = 28.35 
            text = """yetst geystu MAL tsu der arbet, un ven du kumst MAL tsurik, geystu MAL" 
        intervals [11]:
            xmin = 28.35 
            xmax = 31.75 
            text = "tsum hengen."" vayl m'hot yedn gehongen ven m'iz tsurikgekumen oykhet." 
        intervals [12]:
            xmin = 31.75 
            xmax = 33.553 
            text = "yedn tog m'iz tsurikgekumen hot men gehongen." 
        intervals [13]:
            xmin = 33.553 
            xmax = 34.622 
            text = "" 
        intervals [14]:
            xmin = 34.622 
            xmax = 36.357 
            text = "un mayn bruder hot genumen veynen" 
        intervals [15]:
            xmin = 36.357 
            xmax = 40.117 
            text = "vos ikh hob dos getun. zogt er, veyst nisht vos hot oyf dir gevart. un meshiekh hostu nisht derlebt." 
        intervals [16]:
            xmin = 40.117 
            xmax = 40.647 
            text = "" 
        intervals [17]:
            xmin = 40.647 
            xmax = 43.307 
            text = "un ikh hob dikh opgeratevet dem lebn, un vos vet zayn yetst mit dir?" 
        intervals [18]:
            xmin = 43.307 
            xmax = 43.38 
            text = "" 
        intervals [19]:
            xmin = 43.38 
            xmax = 44.977 
            text = "zog ikh, hob nisht keyn moyre far mir." 
        intervals [20]:
            xmin = 44.977 
            xmax = 45.051 
            text = "" 
        intervals [21]:
            xmin = 45.051 
            xmax = 49.719 
            text = "un er hot mir gezogt mir, der UNK er hot mir gezogt mir az far nakht vet er mikh aroysfirn tsum hengen," 
        intervals [22]:
            xmin = 49.719 
            xmax = 50.147 
            text = "" 
        intervals [23]:
            xmin = 50.147 
            xmax = 53.06 
            text = "bin ikh aroysgegangen shoyn tsum apel shoyn tsedreyt." 
        intervals [24]:
            xmin = 53.06 
            xmax = 53.185 
            text = "" 
        intervals [25]:
            xmin = 53.185 
            xmax = 57.299 
            text = "un der der S.S. iz dokh mit undz geven tsuzamen." 
        intervals [26]:
            xmin = 57.299 
            xmax = 59.085 
            text = "er hot dokh undz opgefirt tsu der arbet." 
        intervals [27]:
            xmin = 59.085 
            xmax = 59.698 
            text = "" 
        intervals [28]:
            xmin = 59.698 
            xmax = 62.51 
            text = "zogt er, ""vos bistu MAL RUNTER azoy, nisht gut GESCHLAFEN?""" 
        intervals [29]:
            xmin = 62.51 
            xmax = 63.462 
            text = "" 
        intervals [30]:
            xmin = 63.462 
            xmax = 64.974 
            text = "ikh zog, ""ikh hob PROBLEMS." 
        intervals [31]:
            xmin = 64.974 
            xmax = 65.453 
            text = "" 
        intervals [32]:
            xmin = 65.453 
            xmax = 68.991 
            text = "mayn blok ALTESTER vil mikh haynt firn tsum hengen."" zogt er, ""WHAT?" 
        intervals [33]:
            xmin = 68.991 
            xmax = 69.182 
            text = "" 
        intervals [34]:
            xmin = 69.182 
            xmax = 70.695 
            text = "WAS hostu mit im gemakht?""" 
        intervals [35]:
            xmin = 70.695 
            xmax = 71.241 
            text = "" 
        intervals [36]:
            xmin = 71.241 
            xmax = 75.808 
            text = "zog ikh, ""s'gekumen mayn bruder, un ikh hob im arayngenumen in blok arayn tsu shlofn mit mir," 
        intervals [37]:
            xmin = 75.808 
            xmax = 77.653 
            text = "" 
        intervals [38]:
            xmin = 77.653 
            xmax = 79.891 
            text = "un zey hobn gevolt im TOTES SCHLAGEN." 
        intervals [39]:
            xmin = 79.891 
            xmax = 79.999 
            text = "" 
        intervals [40]:
            xmin = 79.999 
            xmax = 85.291 
            text = "ikh veys dokh shoyn WAS UNK makhn EVERY MORNING, dan HAB ikh zey ZERSCHLAGEN.""" 
        intervals [41]:
            xmin = 85.291 
            xmax = 85.332 
            text = "" 
        intervals [42]:
            xmin = 85.332 
            xmax = 86.929 
            text = "zogt er, ""gut hostu gemakht!" 
        intervals [43]:
            xmin = 86.929 
            xmax = 87.103 
            text = "" 
        intervals [44]:
            xmin = 87.103 
            xmax = 91.822 
            text = "gut hostu gemakht."" ""JA gut, ober der der blok eltster vil mikh derfar hengen!""" 
        intervals [45]:
            xmin = 91.822 
            xmax = 92.031 
            text = "" 
        intervals [46]:
            xmin = 92.031 
            xmax = 94.488 
            text = """ICH gey mit dir tsu ha- ICH gey mit dir tsu im.""" 
        intervals [47]:
            xmin = 94.488 
            xmax = 94.647 
            text = "" 
        intervals [48]:
            xmin = 94.647 
            xmax = 97.594 
            text = "er geyt mit mir tsu im. nokh der arbet vet er mikh opfirn." 
        intervals [49]:
            xmin = 97.594 
            xmax = 98.781 
            text = "" 
        intervals [50]:
            xmin = 98.781 
            xmax = 103.382 
            text = "un nokh der arbet, m'geyt aheym, geyt er mit mir tsum blok ALTESTER un geyt arayn in OFFICE arayn," 
        intervals [51]:
            xmin = 103.382 
            xmax = 104.974 
            text = "" 
        intervals [52]:
            xmin = 104.974 
            xmax = 108.579 
            text = "zogt er, vu zenen di tsvey shtubn-dinstn? geyt der blok ALTESTER un get aruf. spn!" 
        intervals [53]:
            xmin = 108.579 
            xmax = 108.687 
            text = "" 
        intervals [54]:
            xmin = 108.687 
            xmax = 112.866 
            text = "un di tsvey shtubn-dinstn gebn a kum arayn, zey hobn gezen dem S.S. man mit mir," 
        intervals [55]:
            xmin = 112.866 
            xmax = 112.888 
            text = "" 
        intervals [56]:
            xmin = 112.888 
            xmax = 115.447 
            text = "hobn zikh derfreyt az m'geyt mikh firn tsum hengen." 
        intervals [57]:
            xmin = 115.447 
            xmax = 115.858 
            text = "" 
        intervals [58]:
            xmin = 115.858 
            xmax = 118.94 
            text = "der S.S. zogt, ""WHAT'S HAPPENED?"" ""er hot undz GESCHLAGEN.""" 
        intervals [59]:
            xmin = 118.94 
            xmax = 119.79 
            text = "" 
        intervals [60]:
            xmin = 119.79 
            xmax = 124.639 
            text = "zogt er, yetst zogt er, eb ikh aykh gebn. hot er zey tsugegebn nokh k- tsvey knakers tsu dem un dem," 
        intervals [61]:
            xmin = 124.639 
            xmax = 127.429 
            text = "un zogt er, ""zolst MAL nisht ANFANGEN mit dem yunger!""" 
        intervals [62]:
            xmin = 127.429 
            xmax = 129.645 
            text = "" 
        intervals [63]:
            xmin = 129.645 
            xmax = 130.567 
            text = "yidn." 
        intervals [64]:
            xmin = 130.567 
            xmax = 131.164 
            text = "" 
        intervals [65]:
            xmin = 131.164 
            xmax = 134.364 
            text = "un nisht onfangen nokh a mol mit dem mentsh, mit dem BOY." 
        intervals [66]:
            xmin = 134.364 
            xmax = 134.59 
            text = "" 
        intervals [67]:
            xmin = 134.59 
            xmax = 139.68 
            text = "un nokh dem zogt er zogt er tsum blok ALTESTER, ikh hob dir gezogt zolst mer akhtung gebn oyf dem eh oyf dem BOY." 
        intervals [68]:
            xmin = 139.68 
            xmax = 139.787 
            text = "" 
        intervals [69]:
            xmin = 139.787 
            xmax = 142.008 
            text = "zolst mer nisht TOUCHn dem BOY!" 
        intervals [70]:
            xmin = 142.008 
            xmax = 142.487 
            text = "" 
        intervals [71]:
            xmin = 142.487 
            xmax = 146.345 
            text = "zogt er, JAWOHL, un er hot geshrign JAWOHL. ikh vel mer shoyn mer nisht redn." 
        intervals [72]:
            xmin = 146.345 
            xmax = 147.499 
            text = "" 
        intervals [73]:
            xmin = 147.499 
            xmax = 149.889 
            text = "un der un der S.S. man iz avek." 
        intervals [74]:
            xmin = 149.889 
            xmax = 150.908 
            text = "" 
        intervals [75]:
            xmin = 150.908 
            xmax = 159.356 
            text = "S.S. man iz avek. un ikh gey aroys, mayn bruder shtarbt, er vil mikh shoyn zen. geb ikh a kum arayn tsurik in blok arayn, er veynt, er kumt arayn, zogt er, ""nu, abi ikh ze dikh nokh!""" 
        intervals [76]:
            xmin = 159.356 
            xmax = 160.847 
            text = "" 
        intervals [77]:
            xmin = 160.847 
            xmax = 167.945 
            text = "un ikh zits azoy, un m'redt azoy un m'redt azoy, git der blok ALTESTER a kum arayn, un geyt tsu glaykh tsu mir, un zogt er tsu mir, ""kum arayn tsu mir in OFFICE arayn.""" 
        intervals [78]:
            xmin = 167.945 
            xmax = 168.323 
            text = "" 
        intervals [79]:
            xmin = 168.323 
            xmax = 175.455 
            text = "gey ikh arayn tsu im in OFFICE arayn. ""far vos hostu mir nisht dertseylt host aza min,"" zogt er, ""vos iz dayns a FAMILY der S.S. man? der vos vos iz er dayns?""" 
        intervals [80]:
            xmin = 175.455 
            xmax = 175.512 
            text = "" 
        intervals [81]:
            xmin = 175.512 
            xmax = 177.784 
            text = "zog ikh, ""er iz mayns azoy gut vi dayns." 
        intervals [82]:
            xmin = 177.784 
            xmax = 178.718 
            text = "" 
        intervals [83]:
            xmin = 178.718 
            xmax = 185.614 
            text = "vos iz vikhtik?"" zogt er, ""er halt fun dir azoy? un ikh zol dir nisht a-"" zogt er, ""vey, ikh hob far im moyre."" zog ikh, ""muzt tun vos er zogt dir.""" 
        intervals [84]:
            xmin = 185.614 
            xmax = 187.527 
            text = "" 
        intervals [85]:
            xmin = 187.527 
            xmax = 195.368 
            text = "zogt er, ""yetst fun haynt op, yede nakht ven du vest aheymkumen, zolstu nisht shteyn in der LINE nokh a zup, zolst araynkumen tsu mir in OFFICE arayn, mir veln esn tsuzamen nakht mol.""" 
        intervals [86]:
            xmin = 195.368 
            xmax = 195.694 
            text = "" 
        intervals [87]:
            xmin = 195.694 
            xmax = 199.789 
            text = "zog ikh, ""ikh hob a bruder. ikh vil esn mit im tsuzamen.""" 
        intervals [88]:
            xmin = 199.789 
            xmax = 199.963 
            text = "" 
        intervals [89]:
            xmin = 199.963 
            xmax = 201.914 
            text = "zogt er, ""vestu brengen dem bruder oykhet.""" 
        intervals [90]:
            xmin = 201.914 
            xmax = 203.44 
            text = "" 
        intervals [91]:
            xmin = 203.44 
            xmax = 207.804 
            text = "hob ikh ongehoybn tsu brengen dem bruder. m'hot gegesn dort nakht mol. dort hot men gekent esn vifl m'vil." 
        intervals [92]:
            xmin = 207.804 
            xmax = 209.565 
            text = "" 
        intervals [93]:
            xmin = 209.565 
