            text = "" 
        intervals [342]:
            xmin = 874.845 
            xmax = 882.129 
            text = "tsvey sho shpeter, zog ikh, FATHER, LASSEN SIE MICH oysraysn. ikh zol antloyfn. LASSEN SIE MICH antloyfn." 
