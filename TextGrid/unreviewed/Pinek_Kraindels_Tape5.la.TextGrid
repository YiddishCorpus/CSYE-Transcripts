            xmax = 379.851 
            text = "" 
        intervals [156]:
            xmin = 379.851 
            xmax = 385.245 
            text = "un zogt mir on der blok ALTESTER, zolst gedenken, zolst MAL di shnal tsuhaltn, ven nisht, zogt er, knal ICH DICH." 
