            xmin = 940.854 
            xmax = 941.873 
            text = "" 
        intervals [371]:
            xmin = 941.873 
            xmax = 946.575 
            text = "un azoy mir hobn zikh opgeshlept zikh biz Gleyvits. m'iz arayngekumen keyn Gleyvits iz geven a yidisher lager." 
        intervals [372]:
            xmin = 946.575 
            xmax = 946.817 
            text = "" 
        intervals [373]:
            xmin = 946.817 
            xmax = 949.595 
            text = "hot men undz arayngefirt dort bay nakht, opruen zikh." 
        intervals [374]:
