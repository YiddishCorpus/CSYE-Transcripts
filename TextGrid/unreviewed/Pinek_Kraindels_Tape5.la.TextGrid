            text = "" 
        intervals [99]:
            xmin = 221.867 
            xmax = 228.695 
            text = "vos iz vayter hot zikh gevezn vayter mit dem brilantn vos ikh hob gebrengt di brilantn aheym un m'hot dos bahaltn," 
        intervals [100]:
            xmin = 228.695 
            xmax = 228.972 
            text = "" 
        intervals [101]:
            xmin = 228.972 
