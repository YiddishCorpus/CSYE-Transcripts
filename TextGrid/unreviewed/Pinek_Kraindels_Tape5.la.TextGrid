        intervals [453]:
            xmin = 1145.644 
            xmax = 1151.286 
            text = "eh vifl ze'mir ongekumen. ze'mir aroysgegangen dortn aza iz aroysgegangen efsher tsvey toyznt iz men gegangen,un m'iz ongekumen tsvey dray hundert." 
