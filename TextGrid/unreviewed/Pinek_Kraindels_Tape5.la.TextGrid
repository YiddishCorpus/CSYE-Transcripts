            xmin = 976.865 
            xmax = 976.956 
            text = "" 
        intervals [386]:
            xmin = 976.956 
            xmax = 979.037 
            text = "vos iz geven? m'hot undz arayngefirt," 
        intervals [387]:
            xmin = 979.037 
            xmax = 985.117 
            text = "hob ikh mikh avekgeleygt, gey ikh tsum bruder, zog ikh tsum bruder, du leyg dikh avek, ikh gey aroys gebn a kuk vu iz do do ergets a" 
        intervals [388]:
            xmin = 985.117 
            xmax = 986.102 
            text = "" 
        intervals [389]:
            xmin = 986.102 
            xmax = 988.796 
            text = "epes tsu khapn epes esn, efsher vel ikh kenen epes trefn." 
