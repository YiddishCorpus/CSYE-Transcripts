            text = "" 
        intervals [103]:
            xmin = 232.566 
            xmax = 239.557 
            text = "dos iz gevezn in JANUARY der EIGHTEEN, dos iz geven farn EIGHTEEN." 
        intervals [104]:
            xmin = 239.557 
            xmax = 242.803 
            text = "SLICHA, dos iz geven a zekhtsn- in zekhtstn JANUARY." 
        intervals [105]:
