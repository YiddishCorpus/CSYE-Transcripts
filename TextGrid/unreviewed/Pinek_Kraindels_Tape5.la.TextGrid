            text = "finef hundert. finef hundert boyes." 
        intervals [112]:
            xmin = 264.321 
            xmax = 270.056 
            text = "dos iz geven JANUARY finef un fertsik, JANUARY finef un fertsik, m'geyt kastrirn." 
        intervals [113]:
            xmin = 270.056 
