            xmax = 1135.963 
            text = "m'iz shoyn arayngekumen keyn Daytshland. m'iz shoyn geven in Daytshland. hot men undz gefirt mit vagonen ahin un tsurik biz m'hot undz gefirt arayn nakher keyn Dakhau." 
