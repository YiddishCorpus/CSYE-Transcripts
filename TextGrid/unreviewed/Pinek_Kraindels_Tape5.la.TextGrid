            text = "nisht der nisht di, dos iz der blok ALTE- der firer fun dem blok." 
        intervals [94]:
            xmin = 212.9 
            xmax = 212.94 
            text = "" 
        intervals [95]:
            xmin = 212.94 
            xmax = 218.131 
            text = "dos iz geven der firer fun dem blok. un er hot mikh arayngefirt ikh zol esn mit im tsuzamen, mitn bruder tsuzamen." 
        intervals [96]:
            xmin = 218.131 
            xmax = 219.184 
            text = "" 
        intervals [97]:
            xmin = 219.184 
