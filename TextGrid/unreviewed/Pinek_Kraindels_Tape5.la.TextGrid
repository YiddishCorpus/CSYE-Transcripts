            xmin = 997.2 
            xmax = 997.678 
            text = "" 
        intervals [395]:
            xmin = 997.678 
            xmax = 1004.087 
            text = "ikh gey arayn ineveynik arayn, tref ikh di gantse kesl, a UNK fule kesl, di groyse kesl, UNK kartofl, opgekokhte kartofl." 
        intervals [396]:
            xmin = 1004.087 
            xmax = 1006.11 
            text = "ikh nem a kartofl, veykh vi gold." 
