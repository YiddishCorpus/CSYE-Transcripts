        intervals [416]:
            xmin = 1049.637 
            xmax = 1055.857 
            text = "in Tshekhoslovakye, dos hot dos dertseyl ikh nor, dos dos hot nisht genumen biz azoy haynt un morgn, m'iz gegangen azoy gantse vokhn." 
