            xmin = 988.796 
            xmax = 989.106 
            text = "" 
        intervals [391]:
            xmin = 989.106 
            xmax = 992.289 
            text = "gey ikh vu zukht men? in der kekh. ikh zukh di kekh." 
        intervals [392]:
            xmin = 992.289 
            xmax = 992.65 
            text = "" 
        intervals [393]:
            xmin = 992.65 
            xmax = 997.2 
            text = "gey ikh tsu s'geven niderike hayzer, ikh geb a makh oyf di lodn, ze ikh s'ofn." 
