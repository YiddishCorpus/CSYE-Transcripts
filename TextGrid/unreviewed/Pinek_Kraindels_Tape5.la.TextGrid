            text = "hot men oysgeklibn ale yugntlekhe, finef hundert yunge boyes," 
        intervals [107]:
            xmin = 248.45 
            xmax = 254.025 
            text = "hot men undz gegebn a loz arayn in a blok arayn, un m'hot gezogt dos geyt oyf kastrirn." 
        intervals [108]:
