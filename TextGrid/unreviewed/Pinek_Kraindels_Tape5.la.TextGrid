            text = "" 
        intervals [116]:
            xmin = 273.893 
            xmax = 281.835 
            text = "shoyn, ikh hob nisht gevust. Khaim Ernberg hot shoyn gevust vu m'geyt undz firn, vos vos vart oyf undz. er hot shoyn gevust in droysn vos m'geyt tun mit undz." 
        intervals [117]:
            xmin = 281.835 
            xmax = 282.415 
            text = "" 
        intervals [118]:
            xmin = 282.415 
            xmax = 288.028 
            text = "hot er zikh ongehoybn zikh, ir hert, un er iz gegangen arayn tsu dem blok ALTESTER vos hot undz gehitn," 
        intervals [119]:
            xmin = 288.028 
            xmax = 289.485 
            text = "" 
        intervals [120]:
            xmin = 289.485 
            xmax = 293.748 
            text = "un redt mit im. zogt er, ken ikh, zogt er, aroysnemen, zogt er, a yunger fun danet?" 
        intervals [121]:
            xmin = 293.748 
            xmax = 294.362 
            text = "" 
        intervals [122]:
            xmin = 294.362 
            xmax = 298.085 
            text = "oyb ikh vel dir gebn dos vos dos tayerste in der velt iz." 
        intervals [123]:
            xmin = 298.085 
            xmax = 298.767 
            text = "" 
        intervals [124]:
            xmin = 298.767 
            xmax = 303.792 
            text = "zogt er, ""vos iz dos tayerste? vos kenstu mir gebn? broyt? esn? trinken?"" zogt er, ""neyn." 
        intervals [125]:
            xmin = 303.792 
            xmax = 305.308 
            text = "nokh tayers.""" 
        intervals [126]:
            xmin = 305.308 
