        intervals [457]:
            xmin = 1153.502 
            xmax = 1159.503 
            text = "zey hobn zikh avekgezetst, zey hobn gegesn ayz, zey hobn gegesn shney, hobn gekrign hobn gekrign a UNK, avekgezetst hot men zey tsu geshosn." 
