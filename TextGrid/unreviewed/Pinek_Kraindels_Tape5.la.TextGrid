            text = "" 
        intervals [375]:
            xmin = 949.686 
            xmax = 951.429 
            text = "in Gleyvits." 
        intervals [376]:
            xmin = 951.429 
            xmax = 955.738 
            text = "Gleyvits dos tsvishn di grenets fun der tsvishn Poyln un Daytshland." 
        intervals [377]:
            xmin = 955.738 
            xmax = 958.478 
            text = "" 
        intervals [378]:
            xmin = 958.478 
            xmax = 963.567 
            text = "Gleyvitse. Gleyvits. yeder eyner veyst vu Gleyvits." 
        intervals [379]:
            xmin = 963.567 
            xmax = 966.747 
            text = "" 
        intervals [380]:
            xmin = 966.747 
            xmax = 969.103 
            text = "oyf daytsher zayt. Gleyvits." 
