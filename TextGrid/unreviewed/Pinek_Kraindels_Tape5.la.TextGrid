            xmin = 1018.986 
            xmax = 1019.177 
            text = "" 
        intervals [404]:
            xmin = 1019.177 
            xmax = 1025.229 
            text = "ikh bin arayngegangen, hob ikh gekhapt nokh, ongekumen di S.S., m'hot geshrign HERAUS!" 
