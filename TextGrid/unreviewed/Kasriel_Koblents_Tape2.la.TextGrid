            xmin = 42.851 
            xmax = 42.874 
            text = "" 
        intervals [19]:
            xmin = 42.874 
            xmax = 46.732 
            text = "umgefer a finf, zeks sho hobn mir zikh bay ir, zaynen geven bay ir in shtub." 
        intervals [20]:
            xmin = 46.732 
            xmax = 47.278 
            text = "" 
        intervals [21]:
            xmin = 47.278 
            xmax = 49.516 
            text = "zi iz geven a eyntslne froy iz zi geven." 
