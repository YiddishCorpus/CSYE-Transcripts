            text = "" 
        intervals [23]:
            xmin = 49.843 
            xmax = 51.136 
            text = "in ovnt" 
        intervals [24]:
            xmin = 51.136 
            xmax = 51.447 
            text = "" 
        intervals [25]:
            xmin = 51.447 
            xmax = 58.984 
            text = "bin ikh gekum- zaynen mir gekumen durkhn barg, bin ikh oyf, durkh MACKEVIČIAUS dortn aru- arunter oyf ITALIJOS..." 
        intervals [26]:
            xmin = 58.984 
