            xmin = 61.498 
            xmax = 62.888 
            text = "" 
        intervals [29]:
            xmin = 62.888 
            xmax = 66.729 
            text = "un ikh bin arayn tsu mayn shvester <un bay>, ikh hob ongeklapt bay nakht in tir." 
        intervals [30]:
            xmin = 66.729 
            xmax = 67.714 
            text = "" 
        intervals [31]:
            xmin = 67.714 
            xmax = 69.96 
            text = "s'iz geven zeyer shpet iz shoyn geven," 
        intervals [32]:
            xmin = 69.96 
            xmax = 74.728 
            text = "<nor, hm, nor m'hot> mir arayngelozn in shtub, hob ikh shoyn gefunen, der bruder iz shoyn geven in shtub." 
        intervals [33]:
            xmin = 74.728 
            xmax = 74.768 
            text = "" 
        intervals [34]:
            xmin = 74.768 
            xmax = 77.397 
            text = "dortn... er iz vayter nit gelofn." 
        intervals [35]:
            xmin = 77.397 
            xmax = 80.65 
            text = "m'hot genumen bashisn fun hoyf, hot er zikh tsurikgekert aheym." 
        intervals [36]:
            xmin = 80.65 
            xmax = 81.298 
            text = "" 
        intervals [37]:
            xmin = 81.298 
            xmax = 83.89 
            text = "nu, ikh bin arayn in shtub. hm..." 
