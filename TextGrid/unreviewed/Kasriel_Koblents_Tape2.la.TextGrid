        intervals [5]:
            xmin = 17.46 
            xmax = 20.51 
            text = "zi hot mit undz geredt oyf litvish. hot zi gezogt," 
        intervals [6]:
            xmin = 20.51 
            xmax = 26.314 
            text = """geyt nit itster in Kovne, vayl in Slabodke iz geven a groyser pogrom. m'hot oysgeharget zeyer fil yidn." 
