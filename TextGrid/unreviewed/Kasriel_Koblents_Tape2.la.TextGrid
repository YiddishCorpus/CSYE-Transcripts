            text = "" 
        intervals [49]:
            xmin = 113.766 
            xmax = 115.29 
            text = "blonde hor hob ikh gehat." 
        intervals [50]:
            xmin = 115.29 
            xmax = 119.75 
            text = "iz ikh fleg geyn iber di geshef- iber di gesheftn OBESPECHIVen;" 
        intervals [51]:
