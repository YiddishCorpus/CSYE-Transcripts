            xmin = 26.314 
            xmax = 26.455 
            text = "" 
        intervals [8]:
            xmin = 26.455 
            xmax = 28.797 
            text = "un kumt arayn bay mir in shtub;" 
        intervals [9]:
            xmin = 28.797 
            xmax = 31.376 
            text = "ir vet zikh arumvashn, ir <z-> vet zikh opruen." 
        intervals [10]:
            xmin = 31.376 
            xmax = 31.568 
            text = "" 
        intervals [11]:
            xmin = 31.568 
            xmax = 33.536 
            text = "ikh vel aykh onkormenen." 
        intervals [12]:
            xmin = 33.536 
            xmax = 33.694 
            text = "" 
        intervals [13]:
            xmin = 33.694 
            xmax = 36.78 
            text = "un az s'vet vern in ovnt fintster," 
        intervals [14]:
            xmin = 36.78 
            xmax = 38.002 
            text = "dan vet ir" 
        intervals [15]:
            xmin = 38.002 
            xmax = 40.488 
            text = "vi nit iz araynkumen in Kovne.""" 
        intervals [16]:
            xmin = 40.488 
            xmax = 40.883 
            text = "" 
        intervals [17]:
            xmin = 40.883 
            xmax = 42.851 
            text = "azoy iz geven. mir hobn zikh bay ir," 
