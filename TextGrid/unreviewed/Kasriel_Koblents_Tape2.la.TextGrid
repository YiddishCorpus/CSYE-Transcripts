            xmin = 94.455 
            xmax = 98.95 
            text = "" 
        intervals [43]:
            xmin = 98.95 
            xmax = 103.98 
            text = "di ershte teg nokhn kumen in Kovne iz geven a problem mit produktn; s'iz nit geven vos tsum esn." 
        intervals [44]:
            xmin = 103.98 
            xmax = 106.16 
            text = "ikh hob oysgezen" 
        intervals [45]:
            xmin = 106.16 
            xmax = 110.604 
            text = "azoy vi a, a blonder; ikh bin in gantsn nit geven pakhozhe oyf keyn..." 
        intervals [46]:
            xmin = 110.604 
            xmax = 111.572 
            text = "" 
        intervals [47]:
            xmin = 111.572 
