            text = "" 
        intervals [68]:
            xmin = 154.401 
            xmax = 160.709 
            text = "hot zi genumen shoyn zogn, ""farhalt im! zey hobn okersht opgeshnitn, uh, litvishe kinder di oyvern," 
        intervals [69]:
